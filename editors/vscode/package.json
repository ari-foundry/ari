{
  "name": "ari-vscode",
  "displayName": "Ari",
  "description": "Language support for Ari source files through ari-lsp.",
  "version": "0.1.0",
  "publisher": "ari-lang",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:ari",
    "onCommand:ari.checkCurrentFile",
    "onCommand:ari.lintCurrentFile",
    "onCommand:ari.restartLanguageServer",
    "onTaskType:ari"
  ],
  "main": "./extension.js",
  "contributes": {
    "languages": [
      {
        "id": "ari",
        "aliases": [
          "Ari",
          "ari"
        ],
        "extensions": [
          ".ari",
          ".arih"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "ari",
        "scopeName": "source.ari",
        "path": "./syntaxes/ari.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "ari.checkCurrentFile",
        "title": "Ari: Check Current File"
      },
      {
        "command": "ari.lintCurrentFile",
        "title": "Ari: Lint Current File"
      },
      {
        "command": "ari.restartLanguageServer",
        "title": "Ari: Restart Language Server"
      }
    ],
    "taskDefinitions": [
      {
        "type": "ari",
        "required": [
          "target"
        ],
        "properties": {
          "target": {
            "type": "string",
            "enum": [
              "build",
              "check",
              "tools",
              "check-tools",
              "lint",
              "lsp"
            ],
            "description": "Ari make target to run."
          }
        }
      }
    ],
    "configuration": {
      "title": "Ari",
      "properties": {
        "ari.compilerPath": {
          "type": "string",
          "default": "build/ari",
          "description": "Path to the Ari compiler used by ari-lsp for --check diagnostics."
        },
        "ari.lspPath": {
          "type": "string",
          "default": "build/ari-lsp",
          "description": "Path to the ari-lsp executable."
        },
        "ari.lintPath": {
          "type": "string",
          "default": "build/ari-lint",
          "description": "Path to the ari-lint executable used by the Ari: Lint Current File command."
        },
        "ari.lintConfigPath": {
          "type": "string",
          "default": "",
          "description": "Optional path to an Ari lint config file passed to ari-lint and ari-lsp."
        },
        "ari.modulePaths": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Extra module search paths passed to ari-lsp as -I arguments."
        },
        "ari.lintRules": {
          "type": "object",
          "default": {},
          "additionalProperties": {
            "type": "string",
            "enum": [
              "off",
              "hint",
              "note",
              "warning",
              "error"
            ]
          },
          "description": "Lint rule severity overrides passed to ari-lint and ari-lsp, such as {\"lint/trailing-whitespace\":\"error\"}."
        }
      }
    }
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0"
  }
}
