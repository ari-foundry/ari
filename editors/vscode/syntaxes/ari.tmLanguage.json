{
  "scopeName": "source.ari",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#attributes"
    },
    {
      "include": "#declarations"
    },
    {
      "include": "#macros"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#types"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "attributes": {
      "patterns": [
        {
          "name": "meta.attribute.ari",
          "match": "#!?\\[[^\\]]*\\]"
        }
      ]
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.ari",
          "match": "//.*$"
        },
        {
          "name": "comment.block.ari",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.ari",
          "match": "\\b(true|false|null)\\b"
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "name": "meta.function.ari",
          "match": "\\b(fn)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "keyword.declaration.function.ari"
            },
            "2": {
              "name": "entity.name.function.ari"
            }
          }
        },
        {
          "name": "meta.type.declaration.ari",
          "match": "\\b(struct|enum|trait|mod)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "keyword.declaration.type.ari"
            },
            "2": {
              "name": "entity.name.type.ari"
            }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.ari",
          "match": "\\b(return|if|else|while|for|in|match|break|continue|init|next)\\b"
        },
        {
          "name": "keyword.declaration.ari",
          "match": "\\b(fn|extern|mod|pub|use|impl|trait|struct|enum|let|var)\\b"
        },
        {
          "name": "keyword.operator.word.ari",
          "match": "\\b(as|own|drop|ref|mut)\\b"
        }
      ]
    },
    "macros": {
      "patterns": [
        {
          "name": "entity.name.function.macro.ari",
          "match": "\\b[A-Za-z_][A-Za-z0-9_]*!"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.ari",
          "match": "\\b(0b[01_]+|0o[0-7_]+|0x[0-9A-Fa-f_]+|[0-9][0-9_]*(\\.[0-9_]+)?([eE][+-]?[0-9_]+)?)([iu](8|16|32|64)|f(32|64|128))?\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.ari",
          "match": "->|=>|::|==|!=|<=|>=|&&|\\|\\||\\?\\?|[+\\-*/%&|^!~<>]=?|="
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.ari",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.ari",
              "match": "\\\\(x[0-9A-Fa-f]{2}|u\\{[0-9A-Fa-f_]+\\}|.)"
            }
          ]
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.primitive.ari",
          "match": "\\b(i8|i16|i32|i64|u8|u16|u32|u64|f32|f64|f128|bool|string|void)\\b"
        },
        {
          "name": "support.type.ari",
          "match": "\\b(Self|Zone|String|Vec|Box|Option|Result)\\b"
        }
      ]
    }
  }
}
