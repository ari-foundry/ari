fn fib(n: i64) -> i64 {
  if n <= 1 {
    return n;
  }

  var index = 2;
  var previous = 0;
  var current = 1;

  while index <= n {
    let next_value = previous + current;
    previous = current;
    current = next_value;
    index = index + 1;
  }

  return current;
}

fn main() -> i64 {
  let value = fib(10);
  println("fib(10)={}", value);
  return 0;
}
