  }

  fn flush(self: ref mut Self) -> std::Result[(), std::error::Error] {
    if self.handle.is_open() {
      return std::Ok<(), std::error::Error>(());
    }
    return std::Err<(), std::error::Error>(std::error::new(std::error::BrokenPipe));
  }
}

