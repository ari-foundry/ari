    return std::error::map_raw<i64>(udp_send_to_raw(self.handle.raw(), values, addr));
  }

  fn send(self: ref Self, values: std::Slice[u8]) -> std::Result[i64, std::error::Error] {
    return std::error::map_raw<i64>(
      udp_count_raw(self.handle.raw(), udp_send_raw(self.handle.raw(), values.as_ptr(), values.len))
    );
  }

  fn recv(self: ref mut Self, output: std::Slice[u8]) -> std::Result[i64, std::error::Error] {
    return std::error::map_raw<i64>(
      udp_count_raw(self.handle.raw(), udp_recv_raw(self.handle.raw(), output.as_ptr(), output.len))
    );
  }

  fn recv_from(self: ref mut Self, output: std::Slice[u8]) -> std::Result[UdpRecvFrom, std::error::Error] {
    return std::error::map_raw<UdpRecvFrom>(
      udp_recv_from_raw(self.handle.raw(), output, 0)
    );
  }

  fn peek_from(self: ref mut Self, output: std::Slice[u8]) -> std::Result[UdpRecvFrom, std::error::Error] {
    return std::error::map_raw<UdpRecvFrom>(
      udp_recv_from_raw(self.handle.raw(), output, 2)
    );
  }

  fn send_byte_to_unchecked(self: ref Self, value: u8, addr: SocketAddr) -> bool {
    return self.send_byte_to(value, addr).is_ok();
  }

  fn send_byte_to(self: ref Self, value: u8, addr: SocketAddr) -> std::Result[(), std::error::Error] {
    if !self.is_open() {
      return std::Err<(), std::error::Error>(std::error::new(std::error::InvalidInput));
    }
    let ip = addr.ip;
    if ip.is_v4() {
      return std::error::map_raw<()>(
        socket_unit_raw(
          self.handle.raw(),
          udp_send_byte_to_v4_raw(
            self.handle.raw(),
            value,
            ip.s0 as i64,
            ip.s1 as i64,
            ip.s2 as i64,
            ip.s3 as i64,
            addr.port as i64
          )
        )
      );
    }
    if ip.is_v6() {
      return std::error::map_raw<()>(
        socket_unit_raw(
          self.handle.raw(),
          udp_send_byte_to_v6_raw(
            self.handle.raw(),
            value,
            ip.s0 as i64,
            ip.s1 as i64,
            ip.s2 as i64,
            ip.s3 as i64,
            ip.s4 as i64,
            ip.s5 as i64,
            ip.s6 as i64,
            ip.s7 as i64,
            addr.port as i64
          )
        )
      );
    }
    return std::Err<(), std::error::Error>(std::error::new(std::error::Unsupported));
  }

  fn recv_byte_unchecked(self: ref mut Self) -> i64 {
    if !self.is_open() {
      return -1;
    }
    return udp_recv_byte_raw(self.handle.raw());
  }

  fn try_recv_byte(self: ref mut Self) -> std::Option[u8] {
    return self.recv_byte().ok();
  }

  fn recv_byte(self: ref mut Self) -> std::Result[u8, std::error::Error] {
    if !self.is_open() {
      return std::Err<u8, std::error::Error>(std::error::new(std::error::InvalidInput));
    }
    let value = udp_recv_byte_raw(self.handle.raw());
    if value < 0 {
      return std::Err<u8, std::error::Error>(std::error::new(std::error::UnexpectedEof));
    }
    return std::Ok<u8, std::error::Error>(value as u8);
  }
}

