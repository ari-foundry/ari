    return self.handle.set_close_on_exec(enabled);
  }

  fn set_close_on_exec(self: ref Self, enabled: bool) -> std::Result[(), std::error::Error] {
    return self.handle.set_close_on_exec(enabled);
  }

  fn accept_ready_millis(self: ref Self, timeout_millis: i64) -> std::Result[bool, std::error::Error] {
    return self.handle.poll_read_millis(timeout_millis);
  }

  fn accept_ready(self: ref Self, timeout: std::time::Duration) -> std::Result[bool, std::error::Error] {
    return self.accept_ready_millis(timeout.as_millis());
  }

  fn accept(self: ref Self) -> std::Result[UnixStream, std::error::Error] {
    return std::error::map_raw<UnixStream>(self.accept_raw());
  }

  fn accept_optional(self: ref Self) -> std::Option[UnixStream] {
    return self.accept().ok();
  }

  fn try_accept(self: ref Self) -> std::Option[UnixStream] {
    return self.accept_optional();
  }

  fn accept_raw(self: ref Self) -> std::Result[UnixStream, i64] {
    if !self.is_open() {
      return std::Err<UnixStream, i64>(invalid_input_error_raw());
    }
    let raw = tcp_accept_raw(self.handle.raw());
    if raw >= 0 {
      return std::Ok<UnixStream, i64>(unix_stream_from_raw(raw));
    }
    return std::Err<UnixStream, i64>(last_errno_error_raw());
  }

}

