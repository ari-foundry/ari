pub fn ipv4(a: u8, b: u8, c: u8, d: u8) -> Ipv4Addr {
  return Ipv4Addr { a: a, b: b, c: c, d: d };
}

pub fn ipv6(s0: u16, s1: u16, s2: u16, s3: u16, s4: u16, s5: u16, s6: u16, s7: u16) -> Ipv6Addr {
  return Ipv6Addr { s0: s0, s1: s1, s2: s2, s3: s3, s4: s4, s5: s5, s6: s6, s7: s7 };
}

pub fn socket_addr(ip: IpAddr, port: u16) -> SocketAddr {
  return SocketAddr { ip: ip, port: port };
}

pub fn localhost(port: u16) -> SocketAddr {
  let host = Ipv4Addr::localhost();
  return socket_addr(host.as_ip(), port);
}

pub fn lookup_v4_raw(host: string, port: u16) -> std::Result[SocketAddr, i64] {
  let packed = lookup_v4_host_raw(host, port as i64);
  if packed < 0 {
    return std::Err<SocketAddr, i64>(std::error::new(std::error::Other).raw());
  }
  return std::Ok<SocketAddr, i64>(socket_addr_from_packed_v4(packed));
}

pub fn lookup_v4(host: string, port: u16) -> std::Result[SocketAddr, std::error::Error] {
  return std::error::map_raw<SocketAddr>(lookup_v4_raw(host, port));
}

pub fn lookup_v6_raw(host: string, port: u16) -> std::Result[SocketAddr, i64] {
  var segments = [
    0 as u16,
    0 as u16,
    0 as u16,
    0 as u16,
    0 as u16,
    0 as u16,
    0 as u16,
    0 as u16
  ];
  let resolved_port = lookup_v6_host_raw(host, port as i64, segments.as_slice().as_ptr());
  if resolved_port < 0 || resolved_port > 65535 {
    return std::Err<SocketAddr, i64>(std::error::new(std::error::Other).raw());
  }
  return std::Ok<SocketAddr, i64>(
    socket_addr_from_segments_v6(segments.as_slice(), resolved_port as u16)
  );
}

pub fn lookup_v6(host: string, port: u16) -> std::Result[SocketAddr, std::error::Error] {
  return std::error::map_raw<SocketAddr>(lookup_v6_raw(host, port));
}

pub fn lookup_v4_optional(host: string, port: u16) -> std::Option[SocketAddr] {
  return lookup_v4(host, port).ok();
}

pub fn lookup_v6_optional(host: string, port: u16) -> std::Option[SocketAddr] {
  return lookup_v6(host, port).ok();
}

pub fn try_lookup_v4(host: string, port: u16) -> std::Option[SocketAddr] {
  return lookup_v4_optional(host, port);
}

pub fn try_lookup_v6(host: string, port: u16) -> std::Option[SocketAddr] {
  return lookup_v6_optional(host, port);
}

fn known_service_port(name: std::Slice[u8]) -> std::Option[u16] {
  if std::ascii::equals_ignore_case(name, std::string::bytes("http")) {
    return std::Some<u16>(80 as u16);
  }
  if std::ascii::equals_ignore_case(name, std::string::bytes("https")) {
    return std::Some<u16>(443 as u16);
  }
  if std::ascii::equals_ignore_case(name, std::string::bytes("ssh")) {
    return std::Some<u16>(22 as u16);
  }
  if std::ascii::equals_ignore_case(name, std::string::bytes("domain")) {
    return std::Some<u16>(53 as u16);
  }
  if std::ascii::equals_ignore_case(name, std::string::bytes("dns")) {
    return std::Some<u16>(53 as u16);
  }
  if std::ascii::equals_ignore_case(name, std::string::bytes("smtp")) {
    return std::Some<u16>(25 as u16);
  }
  if std::ascii::equals_ignore_case(name, std::string::bytes("submission")) {
    return std::Some<u16>(587 as u16);
  }
  if std::ascii::equals_ignore_case(name, std::string::bytes("imap")) {
    return std::Some<u16>(143 as u16);
  }
  if std::ascii::equals_ignore_case(name, std::string::bytes("imaps")) {
    return std::Some<u16>(993 as u16);
  }
  if std::ascii::equals_ignore_case(name, std::string::bytes("pop3")) {
    return std::Some<u16>(110 as u16);
  }
  if std::ascii::equals_ignore_case(name, std::string::bytes("pop3s")) {
    return std::Some<u16>(995 as u16);
  }
  if std::ascii::equals_ignore_case(name, std::string::bytes("ntp")) {
    return std::Some<u16>(123 as u16);
  }
  return std::None<u16>();
}

pub fn service_port_bytes(name: std::Slice[u8]) -> std::Result[u16, std::error::Error] {
  match known_service_port(name) {
    std::Some(port) => {
      return std::Ok<u16, std::error::Error>(port);
    }
    std::None => {
      return std::Err<u16, std::error::Error>(std::error::new(std::error::InvalidInput));
    }
  }
}

pub fn service_port_bytes_optional(name: std::Slice[u8]) -> std::Option[u16] {
  return known_service_port(name);
}

pub fn service_port(name: string) -> std::Result[u16, std::error::Error] {
  return service_port_bytes(std::string::bytes(name));
}

pub fn service_port_optional(name: string) -> std::Option[u16] {
  return service_port_bytes_optional(std::string::bytes(name));
}

fn endpoint_port(endpoint: string) -> std::Option[u16] {
  let bytes = std::string::bytes(endpoint);
  if bytes.len > 0 && bytes[0] == '[' {
    var close = -1;
    var close_index = 1;
    while close_index < bytes.len {
      if bytes[close_index] == ']' {
        close = close_index;
        close_index = bytes.len;
      } else {
        close_index = close_index + 1;
      }
    }

    if close <= 1 || close + 2 >= bytes.len || bytes[close + 1] != ':' {
      return std::None<u16>();
    }

    var bracket_port = 0;
    var bracket_index = close + 2;
    while bracket_index < bytes.len {
      match std::ascii::digit_value(bytes[bracket_index]) {
        std::Some(digit) => {
          bracket_port = (bracket_port * 10) + digit;
          if bracket_port > 65535 {
            return std::None<u16>();
          }
        }
        std::None => {
          return std::None<u16>();
        }
      }
      bracket_index = bracket_index + 1;
    }

    return std::Some<u16>(bracket_port as u16);
  }

  var colon = -1;
  var index = 0;
  while index < bytes.len {
    if bytes[index] == ':' {
      if colon >= 0 {
        return std::None<u16>();
      }
      colon = index;
    }
    index = index + 1;
  }

  if colon <= 0 || colon + 1 >= bytes.len {
    return std::None<u16>();
  }

  var port = 0;
  index = colon + 1;
  while index < bytes.len {
    match std::ascii::digit_value(bytes[index]) {
      std::Some(port_digit) => {
        port = (port * 10) + port_digit;
        if port > 65535 {
          return std::None<u16>();
        }
      }
      std::None => {
        return std::None<u16>();
      }
    }
    index = index + 1;
  }

  return std::Some<u16>(port as u16);
}

pub fn resolve_service(
  zone: ref mut Zone,
  host: string,
  service: string
) -> std::Result[std::vec::Vec[SocketAddr], std::error::Error] {
  match service_port(service) {
    std::Ok(port) => {
      return resolve_all(zone, host, port);
    }
    std::Err(reason) => {
      return std::Err<std::vec::Vec<SocketAddr>, std::error::Error>(reason);
    }
  }
}

pub fn to_socket_addrs_service(
  zone: ref mut Zone,
  host: string,
  service: string
) -> std::Result[std::vec::Vec[SocketAddr], std::error::Error] {
  return resolve_service(zone, host, service);
}

fn endpoint_is_bracketed_v6(endpoint: string) -> bool {
  let bytes = std::string::bytes(endpoint);
  return bytes.len > 0 && bytes[0] == '[';
}

pub fn resolve_raw(endpoint: string) -> std::Result[SocketAddr, i64] {
  if endpoint_port(endpoint).is_none() {
    return std::Err<SocketAddr, i64>(invalid_input_error_raw());
  }

  if endpoint_is_bracketed_v6(endpoint) {
    var segments = [
      0 as u16,
      0 as u16,
      0 as u16,
      0 as u16,
      0 as u16,
      0 as u16,
      0 as u16,
      0 as u16
    ];
    let resolved_port = lookup_v6_endpoint_host_raw(endpoint, segments.as_slice().as_ptr());
    if resolved_port < 0 || resolved_port > 65535 {
      return std::Err<SocketAddr, i64>(std::error::new(std::error::Other).raw());
    }
    return std::Ok<SocketAddr, i64>(
      socket_addr_from_segments_v6(segments.as_slice(), resolved_port as u16)
    );
  }

  let packed = lookup_v4_endpoint_host_raw(endpoint);
  if packed < 0 {
    return std::Err<SocketAddr, i64>(std::error::new(std::error::Other).raw());
  }
  return std::Ok<SocketAddr, i64>(socket_addr_from_packed_v4(packed));
}

pub fn resolve(endpoint: string) -> std::Result[SocketAddr, std::error::Error] {
  return std::error::map_raw<SocketAddr>(resolve_raw(endpoint));
}

pub fn resolve_optional(endpoint: string) -> std::Option[SocketAddr] {
  return resolve(endpoint).ok();
}

pub fn try_resolve(endpoint: string) -> std::Option[SocketAddr] {
  return resolve_optional(endpoint);
}

pub fn resolve_all(
  zone: ref mut Zone,
  host: string,
  port: u16
) -> std::Result[std::vec::Vec[SocketAddr], std::error::Error] {
  var output = std::vec::new<SocketAddr>(zone, 2);
  var reason = std::error::new(std::error::Other);

  match lookup_v4(host, port) {
    std::Ok(v4) => {
      output.push(v4);
    }
    std::Err(v4_error) => {
      reason = v4_error;
    }
  }

  match lookup_v6(host, port) {
    std::Ok(v6) => {
      output.push(v6);
    }
    std::Err(v6_error) => {
      if output.is_empty() {
        reason = v6_error;
      }
    }
  }

  if output.is_empty() {
    return std::Err<std::vec::Vec<SocketAddr>, std::error::Error>(reason);
  }
  return std::Ok<std::vec::Vec<SocketAddr>, std::error::Error>(output);
}

pub fn to_socket_addrs(
  zone: ref mut Zone,
  endpoint: string
) -> std::Result[std::vec::Vec[SocketAddr], std::error::Error] {
  var output = std::vec::new<SocketAddr>(zone, 1);
  match resolve(endpoint) {
    std::Ok(addr) => {
      output.push(addr);
      return std::Ok<std::vec::Vec<SocketAddr>, std::error::Error>(output);
    }
    std::Err(reason) => {
      return std::Err<std::vec::Vec<SocketAddr>, std::error::Error>(reason);
    }
  }
}

pub fn listen(addr: SocketAddr) -> std::Result[TcpListener, std::error::Error] {
  return TcpListener::bind(addr);
}

pub fn tcp_listen(addr: SocketAddr) -> std::Result[TcpListener, std::error::Error] {
  return TcpListener::bind(addr);
}

pub fn tcp_listen_v6(addr: SocketAddr) -> std::Result[TcpListener, std::error::Error] {
  if !addr.ip.is_v6() {
    return std::Err<TcpListener, std::error::Error>(std::error::new(std::error::Unsupported));
  }
  return TcpListener::bind(addr);
}

pub fn connect(addr: SocketAddr) -> std::Result[TcpStream, std::error::Error] {
  return TcpStream::connect(addr);
}

pub fn tcp_connect(addr: SocketAddr) -> std::Result[TcpStream, std::error::Error] {
  return TcpStream::connect(addr);
}

pub fn tcp_connect_v6(addr: SocketAddr) -> std::Result[TcpStream, std::error::Error] {
  if !addr.ip.is_v6() {
    return std::Err<TcpStream, std::error::Error>(std::error::new(std::error::Unsupported));
  }
  return TcpStream::connect(addr);
}

pub fn connect_host(endpoint: string) -> std::Result[TcpStream, std::error::Error] {
  match resolve(endpoint) {
    std::Ok(addr) => {
      return TcpStream::connect(addr);
    }
    std::Err(reason) => {
      return std::Err<TcpStream, std::error::Error>(reason);
    }
  }
}

pub fn tcp_connect_host(endpoint: string) -> std::Result[TcpStream, std::error::Error] {
  return connect_host(endpoint);
}

pub fn udp_bind(addr: SocketAddr) -> std::Result[UdpSocket, std::error::Error] {
  return UdpSocket::bind(addr);
}

pub fn udp_bind_v6(addr: SocketAddr) -> std::Result[UdpSocket, std::error::Error] {
  if !addr.ip.is_v6() {
    return std::Err<UdpSocket, std::error::Error>(std::error::new(std::error::Unsupported));
  }
  return UdpSocket::bind(addr);
}

pub fn unix_listen(path: string) -> std::Result[UnixListener, std::error::Error] {
  return UnixListener::bind(path);
}

pub fn unix_connect(path: string) -> std::Result[UnixStream, std::error::Error] {
  return UnixStream::connect(path);
}

fn socket_addr_from_packed_v4(packed: i64) -> SocketAddr {
  let address = packed >> 16;
  let a = ((address >> 24) & 255) as u8;
  let b = ((address >> 16) & 255) as u8;
  let c = ((address >> 8) & 255) as u8;
  let d = (address & 255) as u8;
  let resolved_port = (packed & 65535) as u16;
  return socket_addr(ipv4(a, b, c, d).as_ip(), resolved_port);
}

fn socket_addr_from_segments_v6(segments: std::Slice[u16], port: u16) -> SocketAddr {
  return socket_addr(
    ipv6(
      segments[0],
      segments[1],
      segments[2],
      segments[3],
      segments[4],
      segments[5],
      segments[6],
      segments[7]
    ).as_ip(),
    port
  );
}

fn local_addr_v4(raw: i64) -> std::Option[SocketAddr] {
  let packed = local_addr_v4_host_raw(raw);
  if packed < 0 {
    return std::None<SocketAddr>();
  }
  return std::Some<SocketAddr>(socket_addr_from_packed_v4(packed));
}

fn peer_addr_v4(raw: i64) -> std::Option[SocketAddr] {
  let packed = peer_addr_v4_host_raw(raw);
  if packed < 0 {
    return std::None<SocketAddr>();
  }
  return std::Some<SocketAddr>(socket_addr_from_packed_v4(packed));
}

fn last_errno_error_raw() -> i64 {
  let error = std::c::error();
  return error.raw();
}

fn unsupported_address_error_raw() -> i64 {
  let error = std::error::new(std::error::Unsupported);
  return error.raw();
}

fn invalid_input_error_raw() -> i64 {
  let error = std::error::new(std::error::InvalidInput);
  return error.raw();
}

fn unexpected_eof_error_raw() -> i64 {
  let error = std::error::new(std::error::UnexpectedEof);
  return error.raw();
}

fn broken_pipe_error_raw() -> i64 {
  let error = std::error::new(std::error::BrokenPipe);
  return error.raw();
}

fn socket_bool_option(value: i64) -> std::Option[bool] {
  if value < 0 {
    return std::None<bool>();
  }
  return std::Some<bool>(value != 0);
}

fn socket_unit_raw(raw: i64, ok: bool) -> std::Result[(), i64] {
  if raw < 0 {
    return std::Err<(), i64>(invalid_input_error_raw());
  }
  if ok {
    return std::Ok<(), i64>(());
  }
  return std::Err<(), i64>(last_errno_error_raw());
}

fn socket_flag_raw(raw: i64, flag: i64) -> std::Result[bool, i64] {
  if raw < 0 {
    return std::Err<bool, i64>(invalid_input_error_raw());
  }
  if flag < 0 {
    return std::Err<bool, i64>(last_errno_error_raw());
  }
  return std::Ok<bool, i64>(flag != 0);
}

fn local_port_raw(raw: i64) -> std::Result[u16, i64] {
  if raw < 0 {
    return std::Err<u16, i64>(invalid_input_error_raw());
  }
  let port = local_port_host_raw(raw);
  if port < 0 || port > 65535 {
    return std::Err<u16, i64>(last_errno_error_raw());
  }
  return std::Ok<u16, i64>(port as u16);
}

fn local_addr_v4_raw(raw: i64) -> std::Result[SocketAddr, i64] {
  if raw < 0 {
    return std::Err<SocketAddr, i64>(invalid_input_error_raw());
  }
  let packed = local_addr_v4_host_raw(raw);
  if packed < 0 {
    return std::Err<SocketAddr, i64>(last_errno_error_raw());
  }
  return std::Ok<SocketAddr, i64>(socket_addr_from_packed_v4(packed));
}

fn peer_addr_v4_raw(raw: i64) -> std::Result[SocketAddr, i64] {
  if raw < 0 {
    return std::Err<SocketAddr, i64>(invalid_input_error_raw());
  }
  let packed = peer_addr_v4_host_raw(raw);
  if packed < 0 {
    return std::Err<SocketAddr, i64>(last_errno_error_raw());
  }
  return std::Ok<SocketAddr, i64>(socket_addr_from_packed_v4(packed));
}

fn local_addr_v6_raw(raw: i64) -> std::Result[SocketAddr, i64] {
  if raw < 0 {
    return std::Err<SocketAddr, i64>(invalid_input_error_raw());
  }
  var segments = [
    0 as u16,
    0 as u16,
    0 as u16,
    0 as u16,
    0 as u16,
    0 as u16,
    0 as u16,
    0 as u16
  ];
  let port = local_addr_v6_host_raw(raw, segments.as_slice().as_ptr());
  if port < 0 || port > 65535 {
    return std::Err<SocketAddr, i64>(last_errno_error_raw());
  }
  return std::Ok<SocketAddr, i64>(socket_addr_from_segments_v6(segments.as_slice(), port as u16));
}

fn peer_addr_v6_raw(raw: i64) -> std::Result[SocketAddr, i64] {
  if raw < 0 {
    return std::Err<SocketAddr, i64>(invalid_input_error_raw());
  }
  var segments = [
    0 as u16,
    0 as u16,
    0 as u16,
    0 as u16,
    0 as u16,
    0 as u16,
    0 as u16,
    0 as u16
  ];
  let port = peer_addr_v6_host_raw(raw, segments.as_slice().as_ptr());
  if port < 0 || port > 65535 {
    return std::Err<SocketAddr, i64>(last_errno_error_raw());
  }
  return std::Ok<SocketAddr, i64>(socket_addr_from_segments_v6(segments.as_slice(), port as u16));
}

fn local_addr_raw(raw: i64) -> std::Result[SocketAddr, i64] {
  if raw < 0 {
    return std::Err<SocketAddr, i64>(invalid_input_error_raw());
  }
  let family = local_addr_family_raw(raw);
  if family == 4 {
    return local_addr_v4_raw(raw);
  }
  if family == 6 {
    return local_addr_v6_raw(raw);
  }
  return std::Err<SocketAddr, i64>(last_errno_error_raw());
}

fn peer_addr_raw(raw: i64) -> std::Result[SocketAddr, i64] {
  if raw < 0 {
    return std::Err<SocketAddr, i64>(invalid_input_error_raw());
  }
  let family = peer_addr_family_raw(raw);
  if family == 4 {
    return peer_addr_v4_raw(raw);
  }
  if family == 6 {
    return peer_addr_v6_raw(raw);
  }
  return std::Err<SocketAddr, i64>(last_errno_error_raw());
}

fn shutdown_raw(raw: i64, mode: Shutdown) -> std::Result[(), i64] {
  if raw < 0 {
    return std::Err<(), i64>(invalid_input_error_raw());
  }
  return socket_unit_raw(raw, shutdown_socket_raw(raw, shutdown_mode(mode)));
}

fn read_socket_byte_raw(raw: i64) -> std::Result[u8, i64] {
  if raw < 0 {
    return std::Err<u8, i64>(invalid_input_error_raw());
  }
  let value = read_socket_byte_host_raw(raw);
  if value == -1 {
    return std::Err<u8, i64>(unexpected_eof_error_raw());
  }
  if value < -1 {
    return std::Err<u8, i64>(last_errno_error_raw());
  }
  return std::Ok<u8, i64>(value as u8);
}

fn read_exact_raw(raw: i64, output: ptr u8, len: i64) -> std::Result[(), i64] {
  if raw < 0 || len < 0 {
    return std::Err<(), i64>(invalid_input_error_raw());
  }
  var index = 0;
  while index < len {
    match read_socket_byte_raw(raw) {
      std::Ok(value) => {
        std::mem::ptr_store(std::mem::ptr_add(output, index), value);
      }
      std::Err(error) => {
        return std::Err<(), i64>(error);
      }
    }
    index = index + 1;
  }
  return std::Ok<(), i64>(());
}

fn write_all_raw(raw: i64, values: std::Slice[u8]) -> std::Result[(), i64] {
  if raw < 0 {
    return std::Err<(), i64>(invalid_input_error_raw());
  }
  var index = 0;
  while index < values.len {
    if !write_socket_byte_raw(raw, values[index]) {
      return std::Err<(), i64>(broken_pipe_error_raw());
    }
    index = index + 1;
  }
  return std::Ok<(), i64>(());
}

fn read_raw(raw: i64, output: std::Slice[u8]) -> std::Result[i64, i64] {
  if raw < 0 {
    return std::Err<i64, i64>(invalid_input_error_raw());
  }
  var index = 0;
  while index < output.len {
    match read_socket_byte_raw(raw) {
      std::Ok(value) => {
        std::mem::ptr_store(std::mem::ptr_add(output.data, index), value);
      }
      std::Err(reason) => {
        if index > 0 {
          return std::Ok<i64, i64>(index);
        }
        return std::Err<i64, i64>(reason);
      }
    }
    index = index + 1;
  }
  return std::Ok<i64, i64>(index);
}

fn write_raw(raw: i64, values: std::Slice[u8]) -> std::Result[i64, i64] {
  if raw < 0 {
    return std::Err<i64, i64>(invalid_input_error_raw());
  }
  var index = 0;
  while index < values.len {
    if !write_socket_byte_raw(raw, values[index]) {
      if index > 0 {
        return std::Ok<i64, i64>(index);
      }
      return std::Err<i64, i64>(broken_pipe_error_raw());
    }
    index = index + 1;
  }
  return std::Ok<i64, i64>(index);
}

fn udp_count_raw(raw: i64, count: i64) -> std::Result[i64, i64] {
  if raw < 0 {
    return std::Err<i64, i64>(invalid_input_error_raw());
  }
  if count < 0 {
    return std::Err<i64, i64>(last_errno_error_raw());
  }
  return std::Ok<i64, i64>(count);
}

fn socket_int_raw(raw: i64, value: i64) -> std::Result[i64, i64] {
  if raw < 0 {
    return std::Err<i64, i64>(invalid_input_error_raw());
  }
  if value < 0 {
    return std::Err<i64, i64>(last_errno_error_raw());
  }
  return std::Ok<i64, i64>(value);
}

fn socket_hop_count_raw(raw: i64, value: i64) -> std::Result[(), i64] {
  if raw < 0 {
    return std::Err<(), i64>(invalid_input_error_raw());
  }
  if value < 1 || value > 255 {
    return std::Err<(), i64>(invalid_input_error_raw());
  }
  return std::Ok<(), i64>(());
}

fn read_exact_bool_raw(raw: i64, output: ptr u8, len: i64) -> bool {
  return read_exact_raw(raw, output, len).is_ok();
}

fn write_all_bool_raw(raw: i64, values: std::Slice[u8]) -> bool {
  return write_all_raw(raw, values).is_ok();
}

fn tcp_listener_from_raw(raw: i64) -> TcpListener {
  var handle = std::os::OwnedFd::from_raw(raw);
  handle.set_close_on_exec_bool(true);
  return TcpListener { handle: handle };
}

fn tcp_stream_from_raw(raw: i64) -> TcpStream {
  var handle = std::os::OwnedFd::from_raw(raw);
  handle.set_close_on_exec_bool(true);
  return TcpStream { handle: handle };
}

fn udp_socket_from_raw(raw: i64) -> UdpSocket {
  var handle = std::os::OwnedFd::from_raw(raw);
  handle.set_close_on_exec_bool(true);
  return UdpSocket { handle: handle };
}

fn unix_listener_from_raw(raw: i64) -> UnixListener {
  var handle = std::os::OwnedFd::from_raw(raw);
  handle.set_close_on_exec_bool(true);
  return UnixListener { handle: handle };
}

fn unix_stream_from_raw(raw: i64) -> UnixStream {
  var handle = std::os::OwnedFd::from_raw(raw);
  handle.set_close_on_exec_bool(true);
  return UnixStream { handle: handle };
}

fn shutdown_mode(mode: Shutdown) -> i64 {
  match mode {
    Read => { return 0; }
    Write => { return 1; }
    Both => { return 2; }
  }
}

impl std::net::ToSocketAddrs for string {
  pub fn to_socket_addrs(
    self,
    zone: ref mut Zone
  ) -> std::Result[std::vec::Vec[std::net::SocketAddr], std::error::Error] {
    return std::net::to_socket_addrs(zone, self);
  }
}

fn tcp_listen_raw(addr: SocketAddr) -> std::Result[i64, i64] {
  let ip = addr.ip;
  if ip.is_v4() {
    let raw_v4 = tcp_listen_v4_raw(
      ip.s0 as i64,
      ip.s1 as i64,
      ip.s2 as i64,
      ip.s3 as i64,
      addr.port as i64
    );
    if raw_v4 >= 0 {
      return std::Ok<i64, i64>(raw_v4);
    }
    return std::Err<i64, i64>(last_errno_error_raw());
  }
  if ip.is_v6() {
    let raw_v6 = tcp_listen_v6_raw(
      ip.s0 as i64,
      ip.s1 as i64,
      ip.s2 as i64,
      ip.s3 as i64,
      ip.s4 as i64,
      ip.s5 as i64,
      ip.s6 as i64,
      ip.s7 as i64,
      addr.port as i64
    );
    if raw_v6 >= 0 {
      return std::Ok<i64, i64>(raw_v6);
    }
    return std::Err<i64, i64>(last_errno_error_raw());
  }
  return std::Err<i64, i64>(unsupported_address_error_raw());
}

fn tcp_connect_raw(addr: SocketAddr) -> std::Result[i64, i64] {
  let ip = addr.ip;
  if ip.is_v4() {
    let raw_v4 = tcp_connect_v4_raw(
      ip.s0 as i64,
      ip.s1 as i64,
      ip.s2 as i64,
      ip.s3 as i64,
      addr.port as i64
    );
    if raw_v4 >= 0 {
      return std::Ok<i64, i64>(raw_v4);
    }
    return std::Err<i64, i64>(last_errno_error_raw());
  }
  if ip.is_v6() {
    let raw_v6 = tcp_connect_v6_raw(
      ip.s0 as i64,
      ip.s1 as i64,
      ip.s2 as i64,
      ip.s3 as i64,
      ip.s4 as i64,
      ip.s5 as i64,
      ip.s6 as i64,
      ip.s7 as i64,
      addr.port as i64
    );
    if raw_v6 >= 0 {
      return std::Ok<i64, i64>(raw_v6);
    }
    return std::Err<i64, i64>(last_errno_error_raw());
  }
  return std::Err<i64, i64>(unsupported_address_error_raw());
}

fn udp_bind_raw(addr: SocketAddr) -> std::Result[i64, i64] {
  let ip = addr.ip;
  if ip.is_v4() {
    let raw_v4 = udp_bind_v4_raw(
      ip.s0 as i64,
      ip.s1 as i64,
      ip.s2 as i64,
      ip.s3 as i64,
      addr.port as i64
    );
    if raw_v4 >= 0 {
      return std::Ok<i64, i64>(raw_v4);
    }
    return std::Err<i64, i64>(last_errno_error_raw());
  }
  if ip.is_v6() {
    let raw_v6 = udp_bind_v6_raw(
      ip.s0 as i64,
      ip.s1 as i64,
      ip.s2 as i64,
      ip.s3 as i64,
      ip.s4 as i64,
      ip.s5 as i64,
