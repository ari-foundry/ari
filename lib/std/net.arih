fn udp_send_to_raw(raw: i64, values: std::Slice[u8], addr: SocketAddr) -> std::Result[i64, i64] {
  if raw < 0 {
    return std::Err<i64, i64>(invalid_input_error_raw());
  }
  let ip = addr.ip;
  if ip.is_v4() {
    return udp_count_raw(
      raw,
      udp_send_to_v4_raw(
        raw,
        values.as_ptr(),
        values.len,
        ip.s0 as i64,
        ip.s1 as i64,
        ip.s2 as i64,
        ip.s3 as i64,
        addr.port as i64
      )
    );
  }
  if ip.is_v6() {
    return udp_count_raw(
      raw,
      udp_send_to_v6_raw(
        raw,
        values.as_ptr(),
        values.len,
        ip.s0 as i64,
        ip.s1 as i64,
        ip.s2 as i64,
        ip.s3 as i64,
        ip.s4 as i64,
        ip.s5 as i64,
        ip.s6 as i64,
        ip.s7 as i64,
        addr.port as i64
      )
    );
  }
  return std::Err<i64, i64>(unsupported_address_error_raw());
}

fn udp_connect_raw(raw: i64, addr: SocketAddr) -> std::Result[(), i64] {
  if raw < 0 {
    return std::Err<(), i64>(invalid_input_error_raw());
  }
  let ip = addr.ip;
  if ip.is_v4() {
    return socket_unit_raw(
      raw,
      udp_connect_v4_raw(
        raw,
        ip.s0 as i64,
        ip.s1 as i64,
        ip.s2 as i64,
        ip.s3 as i64,
        addr.port as i64
      )
    );
  }
  if ip.is_v6() {
    return socket_unit_raw(
      raw,
      udp_connect_v6_raw(
        raw,
        ip.s0 as i64,
        ip.s1 as i64,
        ip.s2 as i64,
        ip.s3 as i64,
        ip.s4 as i64,
        ip.s5 as i64,
        ip.s6 as i64,
        ip.s7 as i64,
        addr.port as i64
      )
    );
  }
  return std::Err<(), i64>(unsupported_address_error_raw());
}

fn udp_recv_addr_from_parts(family: i64, port: i64, segments: std::Slice[u16]) -> std::Result[SocketAddr, i64] {
  if port < 0 || port > 65535 {
    return std::Err<SocketAddr, i64>(last_errno_error_raw());
  }
  if family == 4 {
    return std::Ok<SocketAddr, i64>(
      socket_addr(
        ipv4(segments[0] as u8, segments[1] as u8, segments[2] as u8, segments[3] as u8).as_ip(),
        port as u16
      )
    );
  }
  if family == 6 {
    return std::Ok<SocketAddr, i64>(socket_addr_from_segments_v6(segments, port as u16));
  }
  return std::Err<SocketAddr, i64>(unsupported_address_error_raw());
}

fn udp_recv_from_raw(raw: i64, output: std::Slice[u8], flags: i64) -> std::Result[UdpRecvFrom, i64] {
  if raw < 0 {
    return std::Err<UdpRecvFrom, i64>(invalid_input_error_raw());
  }
  var family = [0];
  var port = [0];
  var segments = [
    0 as u16,
    0 as u16,
    0 as u16,
    0 as u16,
    0 as u16,
    0 as u16,
    0 as u16,
    0 as u16
  ];
  let count = udp_recv_from_host_raw(
    raw,
    output.as_ptr(),
    output.len,
    flags,
    family.as_slice().as_ptr(),
    port.as_slice().as_ptr(),
    segments.as_slice().as_ptr()
  );
  if count < 0 {
    return std::Err<UdpRecvFrom, i64>(last_errno_error_raw());
  }
  match udp_recv_addr_from_parts(
    std::mem::ptr_load(family.as_slice().as_ptr()),
    std::mem::ptr_load(port.as_slice().as_ptr()),
    segments.as_slice()
  ) {
    std::Ok(addr) => {
      return std::Ok<UdpRecvFrom, i64>(UdpRecvFrom { len: count, addr: addr });
    }
    std::Err(reason) => {
      return std::Err<UdpRecvFrom, i64>(reason);
    }
  }
}

fn unix_listen_raw(path: string) -> std::Result[i64, i64] {
  let raw = unix_listen_host_raw(path);
  if raw >= 0 {
    return std::Ok<i64, i64>(raw);
  }
  return std::Err<i64, i64>(last_errno_error_raw());
}

fn unix_connect_raw(path: string) -> std::Result[i64, i64] {
  let raw = unix_connect_host_raw(path);
  if raw >= 0 {
    return std::Ok<i64, i64>(raw);
  }
  return std::Err<i64, i64>(last_errno_error_raw());
}

pub impl std::net::Ipv4Addr {
  fn new(a: u8, b: u8, c: u8, d: u8) -> Ipv4Addr {
    return ipv4(a, b, c, d);
  }

  fn any() -> Ipv4Addr {
    return ipv4(0 as u8, 0 as u8, 0 as u8, 0 as u8);
  }

  fn localhost() -> Ipv4Addr {
    return ipv4(127 as u8, 0 as u8, 0 as u8, 1 as u8);
  }

  fn octet(self: ref Self, index: i64) -> u8 {
    std::assert(index >= 0);
    std::assert(index < 4);
    if index == 0 {
      return self.a;
    }
    if index == 1 {
      return self.b;
    }
    if index == 2 {
      return self.c;
    }
    return self.d;
  }

  fn try_octet(self: ref Self, index: i64) -> std::Option[u8] {
    if index < 0 || index >= 4 {
      return std::None<u8>();
    }
    return std::Some<u8>(self.octet(index));
  }

  fn is_unspecified(self: ref Self) -> bool {
    return self.a == 0 as u8 && self.b == 0 as u8 && self.c == 0 as u8 && self.d == 0 as u8;
  }

  fn is_loopback(self: ref Self) -> bool {
    return self.a == 127 as u8;
  }

  fn as_ip(self: ref Self) -> IpAddr {
    return IpAddr {
      family: 4,
      s0: self.a as u16,
      s1: self.b as u16,
      s2: self.c as u16,
      s3: self.d as u16,
      s4: 0 as u16,
      s5: 0 as u16,
      s6: 0 as u16,
      s7: 0 as u16,
    };
  }
}

pub impl std::net::Ipv6Addr {
  fn new(s0: u16, s1: u16, s2: u16, s3: u16, s4: u16, s5: u16, s6: u16, s7: u16) -> Ipv6Addr {
    return ipv6(s0, s1, s2, s3, s4, s5, s6, s7);
  }

  fn any() -> Ipv6Addr {
    return ipv6(0 as u16, 0 as u16, 0 as u16, 0 as u16, 0 as u16, 0 as u16, 0 as u16, 0 as u16);
  }

  fn localhost() -> Ipv6Addr {
    return ipv6(0 as u16, 0 as u16, 0 as u16, 0 as u16, 0 as u16, 0 as u16, 0 as u16, 1 as u16);
  }

  fn segment(self: ref Self, index: i64) -> u16 {
    std::assert(index >= 0);
    std::assert(index < 8);
    if index == 0 {
      return self.s0;
    }
    if index == 1 {
      return self.s1;
    }
    if index == 2 {
      return self.s2;
    }
    if index == 3 {
      return self.s3;
    }
    if index == 4 {
      return self.s4;
    }
    if index == 5 {
      return self.s5;
    }
    if index == 6 {
      return self.s6;
    }
    return self.s7;
  }

  fn try_segment(self: ref Self, index: i64) -> std::Option[u16] {
    if index < 0 || index >= 8 {
      return std::None<u16>();
    }
    return std::Some<u16>(self.segment(index));
  }

  fn is_unspecified(self: ref Self) -> bool {
    return self.s0 == 0 as u16 && self.s1 == 0 as u16 && self.s2 == 0 as u16 && self.s3 == 0 as u16 &&
      self.s4 == 0 as u16 && self.s5 == 0 as u16 && self.s6 == 0 as u16 && self.s7 == 0 as u16;
  }

  fn is_loopback(self: ref Self) -> bool {
    return self.s0 == 0 as u16 && self.s1 == 0 as u16 && self.s2 == 0 as u16 && self.s3 == 0 as u16 &&
      self.s4 == 0 as u16 && self.s5 == 0 as u16 && self.s6 == 0 as u16 && self.s7 == 1 as u16;
  }

  fn as_ip(self: ref Self) -> IpAddr {
    return IpAddr {
      family: 6,
      s0: self.s0,
      s1: self.s1,
      s2: self.s2,
      s3: self.s3,
      s4: self.s4,
      s5: self.s5,
      s6: self.s6,
      s7: self.s7,
    };
  }
}

pub impl std::net::IpAddr {
  fn is_v4(self: ref Self) -> bool {
    return self.family == 4;
  }

  fn is_v6(self: ref Self) -> bool {
    return self.family == 6;
  }

  fn is_unspecified(self: ref Self) -> bool {
    return self.s0 == 0 as u16 && self.s1 == 0 as u16 && self.s2 == 0 as u16 && self.s3 == 0 as u16 &&
      self.s4 == 0 as u16 && self.s5 == 0 as u16 && self.s6 == 0 as u16 && self.s7 == 0 as u16;
  }

  fn is_loopback(self: ref Self) -> bool {
    if self.is_v4() {
      return self.s0 == 127 as u16;
    }
    return self.s0 == 0 as u16 && self.s1 == 0 as u16 && self.s2 == 0 as u16 && self.s3 == 0 as u16 &&
      self.s4 == 0 as u16 && self.s5 == 0 as u16 && self.s6 == 0 as u16 && self.s7 == 1 as u16;
  }
}

pub impl std::net::SocketAddr {
  fn new(ip: IpAddr, port: u16) -> SocketAddr {
