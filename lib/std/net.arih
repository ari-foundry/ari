// Network address and socket helpers.
//
// Address values stay plain Ari data. Sockets are explicit owned descriptor
// wrappers over the hosted runtime. Public Result helpers return std::error::Error;
// raw-result variants stay compatibility-only for low-level runtime adapters.
pub type Error = std::error::Error;
pub type ErrorKind = std::error::Kind;

pub struct Ipv4Addr {
  a: u8,
  b: u8,
  c: u8,
  d: u8,
}

pub struct Ipv6Addr {
  s0: u16,
  s1: u16,
  s2: u16,
  s3: u16,
  s4: u16,
  s5: u16,
  s6: u16,
  s7: u16,
}

pub struct IpAddr {
  family: i64,
  s0: u16,
  s1: u16,
  s2: u16,
  s3: u16,
  s4: u16,
  s5: u16,
  s6: u16,
  s7: u16,
}

pub struct SocketAddr {
  ip: IpAddr,
  port: u16,
}

pub trait ToSocketAddrs {
  fn to_socket_addrs(self, zone: ref mut Zone) -> std::Result[std::vec::Vec[std::net::SocketAddr], std::error::Error];
}

pub struct UdpRecvFrom {
  len: i64,
  addr: SocketAddr,
}

pub struct TcpListener {
  mut handle: std::os::OwnedFd,
}

pub struct TcpStream {
  mut handle: std::os::OwnedFd,
}

pub struct UdpSocket {
  mut handle: std::os::OwnedFd,
}

pub struct UnixListener {
  mut handle: std::os::OwnedFd,
}

pub struct UnixStream {
  mut handle: std::os::OwnedFd,
}

pub enum Shutdown {
  Read,
  Write,
  Both,
}

