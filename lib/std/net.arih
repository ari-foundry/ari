    return read_exact_bool_raw(self.handle.raw(), output, len);
  }

  fn read_exact(self: ref mut Self, output: ptr u8, len: i64) -> std::Result[(), std::error::Error] {
    return std::error::map_raw<()>(read_exact_raw(self.handle.raw(), output, len));
  }

  fn read(self: ref mut Self, output: std::Slice[u8]) -> std::Result[i64, std::error::Error] {
    return std::error::map_raw<i64>(read_raw(self.handle.raw(), output));
  }

  fn read_exact_slice(self: ref mut Self, output: std::Slice[u8]) -> std::Result[(), std::error::Error] {
    return self.read_exact(output.as_ptr(), output.len);
  }

  fn read_to_end(self: ref mut Self, zone: ref mut Zone) -> std::Result[std::vec::Vec[u8], std::error::Error] {
    return std::Ok<std::vec::Vec[u8], std::error::Error>(
      std::io::read_all<std::net::UnixStream>(zone, self)
    );
  }

  fn read_to_string(self: ref mut Self, zone: ref mut Zone) -> std::Result[std::string::String, std::error::Error] {
    return std::io::read_to_string<std::net::UnixStream>(zone, self);
  }

  fn write_all_unchecked(self: ref mut Self, values: std::Slice[u8]) -> bool {
    return write_all_bool_raw(self.handle.raw(), values);
  }

  fn flush(self: ref mut Self) -> std::Result[(), std::error::Error] {
    if self.handle.is_open() {
      return std::Ok<(), std::error::Error>(());
    }
    return std::Err<(), std::error::Error>(std::error::new(std::error::BrokenPipe));
  }
}

impl std::io::Reader for std::net::TcpStream {
  pub fn read_byte(self: ref mut Self) -> i64 {
    if !self.handle.is_open() {
      return -2;
    }
    return read_socket_byte_host_raw(self.handle.raw());
  }
}

impl std::io::Writer for std::net::TcpStream {
  pub fn write_byte(self: ref mut Self, value: u8) -> bool {
    if !self.handle.is_open() {
      return false;
    }
    return write_socket_byte_raw(self.handle.raw(), value);
  }

  pub fn write(self: ref mut Self, values: std::Slice[u8]) -> std::Result[i64, std::error::Error] {
    return std::error::map_raw<i64>(write_raw(self.handle.raw(), values));
  }

  pub fn write_all(self: ref mut Self, values: std::Slice[u8]) -> std::Result[(), std::error::Error] {
    return std::error::map_raw<()>(write_all_raw(self.handle.raw(), values));
  }

  pub fn flush(self: ref mut Self) -> std::Result[(), std::error::Error] {
    if self.handle.is_open() {
      return std::Ok<(), std::error::Error>(());
    }
    return std::Err<(), std::error::Error>(std::error::new(std::error::BrokenPipe));
  }
}

