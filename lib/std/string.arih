pub struct RawString {
  mut data: ptr u8,
  mut len: i64,
  mut capacity: i64,
}

pub struct String {
  raw: std::string::RawString,
}

pub struct Utf8String {
  text: std::string::String,
}

pub struct Utf8 {
  bytes: std::Slice[u8],
}

pub struct Codepoints {
  bytes: std::Slice[u8],
  mut index: i64,
}

pub struct OsStr {
  bytes: std::Slice[u8],
}

pub struct OsString {
  text: std::string::String,
}

pub struct SplitOnce {
  left: std::Slice[u8],
  right: std::Slice[u8],
}

pub extern "ari" fn alloc_buffer(zone: ref mut Zone, capacity: i64) -> ptr u8 = "ari_builtin_string_alloc_buffer";
pub extern "ari" fn with_capacity(zone: ref mut Zone, capacity: i64) -> RawString = "ari_builtin_string_with_capacity";
pub extern "ari" fn new(zone: ref mut Zone, capacity: i64) -> std::string::String = "ari_builtin_string_new";
extern "ari" fn from_literal_raw(zone: ref mut Zone, text: string) -> std::string::String = "ari_builtin_string_from_string";
pub extern "ari" fn copy_to(value: ref std::string::String, target: ref mut Zone) -> std::string::String = "ari_builtin_string_copy_to";

pub fn with_capacity_with_allocator(
  allocator: ref std::allocator::Allocator,
  capacity: i64
) -> std::string::RawString {
  std::assert(capacity >= 0);
  var allocation_capacity = capacity;
  if allocation_capacity == 0 {
    allocation_capacity = 1;
  }
  return std::string::RawString {
    data: allocator.alloc_array<u8>(allocation_capacity),
    len: 0,
    capacity: capacity,
  };
}

pub fn new_with_allocator(
  allocator: ref std::allocator::Allocator,
  capacity: i64
) -> std::string::String {
  return std::string::String {
    raw: std::string::with_capacity_with_allocator(allocator, capacity),
  };
}

pub fn new_with_region(
  region: ref mut std::region::Region,
  capacity: i64
) -> std::string::String {
  let allocator = std::region::allocator(region);
  return std::string::new_with_allocator(ref allocator, capacity);
}

fn utf8_string_from_owned(value: std::string::String) -> std::string::Utf8String {
  return std::string::Utf8String { text: value };
}

fn os_string_from_owned(value: std::string::String) -> std::string::OsString {
  return std::string::OsString { text: value };
}

fn c_string_len(text: string) -> i64 {
  let data = text as ptr u8;
  var len = 0;
  while ptr_load(ptr_add(data, len)) != '\x00' {
    len = len + 1;
  }
  return len;
}

pub fn utf8(bytes: std::Slice[u8]) -> std::Option[std::string::Utf8] {
  if !std::encoding::is_utf8(bytes) {
    return std::None<std::string::Utf8>();
  }
  return std::Some<std::string::Utf8>(std::string::Utf8 { bytes: bytes });
}

pub fn utf8_string(
  zone: ref mut Zone,
  bytes: std::Slice[u8]
) -> std::Result[std::string::Utf8String, std::encoding::Utf8Error] {
  match std::encoding::validate_utf8(bytes) {
    std::Err(reason) => {
      return std::Err<std::string::Utf8String, std::encoding::Utf8Error>(reason);
    }
    std::Ok(_) => {}
  }
  let text = std::string::from_slice_in(zone, bytes);
  return std::Ok<std::string::Utf8String, std::encoding::Utf8Error>(
    std::string::utf8_string_from_owned(text)
  );
}

pub fn utf8_string_optional(zone: ref mut Zone, bytes: std::Slice[u8]) -> std::Option[std::string::Utf8String] {
  match std::string::utf8_string(zone, bytes) {
    std::Ok(value) => {
      return std::Some<std::string::Utf8String>(value);
    }
    std::Err(_) => {
      return std::None<std::string::Utf8String>();
    }
  }
}

pub fn utf8_string_unchecked(zone: ref mut Zone, bytes: std::Slice[u8]) -> std::string::Utf8String {
  match std::string::utf8_string(zone, bytes) {
    std::Ok(value) => {
      return value;
    }
    std::Err(_) => {
      std::panic();
    }
  }
  return std::string::utf8_string_from_owned(std::string::new(zone, 0));
}

pub fn codepoints(bytes: std::Slice[u8]) -> std::Option[std::string::Codepoints] {
  if !std::encoding::is_utf8(bytes) {
    return std::None<std::string::Codepoints>();
  }
  return std::Some<std::string::Codepoints>(std::string::Codepoints { bytes: bytes, index: 0 });
}

pub fn os_str(bytes: std::Slice[u8]) -> std::string::OsStr {
  return std::string::OsStr { bytes: bytes };
}

pub fn os_string(zone: ref mut Zone, bytes: std::Slice[u8]) -> std::string::OsString {
  let text = std::string::from_slice_in(zone, bytes);
  return std::string::os_string_from_owned(text);
}

pub fn os_string_from_slice(zone: ref mut Zone, text: std::Slice[u8]) -> std::string::OsString {
  let value = std::string::from_slice_in(zone, text);
  return std::string::os_string_from_owned(value);
}

pub fn c_str(text: std::c::CStr) -> std::c::CStr {
  return text;
}

pub fn c_len(text: std::c::CStr) -> i64 {
  return text.len();
}

pub fn c_bytes(text: std::c::CStr) -> std::Slice[u8] {
  return text.as_slice();
}

fn c_len_literal(text: string) -> i64 {
  return c_string_len(text);
}

fn c_bytes_literal(text: string) -> std::Slice[u8] {
  return std::Slice<u8> { data: text as ptr u8, len: c_string_len(text) };
}

pub fn bytes(text: std::Slice[u8]) -> std::Slice[u8] {
  return text;
}

fn bytes_raw(text: string) -> std::Slice[u8] {
  return std::string::c_bytes_literal(text);
}

pub fn from_slice_in(zone: ref mut Zone, values: std::Slice[u8]) -> std::string::String {
  var output = std::string::new(zone, values.len);
  output.extend_from_slice_in(zone, values);
  return output;
}

pub fn from_slice_with_allocator(
  allocator: ref std::allocator::Allocator,
  values: std::Slice[u8]
) -> std::string::String {
  var output = std::string::new_with_allocator(allocator, values.len);
  var index = 0;
  while index < values.len {
    output.push(values[index]);
    index = index + 1;
  }
  return output;
}

pub fn from_slice_with_region(
  region: ref mut std::region::Region,
  values: std::Slice[u8]
) -> std::string::String {
  let allocator = std::region::allocator(region);
  return std::string::from_slice_with_allocator(ref allocator, values);
}

pub fn from(zone: ref mut Zone, text: std::Slice[u8]) -> std::string::String {
  return std::string::from_slice_in(zone, text);
}

fn from_raw(zone: ref mut Zone, text: string) -> std::string::String {
  return std::string::from_literal_raw(zone, text);
}

pub fn copy(zone: ref mut Zone, values: std::Slice[u8]) -> std::string::String {
  return std::string::from_slice_in(zone, values);
}

pub fn copy_with_allocator(
  allocator: ref std::allocator::Allocator,
  values: std::Slice[u8]
) -> std::string::String {
  return std::string::from_slice_with_allocator(allocator, values);
}

pub fn copy_with_region(
  region: ref mut std::region::Region,
  values: std::Slice[u8]
) -> std::string::String {
  return std::string::from_slice_with_region(region, values);
}

pub fn empty(zone: ref mut Zone) -> std::string::String {
  return std::string::new(zone, 0);
}

pub fn empty_with_region(region: ref mut std::region::Region) -> std::string::String {
  return std::string::new_with_region(region, 0);
}

pub fn join_in(
  zone: ref mut Zone,
  parts: std::Slice[std::Slice[u8]],
  separator: std::Slice[u8]
) -> std::string::String {
  var capacity = 0;
  var index = 0;
  while index < parts.len {
    capacity = capacity + parts[index].len;
    if index > 0 {
      capacity = capacity + separator.len;
    }
    index = index + 1;
  }

  var output = std::string::new(zone, capacity);
  index = 0;
  while index < parts.len {
    if index > 0 {
      output.extend_from_slice_in(zone, separator);
    }
    output.extend_from_slice_in(zone, parts[index]);
    index = index + 1;
  }
  return output;
}

fn matches_at(values: std::Slice[u8], offset: i64, needle: std::Slice[u8]) -> bool {
  if offset < 0 {
    return false;
  }
  if needle.len < 0 {
    return false;
  }
  if offset + needle.len > values.len {
    return false;
  }
  var index = 0;
  while index < needle.len {
    if values[offset + index] != needle[index] {
      return false;
    }
    index = index + 1;
  }
  return true;
}

pub fn lines(values: std::Slice[u8]) -> std::SliceSplit[u8] {
  return values.split('\n');
}

pub fn trim_start(values: std::Slice[u8]) -> std::Slice[u8] {
  return std::ascii::trim_start(values);
}

pub fn trim_end(values: std::Slice[u8]) -> std::Slice[u8] {
  return std::ascii::trim_end(values);
}

pub fn trim(values: std::Slice[u8]) -> std::Slice[u8] {
  return std::ascii::trim(values);
}

pub fn split(values: std::Slice[u8], delimiter: char) -> std::SliceSplit[u8] {
  return values.split(delimiter);
}

pub fn split_once(values: std::Slice[u8], delimiter: std::Slice[u8]) -> std::Option[std::string::SplitOnce] {
  let offset = values.find(delimiter);
  if offset < 0 {
    return std::None<std::string::SplitOnce>();
  }
  let left = values.slice(0, offset);
  let right = values.slice(offset + delimiter.len, values.len);
  return std::Some<std::string::SplitOnce>(std::string::SplitOnce { left: left, right: right });
}

pub fn starts_with(values: std::Slice[u8], prefix: std::Slice[u8]) -> bool {
  return values.starts_with(prefix);
}

pub fn ends_with(values: std::Slice[u8], suffix: std::Slice[u8]) -> bool {
  return values.ends_with(suffix);
}

pub fn contains(values: std::Slice[u8], needle: std::Slice[u8]) -> bool {
  return values.contains_slice(needle);
}

pub fn find(values: std::Slice[u8], needle: std::Slice[u8]) -> i64 {
  return values.find(needle);
}

pub fn strip_prefix(values: std::Slice[u8], prefix: std::Slice[u8]) -> std::Option[std::Slice[u8]] {
  return values.strip_prefix(prefix);
}

pub fn strip_suffix(values: std::Slice[u8], suffix: std::Slice[u8]) -> std::Option[std::Slice[u8]] {
  return values.strip_suffix(suffix);
}

pub fn substring(values: std::Slice[u8], start: i64, end: i64) -> std::Slice[u8] {
  return values.slice(start, end);
}

pub fn replace(
  zone: ref mut Zone,
  values: std::Slice[u8],
  needle: std::Slice[u8],
  replacement: std::Slice[u8]
) -> std::string::String {
  if needle.len == 0 {
    return std::string::from_slice_in(zone, values);
  }

  var output = std::string::new(zone, values.len);
  var index = 0;
  while index < values.len {
    if std::string::matches_at(values, index, needle) {
      output.extend_from_slice_in(zone, replacement);
      index = index + needle.len;
    } else {
      output.push_in(zone, values[index]);
      index = index + 1;
    }
  }
  return output;
}

fn next_growth_capacity(current: i64, minimum: i64) -> i64 {
  var capacity = current * 2;
  if capacity < minimum {
    capacity = minimum;
  }
  return capacity;
}

fn grow_to_capacity(value: ref mut std::string::String, capacity: i64) -> void {
  std::assert(capacity >= 0);
  if capacity <= value.raw.capacity {
    return;
  }
  let allocator = std::allocator::of_mut(value);
  let data = allocator.alloc(capacity, 1);
  var index = 0;
  while index < value.raw.len {
    ptr_store(ptr_add(data, index), ptr_load(ptr_add(value.raw.data, index)));
    index = index + 1;
  }
  value.raw.data = data;
  value.raw.capacity = capacity;
}

fn ensure_spare_capacity(value: ref mut std::string::String) -> void {
  if value.raw.len >= value.raw.capacity {
    let capacity = next_growth_capacity(value.raw.capacity, value.raw.len + 1);
    grow_to_capacity(value, capacity);
  }
}

fn append_byte_in(value: ref mut std::string::String, zone: ref mut Zone, byte: char) -> void {
  ensure_spare_capacity(value);
  ptr_store(ptr_add(value.raw.data, value.raw.len), byte);
  value.raw.len = value.raw.len + 1;
}

pub impl std::string::Utf8 {
  fn as_slice(self: ref Self) -> std::Slice[u8] {
    return self.bytes;
  }

  fn len(self: ref Self) -> i64 {
    return self.bytes.len;
  }

  fn is_empty(self: ref Self) -> bool {
    return self.bytes.len == 0;
  }

  fn codepoint_count(self: ref Self) -> i64 {
    return std::encoding::utf8_count(self.bytes).unwrap();
  }

  fn codepoint_at(self: ref Self, byte_index: i64) -> std::Option[std::encoding::Utf8Char] {
    return std::encoding::utf8_at(self.bytes, byte_index);
  }

  fn next_index(self: ref Self, byte_index: i64) -> std::Option[i64] {
    return std::encoding::utf8_next_index(self.bytes, byte_index);
  }

  fn codepoints(self: ref Self) -> std::string::Codepoints {
    return std::string::Codepoints { bytes: self.bytes, index: 0 };
  }
}

pub impl std::string::Utf8String {
  fn as_string(self: ref Self) -> ref std::string::String {
    return ref self.text;
  }

  fn as_slice(self: ref Self) -> std::Slice[u8] {
    return self.text.as_slice();
  }

  fn as_utf8(self: ref Self) -> std::string::Utf8 {
    return std::string::Utf8 { bytes: self.text.as_slice() };
  }

  fn len(self: ref Self) -> i64 {
    return self.text.len();
  }

  fn is_empty(self: ref Self) -> bool {
    return self.text.is_empty();
  }

  fn codepoint_count(self: ref Self) -> i64 {
    return self.as_utf8().codepoint_count();
  }

  fn codepoint_at(self: ref Self, byte_index: i64) -> std::Option[std::encoding::Utf8Char] {
    return self.as_utf8().codepoint_at(byte_index);
  }

  fn next_index(self: ref Self, byte_index: i64) -> std::Option[i64] {
    return self.as_utf8().next_index(byte_index);
  }

  fn codepoints(self: ref Self) -> std::string::Codepoints {
    return self.as_utf8().codepoints();
  }

  fn to_string(self: ref Self, zone: ref mut Zone) -> std::string::String {
    return self.text.copy_to(zone);
  }
}

impl std::Iterator[std::encoding::Utf8Char] for std::string::Codepoints {
  pub fn next(self: ref mut Self) -> std::Option[std::encoding::Utf8Char] {
    if self.index >= self.bytes.len {
      return std::None<std::encoding::Utf8Char>();
    }

    match std::encoding::utf8_at(self.bytes, self.index) {
      std::Some(ch) => {
        self.index = ch.next_index(self.index);
        return std::Some<std::encoding::Utf8Char>(ch);
      }
      std::None => {
        self.index = self.bytes.len;
        return std::None<std::encoding::Utf8Char>();
      }
    }
  }
}

pub impl std::string::OsStr {
  fn as_slice(self: ref Self) -> std::Slice[u8] {
