  ) -> std::Result[std::path::PathBuf, std::error::Error] {
    return std::region::current_dir_join(self, child);
  }

  fn env_get(self: ref mut Self, name: std::Slice[u8]) -> std::Result[std::string::String, std::error::Error] {
    return std::region::env_get(self, name);
  }

  fn env_var(self: ref mut Self, name: std::Slice[u8]) -> std::Option[std::string::String] {
    return std::region::env_var(self, name);
  }

  fn env_get_or_default(self: ref mut Self, name: std::Slice[u8]) -> std::string::String {
    return std::region::env_get_or_default(self, name);
  }

  fn env_arg(self: ref mut Self, index: i64) -> std::Result[std::string::String, std::error::Error] {
    return std::region::env_arg(self, index);
  }

  fn env_args(self: ref mut Self) -> std::vec::Vec[std::string::String] {
    return std::region::env_args(self);
  }

  fn env_args_os(self: ref mut Self) -> std::vec::Vec[std::string::OsStr] {
    return std::region::env_args_os(self);
  }

  fn env_program_name(self: ref mut Self) -> std::Result[std::string::String, std::error::Error] {
    return std::region::env_program_name(self);
  }

  fn env_current_dir(self: ref mut Self) -> std::Result[std::string::String, std::error::Error] {
