    return std::region::path_join(self, base, child);
  }

  fn path_join_many(self: ref mut Self, parts: std::Slice[std::path::PathBytes]) -> std::path::PathBuf {
    return std::region::path_join_many(self, parts);
  }

  fn path_normalize(self: ref mut Self, path: std::Slice[u8]) -> std::path::PathBuf {
    return std::region::path_normalize(self, path);
  }

  fn current_dir_join(
    self: ref mut Self,
