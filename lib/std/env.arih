pub fn current_dir_os_or_default() -> std::string::OsStr {
  return os_from_text(current_dir_raw());
}

pub fn current_dir_os_optional() -> std::Option[std::string::OsStr] {
  return current_dir_os().ok();
}

pub fn try_current_dir_os() -> std::Option[std::string::OsStr] {
  return current_dir_os_optional();
}

pub fn current_dir_path() -> std::Result[std::path::PathBytes, std::error::Error] {
  match current_dir_text() {
    std::Ok(path) => {
      return std::Ok<std::path::PathBytes, std::error::Error>(path_from_text(path));
    }
    std::Err(reason) => {
      return std::Err<std::path::PathBytes, std::error::Error>(reason);
