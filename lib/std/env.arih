}

pub fn program_name_os() -> std::Result[std::string::OsStr, std::error::Error] {
  return arg_os(0);
}

fn current_dir_text() -> std::Result[ptr c_char, std::error::Error] {
  let path = current_dir_raw();
  if text_is_empty(path) {
    return std::Err<ptr c_char, std::error::Error>(other_error());
  }
  return std::Ok<ptr c_char, std::error::Error>(path);
}

fn current_dir_text_or_default() -> ptr c_char {
  return current_dir_raw();
}

fn current_dir_text_optional() -> std::Option[ptr c_char] {
  return current_dir_text().ok();
}

fn try_current_dir_text() -> std::Option[ptr c_char] {
