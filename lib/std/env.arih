pub fn home_dir() -> std::Option[std::path::PathBytes] {
  match get_text_raw_name("HOME") {
    std::Ok(path) => {
      if text_is_empty(path) {
        return std::None<std::path::PathBytes>();
      }
      return std::Some<std::path::PathBytes>(path_from_text(path));
    }
    std::Err(_) => {
      return std::None<std::path::PathBytes>();
    }
  }
}

