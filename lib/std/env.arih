}

pub fn executable_path_path_or_default() -> std::path::PathBytes {
  return path_from_text(executable_path_raw());
}

pub fn executable_path_path_optional() -> std::Option[std::path::PathBytes] {
  return executable_path_path().ok();
}

pub fn try_executable_path_path() -> std::Option[std::path::PathBytes] {
  return executable_path_path_optional();
}
