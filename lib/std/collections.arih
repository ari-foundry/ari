impl[K, V] std::Iterator[std::collections::MapEntry[K, V]] for std::collections::TreeMapRange[K, V] {
  pub fn next(self: ref mut Self) -> std::Option[std::collections::MapEntry[K, V]] {
    if self.current < 0 {
      return std::None<std::collections::MapEntry[K, V]>();
    }
    let node = self.current;
    let key = ptr_load(ptr_add(self.keys, node));
    let less = self.less;
    if !less(key, self.end) {
      self.current = -1;
      return std::None<std::collections::MapEntry[K, V]>();
    }
    self.current = tree_next_node(node, self.left, self.right, self.parent);
    return std::Some<std::collections::MapEntry[K, V]>(
      std::collections::MapEntry<K, V> {
        key: key,
        value: ptr_load(ptr_add(self.values, node)),
      }
    );
  }
}

impl[K, V] std::Iterator[std::collections::MapEntryMut[K, V]] for std::collections::TreeMapRangeMut[K, V] {
  pub fn next(self: ref mut Self) -> std::Option[std::collections::MapEntryMut[K, V]] {
    if self.current < 0 {
      return std::None<std::collections::MapEntryMut[K, V]>();
    }
    let node = self.current;
    let key = ptr_load(ptr_add(self.keys, node));
    let less = self.less;
    if !less(key, self.end) {
      self.current = -1;
      return std::None<std::collections::MapEntryMut[K, V]>();
    }
    self.current = tree_next_node(node, self.left, self.right, self.parent);
    return std::Some<std::collections::MapEntryMut[K, V]>(
      std::collections::MapEntryMut<K, V> {
        key: key,
        value: ptr_add(self.values, node),
      }
    );
  }
}

impl[K, V] std::Iterator[std::collections::MapEntry[K, V]] for std::collections::TreeMapDrain[K, V] {
  pub fn next(self: ref mut Self) -> std::Option[std::collections::MapEntry[K, V]] {
    if self.current < 0 {
      return std::None<std::collections::MapEntry[K, V]>();
    }
    let node = self.current;
    self.current = tree_next_node(node, self.left, self.right, self.parent);
    ptr_store(ptr_add(self.colors, node), -2);
    return std::Some<std::collections::MapEntry[K, V]>(
      std::collections::MapEntry<K, V> {
        key: ptr_load(ptr_add(self.keys, node)),
        value: ptr_load(ptr_add(self.values, node)),
      }
    );
  }
}

impl[K, V] std::Drop for std::collections::TreeMapDrain[K, V] {
  fn drop(self) -> void {
    var cursor = self;
    var index = 0;
    while index < cursor.len {
      if ptr_load(ptr_add(cursor.colors, index)) != -2 {
        let key = ptr_load(ptr_add(cursor.keys, index));
        let value = ptr_load(ptr_add(cursor.values, index));
        drop key;
        drop value;
        ptr_store(ptr_add(cursor.colors, index), -2);
      }
      index = index + 1;
    }
    return;
  }
}

impl[K, V] std::IntoIterator[std::collections::MapEntry[K, V]] for std::collections::TreeMap[K, V] {
  pub fn into_iter(self: ref mut Self) -> std::collections::TreeMapEntries[K, V] {
    return self.entries();
  }
}

impl[K, V] std::zone::ZoneBacked for std::collections::TreeMap[K, V] {
  pub fn zone(self: ref Self) -> std::zone::ZoneMetadata {
    std::assert(self.capacity > 0);
    return std::zone::metadata(self.keys as ptr u8);
  }
}

impl[K, V] std::Drop for std::collections::TreeMap[K, V] {
  fn drop(self) -> void {
    var dropped = self;
    tree_map_drop_values<K, V>(ref mut dropped);
    return;
  }
}

fn tree_set_color[T](set: ref mut std::collections::TreeSet[T], node: i64) -> i64 {
  if node < 0 {
    return 0;
  }
  return ptr_load(ptr_add(set.colors, node));
}

fn tree_set_set_color[T](set: ref mut std::collections::TreeSet[T], node: i64, color: i64) -> void {
  if node >= 0 {
    ptr_store(ptr_add(set.colors, node), color);
  }
}

fn tree_set_rotate_left[T](set: ref mut std::collections::TreeSet[T], node: i64) -> void {
  let pivot = ptr_load(ptr_add(set.right, node));
  std::assert(pivot >= 0);
  ptr_store(ptr_add(set.right, node), ptr_load(ptr_add(set.left, pivot)));
  if ptr_load(ptr_add(set.left, pivot)) >= 0 {
    ptr_store(ptr_add(set.parent, ptr_load(ptr_add(set.left, pivot))), node);
  }
  ptr_store(ptr_add(set.parent, pivot), ptr_load(ptr_add(set.parent, node)));
  if ptr_load(ptr_add(set.parent, node)) < 0 {
    set.root = pivot;
  } else {
    let parent = ptr_load(ptr_add(set.parent, node));
    if node == ptr_load(ptr_add(set.left, parent)) {
      ptr_store(ptr_add(set.left, parent), pivot);
    } else {
      ptr_store(ptr_add(set.right, parent), pivot);
    }
  }
  ptr_store(ptr_add(set.left, pivot), node);
  ptr_store(ptr_add(set.parent, node), pivot);
}

fn tree_set_rotate_right[T](set: ref mut std::collections::TreeSet[T], node: i64) -> void {
  let pivot = ptr_load(ptr_add(set.left, node));
  std::assert(pivot >= 0);
  ptr_store(ptr_add(set.left, node), ptr_load(ptr_add(set.right, pivot)));
  if ptr_load(ptr_add(set.right, pivot)) >= 0 {
    ptr_store(ptr_add(set.parent, ptr_load(ptr_add(set.right, pivot))), node);
  }
  ptr_store(ptr_add(set.parent, pivot), ptr_load(ptr_add(set.parent, node)));
  if ptr_load(ptr_add(set.parent, node)) < 0 {
    set.root = pivot;
  } else {
    let parent = ptr_load(ptr_add(set.parent, node));
    if node == ptr_load(ptr_add(set.right, parent)) {
      ptr_store(ptr_add(set.right, parent), pivot);
    } else {
      ptr_store(ptr_add(set.left, parent), pivot);
    }
  }
  ptr_store(ptr_add(set.right, pivot), node);
  ptr_store(ptr_add(set.parent, node), pivot);
}

fn tree_set_left_child[T](set: ref mut std::collections::TreeSet[T], node: i64) -> i64 {
  if node < 0 {
    return -1;
  }
  return ptr_load(ptr_add(set.left, node));
}

fn tree_set_right_child[T](set: ref mut std::collections::TreeSet[T], node: i64) -> i64 {
  if node < 0 {
    return -1;
  }
  return ptr_load(ptr_add(set.right, node));
}

fn tree_set_transplant[T](
  set: ref mut std::collections::TreeSet[T],
  old_node: i64,
  new_node: i64
) -> void {
  let parent = ptr_load(ptr_add(set.parent, old_node));
  if parent < 0 {
    set.root = new_node;
  } else if old_node == ptr_load(ptr_add(set.left, parent)) {
    ptr_store(ptr_add(set.left, parent), new_node);
  } else {
    ptr_store(ptr_add(set.right, parent), new_node);
  }
  if new_node >= 0 {
    ptr_store(ptr_add(set.parent, new_node), parent);
  }
}

fn tree_set_fix_delete[T](
  set: ref mut std::collections::TreeSet[T],
  start: i64,
  start_parent: i64,
  start_is_left: bool
) -> void {
  var node = start;
  var parent = start_parent;
  var is_left = start_is_left;
  while node != set.root && tree_set_color<T>(set, node) == 0 {
    if parent < 0 {
      return;
    }
    if is_left {
      var right_sibling = ptr_load(ptr_add(set.right, parent));
      if tree_set_color<T>(set, right_sibling) == 1 {
        tree_set_set_color<T>(set, right_sibling, 0);
        tree_set_set_color<T>(set, parent, 1);
        tree_set_rotate_left<T>(set, parent);
        right_sibling = ptr_load(ptr_add(set.right, parent));
      }
      if tree_set_color<T>(set, tree_set_left_child<T>(set, right_sibling)) == 0 &&
         tree_set_color<T>(set, tree_set_right_child<T>(set, right_sibling)) == 0 {
        tree_set_set_color<T>(set, right_sibling, 1);
        node = parent;
        parent = ptr_load(ptr_add(set.parent, node));
        is_left = parent >= 0 && node == ptr_load(ptr_add(set.left, parent));
      } else {
        if tree_set_color<T>(set, tree_set_right_child<T>(set, right_sibling)) == 0 {
          tree_set_set_color<T>(set, tree_set_left_child<T>(set, right_sibling), 0);
          tree_set_set_color<T>(set, right_sibling, 1);
          tree_set_rotate_right<T>(set, right_sibling);
          right_sibling = ptr_load(ptr_add(set.right, parent));
        }
        tree_set_set_color<T>(set, right_sibling, tree_set_color<T>(set, parent));
        tree_set_set_color<T>(set, parent, 0);
        tree_set_set_color<T>(set, tree_set_right_child<T>(set, right_sibling), 0);
        tree_set_rotate_left<T>(set, parent);
        node = set.root;
        parent = -1;
      }
    } else {
      var left_sibling = ptr_load(ptr_add(set.left, parent));
      if tree_set_color<T>(set, left_sibling) == 1 {
        tree_set_set_color<T>(set, left_sibling, 0);
        tree_set_set_color<T>(set, parent, 1);
        tree_set_rotate_right<T>(set, parent);
        left_sibling = ptr_load(ptr_add(set.left, parent));
      }
      if tree_set_color<T>(set, tree_set_right_child<T>(set, left_sibling)) == 0 &&
         tree_set_color<T>(set, tree_set_left_child<T>(set, left_sibling)) == 0 {
        tree_set_set_color<T>(set, left_sibling, 1);
        node = parent;
        parent = ptr_load(ptr_add(set.parent, node));
        is_left = parent >= 0 && node == ptr_load(ptr_add(set.left, parent));
      } else {
        if tree_set_color<T>(set, tree_set_left_child<T>(set, left_sibling)) == 0 {
          tree_set_set_color<T>(set, tree_set_right_child<T>(set, left_sibling), 0);
          tree_set_set_color<T>(set, left_sibling, 1);
          tree_set_rotate_left<T>(set, left_sibling);
          left_sibling = ptr_load(ptr_add(set.left, parent));
        }
        tree_set_set_color<T>(set, left_sibling, tree_set_color<T>(set, parent));
        tree_set_set_color<T>(set, parent, 0);
        tree_set_set_color<T>(set, tree_set_left_child<T>(set, left_sibling), 0);
        tree_set_rotate_right<T>(set, parent);
        node = set.root;
        parent = -1;
      }
    }
  }
  tree_set_set_color<T>(set, node, 0);
}

fn tree_set_delete_slot[T](set: ref mut std::collections::TreeSet[T], target: i64) -> void {
  var removed = target;
  var removed_color = tree_set_color<T>(set, removed);
  var fix_node = -1;
  var fix_parent = -1;
  var fix_is_left = false;
  let left = ptr_load(ptr_add(set.left, target));
  let right = ptr_load(ptr_add(set.right, target));
  if left < 0 {
    fix_node = right;
    fix_parent = ptr_load(ptr_add(set.parent, target));
    if fix_parent >= 0 {
      fix_is_left = target == ptr_load(ptr_add(set.left, fix_parent));
    }
    tree_set_transplant<T>(set, target, right);
  } else if right < 0 {
    fix_node = left;
    fix_parent = ptr_load(ptr_add(set.parent, target));
    if fix_parent >= 0 {
      fix_is_left = target == ptr_load(ptr_add(set.left, fix_parent));
    }
    tree_set_transplant<T>(set, target, left);
  } else {
    removed = tree_first_node(right, set.left);
    removed_color = tree_set_color<T>(set, removed);
    fix_node = ptr_load(ptr_add(set.right, removed));
    if ptr_load(ptr_add(set.parent, removed)) == target {
      fix_parent = removed;
      fix_is_left = false;
      if fix_node >= 0 {
        ptr_store(ptr_add(set.parent, fix_node), removed);
      }
    } else {
      fix_parent = ptr_load(ptr_add(set.parent, removed));
      fix_is_left = removed == ptr_load(ptr_add(set.left, fix_parent));
      tree_set_transplant<T>(set, removed, fix_node);
      ptr_store(ptr_add(set.right, removed), right);
      ptr_store(ptr_add(set.parent, right), removed);
    }
    tree_set_transplant<T>(set, target, removed);
    ptr_store(ptr_add(set.left, removed), left);
    ptr_store(ptr_add(set.parent, left), removed);
    ptr_store(ptr_add(set.colors, removed), tree_set_color<T>(set, target));
  }
  if removed_color == 0 {
    tree_set_fix_delete<T>(set, fix_node, fix_parent, fix_is_left);
  }
  tree_set_set_color<T>(set, set.root, 0);
  ptr_store(ptr_add(set.left, target), -1);
  ptr_store(ptr_add(set.right, target), -1);
  ptr_store(ptr_add(set.parent, target), -1);
  ptr_store(ptr_add(set.colors, target), 0);
}

fn tree_set_move_last_slot[T](
  set: ref mut std::collections::TreeSet[T],
  target: i64,
  source: i64
) -> void {
  if target == source {
    return;
  }
  ptr_store(ptr_add(set.data, target), ptr_load(ptr_add(set.data, source)));
  ptr_store(ptr_add(set.left, target), ptr_load(ptr_add(set.left, source)));
  ptr_store(ptr_add(set.right, target), ptr_load(ptr_add(set.right, source)));
  ptr_store(ptr_add(set.parent, target), ptr_load(ptr_add(set.parent, source)));
  ptr_store(ptr_add(set.colors, target), ptr_load(ptr_add(set.colors, source)));

  if set.root == source {
    set.root = target;
  }
  let parent = ptr_load(ptr_add(set.parent, target));
  if parent >= 0 {
    if ptr_load(ptr_add(set.left, parent)) == source {
      ptr_store(ptr_add(set.left, parent), target);
    }
    if ptr_load(ptr_add(set.right, parent)) == source {
      ptr_store(ptr_add(set.right, parent), target);
    }
  }
  let left = ptr_load(ptr_add(set.left, target));
  if left >= 0 {
    ptr_store(ptr_add(set.parent, left), target);
  }
  let right = ptr_load(ptr_add(set.right, target));
  if right >= 0 {
    ptr_store(ptr_add(set.parent, right), target);
  }
}

fn tree_set_fix_insert[T](set: ref mut std::collections::TreeSet[T], inserted: i64) -> void {
  var node = inserted;
  while node != set.root && tree_set_color<T>(set, ptr_load(ptr_add(set.parent, node))) == 1 {
    let parent = ptr_load(ptr_add(set.parent, node));
    let grand = ptr_load(ptr_add(set.parent, parent));
    if parent == ptr_load(ptr_add(set.left, grand)) {
      let left_uncle = ptr_load(ptr_add(set.right, grand));
      if tree_set_color<T>(set, left_uncle) == 1 {
        tree_set_set_color<T>(set, parent, 0);
        tree_set_set_color<T>(set, left_uncle, 0);
        tree_set_set_color<T>(set, grand, 1);
        node = grand;
      } else {
        if node == ptr_load(ptr_add(set.right, parent)) {
          node = parent;
          tree_set_rotate_left<T>(set, node);
        }
        let left_fixed_parent = ptr_load(ptr_add(set.parent, node));
        let left_fixed_grand = ptr_load(ptr_add(set.parent, left_fixed_parent));
        tree_set_set_color<T>(set, left_fixed_parent, 0);
        tree_set_set_color<T>(set, left_fixed_grand, 1);
        tree_set_rotate_right<T>(set, left_fixed_grand);
      }
    } else {
      let right_uncle = ptr_load(ptr_add(set.left, grand));
      if tree_set_color<T>(set, right_uncle) == 1 {
        tree_set_set_color<T>(set, parent, 0);
        tree_set_set_color<T>(set, right_uncle, 0);
        tree_set_set_color<T>(set, grand, 1);
        node = grand;
      } else {
        if node == ptr_load(ptr_add(set.left, parent)) {
          node = parent;
          tree_set_rotate_right<T>(set, node);
        }
        let right_fixed_parent = ptr_load(ptr_add(set.parent, node));
        let right_fixed_grand = ptr_load(ptr_add(set.parent, right_fixed_parent));
        tree_set_set_color<T>(set, right_fixed_parent, 0);
        tree_set_set_color<T>(set, right_fixed_grand, 1);
        tree_set_rotate_left<T>(set, right_fixed_grand);
      }
    }
  }
  tree_set_set_color<T>(set, set.root, 0);
}

fn tree_set_find_slot[T](set: ref std::collections::TreeSet[T], value: T) -> i64 {
  let less = set.less;
  var node = set.root;
  while node >= 0 {
    let node_value = ptr_load(ptr_add(set.data, node));
    if less(value, node_value) {
      node = ptr_load(ptr_add(set.left, node));
    } else if less(node_value, value) {
      node = ptr_load(ptr_add(set.right, node));
    } else {
      return node;
    }
  }
  return -1;
}

fn tree_set_find_slot_mut[T](set: ref mut std::collections::TreeSet[T], value: T) -> i64 {
  let less = set.less;
  var node = set.root;
  while node >= 0 {
    let node_value = ptr_load(ptr_add(set.data, node));
    if less(value, node_value) {
      node = ptr_load(ptr_add(set.left, node));
    } else if less(node_value, value) {
      node = ptr_load(ptr_add(set.right, node));
    } else {
      return node;
    }
  }
  return -1;
}

fn tree_set_lower_bound_node[T](set: ref std::collections::TreeSet[T], value: T) -> i64 {
  let less = set.less;
  var node = set.root;
  var best = -1;
  while node >= 0 {
    let node_value = ptr_load(ptr_add(set.data, node));
    if less(node_value, value) {
      node = ptr_load(ptr_add(set.right, node));
    } else {
      best = node;
      node = ptr_load(ptr_add(set.left, node));
    }
  }
  return best;
}

fn tree_set_lower_bound_node_mut[T](set: ref mut std::collections::TreeSet[T], value: T) -> i64 {
  let less = set.less;
  var node = set.root;
  var best = -1;
  while node >= 0 {
    let node_value = ptr_load(ptr_add(set.data, node));
    if less(node_value, value) {
      node = ptr_load(ptr_add(set.right, node));
    } else {
      best = node;
      node = ptr_load(ptr_add(set.left, node));
    }
  }
  return best;
}

fn tree_set_upper_bound_node[T](set: ref std::collections::TreeSet[T], value: T) -> i64 {
  let less = set.less;
  var node = set.root;
  var best = -1;
  while node >= 0 {
    let node_value = ptr_load(ptr_add(set.data, node));
    if less(value, node_value) {
      best = node;
      node = ptr_load(ptr_add(set.left, node));
    } else {
      node = ptr_load(ptr_add(set.right, node));
    }
  }
  return best;
}

fn tree_set_link_existing_node[T](set: ref mut std::collections::TreeSet[T], index: i64) -> void {
  let less = set.less;
  var parent = -1;
  var node = set.root;
  var place_left = false;
  let value = ptr_load(ptr_add(set.data, index));
  ptr_store(ptr_add(set.left, index), -1);
  ptr_store(ptr_add(set.right, index), -1);
  ptr_store(ptr_add(set.parent, index), -1);
  ptr_store(ptr_add(set.colors, index), 1);
  while node >= 0 {
    parent = node;
    let node_value = ptr_load(ptr_add(set.data, node));
    if less(value, node_value) {
      node = ptr_load(ptr_add(set.left, node));
      place_left = true;
    } else {
      node = ptr_load(ptr_add(set.right, node));
      place_left = false;
    }
  }
  ptr_store(ptr_add(set.parent, index), parent);
  if parent < 0 {
    set.root = index;
  } else if place_left {
    ptr_store(ptr_add(set.left, parent), index);
  } else {
    ptr_store(ptr_add(set.right, parent), index);
  }
  tree_set_fix_insert<T>(set, index);
}

fn tree_set_insert_or_drop[T](set: ref mut std::collections::TreeSet[T], value: T) -> bool {
  let less = set.less;
  var parent = -1;
  var node = set.root;
  var place_left = false;
  while node >= 0 {
    parent = node;
    let node_value = ptr_load(ptr_add(set.data, node));
    if less(value, node_value) {
      node = ptr_load(ptr_add(set.left, node));
      place_left = true;
    } else if less(node_value, value) {
      node = ptr_load(ptr_add(set.right, node));
      place_left = false;
    } else {
      drop value;
      return false;
    }
  }
  if set.len >= set.capacity {
    tree_set_grow_to_capacity<T>(set, set.capacity * 2);
  }
  let index = set.len;
  ptr_store(ptr_add(set.data, index), value);
  ptr_store(ptr_add(set.left, index), -1);
  ptr_store(ptr_add(set.right, index), -1);
  ptr_store(ptr_add(set.parent, index), parent);
  ptr_store(ptr_add(set.colors, index), 1);
  if parent < 0 {
    set.root = index;
  } else if place_left {
    ptr_store(ptr_add(set.left, parent), index);
  } else {
    ptr_store(ptr_add(set.right, parent), index);
  }
  set.len = set.len + 1;
  tree_set_fix_insert<T>(set, index);
  return true;
}

fn tree_set_grow_to_capacity[T](
  set: ref mut std::collections::TreeSet[T],
  capacity: i64
) -> void {
  let actual = normalized_tree_capacity(capacity);
  if actual <= set.capacity {
    return;
  }
  let old_data = set.data;
  let old_left = set.left;
  let old_right = set.right;
  let old_parent = set.parent;
  let old_colors = set.colors;
  let metadata = set.zone();
  let new_data = metadata.alloc_array<T>(actual);
  let new_left = metadata.alloc_array<i64>(actual);
  let new_right = metadata.alloc_array<i64>(actual);
  let new_parent = metadata.alloc_array<i64>(actual);
  let new_colors = metadata.alloc_array<i64>(actual);
  var index = 0;
  while index < set.len {
    ptr_store(ptr_add(new_data, index), ptr_load(ptr_add(old_data, index)));
    ptr_store(ptr_add(new_left, index), ptr_load(ptr_add(old_left, index)));
    ptr_store(ptr_add(new_right, index), ptr_load(ptr_add(old_right, index)));
    ptr_store(ptr_add(new_parent, index), ptr_load(ptr_add(old_parent, index)));
    ptr_store(ptr_add(new_colors, index), ptr_load(ptr_add(old_colors, index)));
    index = index + 1;
  }
  set.data = new_data;
  set.left = new_left;
  set.right = new_right;
  set.parent = new_parent;
  set.colors = new_colors;
  set.capacity = actual;
}

fn tree_set_drop_values[T](set: ref mut std::collections::TreeSet[T]) -> void {
  var index = 0;
  while index < set.len {
    let value = ptr_load(ptr_add(set.data, index));
    drop value;
    index = index + 1;
  }
  set.root = -1;
  set.len = 0;
}

pub impl[T] std::collections::TreeSet[T] {
  fn with_less(
    zone: ref mut Zone,
    capacity: i64,
    less: fn(T, T) -> bool
  ) -> std::collections::TreeSet[T] {
    return std::collections::tree_set<T>(zone, capacity, less);
  }

  fn from_iter[I: std::Iterator[T]](
    zone: ref mut Zone,
    capacity: i64,
    less: fn(T, T) -> bool,
    iter: I
  ) -> std::collections::TreeSet[T] {
    var output = std::collections::tree_set<T>(zone, capacity, less);
    output.extend_iter<I>(iter);
    return output;
  }

  fn len(self: ref Self) -> i64 {
    return self.len;
  }

  fn capacity(self: ref Self) -> i64 {
    return self.capacity;
  }

  fn is_empty(self: ref Self) -> bool {
    return self.len == 0;
  }

  fn contains(self: ref Self, value: T) -> bool {
    return tree_set_find_slot<T>(self, value) >= 0;
  }

  fn get(self: ref Self, value: T) -> T {
    let node = tree_set_find_slot<T>(self, value);
    std::assert(node >= 0);
    return ptr_load(ptr_add(self.data, node));
  }

  fn try_get(self: ref Self, value: T) -> std::Option[T] {
    let node = tree_set_find_slot<T>(self, value);
    if node < 0 {
      return std::None<T>();
    }
    return std::Some<T>(ptr_load(ptr_add(self.data, node)));
  }

  fn first(self: ref Self) -> T {
    let node = tree_first_node(self.root, self.left);
    std::assert(node >= 0);
    return ptr_load(ptr_add(self.data, node));
  }

  fn try_first(self: ref Self) -> std::Option[T] {
    let node = tree_first_node(self.root, self.left);
    if node < 0 {
      return std::None<T>();
    }
    return std::Some<T>(ptr_load(ptr_add(self.data, node)));
  }

  fn last(self: ref Self) -> T {
    let node = tree_last_node(self.root, self.right);
    std::assert(node >= 0);
    return ptr_load(ptr_add(self.data, node));
  }

  fn try_last(self: ref Self) -> std::Option[T] {
    let node = tree_last_node(self.root, self.right);
    if node < 0 {
      return std::None<T>();
    }
    return std::Some<T>(ptr_load(ptr_add(self.data, node)));
  }

  fn lower_bound(self: ref Self, value: T) -> std::Option[T] {
    let node = tree_set_lower_bound_node<T>(self, value);
    if node < 0 {
      return std::None<T>();
    }
    return std::Some<T>(ptr_load(ptr_add(self.data, node)));
  }

  fn upper_bound(self: ref Self, value: T) -> std::Option[T] {
    let node = tree_set_upper_bound_node<T>(self, value);
    if node < 0 {
      return std::None<T>();
    }
    return std::Some<T>(ptr_load(ptr_add(self.data, node)));
  }

  fn range(self: ref Self, start: T, end: T) -> std::collections::TreeSetRange[T] {
    return std::collections::TreeSetRange<T> {
      data: self.data,
      left: self.left,
      right: self.right,
      parent: self.parent,
      end: end,
      less: self.less,
      current: tree_set_lower_bound_node<T>(self, start),
    };
  }

  fn is_subset(self: ref Self, other: ref Self) -> bool {
    var index = 0;
    while index < self.len {
      if !other.contains(ptr_load(ptr_add(self.data, index))) {
        return false;
      }
      index = index + 1;
    }
    return true;
  }

  fn is_superset(self: ref Self, other: ref Self) -> bool {
    return other.is_subset(self);
  }

  fn is_disjoint(self: ref Self, other: ref Self) -> bool {
    var index = 0;
    while index < self.len {
      if other.contains(ptr_load(ptr_add(self.data, index))) {
        return false;
      }
      index = index + 1;
    }
    return true;
  }

  fn equals(self: ref Self, other: ref Self) -> bool {
    if self.len != other.len {
      return false;
    }
    return self.is_subset(other);
  }

  fn insert(self: ref mut Self, zone: ref mut Zone, value: T) -> bool {
    let less = self.less;
    var parent = -1;
    var node = self.root;
    var place_left = false;
    while node >= 0 {
      parent = node;
      let node_value = ptr_load(ptr_add(self.data, node));
      if less(value, node_value) {
        node = ptr_load(ptr_add(self.left, node));
        place_left = true;
      } else if less(node_value, value) {
        node = ptr_load(ptr_add(self.right, node));
        place_left = false;
      } else {
        return false;
      }
    }
    if self.len >= self.capacity {
      tree_set_grow_to_capacity<T>(self, self.capacity * 2);
    }
    let index = self.len;
    ptr_store(ptr_add(self.data, index), value);
    ptr_store(ptr_add(self.left, index), -1);
    ptr_store(ptr_add(self.right, index), -1);
    ptr_store(ptr_add(self.parent, index), parent);
    ptr_store(ptr_add(self.colors, index), 1);
    if parent < 0 {
      self.root = index;
    } else if place_left {
      ptr_store(ptr_add(self.left, parent), index);
    } else {
      ptr_store(ptr_add(self.right, parent), index);
    }
    self.len = self.len + 1;
    tree_set_fix_insert<T>(self, index);
    return true;
  }

  fn take(self: ref mut Self, value: T) -> std::Option[T] {
    let index = tree_set_find_slot_mut<T>(self, value);
    if index < 0 {
      return std::None<T>();
    }
    let removed = ptr_load(ptr_add(self.data, index));
    let last = self.len - 1;
    tree_set_delete_slot<T>(self, index);
    tree_set_move_last_slot<T>(self, index, last);
    self.len = last;
    return std::Some<T>(removed);
  }

  fn remove(self: ref mut Self, value: T) -> bool {
    let removed = self.take(value);
    match removed {
      std::Some(payload) => {
        drop payload;
        return true;
      }
      std::None => {
        return false;
      }
    }
  }

  fn replace(self: ref mut Self, zone: ref mut Zone, value: T) -> std::Option[T] {
    let existing = tree_set_find_slot_mut<T>(self, value);
    if existing >= 0 {
      let previous = ptr_load(ptr_add(self.data, existing));
      ptr_store(ptr_add(self.data, existing), value);
      return std::Some<T>(previous);
    }
    self.insert(zone, value);
    return std::None<T>();
  }

  fn split_off(self: ref mut Self, zone: ref mut Zone, start: T) -> std::collections::TreeSet[T] {
    var output = std::collections::tree_set<T>(zone, self.len, self.less);
    var node = tree_set_lower_bound_node_mut<T>(self, start);
    while node >= 0 {
      let moved = ptr_load(ptr_add(self.data, node));
      let last = self.len - 1;
      tree_set_delete_slot<T>(self, node);
      tree_set_move_last_slot<T>(self, node, last);
      self.len = last;
      tree_set_insert_or_drop<T>(ref mut output, moved);
      node = tree_set_lower_bound_node_mut<T>(self, start);
    }
    return output;
  }

  fn append(self: ref mut Self, zone: ref mut Zone, other: ref mut std::collections::TreeSet[T]) -> void {
    while other.len > 0 {
      let node = tree_first_node(other.root, other.left);
      let moved = ptr_load(ptr_add(other.data, node));
      let last = other.len - 1;
      tree_set_delete_slot<T>(other, node);
      tree_set_move_last_slot<T>(other, node, last);
      other.len = last;
      tree_set_insert_or_drop<T>(self, moved);
    }
  }

  fn extend_iter[I: std::Iterator[T]](self: ref mut Self, iter: I) -> void {
    var cursor = iter;
    var item = cursor.next();
    while item.is_some() {
      tree_set_insert_or_drop<T>(self, item.unwrap());
      item = cursor.next();
    }
  }

  fn extend[I: std::Iterator[T]](self: ref mut Self, iter: I) -> void {
    self.extend_iter<I>(iter);
  }

  fn clear(self: ref mut Self) -> void {
    tree_set_drop_values<T>(self);
  }

  fn reserve(self: ref mut Self, zone: ref mut Zone, capacity: i64) -> void {
    tree_set_grow_to_capacity<T>(self, capacity);
  }

  fn reserve_extra(self: ref mut Self, zone: ref mut Zone, additional: i64) -> void {
    std::assert(additional >= 0);
    tree_set_grow_to_capacity<T>(self, self.len + additional);
  }

  fn copy_to(self: ref Self, target: ref mut Zone) -> std::collections::TreeSet[T] {
    var copied = std::collections::tree_set<T>(target, self.len, self.less);
    var index = 0;
    while index < self.len {
      copied.insert(target, ptr_load(ptr_add(self.data, index)));
      index = index + 1;
    }
    return copied;
  }

  fn iter(self: ref Self) -> std::collections::TreeSetIter[T] {
    return std::collections::TreeSetIter<T> {
      data: self.data,
      left: self.left,
      right: self.right,
      parent: self.parent,
      current: tree_first_node(self.root, self.left),
    };
  }

  fn drain(self: ref mut Self) -> std::collections::TreeSetDrain[T] {
    let old_len = self.len;
    let first = tree_first_node(self.root, self.left);
    self.root = -1;
    self.len = 0;
    return std::collections::TreeSetDrain<T> {
      data: self.data,
      left: self.left,
      right: self.right,
      parent: self.parent,
      colors: self.colors,
      len: old_len,
      current: first,
    };
  }
}

impl[T] std::Iterator[T] for std::collections::TreeSetIter[T] {
  pub fn next(self: ref mut Self) -> std::Option[T] {
    if self.current < 0 {
      return std::None<T>();
    }
    let node = self.current;
    self.current = tree_next_node(node, self.left, self.right, self.parent);
    return std::Some<T>(ptr_load(ptr_add(self.data, node)));
  }
}

impl[T] std::Iterator[T] for std::collections::TreeSetRange[T] {
  pub fn next(self: ref mut Self) -> std::Option[T] {
    if self.current < 0 {
      return std::None<T>();
    }
    let node = self.current;
    let value = ptr_load(ptr_add(self.data, node));
    let less = self.less;
    if !less(value, self.end) {
      self.current = -1;
      return std::None<T>();
    }
    self.current = tree_next_node(node, self.left, self.right, self.parent);
    return std::Some<T>(value);
  }
}

impl[T] std::Iterator[T] for std::collections::TreeSetDrain[T] {
  pub fn next(self: ref mut Self) -> std::Option[T] {
    if self.current < 0 {
      return std::None<T>();
    }
    let node = self.current;
    self.current = tree_next_node(node, self.left, self.right, self.parent);
    ptr_store(ptr_add(self.colors, node), -2);
    return std::Some<T>(ptr_load(ptr_add(self.data, node)));
  }
}

impl[T] std::Drop for std::collections::TreeSetDrain[T] {
  fn drop(self) -> void {
    var cursor = self;
    var index = 0;
    while index < cursor.len {
      if ptr_load(ptr_add(cursor.colors, index)) != -2 {
        let value = ptr_load(ptr_add(cursor.data, index));
        drop value;
        ptr_store(ptr_add(cursor.colors, index), -2);
      }
      index = index + 1;
    }
    return;
  }
}

impl[T] std::IntoIterator[T] for std::collections::TreeSet[T] {
  pub fn into_iter(self: ref mut Self) -> std::collections::TreeSetIter[T] {
    return std::collections::TreeSetIter<T> {
      data: self.data,
      left: self.left,
      right: self.right,
      parent: self.parent,
      current: tree_first_node(self.root, self.left),
    };
  }
}

pub impl[T: std::cmp::Ord[T]] std::collections::TreeSet[T] {
  fn new(
    zone: ref mut Zone
  ) -> std::collections::TreeSet[T] {
    return std::collections::TreeSet::with_capacity<T>(zone, 4);
  }

  fn with_capacity(
    zone: ref mut Zone,
    capacity: i64
  ) -> std::collections::TreeSet[T] {
    let less: fn(T, T) -> bool = std::collections::default_less;
    return std::collections::tree_set<T>(
      zone,
      capacity,
      less
    );
  }
}

impl[T] std::zone::ZoneBacked for std::collections::TreeSet[T] {
  pub fn zone(self: ref Self) -> std::zone::ZoneMetadata {
    std::assert(self.capacity > 0);
    return std::zone::metadata(self.data as ptr u8);
  }
}

impl[T] std::Drop for std::collections::TreeSet[T] {
  fn drop(self) -> void {
    var dropped = self;
    tree_set_drop_values<T>(ref mut dropped);
    return;
  }
}

fn normalized_sequence_capacity(capacity: i64) -> i64 {
  if capacity < 1 {
    return 1;
  }
  return capacity;
}

fn circular_slot(head: i64, offset: i64, capacity: i64) -> i64 {
  return (head + offset) % capacity;
}

pub fn deque[T](zone: ref mut Zone, capacity: i64) -> std::collections::Deque[T] {
  let actual = normalized_sequence_capacity(capacity);
  let data = std::zone::alloc_array<T>(zone, actual);
  return std::collections::Deque<T> {
    data: data,
    len: 0,
    capacity: actual,
    head: 0,
  };
}

fn deque_grow_to_capacity[T](
  deque: ref mut std::collections::Deque[T],
  capacity: i64
) -> void {
  let actual = normalized_sequence_capacity(capacity);
  if actual <= deque.capacity {
    return;
  }
  let old_data = deque.data;
  let old_capacity = deque.capacity;
  let old_head = deque.head;
  let metadata = deque.zone();
  let new_data = metadata.alloc_array<T>(actual);
  var index = 0;
  while index < deque.len {
    let old_slot = circular_slot(old_head, index, old_capacity);
    ptr_store(ptr_add(new_data, index), ptr_load(ptr_add(old_data, old_slot)));
    index = index + 1;
  }
  deque.data = new_data;
  deque.capacity = actual;
  deque.head = 0;
}

fn deque_ensure_spare_capacity[T](deque: ref mut std::collections::Deque[T]) -> void {
  if deque.len >= deque.capacity {
    deque_grow_to_capacity<T>(deque, next_growth_capacity(deque.capacity, deque.len + 1));
  }
}

fn deque_drop_values[T](deque: ref mut std::collections::Deque[T]) -> void {
  var index = 0;
  while index < deque.len {
    let slot = circular_slot(deque.head, index, deque.capacity);
    let value = ptr_load(ptr_add(deque.data, slot));
    drop value;
    index = index + 1;
  }
  deque.len = 0;
  deque.head = 0;
}

pub impl[T] std::collections::Deque[T] {
  fn new(zone: ref mut Zone, capacity: i64) -> std::collections::Deque[T] {
    return std::collections::deque<T>(zone, capacity);
  }

  fn from_iter[I: std::Iterator[T]](zone: ref mut Zone, iter: I) -> std::collections::Deque[T] {
    var output = std::collections::deque<T>(zone, 4);
    output.extend_iter<I>(iter);
    return output;
  }

  fn len(self: ref Self) -> i64 {
    return self.len;
  }

  fn capacity(self: ref Self) -> i64 {
    return self.capacity;
  }

  fn is_empty(self: ref Self) -> bool {
    return self.len == 0;
  }

  fn front(self: ref Self) -> T {
    std::assert(self.len > 0);
    return ptr_load(ptr_add(self.data, self.head));
  }

  fn try_front(self: ref Self) -> std::Option[T] {
    if self.len == 0 {
      return std::None<T>();
    }
    return std::Some<T>(self.front());
  }

  fn back(self: ref Self) -> T {
    std::assert(self.len > 0);
    let slot = circular_slot(self.head, self.len - 1, self.capacity);
    return ptr_load(ptr_add(self.data, slot));
  }

  fn try_back(self: ref Self) -> std::Option[T] {
    if self.len == 0 {
      return std::None<T>();
    }
    return std::Some<T>(self.back());
  }

  fn get(self: ref Self, index: i64) -> T {
    std::assert(index >= 0);
    std::assert(index < self.len);
    let slot = circular_slot(self.head, index, self.capacity);
    return ptr_load(ptr_add(self.data, slot));
  }

  fn try_get(self: ref Self, index: i64) -> std::Option[T] {
    if index < 0 {
      return std::None<T>();
    }
    if index >= self.len {
      return std::None<T>();
    }
    return std::Some<T>(self.get(index));
  }

  fn push_back(self: ref mut Self, zone: ref mut Zone, value: T) -> void {
    deque_ensure_spare_capacity<T>(self);
    let slot = circular_slot(self.head, self.len, self.capacity);
    ptr_store(ptr_add(self.data, slot), value);
    self.len = self.len + 1;
  }

  fn push_front(self: ref mut Self, zone: ref mut Zone, value: T) -> void {
    deque_ensure_spare_capacity<T>(self);
    self.head = (self.head + self.capacity - 1) % self.capacity;
    ptr_store(ptr_add(self.data, self.head), value);
    self.len = self.len + 1;
  }

  fn pop_front(self: ref mut Self) -> T {
    std::assert(self.len > 0);
    let value = ptr_load(ptr_add(self.data, self.head));
    self.head = (self.head + 1) % self.capacity;
    self.len = self.len - 1;
    if self.len == 0 {
      self.head = 0;
    }
    return value;
  }

  fn try_pop_front(self: ref mut Self) -> std::Option[T] {
    if self.len == 0 {
      return std::None<T>();
    }
    return std::Some<T>(self.pop_front());
  }

  fn pop_back(self: ref mut Self) -> T {
    std::assert(self.len > 0);
    let slot = circular_slot(self.head, self.len - 1, self.capacity);
    let value = ptr_load(ptr_add(self.data, slot));
    self.len = self.len - 1;
    if self.len == 0 {
      self.head = 0;
    }
    return value;
  }

  fn try_pop_back(self: ref mut Self) -> std::Option[T] {
    if self.len == 0 {
      return std::None<T>();
    }
    return std::Some<T>(self.pop_back());
  }

  fn clear(self: ref mut Self) -> void {
    deque_drop_values<T>(self);
  }

  fn extend_iter[I: std::Iterator[T]](self: ref mut Self, iter: I) -> void {
    var cursor = iter;
    var item = cursor.next();
    while item.is_some() {
      deque_ensure_spare_capacity<T>(self);
      let slot = circular_slot(self.head, self.len, self.capacity);
      ptr_store(ptr_add(self.data, slot), item.unwrap());
      self.len = self.len + 1;
      item = cursor.next();
    }
  }

  fn extend[I: std::Iterator[T]](self: ref mut Self, iter: I) -> void {
    self.extend_iter<I>(iter);
  }

  fn reserve(self: ref mut Self, zone: ref mut Zone, capacity: i64) -> void {
    deque_grow_to_capacity<T>(self, capacity);
  }

  fn reserve_extra(self: ref mut Self, zone: ref mut Zone, additional: i64) -> void {
    std::assert(additional >= 0);
    deque_grow_to_capacity<T>(self, self.len + additional);
  }

  fn copy_to(self: ref Self, target: ref mut Zone) -> std::collections::Deque[T] {
    var copied = std::collections::deque<T>(target, self.len);
    var index = 0;
    while index < self.len {
      copied.push_back(target, self.get(index));
      index = index + 1;
    }
    return copied;
  }

  fn iter(self: ref Self) -> std::collections::DequeIter[T] {
    return std::collections::DequeIter<T> {
      data: self.data,
      len: self.len,
      capacity: self.capacity,
      head: self.head,
      index: 0,
    };
  }
}

impl[T] std::Iterator[T] for std::collections::DequeIter[T] {
  pub fn next(self: ref mut Self) -> std::Option[T] {
    if self.index >= self.len {
      return std::None<T>();
    }
    let slot = circular_slot(self.head, self.index, self.capacity);
    self.index = self.index + 1;
    return std::Some<T>(ptr_load(ptr_add(self.data, slot)));
  }
}

impl[T] std::ExactSizeIterator[T] for std::collections::DequeIter[T] {
  pub fn len(self: ref Self) -> i64 {
    return self.len - self.index;
  }
}

impl[T] std::DoubleEndedIterator[T] for std::collections::DequeIter[T] {
  pub fn next_back(self: ref mut Self) -> std::Option[T] {
    if self.index >= self.len {
      return std::None<T>();
    }
    self.len = self.len - 1;
    let slot = circular_slot(self.head, self.len, self.capacity);
    return std::Some<T>(ptr_load(ptr_add(self.data, slot)));
  }
}

impl[T] std::IntoIterator[T] for std::collections::Deque[T] {
  pub fn into_iter(self: ref mut Self) -> std::collections::DequeIter[T] {
    return self.iter();
  }
}

impl[T] std::zone::ZoneBacked for std::collections::Deque[T] {
  pub fn zone(self: ref Self) -> std::zone::ZoneMetadata {
    std::assert(self.capacity > 0);
    return std::zone::metadata(self.data as ptr u8);
  }
}

impl[T] std::Drop for std::collections::Deque[T] {
  fn drop(self) -> void {
    var dropped = self;
    deque_drop_values<T>(ref mut dropped);
    return;
  }
}

pub fn ring_buffer[T](zone: ref mut Zone, capacity: i64) -> std::collections::RingBuffer[T] {
  let actual = normalized_sequence_capacity(capacity);
  let data = std::zone::alloc_array<T>(zone, actual);
  return std::collections::RingBuffer<T> {
    data: data,
    len: 0,
    capacity: actual,
    head: 0,
  };
}

fn ring_buffer_drop_values[T](buffer: ref mut std::collections::RingBuffer[T]) -> void {
  var index = 0;
  while index < buffer.len {
    let slot = circular_slot(buffer.head, index, buffer.capacity);
    let value = ptr_load(ptr_add(buffer.data, slot));
    drop value;
    index = index + 1;
  }
  buffer.len = 0;
  buffer.head = 0;
}

pub impl[T] std::collections::RingBuffer[T] {
  fn new(zone: ref mut Zone, capacity: i64) -> std::collections::RingBuffer[T] {
    return std::collections::ring_buffer<T>(zone, capacity);
  }

  fn len(self: ref Self) -> i64 {
    return self.len;
  }

  fn capacity(self: ref Self) -> i64 {
    return self.capacity;
  }

  fn is_empty(self: ref Self) -> bool {
    return self.len == 0;
  }

  fn is_full(self: ref Self) -> bool {
    return self.len == self.capacity;
  }

  fn push(self: ref mut Self, value: T) -> bool {
    if self.is_full() {
      return false;
    }
    let slot = circular_slot(self.head, self.len, self.capacity);
    ptr_store(ptr_add(self.data, slot), value);
    self.len = self.len + 1;
    return true;
  }

  fn push_overwrite(self: ref mut Self, value: T) -> std::Option[T] {
    if self.is_full() {
      let old = ptr_load(ptr_add(self.data, self.head));
      ptr_store(ptr_add(self.data, self.head), value);
      self.head = (self.head + 1) % self.capacity;
      return std::Some<T>(old);
    }
    self.push(value);
    return std::None<T>();
  }

  fn peek(self: ref Self) -> T {
    std::assert(self.len > 0);
    return ptr_load(ptr_add(self.data, self.head));
  }

  fn try_peek(self: ref Self) -> std::Option[T] {
    if self.len == 0 {
      return std::None<T>();
    }
    return std::Some<T>(self.peek());
  }

  fn get(self: ref Self, index: i64) -> T {
    std::assert(index >= 0);
    std::assert(index < self.len);
    let slot = circular_slot(self.head, index, self.capacity);
    return ptr_load(ptr_add(self.data, slot));
  }

  fn try_get(self: ref Self, index: i64) -> std::Option[T] {
    if index < 0 {
      return std::None<T>();
    }
    if index >= self.len {
      return std::None<T>();
    }
    return std::Some<T>(self.get(index));
  }

  fn pop(self: ref mut Self) -> T {
    std::assert(self.len > 0);
    let value = ptr_load(ptr_add(self.data, self.head));
    self.head = (self.head + 1) % self.capacity;
    self.len = self.len - 1;
    if self.len == 0 {
      self.head = 0;
    }
    return value;
  }

  fn try_pop(self: ref mut Self) -> std::Option[T] {
    if self.len == 0 {
      return std::None<T>();
    }
    return std::Some<T>(self.pop());
  }

  fn clear(self: ref mut Self) -> void {
    ring_buffer_drop_values<T>(self);
  }

  fn copy_to(self: ref Self, target: ref mut Zone) -> std::collections::RingBuffer[T] {
    var copied = std::collections::ring_buffer<T>(target, self.capacity);
    var index = 0;
    while index < self.len {
      copied.push(self.get(index));
      index = index + 1;
    }
    return copied;
  }

  fn iter(self: ref Self) -> std::collections::RingBufferIter[T] {
    return std::collections::RingBufferIter<T> {
      data: self.data,
      len: self.len,
      capacity: self.capacity,
      head: self.head,
      index: 0,
    };
  }
}

impl[T] std::Iterator[T] for std::collections::RingBufferIter[T] {
  pub fn next(self: ref mut Self) -> std::Option[T] {
    if self.index >= self.len {
      return std::None<T>();
    }
    let slot = circular_slot(self.head, self.index, self.capacity);
    self.index = self.index + 1;
    return std::Some<T>(ptr_load(ptr_add(self.data, slot)));
  }
}

impl[T] std::ExactSizeIterator[T] for std::collections::RingBufferIter[T] {
  pub fn len(self: ref Self) -> i64 {
    return self.len - self.index;
  }
}

impl[T] std::DoubleEndedIterator[T] for std::collections::RingBufferIter[T] {
  pub fn next_back(self: ref mut Self) -> std::Option[T] {
    if self.index >= self.len {
      return std::None<T>();
    }
    self.len = self.len - 1;
    let slot = circular_slot(self.head, self.len, self.capacity);
    return std::Some<T>(ptr_load(ptr_add(self.data, slot)));
  }
}

impl[T] std::IntoIterator[T] for std::collections::RingBuffer[T] {
  pub fn into_iter(self: ref mut Self) -> std::collections::RingBufferIter[T] {
    return self.iter();
  }
}

impl[T] std::zone::ZoneBacked for std::collections::RingBuffer[T] {
  pub fn zone(self: ref Self) -> std::zone::ZoneMetadata {
    std::assert(self.capacity > 0);
    return std::zone::metadata(self.data as ptr u8);
  }
}

impl[T] std::Drop for std::collections::RingBuffer[T] {
  fn drop(self) -> void {
    var dropped = self;
    ring_buffer_drop_values<T>(ref mut dropped);
    return;
  }
}

pub fn linked_list[T](zone: ref mut Zone, capacity: i64) -> std::collections::LinkedList[T] {
  let actual = normalized_sequence_capacity(capacity);
  let data = std::zone::alloc_array<T>(zone, actual);
  let next_node = std::zone::alloc_array<i64>(zone, actual);
  let prev = std::zone::alloc_array<i64>(zone, actual);
  return std::collections::LinkedList<T> {
    data: data,
    next_node: next_node,
    prev: prev,
    head: -1,
    tail: -1,
    len: 0,
    capacity: actual,
    next_slot: 0,
    free: -1,
  };
}

fn linked_list_grow_to_capacity[T](
  list: ref mut std::collections::LinkedList[T],
  capacity: i64
) -> void {
  let actual = normalized_sequence_capacity(capacity);
  if actual <= list.capacity {
    return;
  }
  let old_data = list.data;
  let old_next = list.next_node;
  let old_prev = list.prev;
  let metadata = list.zone();
  let new_data = metadata.alloc_array<T>(actual);
  let new_next = metadata.alloc_array<i64>(actual);
  let new_prev = metadata.alloc_array<i64>(actual);
  var node = list.head;
  while node >= 0 {
    ptr_store(ptr_add(new_data, node), ptr_load(ptr_add(old_data, node)));
    node = ptr_load(ptr_add(old_next, node));
  }
  var index = 0;
  while index < list.next_slot {
    ptr_store(ptr_add(new_next, index), ptr_load(ptr_add(old_next, index)));
    ptr_store(ptr_add(new_prev, index), ptr_load(ptr_add(old_prev, index)));
    index = index + 1;
  }
  list.data = new_data;
  list.next_node = new_next;
  list.prev = new_prev;
  list.capacity = actual;
}

fn linked_list_alloc_node[T](list: ref mut std::collections::LinkedList[T]) -> i64 {
  if list.free >= 0 {
    let reused = list.free;
    list.free = ptr_load(ptr_add(list.next_node, reused));
    return reused;
  }
  if list.next_slot >= list.capacity {
    linked_list_grow_to_capacity<T>(list, next_growth_capacity(list.capacity, list.next_slot + 1));
  }
  let node = list.next_slot;
  list.next_slot = list.next_slot + 1;
  return node;
}

fn linked_list_release_node[T](list: ref mut std::collections::LinkedList[T], node: i64) -> void {
  ptr_store(ptr_add(list.next_node, node), list.free);
  ptr_store(ptr_add(list.prev, node), -1);
  list.free = node;
}

fn linked_list_node_at[T](list: ref std::collections::LinkedList[T], index: i64) -> i64 {
  if index < 0 {
    return -1;
  }
  if index >= list.len {
    return -1;
  }
  var current = list.head;
  var cursor = 0;
  while cursor < index {
    current = ptr_load(ptr_add(list.next_node, current));
    cursor = cursor + 1;
  }
  return current;
}

fn linked_list_node_at_mut[T](list: ref mut std::collections::LinkedList[T], index: i64) -> i64 {
  if index < 0 {
    return -1;
  }
  if index >= list.len {
    return -1;
  }
  var current = list.head;
  var cursor = 0;
  while cursor < index {
    current = ptr_load(ptr_add(list.next_node, current));
    cursor = cursor + 1;
  }
  return current;
}

fn linked_list_detach_node[T](list: ref mut std::collections::LinkedList[T], node: i64) -> T {
  let previous = ptr_load(ptr_add(list.prev, node));
  let following = ptr_load(ptr_add(list.next_node, node));
  if previous >= 0 {
    ptr_store(ptr_add(list.next_node, previous), following);
  } else {
    list.head = following;
  }
  if following >= 0 {
    ptr_store(ptr_add(list.prev, following), previous);
  } else {
    list.tail = previous;
  }
  list.len = list.len - 1;
  let value = ptr_load(ptr_add(list.data, node));
  linked_list_release_node<T>(list, node);
  return value;
}

fn linked_list_drop_values[T](list: ref mut std::collections::LinkedList[T]) -> void {
  var node = list.head;
  while node >= 0 {
    let following = ptr_load(ptr_add(list.next_node, node));
    let value = ptr_load(ptr_add(list.data, node));
    drop value;
    node = following;
  }
  list.head = -1;
  list.tail = -1;
  list.len = 0;
  list.next_slot = 0;
  list.free = -1;
}

pub impl[T] std::collections::LinkedList[T] {
  fn new(zone: ref mut Zone, capacity: i64) -> std::collections::LinkedList[T] {
    return std::collections::linked_list<T>(zone, capacity);
  }

  fn from_iter[I: std::Iterator[T]](zone: ref mut Zone, iter: I) -> std::collections::LinkedList[T] {
    var output = std::collections::linked_list<T>(zone, 4);
    output.extend_iter<I>(iter);
    return output;
  }

  fn len(self: ref Self) -> i64 {
    return self.len;
  }

  fn capacity(self: ref Self) -> i64 {
    return self.capacity;
  }

  fn is_empty(self: ref Self) -> bool {
    return self.len == 0;
  }

  fn front(self: ref Self) -> T {
    std::assert(self.head >= 0);
    return ptr_load(ptr_add(self.data, self.head));
  }

  fn try_front(self: ref Self) -> std::Option[T] {
    if self.head < 0 {
      return std::None<T>();
    }
    return std::Some<T>(self.front());
  }

  fn back(self: ref Self) -> T {
    std::assert(self.tail >= 0);
    return ptr_load(ptr_add(self.data, self.tail));
  }

  fn try_back(self: ref Self) -> std::Option[T] {
    if self.tail < 0 {
      return std::None<T>();
    }
    return std::Some<T>(self.back());
  }

  fn get(self: ref Self, index: i64) -> T {
    let node = linked_list_node_at<T>(self, index);
    std::assert(node >= 0);
    return ptr_load(ptr_add(self.data, node));
  }

  fn try_get(self: ref Self, index: i64) -> std::Option[T] {
    let node = linked_list_node_at<T>(self, index);
    if node < 0 {
      return std::None<T>();
    }
    return std::Some<T>(ptr_load(ptr_add(self.data, node)));
  }

  fn push_front(self: ref mut Self, zone: ref mut Zone, value: T) -> void {
    let node = linked_list_alloc_node<T>(self);
    ptr_store(ptr_add(self.data, node), value);
    ptr_store(ptr_add(self.prev, node), -1);
    ptr_store(ptr_add(self.next_node, node), self.head);
    if self.head >= 0 {
      ptr_store(ptr_add(self.prev, self.head), node);
    } else {
      self.tail = node;
    }
    self.head = node;
    self.len = self.len + 1;
  }

  fn push_back(self: ref mut Self, zone: ref mut Zone, value: T) -> void {
    let node = linked_list_alloc_node<T>(self);
    ptr_store(ptr_add(self.data, node), value);
    ptr_store(ptr_add(self.next_node, node), -1);
    ptr_store(ptr_add(self.prev, node), self.tail);
    if self.tail >= 0 {
      ptr_store(ptr_add(self.next_node, self.tail), node);
    } else {
      self.head = node;
    }
    self.tail = node;
    self.len = self.len + 1;
  }

  fn pop_front(self: ref mut Self) -> T {
    std::assert(self.head >= 0);
    return linked_list_detach_node<T>(self, self.head);
  }

  fn try_pop_front(self: ref mut Self) -> std::Option[T] {
    if self.head < 0 {
      return std::None<T>();
    }
    return std::Some<T>(self.pop_front());
  }

  fn pop_back(self: ref mut Self) -> T {
    std::assert(self.tail >= 0);
    return linked_list_detach_node<T>(self, self.tail);
  }

  fn try_pop_back(self: ref mut Self) -> std::Option[T] {
    if self.tail < 0 {
      return std::None<T>();
    }
    return std::Some<T>(self.pop_back());
  }

  fn remove_at(self: ref mut Self, index: i64) -> T {
    let node = linked_list_node_at_mut<T>(self, index);
    std::assert(node >= 0);
    return linked_list_detach_node<T>(self, node);
  }

  fn try_remove_at(self: ref mut Self, index: i64) -> std::Option[T] {
    let node = linked_list_node_at_mut<T>(self, index);
    if node < 0 {
      return std::None<T>();
    }
    return std::Some<T>(linked_list_detach_node<T>(self, node));
  }

  fn clear(self: ref mut Self) -> void {
    linked_list_drop_values<T>(self);
  }

  fn extend_iter[I: std::Iterator[T]](self: ref mut Self, iter: I) -> void {
    var cursor = iter;
    var item = cursor.next();
    while item.is_some() {
      let node = linked_list_alloc_node<T>(self);
      ptr_store(ptr_add(self.data, node), item.unwrap());
      ptr_store(ptr_add(self.next_node, node), -1);
      ptr_store(ptr_add(self.prev, node), self.tail);
      if self.tail >= 0 {
        ptr_store(ptr_add(self.next_node, self.tail), node);
      } else {
        self.head = node;
      }
      self.tail = node;
      self.len = self.len + 1;
      item = cursor.next();
    }
  }

  fn extend[I: std::Iterator[T]](self: ref mut Self, iter: I) -> void {
    self.extend_iter<I>(iter);
  }

  fn reserve(self: ref mut Self, zone: ref mut Zone, capacity: i64) -> void {
    linked_list_grow_to_capacity<T>(self, capacity);
  }

  fn reserve_extra(self: ref mut Self, zone: ref mut Zone, additional: i64) -> void {
    std::assert(additional >= 0);
    linked_list_grow_to_capacity<T>(self, self.len + additional);
  }

  fn copy_to(self: ref Self, target: ref mut Zone) -> std::collections::LinkedList[T] {
    var copied = std::collections::linked_list<T>(target, self.len);
    var node = self.head;
    while node >= 0 {
      copied.push_back(target, ptr_load(ptr_add(self.data, node)));
      node = ptr_load(ptr_add(self.next_node, node));
    }
    return copied;
  }

  fn iter(self: ref Self) -> std::collections::LinkedListIter[T] {
    return std::collections::LinkedListIter<T> {
      data: self.data,
      next_node: self.next_node,
      current: self.head,
    };
  }
}

impl[T] std::Iterator[T] for std::collections::LinkedListIter[T] {
  pub fn next(self: ref mut Self) -> std::Option[T] {
    if self.current < 0 {
      return std::None<T>();
    }
    let node = self.current;
    self.current = ptr_load(ptr_add(self.next_node, node));
    return std::Some<T>(ptr_load(ptr_add(self.data, node)));
  }
}

impl[T] std::IntoIterator[T] for std::collections::LinkedList[T] {
  pub fn into_iter(self: ref mut Self) -> std::collections::LinkedListIter[T] {
    return self.iter();
  }
}

impl[T] std::zone::ZoneBacked for std::collections::LinkedList[T] {
  pub fn zone(self: ref Self) -> std::zone::ZoneMetadata {
    std::assert(self.capacity > 0);
    return std::zone::metadata(self.data as ptr u8);
  }
}

impl[T] std::Drop for std::collections::LinkedList[T] {
  fn drop(self) -> void {
    var dropped = self;
    linked_list_drop_values<T>(ref mut dropped);
    return;
  }
}

fn slot_swap[T](data: ptr T, left: i64, right: i64) -> void {
  let left_value = ptr_load(ptr_add(data, left));
  let right_value = ptr_load(ptr_add(data, right));
  ptr_store(ptr_add(data, left), right_value);
  ptr_store(ptr_add(data, right), left_value);
}

pub fn binary_heap[T](
  zone: ref mut Zone,
  capacity: i64,
  less: fn(T, T) -> bool
) -> std::collections::BinaryHeap[T] {
  let actual = normalized_sequence_capacity(capacity);
  let data = std::zone::alloc_array<T>(zone, actual);
  return std::collections::BinaryHeap<T> {
    less: less,
    data: data,
    len: 0,
    capacity: actual,
  };
}

fn binary_heap_grow_to_capacity[T](
  heap: ref mut std::collections::BinaryHeap[T],
  capacity: i64
) -> void {
  let actual = normalized_sequence_capacity(capacity);
  if actual <= heap.capacity {
    return;
  }
  let old_data = heap.data;
  let metadata = heap.zone();
  let new_data = metadata.alloc_array<T>(actual);
  var index = 0;
  while index < heap.len {
    ptr_store(ptr_add(new_data, index), ptr_load(ptr_add(old_data, index)));
    index = index + 1;
  }
  heap.data = new_data;
  heap.capacity = actual;
}

fn binary_heap_sift_up[T](heap: ref mut std::collections::BinaryHeap[T], start: i64) -> void {
  let less = heap.less;
  var index = start;
  while index > 0 {
    let parent = (index - 1) / 2;
    if !less(ptr_load(ptr_add(heap.data, parent)), ptr_load(ptr_add(heap.data, index))) {
      return;
    }
    slot_swap<T>(heap.data, parent, index);
    index = parent;
  }
}

fn binary_heap_sift_down[T](heap: ref mut std::collections::BinaryHeap[T], start: i64) -> void {
  let less = heap.less;
  var index = start;
  while true {
    let left = index * 2 + 1;
    if left >= heap.len {
      return;
    }
    var best = left;
    let right = left + 1;
    if right < heap.len {
      if less(ptr_load(ptr_add(heap.data, best)), ptr_load(ptr_add(heap.data, right))) {
        best = right;
      }
    }
    if !less(ptr_load(ptr_add(heap.data, index)), ptr_load(ptr_add(heap.data, best))) {
      return;
    }
    slot_swap<T>(heap.data, index, best);
    index = best;
  }
}

fn binary_heap_drop_values[T](heap: ref mut std::collections::BinaryHeap[T]) -> void {
  var index = 0;
  while index < heap.len {
    let value = ptr_load(ptr_add(heap.data, index));
    drop value;
    index = index + 1;
  }
  heap.len = 0;
}

pub impl[T] std::collections::BinaryHeap[T] {
  fn with_less(
    zone: ref mut Zone,
    capacity: i64,
    less: fn(T, T) -> bool
  ) -> std::collections::BinaryHeap[T] {
    return std::collections::binary_heap<T>(zone, capacity, less);
  }

  fn from_iter[I: std::Iterator[T]](
    zone: ref mut Zone,
    capacity: i64,
    less: fn(T, T) -> bool,
    iter: I
  ) -> std::collections::BinaryHeap[T] {
    var output = std::collections::binary_heap<T>(zone, capacity, less);
    output.extend_iter<I>(iter);
    return output;
  }

  fn len(self: ref Self) -> i64 {
    return self.len;
  }

  fn capacity(self: ref Self) -> i64 {
    return self.capacity;
  }

  fn is_empty(self: ref Self) -> bool {
    return self.len == 0;
  }

  fn peek(self: ref Self) -> T {
    std::assert(self.len > 0);
    return ptr_load(self.data);
  }

  fn try_peek(self: ref Self) -> std::Option[T] {
    if self.len == 0 {
      return std::None<T>();
    }
    return std::Some<T>(self.peek());
  }

  fn peek_mut(self: ref mut Self) -> std::collections::BinaryHeapPeekMut[T] {
    std::assert(self.len > 0);
    return std::collections::BinaryHeapPeekMut<T> {
      heap: self as ptr std::collections::BinaryHeap[T],
      value: self.data,
    };
  }

  fn push(self: ref mut Self, zone: ref mut Zone, value: T) -> void {
    if self.len >= self.capacity {
      binary_heap_grow_to_capacity<T>(self, next_growth_capacity(self.capacity, self.len + 1));
    }
    ptr_store(ptr_add(self.data, self.len), value);
    self.len = self.len + 1;
    binary_heap_sift_up<T>(self, self.len - 1);
  }

  fn pop(self: ref mut Self) -> T {
    std::assert(self.len > 0);
    let top = ptr_load(self.data);
    self.len = self.len - 1;
    if self.len > 0 {
      let last = ptr_load(ptr_add(self.data, self.len));
      ptr_store(self.data, last);
      binary_heap_sift_down<T>(self, 0);
    }
    return top;
  }

  fn try_pop(self: ref mut Self) -> std::Option[T] {
    if self.len == 0 {
      return std::None<T>();
    }
    return std::Some<T>(self.pop());
  }

  fn clear(self: ref mut Self) -> void {
    binary_heap_drop_values<T>(self);
  }

  fn extend_iter[I: std::Iterator[T]](self: ref mut Self, iter: I) -> void {
    var cursor = iter;
    var item = cursor.next();
    while item.is_some() {
      if self.len >= self.capacity {
        binary_heap_grow_to_capacity<T>(self, next_growth_capacity(self.capacity, self.len + 1));
      }
      ptr_store(ptr_add(self.data, self.len), item.unwrap());
      self.len = self.len + 1;
      binary_heap_sift_up<T>(self, self.len - 1);
      item = cursor.next();
    }
  }

  fn extend[I: std::Iterator[T]](self: ref mut Self, iter: I) -> void {
    self.extend_iter<I>(iter);
  }

  fn reserve(self: ref mut Self, zone: ref mut Zone, capacity: i64) -> void {
    binary_heap_grow_to_capacity<T>(self, capacity);
  }

  fn reserve_extra(self: ref mut Self, zone: ref mut Zone, additional: i64) -> void {
    std::assert(additional >= 0);
    binary_heap_grow_to_capacity<T>(self, self.len + additional);
  }

  fn copy_to(self: ref Self, target: ref mut Zone) -> std::collections::BinaryHeap[T] {
    var copied = std::collections::binary_heap<T>(target, self.len, self.less);
    var index = 0;
    while index < self.len {
      ptr_store(ptr_add(copied.data, index), ptr_load(ptr_add(self.data, index)));
      index = index + 1;
    }
    copied.len = self.len;
    return copied;
  }

  fn into_sorted_vec(self: ref mut Self, zone: ref mut Zone) -> std::vec::Vec[T] {
    let length = self.len;
    var output = std::vec::new<T>(zone, length);
    output.raw.len = length;
    var index = length - 1;
    while self.len > 0 {
      ptr_store(ptr_add(output.raw.data, index), self.pop());
      index = index - 1;
    }
    return output;
  }
}

pub impl[T: std::cmp::Ord[T]] std::collections::BinaryHeap[T] {
  fn new(
    zone: ref mut Zone
  ) -> std::collections::BinaryHeap[T] {
    return std::collections::BinaryHeap::with_capacity<T>(zone, 4);
  }

  fn with_capacity(
    zone: ref mut Zone,
    capacity: i64
  ) -> std::collections::BinaryHeap[T] {
    let less: fn(T, T) -> bool = std::collections::default_less;
    return std::collections::binary_heap<T>(
      zone,
      capacity,
      less
    );
  }
}

pub impl[T] std::collections::BinaryHeapPeekMut[T] {
  fn value(self: ref Self) -> T {
    return ptr_load(self.value);
  }

  fn value_mut(self: ref mut Self) -> ref mut T {
    return ref mut *self.value;
  }
}

impl[T] std::Drop for std::collections::BinaryHeapPeekMut[T] {
  fn drop(self) -> void {
    var handle = self;
    let heap: ref mut std::collections::BinaryHeap[T] = ref mut *handle.heap;
    if heap.len > 0 {
      binary_heap_sift_down<T>(heap, 0);
    }
    return;
  }
}

impl[T] std::zone::ZoneBacked for std::collections::BinaryHeap[T] {
  pub fn zone(self: ref Self) -> std::zone::ZoneMetadata {
    std::assert(self.capacity > 0);
    return std::zone::metadata(self.data as ptr u8);
  }
}

impl[T] std::Drop for std::collections::BinaryHeap[T] {
  fn drop(self) -> void {
    var dropped = self;
    binary_heap_drop_values<T>(ref mut dropped);
    return;
  }
}

pub fn priority_queue[T](
  zone: ref mut Zone,
  capacity: i64,
  less: fn(T, T) -> bool
) -> std::collections::PriorityQueue[T] {
  let actual = normalized_sequence_capacity(capacity);
  let data = std::zone::alloc_array<T>(zone, actual);
  return std::collections::PriorityQueue<T> {
    less: less,
    data: data,
    len: 0,
    capacity: actual,
  };
}

fn priority_queue_grow_to_capacity[T](
  queue: ref mut std::collections::PriorityQueue[T],
  capacity: i64
) -> void {
  let actual = normalized_sequence_capacity(capacity);
  if actual <= queue.capacity {
    return;
  }
  let old_data = queue.data;
  let metadata = queue.zone();
  let new_data = metadata.alloc_array<T>(actual);
  var index = 0;
  while index < queue.len {
    ptr_store(ptr_add(new_data, index), ptr_load(ptr_add(old_data, index)));
    index = index + 1;
  }
  queue.data = new_data;
  queue.capacity = actual;
}

fn priority_queue_sift_up[T](queue: ref mut std::collections::PriorityQueue[T], start: i64) -> void {
  let less = queue.less;
  var index = start;
  while index > 0 {
    let parent = (index - 1) / 2;
    if !less(ptr_load(ptr_add(queue.data, parent)), ptr_load(ptr_add(queue.data, index))) {
      return;
    }
    slot_swap<T>(queue.data, parent, index);
    index = parent;
  }
}

fn priority_queue_sift_down[T](queue: ref mut std::collections::PriorityQueue[T], start: i64) -> void {
  let less = queue.less;
  var index = start;
  while true {
    let left = index * 2 + 1;
    if left >= queue.len {
      return;
    }
    var best = left;
    let right = left + 1;
    if right < queue.len {
      if less(ptr_load(ptr_add(queue.data, best)), ptr_load(ptr_add(queue.data, right))) {
        best = right;
      }
    }
    if !less(ptr_load(ptr_add(queue.data, index)), ptr_load(ptr_add(queue.data, best))) {
      return;
    }
    slot_swap<T>(queue.data, index, best);
    index = best;
  }
}

fn priority_queue_drop_values[T](queue: ref mut std::collections::PriorityQueue[T]) -> void {
  var index = 0;
  while index < queue.len {
    let value = ptr_load(ptr_add(queue.data, index));
    drop value;
    index = index + 1;
  }
  queue.len = 0;
}

pub impl[T] std::collections::PriorityQueue[T] {
  fn with_less(
    zone: ref mut Zone,
    capacity: i64,
    less: fn(T, T) -> bool
  ) -> std::collections::PriorityQueue[T] {
    return std::collections::priority_queue<T>(zone, capacity, less);
  }

  fn from_iter[I: std::Iterator[T]](
    zone: ref mut Zone,
    capacity: i64,
    less: fn(T, T) -> bool,
    iter: I
  ) -> std::collections::PriorityQueue[T] {
    var output = std::collections::priority_queue<T>(zone, capacity, less);
    output.extend_iter<I>(iter);
    return output;
  }

  fn len(self: ref Self) -> i64 {
    return self.len;
  }

  fn capacity(self: ref Self) -> i64 {
    return self.capacity;
  }

  fn is_empty(self: ref Self) -> bool {
    return self.len == 0;
  }

  fn peek(self: ref Self) -> T {
    std::assert(self.len > 0);
    return ptr_load(self.data);
  }

  fn try_peek(self: ref Self) -> std::Option[T] {
    if self.len == 0 {
      return std::None<T>();
    }
    return std::Some<T>(self.peek());
  }

  fn push(self: ref mut Self, zone: ref mut Zone, value: T) -> void {
    if self.len >= self.capacity {
      priority_queue_grow_to_capacity<T>(self, next_growth_capacity(self.capacity, self.len + 1));
    }
    ptr_store(ptr_add(self.data, self.len), value);
    self.len = self.len + 1;
    priority_queue_sift_up<T>(self, self.len - 1);
  }

  fn pop(self: ref mut Self) -> T {
    std::assert(self.len > 0);
    let top = ptr_load(self.data);
    self.len = self.len - 1;
    if self.len > 0 {
      let last = ptr_load(ptr_add(self.data, self.len));
      ptr_store(self.data, last);
      priority_queue_sift_down<T>(self, 0);
    }
    return top;
  }

  fn try_pop(self: ref mut Self) -> std::Option[T] {
    if self.len == 0 {
      return std::None<T>();
    }
    return std::Some<T>(self.pop());
  }

  fn clear(self: ref mut Self) -> void {
    priority_queue_drop_values<T>(self);
  }

  fn extend_iter[I: std::Iterator[T]](self: ref mut Self, iter: I) -> void {
    var cursor = iter;
    var item = cursor.next();
    while item.is_some() {
      if self.len >= self.capacity {
        priority_queue_grow_to_capacity<T>(self, next_growth_capacity(self.capacity, self.len + 1));
      }
      ptr_store(ptr_add(self.data, self.len), item.unwrap());
      self.len = self.len + 1;
      priority_queue_sift_up<T>(self, self.len - 1);
      item = cursor.next();
    }
  }

  fn extend[I: std::Iterator[T]](self: ref mut Self, iter: I) -> void {
    self.extend_iter<I>(iter);
  }

  fn reserve(self: ref mut Self, zone: ref mut Zone, capacity: i64) -> void {
    priority_queue_grow_to_capacity<T>(self, capacity);
  }

  fn reserve_extra(self: ref mut Self, zone: ref mut Zone, additional: i64) -> void {
    std::assert(additional >= 0);
    priority_queue_grow_to_capacity<T>(self, self.len + additional);
  }

  fn copy_to(self: ref Self, target: ref mut Zone) -> std::collections::PriorityQueue[T] {
    var copied = std::collections::priority_queue<T>(target, self.len, self.less);
    var index = 0;
    while index < self.len {
      ptr_store(ptr_add(copied.data, index), ptr_load(ptr_add(self.data, index)));
      index = index + 1;
    }
    copied.len = self.len;
    return copied;
  }
}

pub impl[T: std::cmp::Ord[T]] std::collections::PriorityQueue[T] {
  fn new(
    zone: ref mut Zone
  ) -> std::collections::PriorityQueue[T] {
    return std::collections::PriorityQueue::with_capacity<T>(zone, 4);
  }

  fn with_capacity(
    zone: ref mut Zone,
    capacity: i64
  ) -> std::collections::PriorityQueue[T] {
    let less: fn(T, T) -> bool = std::collections::default_less;
    return std::collections::priority_queue<T>(
      zone,
      capacity,
      less
    );
  }
}

impl[T] std::zone::ZoneBacked for std::collections::PriorityQueue[T] {
  pub fn zone(self: ref Self) -> std::zone::ZoneMetadata {
    std::assert(self.capacity > 0);
    return std::zone::metadata(self.data as ptr u8);
  }
}

impl[T] std::Drop for std::collections::PriorityQueue[T] {
  fn drop(self) -> void {
    var dropped = self;
    priority_queue_drop_values<T>(ref mut dropped);
    return;
  }
}
