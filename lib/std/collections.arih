// Linear insertion-order set. This is a source seed for collection APIs before
// HashMap/HashSet policy exists, so membership checks are O(n).
pub struct Set[T] {
  mut data: ptr T,
  mut len: i64,
  mut capacity: i64,
}

pub struct Iter[T] {
  data: ptr T,
  mut len: i64,
  mut index: i64,
}

pub struct SetDrain[T] {
  data: ptr T,
  len: i64,
  mut index: i64,
}

pub struct MapEntry[K, V] {
  key: K,
  value: V,
}

pub struct MapEntryMut[K, V] {
  key: K,
  value: ptr V,
}

pub struct MapValueMut[V] {
  value: ptr V,
}

// Mutable update handles for Rust-style map entry APIs. They keep only the map
// and key; growth recovers the backing zone from the map's allocation metadata.
pub struct HashMapEntry[K, V] {
  map: ptr std::collections::HashMap[K, V],
  key: K,
}

pub struct TreeMapEntry[K, V] {
  map: ptr std::collections::TreeMap[K, V],
  key: K,
}

pub struct HashMapEntries[K, V] {
  keys: ptr K,
  values: ptr V,
  states: ptr i64,
  capacity: i64,
  mut index: i64,
}

pub struct HashMapEntriesMut[K, V] {
  keys: ptr K,
  values: ptr V,
  states: ptr i64,
  capacity: i64,
  mut index: i64,
}

pub struct HashMapKeys[K] {
  keys: ptr K,
  states: ptr i64,
  capacity: i64,
  mut index: i64,
}

pub struct HashMapValues[V] {
  values: ptr V,
  states: ptr i64,
  capacity: i64,
  mut index: i64,
}

pub struct HashMapValuesMut[V] {
  values: ptr V,
  states: ptr i64,
  capacity: i64,
  mut index: i64,
}

pub struct HashMapDrain[K, V] {
  keys: ptr K,
  values: ptr V,
  states: ptr i64,
  capacity: i64,
  mut index: i64,
}

pub struct HashSetIter[T] {
  data: ptr T,
  states: ptr i64,
  capacity: i64,
  mut index: i64,
}

pub struct HashSetDrain[T] {
  data: ptr T,
  states: ptr i64,
  capacity: i64,
  mut index: i64,
}

pub struct TreeMapKeys[K] {
  keys: ptr K,
  left: ptr i64,
  right: ptr i64,
  parent: ptr i64,
  mut current: i64,
}

pub struct TreeMapValues[V] {
  values: ptr V,
  left: ptr i64,
  right: ptr i64,
  parent: ptr i64,
  mut current: i64,
}

pub struct TreeMapValuesMut[V] {
  values: ptr V,
  left: ptr i64,
  right: ptr i64,
  parent: ptr i64,
  mut current: i64,
}

pub struct TreeMapEntries[K, V] {
  keys: ptr K,
  values: ptr V,
  left: ptr i64,
  right: ptr i64,
  parent: ptr i64,
  mut current: i64,
}

pub struct TreeMapEntriesMut[K, V] {
  keys: ptr K,
  values: ptr V,
  left: ptr i64,
  right: ptr i64,
  parent: ptr i64,
  mut current: i64,
}

pub struct TreeMapRange[K, V] {
  keys: ptr K,
  values: ptr V,
  left: ptr i64,
  right: ptr i64,
  parent: ptr i64,
  end: K,
  less: fn(K, K) -> bool,
  mut current: i64,
}

pub struct TreeMapRangeMut[K, V] {
  keys: ptr K,
  values: ptr V,
  left: ptr i64,
  right: ptr i64,
  parent: ptr i64,
  end: K,
  less: fn(K, K) -> bool,
  mut current: i64,
}

pub struct TreeMapDrain[K, V] {
  keys: ptr K,
  values: ptr V,
  left: ptr i64,
  right: ptr i64,
  parent: ptr i64,
  colors: ptr i64,
  len: i64,
  mut current: i64,
}

pub struct TreeSetIter[T] {
  data: ptr T,
  left: ptr i64,
  right: ptr i64,
  parent: ptr i64,
  mut current: i64,
}

pub struct TreeSetRange[T] {
  data: ptr T,
  left: ptr i64,
  right: ptr i64,
  parent: ptr i64,
  end: T,
  less: fn(T, T) -> bool,
  mut current: i64,
}

pub struct TreeSetDrain[T] {
  data: ptr T,
  left: ptr i64,
  right: ptr i64,
  parent: ptr i64,
  colors: ptr i64,
  len: i64,
  mut current: i64,
}

pub impl[K, V] std::collections::MapEntry[K, V] {
  fn key(self: ref Self) -> K {
    return self.key;
  }

  fn value(self: ref Self) -> V {
    return self.value;
  }
}

pub impl[K, V] std::collections::MapEntryMut[K, V] {
  fn key(self: ref Self) -> K {
    return self.key;
  }

  fn value(self: ref Self) -> V {
    return ptr_load(self.value);
  }

  fn value_mut(self: ref mut Self) -> ref mut V {
    return ref mut *self.value;
  }
}

pub impl[V] std::collections::MapValueMut[V] {
  fn value(self: ref Self) -> V {
    return ptr_load(self.value);
  }

  fn value_mut(self: ref mut Self) -> ref mut V {
    return ref mut *self.value;
  }
}

// Growable double-ended queue backed by a circular buffer.
pub struct Deque[T] {
  mut data: ptr T,
  mut len: i64,
  mut capacity: i64,
  mut head: i64,
}

pub struct DequeIter[T] {
  data: ptr T,
  mut len: i64,
  capacity: i64,
  head: i64,
  mut index: i64,
}

// Fixed-capacity queue. `push` fails when full, while `push_overwrite` keeps
// the newest values and returns the overwritten oldest value.
pub struct RingBuffer[T] {
  mut data: ptr T,
  mut len: i64,
  capacity: i64,
  mut head: i64,
}

pub struct RingBufferIter[T] {
  data: ptr T,
  mut len: i64,
  capacity: i64,
  head: i64,
  mut index: i64,
}

// Intrusive-index linked list over zone storage. Freed node slots are reused.
pub struct LinkedList[T] {
  mut data: ptr T,
  mut next_node: ptr i64,
  mut prev: ptr i64,
  mut head: i64,
  mut tail: i64,
  mut len: i64,
  mut capacity: i64,
  mut next_slot: i64,
  mut free: i64,
}

pub struct LinkedListIter[T] {
  data: ptr T,
  next_node: ptr i64,
  mut current: i64,
}

// Max-priority binary heap. `less(a, b)` means `a` has lower priority than `b`.
pub struct BinaryHeap[T] {
  less: fn(T, T) -> bool,
  mut data: ptr T,
  mut len: i64,
  mut capacity: i64,
}

pub struct BinaryHeapPeekMut[T] {
  heap: ptr std::collections::BinaryHeap[T],
  value: ptr T,
}

pub struct PriorityQueue[T] {
  less: fn(T, T) -> bool,
  mut data: ptr T,
  mut len: i64,
  mut capacity: i64,
}

// Open-addressed hash map. Callers provide the hash function until std::Hash
// exists as a trait that the compiler can resolve for generic keys.
pub struct HashMap[K, V] {
  hash: fn(K) -> u64,
  mut keys: ptr K,
  mut values: ptr V,
  mut states: ptr i64,
  mut len: i64,
  mut capacity: i64,
}

pub struct HashSet[T] {
  hash: fn(T) -> u64,
  mut data: ptr T,
  mut states: ptr i64,
  mut len: i64,
  mut capacity: i64,
}

// Red-black tree maps and sets. Callers provide a strict less-than relation
// until std::Ord dispatch is strong enough for fully trait-driven containers.
pub struct TreeMap[K, V] {
  less: fn(K, K) -> bool,
  mut keys: ptr K,
  mut values: ptr V,
  mut left: ptr i64,
  mut right: ptr i64,
  mut parent: ptr i64,
  mut colors: ptr i64,
  mut root: i64,
  mut len: i64,
  mut capacity: i64,
}

pub struct TreeSet[T] {
  less: fn(T, T) -> bool,
  mut data: ptr T,
  mut left: ptr i64,
  mut right: ptr i64,
  mut parent: ptr i64,
  mut colors: ptr i64,
  mut root: i64,
  mut len: i64,
  mut capacity: i64,
}

pub fn new[T](zone: ref mut Zone, capacity: i64) -> std::collections::Set[T] {
  std::assert(capacity >= 0);
  var allocation_capacity = capacity;
  if allocation_capacity == 0 {
    allocation_capacity = 1;
  }
  let data = std::zone::alloc_array<T>(zone, allocation_capacity);
  return std::collections::Set<T> {
    data: data,
    len: 0,
    capacity: capacity,
  };
}

pub fn from_slice_in[T](zone: ref mut Zone, values: std::Slice[T]) -> std::collections::Set[T] {
  var set = std::collections::new<T>(zone, values.len);
  var index = 0;
  while index < values.len {
    set.insert(zone, values[index]);
    index = index + 1;
  }
  return set;
}

pub fn hash_i64(value: i64) -> u64 {
  return std::hash::value<i64>(value);
}

pub fn hash_string(value: std::string::String) -> u64 {
  return std::hash::string(value);
}

fn default_hash[T: std::hash::Hash[T]](value: T) -> u64 {
  return std::hash::value<T>(value);
}

pub fn less_i64(left: i64, right: i64) -> bool {
  return left < right;
}

fn default_less[T: std::cmp::Ord[T]](left: T, right: T) -> bool {
  return left < right;
}

fn next_growth_capacity(current: i64, minimum: i64) -> i64 {
  var capacity = current * 2;
  if capacity < minimum {
    capacity = minimum;
  }
  return capacity;
}

fn grow_to_capacity[T](set: ref mut std::collections::Set[T], capacity: i64) -> void {
  std::assert(capacity >= 0);
  if capacity <= set.capacity {
    return;
  }
  // Zones own backing storage; growth copies live values into a larger buffer.
  let metadata = set.zone();
  let data = metadata.alloc_array<T>(capacity);
  var index = 0;
  while index < set.len {
    ptr_store(ptr_add(data, index), ptr_load(ptr_add(set.data, index)));
    index = index + 1;
  }
  set.data = data;
  set.capacity = capacity;
}

fn ensure_spare_capacity[T](set: ref mut std::collections::Set[T]) -> void {
  if set.len >= set.capacity {
    let capacity = next_growth_capacity(set.capacity, set.len + 1);
    grow_to_capacity<T>(set, capacity);
  }
}

fn remove_at[T](set: ref mut std::collections::Set[T], index: i64) -> T {
  std::assert(index >= 0);
  std::assert(index < set.len);
  let value = ptr_load(ptr_add(set.data, index));
  var cursor = index;
  while cursor + 1 < set.len {
    ptr_store(ptr_add(set.data, cursor), ptr_load(ptr_add(set.data, cursor + 1)));
    cursor = cursor + 1;
  }
  set.len = set.len - 1;
  return value;
}

fn drop_values[T](set: ref mut std::collections::Set[T]) -> void {
  // Drop only initialized live elements. The explicit Zone owns raw storage.
  var index = 0;
  while index < set.len {
    let value = ptr_load(ptr_add(set.data, index));
    drop value;
    index = index + 1;
  }
  set.len = 0;
}

pub impl[T] std::collections::Set[T] {
  fn new(zone: ref mut Zone, capacity: i64) -> std::collections::Set[T] {
    return std::collections::new<T>(zone, capacity);
  }

  fn from_iter[I: std::Iterator[T]](zone: ref mut Zone, iter: I) -> std::collections::Set[T] {
    var output = std::collections::new<T>(zone, 4);
    output.extend_iter<I>(iter);
    return output;
  }

  fn len(self: ref Self) -> i64 {
    return self.len;
  }

  fn capacity(self: ref Self) -> i64 {
    return self.capacity;
  }

  fn is_empty(self: ref Self) -> bool {
    return self.len == 0;
  }

  fn first(self: ref Self) -> T {
    std::assert(self.len > 0);
    return ptr_load(self.data);
  }

  fn try_first(self: ref Self) -> std::Option[T] {
    if self.len == 0 {
      return std::None<T>();
    }
    return std::Some<T>(ptr_load(self.data));
  }

  fn last(self: ref Self) -> T {
    std::assert(self.len > 0);
    return ptr_load(ptr_add(self.data, self.len - 1));
  }

  fn try_last(self: ref Self) -> std::Option[T] {
    if self.len == 0 {
      return std::None<T>();
    }
    return std::Some<T>(ptr_load(ptr_add(self.data, self.len - 1)));
  }

  fn get(self: ref Self, index: i64) -> T {
    std::assert(index >= 0);
    std::assert(index < self.len);
    return ptr_load(ptr_add(self.data, index));
  }

  fn try_get(self: ref Self, index: i64) -> std::Option[T] {
    if index < 0 {
      return std::None<T>();
    }
    if index >= self.len {
      return std::None<T>();
    }
    return std::Some<T>(ptr_load(ptr_add(self.data, index)));
  }

  fn index_of(self: ref Self, value: T) -> i64 {
    var index = 0;
    while index < self.len {
      if ptr_load(ptr_add(self.data, index)) == value {
        return index;
      }
      index = index + 1;
    }
    return -1;
  }

  fn contains(self: ref Self, value: T) -> bool {
    return self.index_of(value) >= 0;
  }

  fn is_subset(self: ref Self, other: ref Self) -> bool {
    var index = 0;
    while index < self.len {
      if !other.contains(ptr_load(ptr_add(self.data, index))) {
        return false;
      }
      index = index + 1;
    }
    return true;
  }

  fn is_superset(self: ref Self, other: ref Self) -> bool {
    return other.is_subset(self);
  }

  fn is_disjoint(self: ref Self, other: ref Self) -> bool {
    var index = 0;
    while index < self.len {
      if other.contains(ptr_load(ptr_add(self.data, index))) {
        return false;
      }
      index = index + 1;
    }
    return true;
  }

  fn equals(self: ref Self, other: ref Self) -> bool {
    if self.len != other.len {
      return false;
    }
    return self.is_subset(other);
  }

  fn insert(self: ref mut Self, zone: ref mut Zone, value: T) -> bool {
    if self.contains(value) {
      return false;
    }
    ensure_spare_capacity<T>(self);
    ptr_store(ptr_add(self.data, self.len), value);
    self.len = self.len + 1;
    return true;
  }

  fn replace(self: ref mut Self, zone: ref mut Zone, value: T) -> std::Option[T] {
    let index = self.index_of(value);
    if index < 0 {
      self.insert(zone, value);
      return std::None<T>();
    }
    let previous = ptr_load(ptr_add(self.data, index));
    ptr_store(ptr_add(self.data, index), value);
    return std::Some<T>(previous);
  }

  fn remove(self: ref mut Self, value: T) -> bool {
    let index = self.index_of(value);
    if index < 0 {
      return false;
    }
    let removed = remove_at<T>(self, index);
    drop removed;
    return true;
  }

  fn pop(self: ref mut Self) -> T {
    std::assert(self.len > 0);
    return remove_at<T>(self, self.len - 1);
  }

  fn try_pop(self: ref mut Self) -> std::Option[T] {
    if self.is_empty() {
      return std::None<T>();
    }
    return std::Some<T>(self.pop());
  }

  fn take(self: ref mut Self, value: T) -> std::Option[T] {
    let index = self.index_of(value);
    if index < 0 {
      return std::None<T>();
    }
    return std::Some<T>(remove_at<T>(self, index));
  }

  fn clear(self: ref mut Self) -> void {
    drop_values<T>(self);
  }

  fn retain(self: ref mut Self, keep: fn(ref T) -> bool) -> void {
    var index = 0;
    while index < self.len {
      let current = ptr_add(self.data, index);
      if keep(ref *current) {
        index = index + 1;
      } else {
        let removed = remove_at<T>(self, index);
        drop removed;
      }
    }
  }

  fn extend_iter[I: std::Iterator[T]](self: ref mut Self, iter: I) -> void {
    var cursor = iter;
    var item = cursor.next();
    while item.is_some() {
      let value = item.unwrap();
      if self.contains(value) {
        drop value;
        item = cursor.next();
        continue;
      }
      ensure_spare_capacity<T>(self);
      ptr_store(ptr_add(self.data, self.len), value);
      self.len = self.len + 1;
      item = cursor.next();
    }
  }

  fn extend[I: std::Iterator[T]](self: ref mut Self, iter: I) -> void {
    self.extend_iter<I>(iter);
  }

  fn reserve(self: ref mut Self, zone: ref mut Zone, capacity: i64) -> void {
    grow_to_capacity<T>(self, capacity);
  }

  fn reserve_extra(self: ref mut Self, zone: ref mut Zone, additional: i64) -> void {
    std::assert(additional >= 0);
    grow_to_capacity<T>(self, self.len + additional);
  }

  fn as_slice(self: ref Self) -> std::Slice[T] {
    return std::Slice<T> { data: self.data, len: self.len };
  }

  fn iter(self: ref Self) -> std::collections::Iter[T] {
    return std::collections::Iter<T> { data: self.data, len: self.len, index: 0 };
  }

  fn drain(self: ref mut Self) -> std::collections::SetDrain[T] {
    let cursor = std::collections::SetDrain<T> {
      data: self.data,
      len: self.len,
      index: 0,
    };
    self.len = 0;
    return cursor;
  }

  fn copy_to(self: ref Self, target: ref mut Zone) -> std::collections::Set[T] {
    var copied = std::collections::new<T>(target, self.len);
    var index = 0;
    while index < self.len {
      copied.insert(target, ptr_load(ptr_add(self.data, index)));
      index = index + 1;
    }
    return copied;
  }
}

impl[T] std::Iterator[T] for std::collections::Iter[T] {
  pub fn next(self: ref mut Self) -> std::Option[T] {
    if self.index >= self.len {
      return std::None<T>();
    }
    let value = ptr_load(ptr_add(self.data, self.index));
    self.index = self.index + 1;
    return std::Some<T>(value);
  }
}

impl[T] std::ExactSizeIterator[T] for std::collections::Iter[T] {
  pub fn len(self: ref Self) -> i64 {
    return self.len - self.index;
  }
}

impl[T] std::DoubleEndedIterator[T] for std::collections::Iter[T] {
  pub fn next_back(self: ref mut Self) -> std::Option[T] {
    if self.index >= self.len {
      return std::None<T>();
    }
    self.len = self.len - 1;
    return std::Some<T>(ptr_load(ptr_add(self.data, self.len)));
  }
}

impl[T] std::Iterator[T] for std::collections::SetDrain[T] {
  pub fn next(self: ref mut Self) -> std::Option[T] {
    if self.index >= self.len {
      return std::None<T>();
    }
    let value = ptr_load(ptr_add(self.data, self.index));
    self.index = self.index + 1;
    return std::Some<T>(value);
  }
}

impl[T] std::Drop for std::collections::SetDrain[T] {
  fn drop(self) -> void {
    var cursor = self;
    while cursor.index < cursor.len {
      let value = ptr_load(ptr_add(cursor.data, cursor.index));
      drop value;
      cursor.index = cursor.index + 1;
    }
    return;
  }
}

impl[T] std::IntoIterator[T] for std::collections::Set[T] {
  pub fn into_iter(self: ref mut Self) -> std::collections::Iter[T] {
    return std::collections::Iter<T> { data: self.data, len: self.len, index: 0 };
  }
}

impl[T] std::zone::ZoneBacked for std::collections::Set[T] {
  pub fn zone(self: ref Self) -> std::zone::ZoneMetadata {
    return std::zone::metadata(self.data as ptr u8);
  }
}

impl[T] std::Drop for std::collections::Set[T] {
  fn drop(self) -> void {
    var dropped = self;
    drop_values<T>(ref mut dropped);
    return;
  }
}

fn normalized_hash_capacity(capacity: i64) -> i64 {
  if capacity < 8 {
    return 8;
  }
  return capacity;
}

// Convert a desired live element count to buckets under the load-factor rule.
fn hash_capacity_for_len(len: i64) -> i64 {
  var capacity = normalized_hash_capacity(len + 1);
  while (len + 1) * 4 >= capacity * 3 {
    capacity = capacity * 2;
  }
  return capacity;
}

fn bucket_for(hash: u64, capacity: i64) -> i64 {
  return (hash % (capacity as u64)) as i64;
}

fn init_states(states: ptr i64, capacity: i64) -> void {
  var index = 0;
  while index < capacity {
    ptr_store(ptr_add(states, index), 0);
    index = index + 1;
  }
}

fn next_live_bucket(states: ptr i64, capacity: i64, start: i64) -> i64 {
  var index = start;
  while index < capacity {
    if ptr_load(ptr_add(states, index)) == 1 {
      return index;
    }
    index = index + 1;
  }
  return -1;
}

fn next_drain_bucket(states: ptr i64, capacity: i64, start: i64) -> i64 {
  var index = start;
  while index < capacity {
    if ptr_load(ptr_add(states, index)) == 3 {
      return index;
    }
    index = index + 1;
  }
  return -1;
}

pub fn hash_map[K, V](
  zone: ref mut Zone,
  capacity: i64,
  hash: fn(K) -> u64
) -> std::collections::HashMap[K, V] {
  let actual = normalized_hash_capacity(capacity);
  let keys = std::zone::alloc_array<K>(zone, actual);
  let values = std::zone::alloc_array<V>(zone, actual);
  let states = std::zone::alloc_array<i64>(zone, actual);
  init_states(states, actual);
  return std::collections::HashMap<K, V> {
    hash: hash,
    keys: keys,
    values: values,
    states: states,
    len: 0,
    capacity: actual,
  };
}

pub fn string_hash_map[V](
  zone: ref mut Zone,
  capacity: i64
) -> std::collections::HashMap[std::string::String, V] {
  return std::collections::hash_map<std::string::String, V>(
    zone,
    capacity,
    std::collections::hash_string
  );
}

pub fn hash_set[T](
  zone: ref mut Zone,
  capacity: i64,
  hash: fn(T) -> u64
) -> std::collections::HashSet[T] {
  let actual = normalized_hash_capacity(capacity);
  let data = std::zone::alloc_array<T>(zone, actual);
  let states = std::zone::alloc_array<i64>(zone, actual);
  init_states(states, actual);
  return std::collections::HashSet<T> {
    hash: hash,
    data: data,
    states: states,
    len: 0,
    capacity: actual,
  };
}

pub fn string_hash_set(
  zone: ref mut Zone,
  capacity: i64
) -> std::collections::HashSet[std::string::String] {
  return std::collections::hash_set<std::string::String>(
    zone,
    capacity,
    std::collections::hash_string
  );
}

fn hash_map_find_slot[K, V](map: ref std::collections::HashMap[K, V], key: K) -> i64 {
  let hash = map.hash;
  var index = bucket_for(hash(key), map.capacity);
  var scanned = 0;
  while scanned < map.capacity {
    let state = ptr_load(ptr_add(map.states, index));
    if state == 0 {
      return -1;
    }
    if state == 1 {
      if ptr_load(ptr_add(map.keys, index)) == key {
        return index;
      }
    }
    index = (index + 1) % map.capacity;
    scanned = scanned + 1;
  }
  return -1;
}

fn hash_map_find_slot_mut[K, V](map: ref mut std::collections::HashMap[K, V], key: K) -> i64 {
  let hash = map.hash;
  var index = bucket_for(hash(key), map.capacity);
  var scanned = 0;
  while scanned < map.capacity {
    let state = ptr_load(ptr_add(map.states, index));
    if state == 0 {
      return -1;
    }
    if state == 1 {
      if ptr_load(ptr_add(map.keys, index)) == key {
        return index;
      }
    }
    index = (index + 1) % map.capacity;
    scanned = scanned + 1;
  }
  return -1;
}

fn hash_map_find_string_slot[V](
  map: ref std::collections::HashMap[std::string::String, V],
  key: std::Slice[u8]
) -> i64 {
  var index = bucket_for(std::hash::bytes(key), map.capacity);
  var scanned = 0;
  while scanned < map.capacity {
    let state = ptr_load(ptr_add(map.states, index));
    if state == 0 {
      return -1;
    }
    if state == 1 {
      let stored_key = ptr_load(ptr_add(map.keys, index));
      if stored_key.equals(key) {
        return index;
      }
    }
    index = (index + 1) % map.capacity;
    scanned = scanned + 1;
  }
  return -1;
}

fn hash_map_find_string_slot_mut[V](
  map: ref mut std::collections::HashMap[std::string::String, V],
  key: std::Slice[u8]
) -> i64 {
  var index = bucket_for(std::hash::bytes(key), map.capacity);
  var scanned = 0;
  while scanned < map.capacity {
    let state = ptr_load(ptr_add(map.states, index));
    if state == 0 {
      return -1;
    }
    if state == 1 {
      let stored_key = ptr_load(ptr_add(map.keys, index));
      if stored_key.equals(key) {
        return index;
      }
    }
    index = (index + 1) % map.capacity;
    scanned = scanned + 1;
  }
  return -1;
}

fn hash_map_find_insert_slot[K, V](map: ref mut std::collections::HashMap[K, V], key: K) -> i64 {
  let hash = map.hash;
  var index = bucket_for(hash(key), map.capacity);
  var scanned = 0;
  var tombstone = -1;
  while scanned < map.capacity {
    let state = ptr_load(ptr_add(map.states, index));
    if state == 0 {
      if tombstone >= 0 {
        return tombstone;
      }
      return index;
    }
    if state == 2 {
      if tombstone < 0 {
        tombstone = index;
      }
    }
    index = (index + 1) % map.capacity;
    scanned = scanned + 1;
  }
  return tombstone;
}

fn hash_map_place_existing[K, V](map: ref mut std::collections::HashMap[K, V], key: K, value: V) -> void {
  let index = hash_map_find_insert_slot<K, V>(map, key);
  std::assert(index >= 0);
  ptr_store(ptr_add(map.keys, index), key);
  ptr_store(ptr_add(map.values, index), value);
  ptr_store(ptr_add(map.states, index), 1);
  map.len = map.len + 1;
}

fn hash_map_insert_absent_slot[K, V](
  map: ref mut std::collections::HashMap[K, V],
  key: K,
  value: V
) -> i64 {
  hash_map_ensure_spare_capacity<K, V>(map);
  let index = hash_map_find_insert_slot<K, V>(map, key);
  std::assert(index >= 0);
  ptr_store(ptr_add(map.keys, index), key);
  ptr_store(ptr_add(map.values, index), value);
  ptr_store(ptr_add(map.states, index), 1);
  map.len = map.len + 1;
  return index;
}

fn hash_map_grow_to_capacity[K, V](
  map: ref mut std::collections::HashMap[K, V],
  capacity: i64
) -> void {
  let actual = normalized_hash_capacity(capacity);
  if actual <= map.capacity {
    return;
  }
  let old_keys = map.keys;
  let old_values = map.values;
  let old_states = map.states;
  let old_capacity = map.capacity;
  let metadata = map.zone();
  let new_keys = metadata.alloc_array<K>(actual);
  let new_values = metadata.alloc_array<V>(actual);
  let new_states = metadata.alloc_array<i64>(actual);
  init_states(new_states, actual);
  map.keys = new_keys;
  map.values = new_values;
  map.states = new_states;
  map.capacity = actual;
  map.len = 0;
  var index = 0;
  while index < old_capacity {
    if ptr_load(ptr_add(old_states, index)) == 1 {
      hash_map_place_existing<K, V>(
        map,
        ptr_load(ptr_add(old_keys, index)),
        ptr_load(ptr_add(old_values, index))
      );
    }
    index = index + 1;
  }
}

fn hash_map_ensure_spare_capacity[K, V](
  map: ref mut std::collections::HashMap[K, V]
) -> void {
  if (map.len + 1) * 4 >= map.capacity * 3 {
    hash_map_grow_to_capacity<K, V>(map, map.capacity * 2);
  }
}

fn hash_map_drop_values[K, V](map: ref mut std::collections::HashMap[K, V]) -> void {
  var index = 0;
  while index < map.capacity {
    if ptr_load(ptr_add(map.states, index)) == 1 {
      let key = ptr_load(ptr_add(map.keys, index));
      let value = ptr_load(ptr_add(map.values, index));
      drop key;
      drop value;
      ptr_store(ptr_add(map.states, index), 0);
    }
    index = index + 1;
  }
  map.len = 0;
}

pub impl[K, V] std::collections::HashMap[K, V] {
  fn with_hash(
    zone: ref mut Zone,
    capacity: i64,
    hash: fn(K) -> u64
  ) -> std::collections::HashMap[K, V] {
    return std::collections::hash_map<K, V>(zone, capacity, hash);
  }

  fn from_iter[I: std::Iterator[std::collections::MapEntry[K, V]]](
    zone: ref mut Zone,
    capacity: i64,
    hash: fn(K) -> u64,
    iter: I
  ) -> std::collections::HashMap[K, V] {
    var output = std::collections::hash_map<K, V>(zone, capacity, hash);
    output.extend_iter<I>(iter);
    return output;
  }

  fn len(self: ref Self) -> i64 {
    return self.len;
  }

  fn capacity(self: ref Self) -> i64 {
    return self.capacity;
  }

  fn is_empty(self: ref Self) -> bool {
    return self.len == 0;
  }

  fn contains(self: ref Self, key: K) -> bool {
    return hash_map_find_slot<K, V>(self, key) >= 0;
  }

  fn contains_key(self: ref Self, key: K) -> bool {
    return self.contains(key);
  }

  fn contains_value(self: ref Self, value: V) -> bool {
    var bucket = next_live_bucket(self.states, self.capacity, 0);
    while bucket >= 0 {
      if ptr_load(ptr_add(self.values, bucket)) == value {
        return true;
      }
      bucket = next_live_bucket(self.states, self.capacity, bucket + 1);
    }
    return false;
  }

  fn try_get(self: ref Self, key: K) -> std::Option[V] {
    let index = hash_map_find_slot<K, V>(self, key);
    if index < 0 {
      return std::None<V>();
    }
    return std::Some<V>(ptr_load(ptr_add(self.values, index)));
  }

  fn try_get_mut(self: ref mut Self, key: K) -> std::Option[std::collections::MapValueMut[V]] {
    let index = hash_map_find_slot_mut<K, V>(self, key);
    if index < 0 {
      return std::None<std::collections::MapValueMut[V]>();
    }
    return std::Some<std::collections::MapValueMut[V]>(
      std::collections::MapValueMut<V> {
        value: ptr_add(self.values, index),
      }
    );
  }

  fn get_or(self: ref Self, key: K, fallback: V) -> V {
    return self.try_get(key).unwrap_or(fallback);
  }

  fn get(self: ref Self, key: K) -> V {
    let index = hash_map_find_slot<K, V>(self, key);
    std::assert(index >= 0);
    return ptr_load(ptr_add(self.values, index));
  }

  fn get_mut(self: ref mut Self, key: K) -> ref mut V {
    let index = hash_map_find_slot_mut<K, V>(self, key);
    std::assert(index >= 0);
    return ref mut *ptr_add(self.values, index);
  }

  fn insert(self: ref mut Self, zone: ref mut Zone, key: K, value: V) -> std::Option[V] {
    let existing = hash_map_find_slot_mut<K, V>(self, key);
    if existing >= 0 {
      let old_key = ptr_load(ptr_add(self.keys, existing));
      let previous = ptr_load(ptr_add(self.values, existing));
      drop old_key;
      ptr_store(ptr_add(self.keys, existing), key);
      ptr_store(ptr_add(self.values, existing), value);
      return std::Some<V>(previous);
    }
    hash_map_insert_absent_slot<K, V>(self, key, value);
    return std::None<V>();
  }

  fn replace(self: ref mut Self, zone: ref mut Zone, key: K, value: V) -> std::Option[V] {
    return self.insert(zone, key, value);
  }

  fn entry(self: ref mut Self, zone: ref mut Zone, key: K) -> std::collections::HashMapEntry[K, V] {
    return std::collections::HashMapEntry<K, V> {
      map: self as ptr std::collections::HashMap[K, V],
      key: key,
    };
  }

  fn remove(self: ref mut Self, key: K) -> std::Option[V] {
    let index = hash_map_find_slot_mut<K, V>(self, key);
    if index < 0 {
      return std::None<V>();
    }
    let removed_key = ptr_load(ptr_add(self.keys, index));
    let removed_value = ptr_load(ptr_add(self.values, index));
    drop removed_key;
    ptr_store(ptr_add(self.states, index), 2);
    self.len = self.len - 1;
    return std::Some<V>(removed_value);
  }

  fn remove_entry(self: ref mut Self, key: K) -> std::Option[std::collections::MapEntry[K, V]] {
    let index = hash_map_find_slot_mut<K, V>(self, key);
    if index < 0 {
      return std::None<std::collections::MapEntry[K, V]>();
    }
    let removed_key = ptr_load(ptr_add(self.keys, index));
    let removed_value = ptr_load(ptr_add(self.values, index));
    ptr_store(ptr_add(self.states, index), 2);
    self.len = self.len - 1;
    return std::Some<std::collections::MapEntry[K, V]>(
      std::collections::MapEntry<K, V> {
        key: removed_key,
        value: removed_value,
      }
    );
  }

  fn clear(self: ref mut Self) -> void {
    hash_map_drop_values<K, V>(self);
  }

  fn retain(self: ref mut Self, keep: fn(ref K, ref mut V) -> bool) -> void {
    var bucket = next_live_bucket(self.states, self.capacity, 0);
    while bucket >= 0 {
      let key_ptr = ptr_add(self.keys, bucket);
      let value_ptr = ptr_add(self.values, bucket);
      if keep(ref *key_ptr, ref mut *value_ptr) {
        bucket = next_live_bucket(self.states, self.capacity, bucket + 1);
      } else {
        let key = ptr_load(key_ptr);
        let value = ptr_load(value_ptr);
        drop key;
        drop value;
        ptr_store(ptr_add(self.states, bucket), 2);
        self.len = self.len - 1;
        bucket = next_live_bucket(self.states, self.capacity, bucket + 1);
      }
    }
  }

  fn extend_iter[I: std::Iterator[std::collections::MapEntry[K, V]]](self: ref mut Self, iter: I) -> void {
    var cursor = iter;
    var item = cursor.next();
    while item.is_some() {
      let entry = item.unwrap();
      let existing = hash_map_find_slot_mut<K, V>(self, entry.key);
      if existing >= 0 {
        let old_key = ptr_load(ptr_add(self.keys, existing));
        let previous = ptr_load(ptr_add(self.values, existing));
        drop old_key;
        drop previous;
        ptr_store(ptr_add(self.keys, existing), entry.key);
        ptr_store(ptr_add(self.values, existing), entry.value);
      } else {
        hash_map_insert_absent_slot<K, V>(self, entry.key, entry.value);
      }
      item = cursor.next();
    }
  }

  fn extend[I: std::Iterator[std::collections::MapEntry[K, V]]](self: ref mut Self, iter: I) -> void {
    self.extend_iter<I>(iter);
  }

  fn reserve(self: ref mut Self, zone: ref mut Zone, capacity: i64) -> void {
    hash_map_grow_to_capacity<K, V>(self, capacity);
  }

  fn reserve_extra(self: ref mut Self, zone: ref mut Zone, additional: i64) -> void {
    std::assert(additional >= 0);
    hash_map_grow_to_capacity<K, V>(self, hash_capacity_for_len(self.len + additional));
  }

  fn copy_to(self: ref Self, target: ref mut Zone) -> std::collections::HashMap[K, V] {
    var copied = std::collections::hash_map<K, V>(
      target,
      hash_capacity_for_len(self.len),
      self.hash
    );
    var bucket = next_live_bucket(self.states, self.capacity, 0);
    while bucket >= 0 {
      copied.insert(
        target,
        ptr_load(ptr_add(self.keys, bucket)),
        ptr_load(ptr_add(self.values, bucket))
      );
      bucket = next_live_bucket(self.states, self.capacity, bucket + 1);
    }
    return copied;
  }

  fn keys(self: ref Self) -> std::collections::HashMapKeys[K] {
    return std::collections::HashMapKeys<K> {
      keys: self.keys,
      states: self.states,
      capacity: self.capacity,
      index: 0,
    };
  }

  fn values(self: ref Self) -> std::collections::HashMapValues[V] {
    return std::collections::HashMapValues<V> {
      values: self.values,
      states: self.states,
      capacity: self.capacity,
      index: 0,
    };
  }

  fn values_mut(self: ref mut Self) -> std::collections::HashMapValuesMut[V] {
    return std::collections::HashMapValuesMut<V> {
      values: self.values,
      states: self.states,
      capacity: self.capacity,
      index: 0,
    };
  }

  fn entries(self: ref Self) -> std::collections::HashMapEntries[K, V] {
    return std::collections::HashMapEntries<K, V> {
      keys: self.keys,
      values: self.values,
      states: self.states,
      capacity: self.capacity,
      index: 0,
    };
  }

  fn iter(self: ref Self) -> std::collections::HashMapEntries[K, V] {
    return self.entries();
  }

  fn iter_mut(self: ref mut Self) -> std::collections::HashMapEntriesMut[K, V] {
    return std::collections::HashMapEntriesMut<K, V> {
      keys: self.keys,
      values: self.values,
      states: self.states,
      capacity: self.capacity,
      index: 0,
    };
  }

  fn drain(self: ref mut Self) -> std::collections::HashMapDrain[K, V] {
    var bucket = next_live_bucket(self.states, self.capacity, 0);
    while bucket >= 0 {
      ptr_store(ptr_add(self.states, bucket), 3);
      bucket = next_live_bucket(self.states, self.capacity, bucket + 1);
    }
    self.len = 0;
    return std::collections::HashMapDrain<K, V> {
      keys: self.keys,
      values: self.values,
      states: self.states,
      capacity: self.capacity,
      index: 0,
    };
  }
}

pub impl[K: std::hash::Hash[K], V] std::collections::HashMap[K, V] {
  fn new(
    zone: ref mut Zone
  ) -> std::collections::HashMap[K, V] {
    return std::collections::HashMap::with_capacity<K, V>(zone, 4);
  }

  fn with_capacity(
    zone: ref mut Zone,
    capacity: i64
  ) -> std::collections::HashMap[K, V] {
    let hash: fn(K) -> u64 = std::collections::default_hash;
    return std::collections::hash_map<K, V>(
      zone,
      capacity,
      hash
    );
  }
}

pub impl[V] std::collections::HashMap[std::string::String, V] {
  fn contains_key_bytes(self: ref Self, key: std::Slice[u8]) -> bool {
    return std::collections::hash_map_find_string_slot<V>(self, key) >= 0;
  }

  fn try_get_bytes(self: ref Self, key: std::Slice[u8]) -> std::Option[V] {
    let index = std::collections::hash_map_find_string_slot<V>(self, key);
    if index < 0 {
      return std::None<V>();
    }
    return std::Some<V>(ptr_load(ptr_add(self.values, index)));
  }

  fn get_bytes(self: ref Self, key: std::Slice[u8]) -> V {
    let index = std::collections::hash_map_find_string_slot<V>(self, key);
    std::assert(index >= 0);
    return ptr_load(ptr_add(self.values, index));
  }

  fn get_or_bytes(self: ref Self, key: std::Slice[u8], fallback: V) -> V {
    return self.try_get_bytes(key).unwrap_or(fallback);
  }

  fn try_get_mut_bytes(self: ref mut Self, key: std::Slice[u8]) -> std::Option[std::collections::MapValueMut[V]] {
    let index = std::collections::hash_map_find_string_slot_mut<V>(self, key);
    if index < 0 {
      return std::None<std::collections::MapValueMut[V]>();
    }
    return std::Some<std::collections::MapValueMut[V]>(
      std::collections::MapValueMut<V> {
        value: ptr_add(self.values, index),
      }
    );
  }

  fn get_mut_bytes(self: ref mut Self, key: std::Slice[u8]) -> ref mut V {
    let index = std::collections::hash_map_find_string_slot_mut<V>(self, key);
    std::assert(index >= 0);
    return ref mut *ptr_add(self.values, index);
  }

  fn remove_bytes(self: ref mut Self, key: std::Slice[u8]) -> std::Option[V] {
    let index = std::collections::hash_map_find_string_slot_mut<V>(self, key);
    if index < 0 {
      return std::None<V>();
    }
    let removed_key = ptr_load(ptr_add(self.keys, index));
    let removed_value = ptr_load(ptr_add(self.values, index));
    drop removed_key;
    ptr_store(ptr_add(self.states, index), 2);
    self.len = self.len - 1;
    return std::Some<V>(removed_value);
  }

  fn remove_entry_bytes(self: ref mut Self, key: std::Slice[u8]) -> std::Option[std::collections::MapEntry[std::string::String, V]] {
    let index = std::collections::hash_map_find_string_slot_mut<V>(self, key);
    if index < 0 {
      return std::None<std::collections::MapEntry[std::string::String, V]>();
    }
    let removed_key = ptr_load(ptr_add(self.keys, index));
    let removed_value = ptr_load(ptr_add(self.values, index));
    ptr_store(ptr_add(self.states, index), 2);
    self.len = self.len - 1;
    return std::Some<std::collections::MapEntry[std::string::String, V]>(
      std::collections::MapEntry<std::string::String, V> {
        key: removed_key,
        value: removed_value,
      }
    );
  }
}

pub impl[K, V] std::collections::HashMapEntry[K, V] {
  fn and_modify(self, op: fn(ref mut V) -> void) -> Self {
    let map: ref mut std::collections::HashMap[K, V] = ref mut *self.map;
    let index = hash_map_find_slot_mut<K, V>(map, self.key);
    if index >= 0 {
      op(ref mut *ptr_add(map.values, index));
    }
    return self;
  }

  fn key(self: ref Self) -> K {
    return self.key;
  }

  fn value(self: ref Self) -> V {
    let map: ref std::collections::HashMap[K, V] = ref *self.map;
    let index = hash_map_find_slot<K, V>(map, self.key);
    std::assert(index >= 0);
    return ptr_load(ptr_add(map.values, index));
  }

  fn value_mut(self: ref mut Self) -> ref mut V {
    let map: ref mut std::collections::HashMap[K, V] = ref mut *self.map;
    let index = hash_map_find_slot_mut<K, V>(map, self.key);
    std::assert(index >= 0);
    return ref mut *ptr_add(map.values, index);
  }

  fn insert(self: ref mut Self, value: V) -> std::Option[V] {
    let map: ref mut std::collections::HashMap[K, V] = ref mut *self.map;
    let existing = hash_map_find_slot_mut<K, V>(map, self.key);
    if existing >= 0 {
      let previous = ptr_load(ptr_add(map.values, existing));
      ptr_store(ptr_add(map.values, existing), value);
      return std::Some<V>(previous);
    }

    hash_map_insert_absent_slot<K, V>(map, self.key, value);
    return std::None<V>();
  }

  fn insert_entry(self, value: V) -> Self {
    let map_ptr = self.map;
    let key = self.key;
    {
      let map: ref mut std::collections::HashMap[K, V] = ref mut *map_ptr;
      let existing = hash_map_find_slot_mut<K, V>(map, key);
      if existing >= 0 {
        let previous = ptr_load(ptr_add(map.values, existing));
        drop previous;
        ptr_store(ptr_add(map.values, existing), value);
      } else {
        hash_map_insert_absent_slot<K, V>(map, key, value);
      }
    }
    return std::collections::HashMapEntry<K, V> {
      map: map_ptr,
      key: key,
    };
  }

  fn remove(self: ref mut Self) -> std::Option[V] {
    let map: ref mut std::collections::HashMap[K, V] = ref mut *self.map;
    return map.remove(self.key);
  }

  fn or_insert(self: ref mut Self, value: V) -> ref mut V {
    let map: ref mut std::collections::HashMap[K, V] = ref mut *self.map;
    let existing = hash_map_find_slot_mut<K, V>(map, self.key);
    if existing >= 0 {
      return ref mut *ptr_add(map.values, existing);
    }

    let inserted = hash_map_insert_absent_slot<K, V>(map, self.key, value);
    return ref mut *ptr_add(map.values, inserted);
  }

  fn or_insert_with(self: ref mut Self, make_value: fn() -> V) -> ref mut V {
    let map: ref mut std::collections::HashMap[K, V] = ref mut *self.map;
    let existing = hash_map_find_slot_mut<K, V>(map, self.key);
    if existing >= 0 {
      return ref mut *ptr_add(map.values, existing);
    }

    let inserted = hash_map_insert_absent_slot<K, V>(map, self.key, make_value());
    return ref mut *ptr_add(map.values, inserted);
  }
}

pub impl[K, V: std::Default] std::collections::HashMapEntry[K, V] {
  fn or_default(self: ref mut Self) -> ref mut V {
    let map: ref mut std::collections::HashMap[K, V] = ref mut *self.map;
    let existing = hash_map_find_slot_mut<K, V>(map, self.key);
    if existing >= 0 {
      return ref mut *ptr_add(map.values, existing);
    }

    let inserted = hash_map_insert_absent_slot<K, V>(
      map,
      self.key,
      std::Default::default<V>()
    );
    return ref mut *ptr_add(map.values, inserted);
  }
}

impl[K, V] std::zone::ZoneBacked for std::collections::HashMapEntry[K, V] {
  pub fn zone(self: ref Self) -> std::zone::ZoneMetadata {
    let map: ref std::collections::HashMap[K, V] = ref *self.map;
    return map.zone();
  }
}

impl[K] std::Iterator[K] for std::collections::HashMapKeys[K] {
  pub fn next(self: ref mut Self) -> std::Option[K] {
    let bucket = next_live_bucket(self.states, self.capacity, self.index);
    if bucket < 0 {
      return std::None<K>();
    }
    self.index = bucket + 1;
    return std::Some<K>(ptr_load(ptr_add(self.keys, bucket)));
  }
}

impl[V] std::Iterator[V] for std::collections::HashMapValues[V] {
  pub fn next(self: ref mut Self) -> std::Option[V] {
    let bucket = next_live_bucket(self.states, self.capacity, self.index);
    if bucket < 0 {
      return std::None<V>();
    }
    self.index = bucket + 1;
    return std::Some<V>(ptr_load(ptr_add(self.values, bucket)));
  }
}

pub impl[V] std::collections::HashMapValuesMut[V] {
  fn has_next(self: ref Self) -> bool {
    return next_live_bucket(self.states, self.capacity, self.index) >= 0;
  }

  fn next(self: ref mut Self) -> ref mut V {
    let bucket = next_live_bucket(self.states, self.capacity, self.index);
    std::assert(bucket >= 0);
    self.index = bucket + 1;
    return ref mut *ptr_add(self.values, bucket);
  }
}

impl[K, V] std::Iterator[std::collections::MapEntry[K, V]] for std::collections::HashMapEntries[K, V] {
  pub fn next(self: ref mut Self) -> std::Option[std::collections::MapEntry[K, V]] {
    let bucket = next_live_bucket(self.states, self.capacity, self.index);
    if bucket < 0 {
      return std::None<std::collections::MapEntry[K, V]>();
    }
    self.index = bucket + 1;
    return std::Some<std::collections::MapEntry[K, V]>(
      std::collections::MapEntry<K, V> {
        key: ptr_load(ptr_add(self.keys, bucket)),
        value: ptr_load(ptr_add(self.values, bucket)),
      }
    );
  }
}

impl[K, V] std::Iterator[std::collections::MapEntryMut[K, V]] for std::collections::HashMapEntriesMut[K, V] {
  pub fn next(self: ref mut Self) -> std::Option[std::collections::MapEntryMut[K, V]] {
    let bucket = next_live_bucket(self.states, self.capacity, self.index);
    if bucket < 0 {
      return std::None<std::collections::MapEntryMut[K, V]>();
    }
    self.index = bucket + 1;
    return std::Some<std::collections::MapEntryMut[K, V]>(
      std::collections::MapEntryMut<K, V> {
        key: ptr_load(ptr_add(self.keys, bucket)),
        value: ptr_add(self.values, bucket),
      }
    );
  }
}

impl[K, V] std::Iterator[std::collections::MapEntry[K, V]] for std::collections::HashMapDrain[K, V] {
  pub fn next(self: ref mut Self) -> std::Option[std::collections::MapEntry[K, V]] {
    let bucket = next_drain_bucket(self.states, self.capacity, self.index);
    if bucket < 0 {
      return std::None<std::collections::MapEntry[K, V]>();
    }
    self.index = bucket + 1;
    ptr_store(ptr_add(self.states, bucket), 0);
    return std::Some<std::collections::MapEntry[K, V]>(
      std::collections::MapEntry<K, V> {
        key: ptr_load(ptr_add(self.keys, bucket)),
        value: ptr_load(ptr_add(self.values, bucket)),
      }
    );
  }
}

impl[K, V] std::Drop for std::collections::HashMapDrain[K, V] {
  fn drop(self) -> void {
    var cursor = self;
    var bucket = next_drain_bucket(cursor.states, cursor.capacity, cursor.index);
    while bucket >= 0 {
      let key = ptr_load(ptr_add(cursor.keys, bucket));
      let value = ptr_load(ptr_add(cursor.values, bucket));
      drop key;
      drop value;
      ptr_store(ptr_add(cursor.states, bucket), 0);
      bucket = next_drain_bucket(cursor.states, cursor.capacity, bucket + 1);
    }
    return;
  }
}

impl[K, V] std::IntoIterator[std::collections::MapEntry[K, V]] for std::collections::HashMap[K, V] {
  pub fn into_iter(self: ref mut Self) -> std::collections::HashMapEntries[K, V] {
    return self.entries();
  }
}

impl[K, V] std::zone::ZoneBacked for std::collections::HashMap[K, V] {
  pub fn zone(self: ref Self) -> std::zone::ZoneMetadata {
    std::assert(self.capacity > 0);
    return std::zone::metadata(self.keys as ptr u8);
  }
}

impl[K, V] std::Drop for std::collections::HashMap[K, V] {
  fn drop(self) -> void {
    var dropped = self;
    hash_map_drop_values<K, V>(ref mut dropped);
    return;
  }
}

fn hash_set_find_slot[T](set: ref std::collections::HashSet[T], value: T) -> i64 {
  let hash = set.hash;
  var index = bucket_for(hash(value), set.capacity);
  var scanned = 0;
  while scanned < set.capacity {
    let state = ptr_load(ptr_add(set.states, index));
    if state == 0 {
      return -1;
    }
    if state == 1 {
      if ptr_load(ptr_add(set.data, index)) == value {
        return index;
      }
    }
    index = (index + 1) % set.capacity;
    scanned = scanned + 1;
  }
  return -1;
}

fn hash_set_find_slot_mut[T](set: ref mut std::collections::HashSet[T], value: T) -> i64 {
  let hash = set.hash;
  var index = bucket_for(hash(value), set.capacity);
  var scanned = 0;
  while scanned < set.capacity {
    let state = ptr_load(ptr_add(set.states, index));
    if state == 0 {
      return -1;
    }
    if state == 1 {
      if ptr_load(ptr_add(set.data, index)) == value {
        return index;
      }
    }
    index = (index + 1) % set.capacity;
    scanned = scanned + 1;
  }
  return -1;
}

fn hash_set_find_string_slot(set: ref std::collections::HashSet[std::string::String], value: std::Slice[u8]) -> i64 {
  var index = bucket_for(std::hash::bytes(value), set.capacity);
  var scanned = 0;
  while scanned < set.capacity {
    let state = ptr_load(ptr_add(set.states, index));
    if state == 0 {
      return -1;
    }
    if state == 1 {
      let stored_value = ptr_load(ptr_add(set.data, index));
      if stored_value.equals(value) {
        return index;
      }
    }
    index = (index + 1) % set.capacity;
    scanned = scanned + 1;
  }
  return -1;
}

fn hash_set_find_string_slot_mut(set: ref mut std::collections::HashSet[std::string::String], value: std::Slice[u8]) -> i64 {
  var index = bucket_for(std::hash::bytes(value), set.capacity);
  var scanned = 0;
  while scanned < set.capacity {
    let state = ptr_load(ptr_add(set.states, index));
    if state == 0 {
      return -1;
    }
    if state == 1 {
      let stored_value = ptr_load(ptr_add(set.data, index));
      if stored_value.equals(value) {
        return index;
      }
    }
    index = (index + 1) % set.capacity;
    scanned = scanned + 1;
  }
  return -1;
}

fn hash_set_find_insert_slot[T](set: ref mut std::collections::HashSet[T], value: T) -> i64 {
  let hash = set.hash;
  var index = bucket_for(hash(value), set.capacity);
  var scanned = 0;
  var tombstone = -1;
  while scanned < set.capacity {
    let state = ptr_load(ptr_add(set.states, index));
    if state == 0 {
      if tombstone >= 0 {
        return tombstone;
      }
      return index;
    }
    if state == 2 {
      if tombstone < 0 {
        tombstone = index;
      }
    }
    index = (index + 1) % set.capacity;
    scanned = scanned + 1;
  }
  return tombstone;
}

fn hash_set_place_existing[T](set: ref mut std::collections::HashSet[T], value: T) -> void {
  let index = hash_set_find_insert_slot<T>(set, value);
  std::assert(index >= 0);
  ptr_store(ptr_add(set.data, index), value);
  ptr_store(ptr_add(set.states, index), 1);
  set.len = set.len + 1;
}

fn hash_set_grow_to_capacity[T](
  set: ref mut std::collections::HashSet[T],
  capacity: i64
) -> void {
  let actual = normalized_hash_capacity(capacity);
  if actual <= set.capacity {
    return;
  }
  let old_data = set.data;
  let old_states = set.states;
  let old_capacity = set.capacity;
  let metadata = set.zone();
  let new_data = metadata.alloc_array<T>(actual);
  let new_states = metadata.alloc_array<i64>(actual);
  init_states(new_states, actual);
  set.data = new_data;
  set.states = new_states;
  set.capacity = actual;
  set.len = 0;
  var index = 0;
  while index < old_capacity {
    if ptr_load(ptr_add(old_states, index)) == 1 {
      hash_set_place_existing<T>(set, ptr_load(ptr_add(old_data, index)));
    }
    index = index + 1;
  }
}

fn hash_set_ensure_spare_capacity[T](
  set: ref mut std::collections::HashSet[T]
) -> void {
  if (set.len + 1) * 4 >= set.capacity * 3 {
    hash_set_grow_to_capacity<T>(set, set.capacity * 2);
  }
}

fn hash_set_drop_values[T](set: ref mut std::collections::HashSet[T]) -> void {
  var index = 0;
  while index < set.capacity {
    if ptr_load(ptr_add(set.states, index)) == 1 {
      let value = ptr_load(ptr_add(set.data, index));
      drop value;
      ptr_store(ptr_add(set.states, index), 0);
    }
    index = index + 1;
  }
  set.len = 0;
}

pub impl[T] std::collections::HashSet[T] {
  fn with_hash(
    zone: ref mut Zone,
    capacity: i64,
    hash: fn(T) -> u64
  ) -> std::collections::HashSet[T] {
    return std::collections::hash_set<T>(zone, capacity, hash);
  }

  fn from_iter[I: std::Iterator[T]](
    zone: ref mut Zone,
    capacity: i64,
    hash: fn(T) -> u64,
    iter: I
  ) -> std::collections::HashSet[T] {
    var output = std::collections::hash_set<T>(zone, capacity, hash);
    output.extend_iter<I>(iter);
    return output;
  }

  fn len(self: ref Self) -> i64 {
    return self.len;
  }

  fn capacity(self: ref Self) -> i64 {
    return self.capacity;
  }

  fn is_empty(self: ref Self) -> bool {
    return self.len == 0;
  }

  fn contains(self: ref Self, value: T) -> bool {
    return hash_set_find_slot<T>(self, value) >= 0;
  }

  fn get(self: ref Self, value: T) -> T {
    let index = hash_set_find_slot<T>(self, value);
    std::assert(index >= 0);
    return ptr_load(ptr_add(self.data, index));
  }

  fn try_get(self: ref Self, value: T) -> std::Option[T] {
    let index = hash_set_find_slot<T>(self, value);
    if index < 0 {
      return std::None<T>();
    }
    return std::Some<T>(ptr_load(ptr_add(self.data, index)));
  }

  fn is_subset(self: ref Self, other: ref Self) -> bool {
    var index = 0;
    while index < self.capacity {
      if ptr_load(ptr_add(self.states, index)) == 1 {
        if !other.contains(ptr_load(ptr_add(self.data, index))) {
          return false;
        }
      }
      index = index + 1;
    }
    return true;
  }

  fn is_superset(self: ref Self, other: ref Self) -> bool {
    return other.is_subset(self);
  }

  fn is_disjoint(self: ref Self, other: ref Self) -> bool {
    var index = 0;
    while index < self.capacity {
      if ptr_load(ptr_add(self.states, index)) == 1 {
        if other.contains(ptr_load(ptr_add(self.data, index))) {
          return false;
        }
      }
      index = index + 1;
    }
    return true;
  }

  fn equals(self: ref Self, other: ref Self) -> bool {
    if self.len != other.len {
      return false;
    }
    return self.is_subset(other);
  }

  fn insert(self: ref mut Self, zone: ref mut Zone, value: T) -> bool {
    if hash_set_find_slot_mut<T>(self, value) >= 0 {
      return false;
    }
    hash_set_ensure_spare_capacity<T>(self);
    hash_set_place_existing<T>(self, value);
    return true;
  }

  fn replace(self: ref mut Self, zone: ref mut Zone, value: T) -> std::Option[T] {
    let existing = hash_set_find_slot_mut<T>(self, value);
    if existing >= 0 {
      let previous = ptr_load(ptr_add(self.data, existing));
      ptr_store(ptr_add(self.data, existing), value);
      return std::Some<T>(previous);
    }
    self.insert(zone, value);
    return std::None<T>();
  }

  fn take(self: ref mut Self, value: T) -> std::Option[T] {
    let index = hash_set_find_slot_mut<T>(self, value);
    if index < 0 {
      return std::None<T>();
    }
    let removed = ptr_load(ptr_add(self.data, index));
    ptr_store(ptr_add(self.states, index), 2);
    self.len = self.len - 1;
    return std::Some<T>(removed);
  }

  fn remove(self: ref mut Self, value: T) -> bool {
    let removed = self.take(value);
    match removed {
      std::Some(found) => {
        drop found;
        return true;
      }
      std::None => {
        return false;
      }
    }
  }

  fn clear(self: ref mut Self) -> void {
    hash_set_drop_values<T>(self);
  }

  fn retain(self: ref mut Self, keep: fn(ref T) -> bool) -> void {
    var bucket = next_live_bucket(self.states, self.capacity, 0);
    while bucket >= 0 {
      let value_ptr = ptr_add(self.data, bucket);
      if keep(ref *value_ptr) {
        bucket = next_live_bucket(self.states, self.capacity, bucket + 1);
      } else {
        let value = ptr_load(value_ptr);
        drop value;
        ptr_store(ptr_add(self.states, bucket), 2);
        self.len = self.len - 1;
        bucket = next_live_bucket(self.states, self.capacity, bucket + 1);
      }
    }
  }

  fn extend_iter[I: std::Iterator[T]](self: ref mut Self, iter: I) -> void {
    var cursor = iter;
    var item = cursor.next();
    while item.is_some() {
      let value = item.unwrap();
      let existing = hash_set_find_slot_mut<T>(self, value);
      if existing >= 0 {
        drop value;
        item = cursor.next();
        continue;
      }
      hash_set_ensure_spare_capacity<T>(self);
      hash_set_place_existing<T>(self, value);
      item = cursor.next();
    }
  }

  fn extend[I: std::Iterator[T]](self: ref mut Self, iter: I) -> void {
    self.extend_iter<I>(iter);
  }

  fn reserve(self: ref mut Self, zone: ref mut Zone, capacity: i64) -> void {
    hash_set_grow_to_capacity<T>(self, capacity);
  }

  fn reserve_extra(self: ref mut Self, zone: ref mut Zone, additional: i64) -> void {
    std::assert(additional >= 0);
    hash_set_grow_to_capacity<T>(self, hash_capacity_for_len(self.len + additional));
  }

  fn copy_to(self: ref Self, target: ref mut Zone) -> std::collections::HashSet[T] {
    var copied = std::collections::hash_set<T>(
      target,
      hash_capacity_for_len(self.len),
      self.hash
    );
    var bucket = next_live_bucket(self.states, self.capacity, 0);
    while bucket >= 0 {
      copied.insert(target, ptr_load(ptr_add(self.data, bucket)));
      bucket = next_live_bucket(self.states, self.capacity, bucket + 1);
    }
    return copied;
  }

  fn iter(self: ref Self) -> std::collections::HashSetIter[T] {
    return std::collections::HashSetIter<T> {
      data: self.data,
      states: self.states,
      capacity: self.capacity,
      index: 0,
    };
  }

  fn drain(self: ref mut Self) -> std::collections::HashSetDrain[T] {
    var bucket = next_live_bucket(self.states, self.capacity, 0);
    while bucket >= 0 {
      ptr_store(ptr_add(self.states, bucket), 3);
      bucket = next_live_bucket(self.states, self.capacity, bucket + 1);
    }
    self.len = 0;
    return std::collections::HashSetDrain<T> {
      data: self.data,
      states: self.states,
      capacity: self.capacity,
      index: 0,
    };
  }
}

pub impl[T: std::hash::Hash[T]] std::collections::HashSet[T] {
  fn new(
    zone: ref mut Zone
  ) -> std::collections::HashSet[T] {
    return std::collections::HashSet::with_capacity<T>(zone, 4);
  }

  fn with_capacity(
    zone: ref mut Zone,
    capacity: i64
  ) -> std::collections::HashSet[T] {
    let hash: fn(T) -> u64 = std::collections::default_hash;
    return std::collections::hash_set<T>(
      zone,
      capacity,
      hash
    );
  }
}

pub impl std::collections::HashSet[std::string::String] {
  fn contains_bytes(self: ref Self, value: std::Slice[u8]) -> bool {
    return std::collections::hash_set_find_string_slot(self, value) >= 0;
  }

  fn try_get_bytes(self: ref Self, value: std::Slice[u8]) -> std::Option[std::string::String] {
    let index = std::collections::hash_set_find_string_slot(self, value);
    if index < 0 {
      return std::None<std::string::String>();
    }
    return std::Some<std::string::String>(ptr_load(ptr_add(self.data, index)));
  }

  fn get_bytes(self: ref Self, value: std::Slice[u8]) -> std::string::String {
    let index = std::collections::hash_set_find_string_slot(self, value);
    std::assert(index >= 0);
    return ptr_load(ptr_add(self.data, index));
  }

  fn take_bytes(self: ref mut Self, value: std::Slice[u8]) -> std::Option[std::string::String] {
    let index = std::collections::hash_set_find_string_slot_mut(self, value);
    if index < 0 {
      return std::None<std::string::String>();
    }
    let removed = ptr_load(ptr_add(self.data, index));
    ptr_store(ptr_add(self.states, index), 2);
    self.len = self.len - 1;
    return std::Some<std::string::String>(removed);
  }

  fn remove_bytes(self: ref mut Self, value: std::Slice[u8]) -> bool {
    let removed = self.take_bytes(value);
    match removed {
      std::Some(found) => {
        drop found;
        return true;
      }
      std::None => {
        return false;
      }
    }
  }
}

impl[T] std::Iterator[T] for std::collections::HashSetIter[T] {
  pub fn next(self: ref mut Self) -> std::Option[T] {
    let bucket = next_live_bucket(self.states, self.capacity, self.index);
    if bucket < 0 {
      return std::None<T>();
    }
    self.index = bucket + 1;
    return std::Some<T>(ptr_load(ptr_add(self.data, bucket)));
  }
}

impl[T] std::Iterator[T] for std::collections::HashSetDrain[T] {
  pub fn next(self: ref mut Self) -> std::Option[T] {
    let bucket = next_drain_bucket(self.states, self.capacity, self.index);
    if bucket < 0 {
      return std::None<T>();
    }
    self.index = bucket + 1;
    ptr_store(ptr_add(self.states, bucket), 0);
    return std::Some<T>(ptr_load(ptr_add(self.data, bucket)));
  }
}

impl[T] std::Drop for std::collections::HashSetDrain[T] {
  fn drop(self) -> void {
    var cursor = self;
    var bucket = next_drain_bucket(cursor.states, cursor.capacity, cursor.index);
    while bucket >= 0 {
      let value = ptr_load(ptr_add(cursor.data, bucket));
      drop value;
      ptr_store(ptr_add(cursor.states, bucket), 0);
      bucket = next_drain_bucket(cursor.states, cursor.capacity, bucket + 1);
    }
    return;
  }
}

impl[T] std::IntoIterator[T] for std::collections::HashSet[T] {
  pub fn into_iter(self: ref mut Self) -> std::collections::HashSetIter[T] {
    return std::collections::HashSetIter<T> {
      data: self.data,
      states: self.states,
      capacity: self.capacity,
      index: 0,
    };
  }
}

impl[T] std::zone::ZoneBacked for std::collections::HashSet[T] {
  pub fn zone(self: ref Self) -> std::zone::ZoneMetadata {
    std::assert(self.capacity > 0);
    return std::zone::metadata(self.data as ptr u8);
  }
}

impl[T] std::Drop for std::collections::HashSet[T] {
  fn drop(self) -> void {
    var dropped = self;
    hash_set_drop_values<T>(ref mut dropped);
    return;
  }
}

fn normalized_tree_capacity(capacity: i64) -> i64 {
  if capacity < 8 {
    return 8;
  }
  return capacity;
}

pub fn tree_map[K, V](
  zone: ref mut Zone,
  capacity: i64,
  less: fn(K, K) -> bool
) -> std::collections::TreeMap[K, V] {
  let actual = normalized_tree_capacity(capacity);
  let keys = std::zone::alloc_array<K>(zone, actual);
  let values = std::zone::alloc_array<V>(zone, actual);
  let left = std::zone::alloc_array<i64>(zone, actual);
  let right = std::zone::alloc_array<i64>(zone, actual);
  let parent = std::zone::alloc_array<i64>(zone, actual);
  let colors = std::zone::alloc_array<i64>(zone, actual);
  return std::collections::TreeMap<K, V> {
    less: less,
    keys: keys,
    values: values,
    left: left,
    right: right,
    parent: parent,
    colors: colors,
    root: -1,
    len: 0,
    capacity: actual,
  };
}

pub fn tree_set[T](
  zone: ref mut Zone,
  capacity: i64,
  less: fn(T, T) -> bool
) -> std::collections::TreeSet[T] {
  let actual = normalized_tree_capacity(capacity);
  let data = std::zone::alloc_array<T>(zone, actual);
  let left = std::zone::alloc_array<i64>(zone, actual);
  let right = std::zone::alloc_array<i64>(zone, actual);
  let parent = std::zone::alloc_array<i64>(zone, actual);
  let colors = std::zone::alloc_array<i64>(zone, actual);
  return std::collections::TreeSet<T> {
    less: less,
    data: data,
    left: left,
    right: right,
    parent: parent,
    colors: colors,
    root: -1,
    len: 0,
    capacity: actual,
  };
}

fn tree_map_color[K, V](map: ref mut std::collections::TreeMap[K, V], node: i64) -> i64 {
  if node < 0 {
    return 0;
  }
  return ptr_load(ptr_add(map.colors, node));
}

fn tree_map_set_color[K, V](map: ref mut std::collections::TreeMap[K, V], node: i64, color: i64) -> void {
  if node >= 0 {
    ptr_store(ptr_add(map.colors, node), color);
  }
}

fn tree_map_rotate_left[K, V](map: ref mut std::collections::TreeMap[K, V], node: i64) -> void {
  let pivot = ptr_load(ptr_add(map.right, node));
  std::assert(pivot >= 0);
  ptr_store(ptr_add(map.right, node), ptr_load(ptr_add(map.left, pivot)));
  if ptr_load(ptr_add(map.left, pivot)) >= 0 {
    ptr_store(ptr_add(map.parent, ptr_load(ptr_add(map.left, pivot))), node);
  }
  ptr_store(ptr_add(map.parent, pivot), ptr_load(ptr_add(map.parent, node)));
  if ptr_load(ptr_add(map.parent, node)) < 0 {
    map.root = pivot;
  } else {
    let parent = ptr_load(ptr_add(map.parent, node));
    if node == ptr_load(ptr_add(map.left, parent)) {
      ptr_store(ptr_add(map.left, parent), pivot);
    } else {
      ptr_store(ptr_add(map.right, parent), pivot);
    }
  }
  ptr_store(ptr_add(map.left, pivot), node);
  ptr_store(ptr_add(map.parent, node), pivot);
}

fn tree_map_rotate_right[K, V](map: ref mut std::collections::TreeMap[K, V], node: i64) -> void {
  let pivot = ptr_load(ptr_add(map.left, node));
  std::assert(pivot >= 0);
  ptr_store(ptr_add(map.left, node), ptr_load(ptr_add(map.right, pivot)));
  if ptr_load(ptr_add(map.right, pivot)) >= 0 {
    ptr_store(ptr_add(map.parent, ptr_load(ptr_add(map.right, pivot))), node);
  }
  ptr_store(ptr_add(map.parent, pivot), ptr_load(ptr_add(map.parent, node)));
  if ptr_load(ptr_add(map.parent, node)) < 0 {
    map.root = pivot;
  } else {
    let parent = ptr_load(ptr_add(map.parent, node));
    if node == ptr_load(ptr_add(map.right, parent)) {
      ptr_store(ptr_add(map.right, parent), pivot);
    } else {
      ptr_store(ptr_add(map.left, parent), pivot);
    }
  }
  ptr_store(ptr_add(map.right, pivot), node);
  ptr_store(ptr_add(map.parent, node), pivot);
}

fn tree_map_left_child[K, V](map: ref mut std::collections::TreeMap[K, V], node: i64) -> i64 {
  if node < 0 {
    return -1;
  }
  return ptr_load(ptr_add(map.left, node));
}

fn tree_map_right_child[K, V](map: ref mut std::collections::TreeMap[K, V], node: i64) -> i64 {
  if node < 0 {
    return -1;
  }
  return ptr_load(ptr_add(map.right, node));
}

fn tree_map_transplant[K, V](
  map: ref mut std::collections::TreeMap[K, V],
  old_node: i64,
  new_node: i64
) -> void {
  let parent = ptr_load(ptr_add(map.parent, old_node));
  if parent < 0 {
    map.root = new_node;
  } else if old_node == ptr_load(ptr_add(map.left, parent)) {
    ptr_store(ptr_add(map.left, parent), new_node);
  } else {
    ptr_store(ptr_add(map.right, parent), new_node);
  }
  if new_node >= 0 {
    ptr_store(ptr_add(map.parent, new_node), parent);
  }
}

fn tree_map_fix_delete[K, V](
  map: ref mut std::collections::TreeMap[K, V],
  start: i64,
  start_parent: i64,
  start_is_left: bool
) -> void {
  var node = start;
  var parent = start_parent;
  var is_left = start_is_left;
  while node != map.root && tree_map_color<K, V>(map, node) == 0 {
    if parent < 0 {
      return;
    }
    if is_left {
      var right_sibling = ptr_load(ptr_add(map.right, parent));
      if tree_map_color<K, V>(map, right_sibling) == 1 {
        tree_map_set_color<K, V>(map, right_sibling, 0);
        tree_map_set_color<K, V>(map, parent, 1);
        tree_map_rotate_left<K, V>(map, parent);
        right_sibling = ptr_load(ptr_add(map.right, parent));
      }
      if tree_map_color<K, V>(map, tree_map_left_child<K, V>(map, right_sibling)) == 0 &&
         tree_map_color<K, V>(map, tree_map_right_child<K, V>(map, right_sibling)) == 0 {
        tree_map_set_color<K, V>(map, right_sibling, 1);
        node = parent;
        parent = ptr_load(ptr_add(map.parent, node));
        is_left = parent >= 0 && node == ptr_load(ptr_add(map.left, parent));
      } else {
        if tree_map_color<K, V>(map, tree_map_right_child<K, V>(map, right_sibling)) == 0 {
          tree_map_set_color<K, V>(map, tree_map_left_child<K, V>(map, right_sibling), 0);
          tree_map_set_color<K, V>(map, right_sibling, 1);
          tree_map_rotate_right<K, V>(map, right_sibling);
          right_sibling = ptr_load(ptr_add(map.right, parent));
        }
        tree_map_set_color<K, V>(map, right_sibling, tree_map_color<K, V>(map, parent));
        tree_map_set_color<K, V>(map, parent, 0);
        tree_map_set_color<K, V>(map, tree_map_right_child<K, V>(map, right_sibling), 0);
        tree_map_rotate_left<K, V>(map, parent);
        node = map.root;
        parent = -1;
      }
    } else {
      var left_sibling = ptr_load(ptr_add(map.left, parent));
      if tree_map_color<K, V>(map, left_sibling) == 1 {
        tree_map_set_color<K, V>(map, left_sibling, 0);
        tree_map_set_color<K, V>(map, parent, 1);
        tree_map_rotate_right<K, V>(map, parent);
        left_sibling = ptr_load(ptr_add(map.left, parent));
      }
      if tree_map_color<K, V>(map, tree_map_right_child<K, V>(map, left_sibling)) == 0 &&
         tree_map_color<K, V>(map, tree_map_left_child<K, V>(map, left_sibling)) == 0 {
        tree_map_set_color<K, V>(map, left_sibling, 1);
        node = parent;
        parent = ptr_load(ptr_add(map.parent, node));
        is_left = parent >= 0 && node == ptr_load(ptr_add(map.left, parent));
      } else {
        if tree_map_color<K, V>(map, tree_map_left_child<K, V>(map, left_sibling)) == 0 {
          tree_map_set_color<K, V>(map, tree_map_right_child<K, V>(map, left_sibling), 0);
          tree_map_set_color<K, V>(map, left_sibling, 1);
          tree_map_rotate_left<K, V>(map, left_sibling);
          left_sibling = ptr_load(ptr_add(map.left, parent));
        }
        tree_map_set_color<K, V>(map, left_sibling, tree_map_color<K, V>(map, parent));
        tree_map_set_color<K, V>(map, parent, 0);
        tree_map_set_color<K, V>(map, tree_map_left_child<K, V>(map, left_sibling), 0);
        tree_map_rotate_right<K, V>(map, parent);
        node = map.root;
        parent = -1;
      }
    }
  }
  tree_map_set_color<K, V>(map, node, 0);
}

fn tree_map_delete_slot[K, V](map: ref mut std::collections::TreeMap[K, V], target: i64) -> void {
  var removed = target;
  var removed_color = tree_map_color<K, V>(map, removed);
  var fix_node = -1;
  var fix_parent = -1;
  var fix_is_left = false;
  let left = ptr_load(ptr_add(map.left, target));
  let right = ptr_load(ptr_add(map.right, target));
  if left < 0 {
    fix_node = right;
    fix_parent = ptr_load(ptr_add(map.parent, target));
    if fix_parent >= 0 {
      fix_is_left = target == ptr_load(ptr_add(map.left, fix_parent));
    }
    tree_map_transplant<K, V>(map, target, right);
  } else if right < 0 {
    fix_node = left;
    fix_parent = ptr_load(ptr_add(map.parent, target));
    if fix_parent >= 0 {
      fix_is_left = target == ptr_load(ptr_add(map.left, fix_parent));
    }
    tree_map_transplant<K, V>(map, target, left);
  } else {
    removed = tree_first_node(right, map.left);
    removed_color = tree_map_color<K, V>(map, removed);
    fix_node = ptr_load(ptr_add(map.right, removed));
    if ptr_load(ptr_add(map.parent, removed)) == target {
      fix_parent = removed;
      fix_is_left = false;
      if fix_node >= 0 {
        ptr_store(ptr_add(map.parent, fix_node), removed);
      }
    } else {
      fix_parent = ptr_load(ptr_add(map.parent, removed));
      fix_is_left = removed == ptr_load(ptr_add(map.left, fix_parent));
      tree_map_transplant<K, V>(map, removed, fix_node);
      ptr_store(ptr_add(map.right, removed), right);
      ptr_store(ptr_add(map.parent, right), removed);
    }
    tree_map_transplant<K, V>(map, target, removed);
    ptr_store(ptr_add(map.left, removed), left);
    ptr_store(ptr_add(map.parent, left), removed);
    ptr_store(ptr_add(map.colors, removed), tree_map_color<K, V>(map, target));
  }
  if removed_color == 0 {
    tree_map_fix_delete<K, V>(map, fix_node, fix_parent, fix_is_left);
  }
  tree_map_set_color<K, V>(map, map.root, 0);
  ptr_store(ptr_add(map.left, target), -1);
  ptr_store(ptr_add(map.right, target), -1);
  ptr_store(ptr_add(map.parent, target), -1);
  ptr_store(ptr_add(map.colors, target), 0);
}

fn tree_map_move_last_slot[K, V](
  map: ref mut std::collections::TreeMap[K, V],
  target: i64,
  source: i64
) -> void {
  if target == source {
    return;
  }
  ptr_store(ptr_add(map.keys, target), ptr_load(ptr_add(map.keys, source)));
  ptr_store(ptr_add(map.values, target), ptr_load(ptr_add(map.values, source)));
  ptr_store(ptr_add(map.left, target), ptr_load(ptr_add(map.left, source)));
  ptr_store(ptr_add(map.right, target), ptr_load(ptr_add(map.right, source)));
  ptr_store(ptr_add(map.parent, target), ptr_load(ptr_add(map.parent, source)));
  ptr_store(ptr_add(map.colors, target), ptr_load(ptr_add(map.colors, source)));

  if map.root == source {
    map.root = target;
  }
  let parent = ptr_load(ptr_add(map.parent, target));
  if parent >= 0 {
    if ptr_load(ptr_add(map.left, parent)) == source {
      ptr_store(ptr_add(map.left, parent), target);
    }
    if ptr_load(ptr_add(map.right, parent)) == source {
      ptr_store(ptr_add(map.right, parent), target);
    }
  }
  let left = ptr_load(ptr_add(map.left, target));
  if left >= 0 {
    ptr_store(ptr_add(map.parent, left), target);
  }
  let right = ptr_load(ptr_add(map.right, target));
  if right >= 0 {
    ptr_store(ptr_add(map.parent, right), target);
  }
}

fn tree_map_fix_insert[K, V](map: ref mut std::collections::TreeMap[K, V], inserted: i64) -> void {
  var node = inserted;
  while node != map.root && tree_map_color<K, V>(map, ptr_load(ptr_add(map.parent, node))) == 1 {
    let parent = ptr_load(ptr_add(map.parent, node));
    let grand = ptr_load(ptr_add(map.parent, parent));
    if parent == ptr_load(ptr_add(map.left, grand)) {
      let left_uncle = ptr_load(ptr_add(map.right, grand));
      if tree_map_color<K, V>(map, left_uncle) == 1 {
        tree_map_set_color<K, V>(map, parent, 0);
        tree_map_set_color<K, V>(map, left_uncle, 0);
        tree_map_set_color<K, V>(map, grand, 1);
        node = grand;
      } else {
        if node == ptr_load(ptr_add(map.right, parent)) {
          node = parent;
          tree_map_rotate_left<K, V>(map, node);
        }
        let left_fixed_parent = ptr_load(ptr_add(map.parent, node));
        let left_fixed_grand = ptr_load(ptr_add(map.parent, left_fixed_parent));
        tree_map_set_color<K, V>(map, left_fixed_parent, 0);
        tree_map_set_color<K, V>(map, left_fixed_grand, 1);
        tree_map_rotate_right<K, V>(map, left_fixed_grand);
      }
    } else {
      let right_uncle = ptr_load(ptr_add(map.left, grand));
      if tree_map_color<K, V>(map, right_uncle) == 1 {
        tree_map_set_color<K, V>(map, parent, 0);
        tree_map_set_color<K, V>(map, right_uncle, 0);
        tree_map_set_color<K, V>(map, grand, 1);
        node = grand;
      } else {
        if node == ptr_load(ptr_add(map.left, parent)) {
          node = parent;
          tree_map_rotate_right<K, V>(map, node);
        }
        let right_fixed_parent = ptr_load(ptr_add(map.parent, node));
        let right_fixed_grand = ptr_load(ptr_add(map.parent, right_fixed_parent));
        tree_map_set_color<K, V>(map, right_fixed_parent, 0);
        tree_map_set_color<K, V>(map, right_fixed_grand, 1);
        tree_map_rotate_left<K, V>(map, right_fixed_grand);
      }
    }
  }
  tree_map_set_color<K, V>(map, map.root, 0);
}

fn tree_map_find_slot[K, V](map: ref std::collections::TreeMap[K, V], key: K) -> i64 {
  let less = map.less;
  var node = map.root;
  while node >= 0 {
    let node_key = ptr_load(ptr_add(map.keys, node));
    if less(key, node_key) {
      node = ptr_load(ptr_add(map.left, node));
    } else if less(node_key, key) {
      node = ptr_load(ptr_add(map.right, node));
    } else {
      return node;
    }
  }
  return -1;
}

fn tree_map_find_slot_mut[K, V](map: ref mut std::collections::TreeMap[K, V], key: K) -> i64 {
  let less = map.less;
  var node = map.root;
  while node >= 0 {
    let node_key = ptr_load(ptr_add(map.keys, node));
    if less(key, node_key) {
      node = ptr_load(ptr_add(map.left, node));
    } else if less(node_key, key) {
      node = ptr_load(ptr_add(map.right, node));
    } else {
      return node;
    }
  }
  return -1;
}

fn tree_map_lower_bound_node[K, V](map: ref std::collections::TreeMap[K, V], key: K) -> i64 {
  let less = map.less;
  var node = map.root;
  var best = -1;
  while node >= 0 {
    let node_key = ptr_load(ptr_add(map.keys, node));
    if less(node_key, key) {
      node = ptr_load(ptr_add(map.right, node));
    } else {
      best = node;
      node = ptr_load(ptr_add(map.left, node));
    }
  }
  return best;
}

fn tree_map_lower_bound_node_mut[K, V](map: ref mut std::collections::TreeMap[K, V], key: K) -> i64 {
  let less = map.less;
  var node = map.root;
  var best = -1;
  while node >= 0 {
    let node_key = ptr_load(ptr_add(map.keys, node));
    if less(node_key, key) {
      node = ptr_load(ptr_add(map.right, node));
    } else {
      best = node;
      node = ptr_load(ptr_add(map.left, node));
    }
  }
  return best;
}

fn tree_map_upper_bound_node[K, V](map: ref std::collections::TreeMap[K, V], key: K) -> i64 {
  let less = map.less;
  var node = map.root;
  var best = -1;
  while node >= 0 {
    let node_key = ptr_load(ptr_add(map.keys, node));
    if less(key, node_key) {
      best = node;
      node = ptr_load(ptr_add(map.left, node));
    } else {
      node = ptr_load(ptr_add(map.right, node));
    }
  }
  return best;
}

fn tree_map_link_existing_node[K, V](map: ref mut std::collections::TreeMap[K, V], index: i64) -> void {
  let less = map.less;
  var parent = -1;
  var node = map.root;
  var place_left = false;
  let key = ptr_load(ptr_add(map.keys, index));
  ptr_store(ptr_add(map.left, index), -1);
  ptr_store(ptr_add(map.right, index), -1);
  ptr_store(ptr_add(map.parent, index), -1);
  ptr_store(ptr_add(map.colors, index), 1);
  while node >= 0 {
    parent = node;
    let node_key = ptr_load(ptr_add(map.keys, node));
    if less(key, node_key) {
      node = ptr_load(ptr_add(map.left, node));
      place_left = true;
    } else {
      node = ptr_load(ptr_add(map.right, node));
      place_left = false;
    }
  }
  ptr_store(ptr_add(map.parent, index), parent);
  if parent < 0 {
    map.root = index;
  } else if place_left {
    ptr_store(ptr_add(map.left, parent), index);
  } else {
    ptr_store(ptr_add(map.right, parent), index);
  }
  tree_map_fix_insert<K, V>(map, index);
}

fn tree_first_node(root: i64, left: ptr i64) -> i64 {
  var node = root;
  if node < 0 {
    return -1;
  }
  while ptr_load(ptr_add(left, node)) >= 0 {
    node = ptr_load(ptr_add(left, node));
  }
  return node;
}

fn tree_last_node(root: i64, right: ptr i64) -> i64 {
  var node = root;
  if node < 0 {
    return -1;
  }
  while ptr_load(ptr_add(right, node)) >= 0 {
    node = ptr_load(ptr_add(right, node));
  }
  return node;
}

fn tree_next_node(node: i64, left: ptr i64, right: ptr i64, parent: ptr i64) -> i64 {
  if node < 0 {
    return -1;
  }
  let right_child = ptr_load(ptr_add(right, node));
  if right_child >= 0 {
    return tree_first_node(right_child, left);
  }

  var child = node;
  var ancestor = ptr_load(ptr_add(parent, child));
  while ancestor >= 0 && child == ptr_load(ptr_add(right, ancestor)) {
    child = ancestor;
    ancestor = ptr_load(ptr_add(parent, ancestor));
  }
  return ancestor;
}

fn tree_map_grow_to_capacity[K, V](
  map: ref mut std::collections::TreeMap[K, V],
  capacity: i64
) -> void {
  let actual = normalized_tree_capacity(capacity);
  if actual <= map.capacity {
    return;
  }
  let old_keys = map.keys;
  let old_values = map.values;
  let old_left = map.left;
  let old_right = map.right;
  let old_parent = map.parent;
  let old_colors = map.colors;
  let metadata = map.zone();
  let new_keys = metadata.alloc_array<K>(actual);
  let new_values = metadata.alloc_array<V>(actual);
  let new_left = metadata.alloc_array<i64>(actual);
  let new_right = metadata.alloc_array<i64>(actual);
  let new_parent = metadata.alloc_array<i64>(actual);
  let new_colors = metadata.alloc_array<i64>(actual);
  var index = 0;
  while index < map.len {
    ptr_store(ptr_add(new_keys, index), ptr_load(ptr_add(old_keys, index)));
    ptr_store(ptr_add(new_values, index), ptr_load(ptr_add(old_values, index)));
    ptr_store(ptr_add(new_left, index), ptr_load(ptr_add(old_left, index)));
    ptr_store(ptr_add(new_right, index), ptr_load(ptr_add(old_right, index)));
    ptr_store(ptr_add(new_parent, index), ptr_load(ptr_add(old_parent, index)));
    ptr_store(ptr_add(new_colors, index), ptr_load(ptr_add(old_colors, index)));
    index = index + 1;
  }
  map.keys = new_keys;
  map.values = new_values;
  map.left = new_left;
  map.right = new_right;
  map.parent = new_parent;
  map.colors = new_colors;
  map.capacity = actual;
}

fn tree_map_insert_absent_slot[K, V](
  map: ref mut std::collections::TreeMap[K, V],
  key: K,
  value: V
) -> i64 {
  if map.len >= map.capacity {
    tree_map_grow_to_capacity<K, V>(map, map.capacity * 2);
  }

  let less = map.less;
  var parent = -1;
  var node = map.root;
  var place_left = false;
  while node >= 0 {
    parent = node;
    let node_key = ptr_load(ptr_add(map.keys, node));
    if less(key, node_key) {
      node = ptr_load(ptr_add(map.left, node));
      place_left = true;
    } else if less(node_key, key) {
      node = ptr_load(ptr_add(map.right, node));
      place_left = false;
    } else {
      std::assert(false);
      return node;
    }
  }

  let index = map.len;
  ptr_store(ptr_add(map.keys, index), key);
  ptr_store(ptr_add(map.values, index), value);
  ptr_store(ptr_add(map.left, index), -1);
  ptr_store(ptr_add(map.right, index), -1);
  ptr_store(ptr_add(map.parent, index), parent);
  ptr_store(ptr_add(map.colors, index), 1);
  if parent < 0 {
    map.root = index;
  } else if place_left {
    ptr_store(ptr_add(map.left, parent), index);
  } else {
    ptr_store(ptr_add(map.right, parent), index);
  }
  map.len = map.len + 1;
  tree_map_fix_insert<K, V>(map, index);
  return index;
}

fn tree_map_insert_or_replace_drop[K, V](
  map: ref mut std::collections::TreeMap[K, V],
  key: K,
  value: V
) -> void {
  let existing = tree_map_find_slot_mut<K, V>(map, key);
  if existing >= 0 {
    let old_key = ptr_load(ptr_add(map.keys, existing));
    let previous = ptr_load(ptr_add(map.values, existing));
    drop old_key;
    drop previous;
    ptr_store(ptr_add(map.keys, existing), key);
    ptr_store(ptr_add(map.values, existing), value);
    return;
  }
  tree_map_insert_absent_slot<K, V>(map, key, value);
}

fn tree_map_drop_values[K, V](map: ref mut std::collections::TreeMap[K, V]) -> void {
  var index = 0;
  while index < map.len {
    let key = ptr_load(ptr_add(map.keys, index));
    let value = ptr_load(ptr_add(map.values, index));
    drop key;
    drop value;
    index = index + 1;
  }
  map.root = -1;
  map.len = 0;
}

pub impl[K, V] std::collections::TreeMap[K, V] {
  fn with_less(
    zone: ref mut Zone,
    capacity: i64,
    less: fn(K, K) -> bool
  ) -> std::collections::TreeMap[K, V] {
    return std::collections::tree_map<K, V>(zone, capacity, less);
  }

  fn from_iter[I: std::Iterator[std::collections::MapEntry[K, V]]](
    zone: ref mut Zone,
    capacity: i64,
    less: fn(K, K) -> bool,
    iter: I
  ) -> std::collections::TreeMap[K, V] {
    var output = std::collections::tree_map<K, V>(zone, capacity, less);
    output.extend_iter<I>(iter);
    return output;
  }

  fn len(self: ref Self) -> i64 {
    return self.len;
  }

  fn capacity(self: ref Self) -> i64 {
    return self.capacity;
  }

  fn is_empty(self: ref Self) -> bool {
    return self.len == 0;
  }

  fn contains(self: ref Self, key: K) -> bool {
    return tree_map_find_slot<K, V>(self, key) >= 0;
  }

  fn contains_key(self: ref Self, key: K) -> bool {
    return self.contains(key);
  }

  fn contains_value(self: ref Self, value: V) -> bool {
    var index = 0;
    while index < self.len {
      if ptr_load(ptr_add(self.values, index)) == value {
        return true;
      }
      index = index + 1;
    }
    return false;
  }

  fn first_key(self: ref Self) -> K {
    let node = tree_first_node(self.root, self.left);
    std::assert(node >= 0);
    return ptr_load(ptr_add(self.keys, node));
  }

  fn try_first_key(self: ref Self) -> std::Option[K] {
    let node = tree_first_node(self.root, self.left);
    if node < 0 {
      return std::None<K>();
    }
    return std::Some<K>(ptr_load(ptr_add(self.keys, node)));
  }

  fn last_key(self: ref Self) -> K {
    let node = tree_last_node(self.root, self.right);
    std::assert(node >= 0);
    return ptr_load(ptr_add(self.keys, node));
  }

  fn try_last_key(self: ref Self) -> std::Option[K] {
    let node = tree_last_node(self.root, self.right);
    if node < 0 {
      return std::None<K>();
    }
    return std::Some<K>(ptr_load(ptr_add(self.keys, node)));
  }

  fn first_value(self: ref Self) -> V {
    let node = tree_first_node(self.root, self.left);
    std::assert(node >= 0);
    return ptr_load(ptr_add(self.values, node));
  }

  fn try_first_value(self: ref Self) -> std::Option[V] {
    let node = tree_first_node(self.root, self.left);
    if node < 0 {
      return std::None<V>();
    }
    return std::Some<V>(ptr_load(ptr_add(self.values, node)));
  }

  fn first_entry(self: ref Self) -> std::collections::MapEntry[K, V] {
    let node = tree_first_node(self.root, self.left);
    std::assert(node >= 0);
    return std::collections::MapEntry<K, V> {
      key: ptr_load(ptr_add(self.keys, node)),
      value: ptr_load(ptr_add(self.values, node)),
    };
  }

  fn try_first_entry(self: ref Self) -> std::Option[std::collections::MapEntry[K, V]] {
    let node = tree_first_node(self.root, self.left);
    if node < 0 {
      return std::None<std::collections::MapEntry[K, V]>();
    }
    return std::Some<std::collections::MapEntry[K, V]>(
      std::collections::MapEntry<K, V> {
        key: ptr_load(ptr_add(self.keys, node)),
        value: ptr_load(ptr_add(self.values, node)),
      }
    );
  }

  fn last_value(self: ref Self) -> V {
    let node = tree_last_node(self.root, self.right);
    std::assert(node >= 0);
    return ptr_load(ptr_add(self.values, node));
  }

  fn try_last_value(self: ref Self) -> std::Option[V] {
    let node = tree_last_node(self.root, self.right);
    if node < 0 {
      return std::None<V>();
    }
    return std::Some<V>(ptr_load(ptr_add(self.values, node)));
  }

  fn last_entry(self: ref Self) -> std::collections::MapEntry[K, V] {
    let node = tree_last_node(self.root, self.right);
    std::assert(node >= 0);
    return std::collections::MapEntry<K, V> {
      key: ptr_load(ptr_add(self.keys, node)),
      value: ptr_load(ptr_add(self.values, node)),
    };
  }

  fn try_last_entry(self: ref Self) -> std::Option[std::collections::MapEntry[K, V]] {
    let node = tree_last_node(self.root, self.right);
    if node < 0 {
      return std::None<std::collections::MapEntry[K, V]>();
    }
    return std::Some<std::collections::MapEntry[K, V]>(
      std::collections::MapEntry<K, V> {
        key: ptr_load(ptr_add(self.keys, node)),
        value: ptr_load(ptr_add(self.values, node)),
      }
    );
  }

  fn pop_first(self: ref mut Self) -> std::Option[std::collections::MapEntry[K, V]] {
    let node = tree_first_node(self.root, self.left);
    if node < 0 {
      return std::None<std::collections::MapEntry[K, V]>();
    }
    let removed_key = ptr_load(ptr_add(self.keys, node));
    let removed_value = ptr_load(ptr_add(self.values, node));
    let last = self.len - 1;
    tree_map_delete_slot<K, V>(self, node);
    tree_map_move_last_slot<K, V>(self, node, last);
    self.len = last;
    return std::Some<std::collections::MapEntry[K, V]>(
      std::collections::MapEntry<K, V> {
        key: removed_key,
        value: removed_value,
      }
    );
  }

  fn pop_last(self: ref mut Self) -> std::Option[std::collections::MapEntry[K, V]] {
    let node = tree_last_node(self.root, self.right);
    if node < 0 {
      return std::None<std::collections::MapEntry[K, V]>();
    }
    let removed_key = ptr_load(ptr_add(self.keys, node));
    let removed_value = ptr_load(ptr_add(self.values, node));
    let last = self.len - 1;
    tree_map_delete_slot<K, V>(self, node);
    tree_map_move_last_slot<K, V>(self, node, last);
    self.len = last;
    return std::Some<std::collections::MapEntry[K, V]>(
      std::collections::MapEntry<K, V> {
        key: removed_key,
        value: removed_value,
      }
    );
  }

  fn try_get(self: ref Self, key: K) -> std::Option[V] {
    let index = tree_map_find_slot<K, V>(self, key);
    if index < 0 {
      return std::None<V>();
    }
    return std::Some<V>(ptr_load(ptr_add(self.values, index)));
  }

  fn try_get_mut(self: ref mut Self, key: K) -> std::Option[std::collections::MapValueMut[V]] {
    let index = tree_map_find_slot_mut<K, V>(self, key);
    if index < 0 {
      return std::None<std::collections::MapValueMut[V]>();
    }
    return std::Some<std::collections::MapValueMut[V]>(
      std::collections::MapValueMut<V> {
        value: ptr_add(self.values, index),
      }
    );
  }

  fn get_or(self: ref Self, key: K, fallback: V) -> V {
    return self.try_get(key).unwrap_or(fallback);
  }

  fn get(self: ref Self, key: K) -> V {
    let index = tree_map_find_slot<K, V>(self, key);
    std::assert(index >= 0);
    return ptr_load(ptr_add(self.values, index));
  }

  fn get_mut(self: ref mut Self, key: K) -> ref mut V {
    let index = tree_map_find_slot_mut<K, V>(self, key);
    std::assert(index >= 0);
    return ref mut *ptr_add(self.values, index);
  }

  fn lower_bound(self: ref Self, key: K) -> std::Option[std::collections::MapEntry[K, V]] {
    let node = tree_map_lower_bound_node<K, V>(self, key);
    if node < 0 {
      return std::None<std::collections::MapEntry[K, V]>();
    }
    return std::Some<std::collections::MapEntry[K, V]>(
      std::collections::MapEntry<K, V> {
        key: ptr_load(ptr_add(self.keys, node)),
        value: ptr_load(ptr_add(self.values, node)),
      }
    );
  }

  fn upper_bound(self: ref Self, key: K) -> std::Option[std::collections::MapEntry[K, V]] {
    let node = tree_map_upper_bound_node<K, V>(self, key);
    if node < 0 {
      return std::None<std::collections::MapEntry[K, V]>();
    }
    return std::Some<std::collections::MapEntry[K, V]>(
      std::collections::MapEntry<K, V> {
        key: ptr_load(ptr_add(self.keys, node)),
        value: ptr_load(ptr_add(self.values, node)),
      }
    );
  }

  fn range(self: ref Self, start: K, end: K) -> std::collections::TreeMapRange[K, V] {
    return std::collections::TreeMapRange<K, V> {
      keys: self.keys,
      values: self.values,
      left: self.left,
      right: self.right,
      parent: self.parent,
      end: end,
      less: self.less,
      current: tree_map_lower_bound_node<K, V>(self, start),
    };
  }

  fn range_mut(self: ref mut Self, start: K, end: K) -> std::collections::TreeMapRangeMut[K, V] {
    let map_ref: ref std::collections::TreeMap[K, V] =
      ref *(self as ptr std::collections::TreeMap[K, V]);
    return std::collections::TreeMapRangeMut<K, V> {
      keys: self.keys,
      values: self.values,
      left: self.left,
      right: self.right,
      parent: self.parent,
      end: end,
      less: self.less,
      current: tree_map_lower_bound_node<K, V>(map_ref, start),
    };
  }

  fn insert(self: ref mut Self, zone: ref mut Zone, key: K, value: V) -> std::Option[V] {
    let existing = tree_map_find_slot_mut<K, V>(self, key);
    if existing >= 0 {
      let old_key = ptr_load(ptr_add(self.keys, existing));
      let previous = ptr_load(ptr_add(self.values, existing));
      drop old_key;
      ptr_store(ptr_add(self.keys, existing), key);
      ptr_store(ptr_add(self.values, existing), value);
      return std::Some<V>(previous);
    }
    tree_map_insert_absent_slot<K, V>(self, key, value);
    return std::None<V>();
  }

  fn replace(self: ref mut Self, zone: ref mut Zone, key: K, value: V) -> std::Option[V] {
    return self.insert(zone, key, value);
  }

  fn entry(self: ref mut Self, zone: ref mut Zone, key: K) -> std::collections::TreeMapEntry[K, V] {
    return std::collections::TreeMapEntry<K, V> {
      map: self as ptr std::collections::TreeMap[K, V],
      key: key,
    };
  }

  fn remove(self: ref mut Self, key: K) -> std::Option[V] {
    let index = tree_map_find_slot_mut<K, V>(self, key);
    if index < 0 {
      return std::None<V>();
    }
    let removed_key = ptr_load(ptr_add(self.keys, index));
    let removed_value = ptr_load(ptr_add(self.values, index));
    let last = self.len - 1;
    drop removed_key;
    tree_map_delete_slot<K, V>(self, index);
    tree_map_move_last_slot<K, V>(self, index, last);
    self.len = last;
    return std::Some<V>(removed_value);
  }

  fn remove_entry(self: ref mut Self, key: K) -> std::Option[std::collections::MapEntry[K, V]] {
    let index = tree_map_find_slot_mut<K, V>(self, key);
    if index < 0 {
      return std::None<std::collections::MapEntry[K, V]>();
    }
    let removed_key = ptr_load(ptr_add(self.keys, index));
    let removed_value = ptr_load(ptr_add(self.values, index));
    let last = self.len - 1;
    tree_map_delete_slot<K, V>(self, index);
    tree_map_move_last_slot<K, V>(self, index, last);
    self.len = last;
    return std::Some<std::collections::MapEntry[K, V]>(
      std::collections::MapEntry<K, V> {
        key: removed_key,
        value: removed_value,
      }
    );
  }

  fn split_off(self: ref mut Self, zone: ref mut Zone, start: K) -> std::collections::TreeMap[K, V] {
    var output = std::collections::tree_map<K, V>(zone, self.len, self.less);
    var node = tree_map_lower_bound_node_mut<K, V>(self, start);
    while node >= 0 {
      let moved_key = ptr_load(ptr_add(self.keys, node));
      let moved_value = ptr_load(ptr_add(self.values, node));
      let last = self.len - 1;
      tree_map_delete_slot<K, V>(self, node);
      tree_map_move_last_slot<K, V>(self, node, last);
      self.len = last;
      tree_map_insert_absent_slot<K, V>(ref mut output, moved_key, moved_value);
      node = tree_map_lower_bound_node_mut<K, V>(self, start);
    }
    return output;
  }

  fn append(self: ref mut Self, zone: ref mut Zone, other: ref mut std::collections::TreeMap[K, V]) -> void {
    var item = other.pop_first();
    while item.is_some() {
      let entry = item.unwrap();
      tree_map_insert_or_replace_drop<K, V>(self, entry.key, entry.value);
      item = other.pop_first();
    }
  }

  fn extend_iter[I: std::Iterator[std::collections::MapEntry[K, V]]](self: ref mut Self, iter: I) -> void {
    var cursor = iter;
    var item = cursor.next();
    while item.is_some() {
      let entry = item.unwrap();
      tree_map_insert_or_replace_drop<K, V>(self, entry.key, entry.value);
      item = cursor.next();
    }
  }

  fn extend[I: std::Iterator[std::collections::MapEntry[K, V]]](self: ref mut Self, iter: I) -> void {
    self.extend_iter<I>(iter);
  }

  fn clear(self: ref mut Self) -> void {
    tree_map_drop_values<K, V>(self);
  }

  fn reserve(self: ref mut Self, zone: ref mut Zone, capacity: i64) -> void {
    tree_map_grow_to_capacity<K, V>(self, capacity);
  }

  fn reserve_extra(self: ref mut Self, zone: ref mut Zone, additional: i64) -> void {
    std::assert(additional >= 0);
    tree_map_grow_to_capacity<K, V>(self, self.len + additional);
  }

  fn copy_to(self: ref Self, target: ref mut Zone) -> std::collections::TreeMap[K, V] {
    var copied = std::collections::tree_map<K, V>(target, self.len, self.less);
    var index = 0;
    while index < self.len {
      copied.insert(
        target,
        ptr_load(ptr_add(self.keys, index)),
        ptr_load(ptr_add(self.values, index))
      );
      index = index + 1;
    }
    return copied;
  }

  fn keys(self: ref Self) -> std::collections::TreeMapKeys[K] {
    return std::collections::TreeMapKeys<K> {
      keys: self.keys,
      left: self.left,
      right: self.right,
      parent: self.parent,
      current: tree_first_node(self.root, self.left),
    };
  }

  fn values(self: ref Self) -> std::collections::TreeMapValues[V] {
    return std::collections::TreeMapValues<V> {
      values: self.values,
      left: self.left,
      right: self.right,
      parent: self.parent,
      current: tree_first_node(self.root, self.left),
    };
  }

  fn values_mut(self: ref mut Self) -> std::collections::TreeMapValuesMut[V] {
    return std::collections::TreeMapValuesMut<V> {
      values: self.values,
      left: self.left,
      right: self.right,
      parent: self.parent,
      current: tree_first_node(self.root, self.left),
    };
  }

  fn entries(self: ref Self) -> std::collections::TreeMapEntries[K, V] {
    return std::collections::TreeMapEntries<K, V> {
      keys: self.keys,
      values: self.values,
      left: self.left,
      right: self.right,
      parent: self.parent,
      current: tree_first_node(self.root, self.left),
    };
  }

  fn iter(self: ref Self) -> std::collections::TreeMapEntries[K, V] {
    return self.entries();
  }

  fn iter_mut(self: ref mut Self) -> std::collections::TreeMapEntriesMut[K, V] {
    return std::collections::TreeMapEntriesMut<K, V> {
      keys: self.keys,
      values: self.values,
      left: self.left,
      right: self.right,
      parent: self.parent,
      current: tree_first_node(self.root, self.left),
    };
  }

  fn drain(self: ref mut Self) -> std::collections::TreeMapDrain[K, V] {
    let old_len = self.len;
    let first = tree_first_node(self.root, self.left);
    self.root = -1;
    self.len = 0;
    return std::collections::TreeMapDrain<K, V> {
      keys: self.keys,
      values: self.values,
      left: self.left,
      right: self.right,
      parent: self.parent,
      colors: self.colors,
      len: old_len,
      current: first,
    };
  }
}

pub impl[K: std::cmp::Ord[K], V] std::collections::TreeMap[K, V] {
  fn new(
    zone: ref mut Zone
  ) -> std::collections::TreeMap[K, V] {
    return std::collections::TreeMap::with_capacity<K, V>(zone, 4);
  }

  fn with_capacity(
    zone: ref mut Zone,
    capacity: i64
  ) -> std::collections::TreeMap[K, V] {
    let less: fn(K, K) -> bool = std::collections::default_less;
    return std::collections::tree_map<K, V>(
      zone,
      capacity,
      less
    );
  }
}

pub impl[K, V] std::collections::TreeMapEntry[K, V] {
  fn and_modify(self, op: fn(ref mut V) -> void) -> Self {
    let map: ref mut std::collections::TreeMap[K, V] = ref mut *self.map;
    let index = tree_map_find_slot_mut<K, V>(map, self.key);
    if index >= 0 {
      op(ref mut *ptr_add(map.values, index));
    }
    return self;
  }

  fn key(self: ref Self) -> K {
    return self.key;
  }

  fn value(self: ref Self) -> V {
    let map: ref std::collections::TreeMap[K, V] = ref *self.map;
    let index = tree_map_find_slot<K, V>(map, self.key);
    std::assert(index >= 0);
    return ptr_load(ptr_add(map.values, index));
  }

  fn value_mut(self: ref mut Self) -> ref mut V {
    let map: ref mut std::collections::TreeMap[K, V] = ref mut *self.map;
    let index = tree_map_find_slot_mut<K, V>(map, self.key);
    std::assert(index >= 0);
    return ref mut *ptr_add(map.values, index);
  }

  fn insert(self: ref mut Self, value: V) -> std::Option[V] {
    let map: ref mut std::collections::TreeMap[K, V] = ref mut *self.map;
    let existing = tree_map_find_slot_mut<K, V>(map, self.key);
    if existing >= 0 {
      let previous = ptr_load(ptr_add(map.values, existing));
      ptr_store(ptr_add(map.values, existing), value);
      return std::Some<V>(previous);
    }

    tree_map_insert_absent_slot<K, V>(map, self.key, value);
    return std::None<V>();
  }

  fn insert_entry(self, value: V) -> Self {
    let map_ptr = self.map;
    let key = self.key;
    {
      let map: ref mut std::collections::TreeMap[K, V] = ref mut *map_ptr;
      let existing = tree_map_find_slot_mut<K, V>(map, key);
      if existing >= 0 {
        let previous = ptr_load(ptr_add(map.values, existing));
        drop previous;
        ptr_store(ptr_add(map.values, existing), value);
      } else {
        tree_map_insert_absent_slot<K, V>(map, key, value);
      }
    }
    return std::collections::TreeMapEntry<K, V> {
      map: map_ptr,
      key: key,
    };
  }

  fn remove(self: ref mut Self) -> std::Option[V] {
    let map: ref mut std::collections::TreeMap[K, V] = ref mut *self.map;
    return map.remove(self.key);
  }

  fn or_insert(self: ref mut Self, value: V) -> ref mut V {
    let map: ref mut std::collections::TreeMap[K, V] = ref mut *self.map;
    let existing = tree_map_find_slot_mut<K, V>(map, self.key);
    if existing >= 0 {
      return ref mut *ptr_add(map.values, existing);
    }

    let inserted = tree_map_insert_absent_slot<K, V>(map, self.key, value);
    return ref mut *ptr_add(map.values, inserted);
  }

  fn or_insert_with(self: ref mut Self, make_value: fn() -> V) -> ref mut V {
    let map: ref mut std::collections::TreeMap[K, V] = ref mut *self.map;
    let existing = tree_map_find_slot_mut<K, V>(map, self.key);
    if existing >= 0 {
      return ref mut *ptr_add(map.values, existing);
    }

    let inserted = tree_map_insert_absent_slot<K, V>(map, self.key, make_value());
    return ref mut *ptr_add(map.values, inserted);
  }
}

pub impl[K, V: std::Default] std::collections::TreeMapEntry[K, V] {
  fn or_default(self: ref mut Self) -> ref mut V {
    let map: ref mut std::collections::TreeMap[K, V] = ref mut *self.map;
    let existing = tree_map_find_slot_mut<K, V>(map, self.key);
    if existing >= 0 {
      return ref mut *ptr_add(map.values, existing);
    }

    let inserted = tree_map_insert_absent_slot<K, V>(
      map,
      self.key,
      std::Default::default<V>()
    );
    return ref mut *ptr_add(map.values, inserted);
  }
}

impl[K, V] std::zone::ZoneBacked for std::collections::TreeMapEntry[K, V] {
  pub fn zone(self: ref Self) -> std::zone::ZoneMetadata {
    let map: ref std::collections::TreeMap[K, V] = ref *self.map;
    return map.zone();
  }
}

impl[K] std::Iterator[K] for std::collections::TreeMapKeys[K] {
  pub fn next(self: ref mut Self) -> std::Option[K] {
    if self.current < 0 {
      return std::None<K>();
    }
    let node = self.current;
    self.current = tree_next_node(node, self.left, self.right, self.parent);
    return std::Some<K>(ptr_load(ptr_add(self.keys, node)));
  }
}

impl[V] std::Iterator[V] for std::collections::TreeMapValues[V] {
  pub fn next(self: ref mut Self) -> std::Option[V] {
    if self.current < 0 {
      return std::None<V>();
    }
    let node = self.current;
    self.current = tree_next_node(node, self.left, self.right, self.parent);
    return std::Some<V>(ptr_load(ptr_add(self.values, node)));
  }
}

pub impl[V] std::collections::TreeMapValuesMut[V] {
  fn has_next(self: ref Self) -> bool {
    return self.current >= 0;
  }

  fn next(self: ref mut Self) -> ref mut V {
    std::assert(self.current >= 0);
    let node = self.current;
    self.current = tree_next_node(node, self.left, self.right, self.parent);
    return ref mut *ptr_add(self.values, node);
  }
}

impl[K, V] std::Iterator[std::collections::MapEntry[K, V]] for std::collections::TreeMapEntries[K, V] {
  pub fn next(self: ref mut Self) -> std::Option[std::collections::MapEntry[K, V]] {
    if self.current < 0 {
      return std::None<std::collections::MapEntry[K, V]>();
    }
    let node = self.current;
    self.current = tree_next_node(node, self.left, self.right, self.parent);
    return std::Some<std::collections::MapEntry[K, V]>(
      std::collections::MapEntry<K, V> {
        key: ptr_load(ptr_add(self.keys, node)),
        value: ptr_load(ptr_add(self.values, node)),
      }
    );
  }
}

