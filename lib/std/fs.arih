}

pub fn open_write_unchecked(path: ref std::string::String) -> File {
  return open_unchecked_bytes(path.as_slice(), std::string::bytes("w"));
}

pub fn open_write(path: ref std::string::String) -> std::Result[File, std::error::Error] {
