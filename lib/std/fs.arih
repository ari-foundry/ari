pub fn open_read_optional(path: ref std::string::String) -> std::Option[File] {
  let file = open_read_unchecked(path);
  if file.is_open() {
    return std::Some<File>(file);
  }
  return std::None<File>();
}

pub fn open_write_optional(path: ref std::string::String) -> std::Option[File] {
  let file = open_write_unchecked(path);
  if file.is_open() {
    return std::Some<File>(file);
  }
  return std::None<File>();
