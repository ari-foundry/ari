pub fn close_dir_raw(dir: Dir) -> std::Result[(), i64] {
  if !dir.is_open() {
    return std::Err<(), i64>(invalid_input_error_raw());
  }
  return unit_raw(close_dir_unchecked(dir));
}

pub fn close_dir(dir: Dir) -> std::Result[(), std::error::Error] {
  return std::error::map_raw<()>(close_dir_raw(dir));
}

fn metadata_from_parts(
  kind: i64,
  size: i64,
  permissions: Permissions,
  accessed_nanos: i64,
  modified_nanos: i64,
  changed_nanos: i64,
  owner_id: i64,
  group_id: i64
) -> std::Option[Metadata] {
  if kind < 0 || size < 0 || accessed_nanos < 0 || modified_nanos < 0 || changed_nanos < 0 ||
     owner_id < 0 || group_id < 0 {
    return std::None<Metadata>();
  }
  return std::Some<Metadata>(Metadata {
    byte_len: size,
    kind: file_kind_from_raw(kind),
    permissions: permissions,
    accessed_at: system_time_from_nanos(accessed_nanos),
    modified_at: system_time_from_nanos(modified_nanos),
    changed_at: system_time_from_nanos(changed_nanos),
    owner_id_value: owner_id,
    group_id_value: group_id,
  });
}

fn metadata_from_raw(
  path: ref std::string::String,
  kind: i64,
  size: i64,
  accessed_nanos: i64,
  modified_nanos: i64,
  changed_nanos: i64,
  owner_id: i64,
  group_id: i64
) -> std::Option[Metadata] {
  return metadata_from_parts(
    kind,
    size,
    permissions(path),
    accessed_nanos,
    modified_nanos,
    changed_nanos,
    owner_id,
    group_id
  );
}

fn permissions_bytes(path: std::Slice[u8]) -> Permissions {
  return Permissions {
    readable: can_read_bytes_raw(path.data, path.len),
    writable: can_write_bytes_raw(path.data, path.len),
    executable: can_execute_bytes_raw(path.data, path.len),
  };
}

fn metadata_from_bytes(
  path: std::Slice[u8],
  kind: i64,
  size: i64,
  accessed_nanos: i64,
  modified_nanos: i64,
  changed_nanos: i64,
  owner_id: i64,
  group_id: i64
) -> std::Option[Metadata] {
  return metadata_from_parts(
    kind,
    size,
    permissions_bytes(path),
    accessed_nanos,
    modified_nanos,
    changed_nanos,
    owner_id,
    group_id
  );
}

pub fn metadata_raw(path: ref std::string::String) -> std::Result[Metadata, i64] {
  return metadata_bytes_raw(path.as_slice());
}

pub fn metadata(path: ref std::string::String) -> std::Result[Metadata, std::error::Error] {
  return std::error::map_raw<Metadata>(metadata_raw(path));
}

pub fn metadata_optional(path: ref std::string::String) -> std::Option[Metadata] {
  match metadata(path) {
    std::Ok(value) => {
      return std::Some<Metadata>(value);
    }
    std::Err(_) => {}
  }
  return std::None<Metadata>();
}

pub fn try_metadata(path: ref std::string::String) -> std::Option[Metadata] {
  return metadata_optional(path);
}

pub fn metadata_unchecked(path: ref std::string::String) -> Metadata {
  match metadata(path) {
    std::Ok(value) => {
      return value;
    }
    std::Err(_) => {}
  }
  std::panic();
  return Metadata {
    byte_len: 0,
    kind: Other,
    permissions: Permissions::none(),
    accessed_at: std::time::system_from_unix(0, 0),
    modified_at: std::time::system_from_unix(0, 0),
    changed_at: std::time::system_from_unix(0, 0),
    owner_id_value: -1,
    group_id_value: -1,
  };
}

pub fn symlink_metadata_raw(path: ref std::string::String) -> std::Result[Metadata, i64] {
  return symlink_metadata_bytes_raw(path.as_slice());
}

pub fn symlink_metadata(path: ref std::string::String) -> std::Result[Metadata, std::error::Error] {
  return std::error::map_raw<Metadata>(symlink_metadata_raw(path));
