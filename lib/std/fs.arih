// Small filesystem helpers.
//
// The first std::fs slice keeps the OS boundary explicit: Ari source owns the
// handle shape and Option helpers, while the runtime owns platform syscalls.
pub type Error = std::error::Error;
pub type ErrorKind = std::error::Kind;

pub struct File {
  fd: i64,
}

pub type TempFile = std::process::TempFile;
pub type TempDir = std::process::TempDir;

pub struct OpenOptions {
  read_enabled: bool,
  write_enabled: bool,
  append_enabled: bool,
  truncate_enabled: bool,
  create_enabled: bool,
  create_new_enabled: bool,
}

pub struct Dir {
  handle: ptr c_void,
}

pub struct DirEntry {
  name_value: std::string::String,
  path_value: std::string::String,
}

pub enum Operation {
  FsOpen,
  FsCreate,
  FsRead,
  FsWrite,
  FsAppend,
  FsCopy,
  FsRemove,
  FsRemoveDir,
  FsCreateDir,
  FsRename,
  FsMetadata,
  FsSymlinkMetadata,
  FsFileType,
  FsMode,
  FsCanonicalize,
  FsReadLink,
  FsReadDir,
  FsTempFile,
  FsTempDir,
  FsLock,
  FsUnlock,
  FsPermissions,
  FsOtherOperation,
}

pub struct PathError {
  operation_value: Operation,
  path_value: std::Slice[u8],
  reason_value: Error,
}

pub struct TwoPathError {
  operation_value: Operation,
  source_value: std::Slice[u8],
  target_value: std::Slice[u8],
  reason_value: Error,
}

pub struct DirEntryInfo {
  entry_value: DirEntry,
  metadata_result_value: std::Result[Metadata, Error],
  symlink_metadata_result_value: std::Result[Metadata, Error],
  file_type_result_value: std::Result[FileKind, Error],
}

pub struct Permissions {
  readable: bool,
  writable: bool,
  executable: bool,
}

pub enum FileKind {
  Regular,
  Directory,
  Symlink,
  Other,
}

pub struct Metadata {
  byte_len: i64,
  kind: FileKind,
  permissions: Permissions,
  accessed_at: std::time::SystemTime,
  modified_at: std::time::SystemTime,
  changed_at: std::time::SystemTime,
  owner_id_value: i64,
  group_id_value: i64,
}

