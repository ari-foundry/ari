  return unit_raw(symbolic_link_unchecked(target, link_path));
}

pub fn symbolic_link(target: ref std::string::String, link_path: ref std::string::String) -> std::Result[(), std::error::Error] {
  return std::error::map_raw<()>(symbolic_link_raw(target, link_path));
}

pub fn symbolic_link_bool(target: ref std::string::String, link_path: ref std::string::String) -> bool {
  return symbolic_link_unchecked(target, link_path);
}

pub fn create_dir_raw(path: ref std::string::String) -> std::Result[(), i64] {
  return unit_raw(create_dir_unchecked(path));
}

pub fn create_dir(path: ref std::string::String) -> std::Result[(), std::error::Error] {
  return std::error::map_raw<()>(create_dir_raw(path));
}

pub fn create_dir_bool(path: ref std::string::String) -> bool {
  return create_dir_unchecked(path);
}

pub fn create_dir_all_raw(path: ref std::string::String) -> std::Result[(), i64] {
  return unit_raw(create_dir_all_unchecked(path));
}

pub fn create_dir_all(path: ref std::string::String) -> std::Result[(), std::error::Error] {
  return std::error::map_raw<()>(create_dir_all_raw(path));
