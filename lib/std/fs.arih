pub fn try_symlink_metadata(path: ref std::string::String) -> std::Option[Metadata] {
  return symlink_metadata_optional(path);
}

pub fn symlink_metadata_unchecked(path: ref std::string::String) -> Metadata {
  match symlink_metadata(path) {
    std::Ok(value) => {
      return value;
    }
    std::Err(_) => {}
  }
  std::panic();
  return Metadata {
    byte_len: 0,
    kind: Other,
    permissions: Permissions::none(),
    accessed_at: std::time::system_from_unix(0, 0),
    modified_at: std::time::system_from_unix(0, 0),
    changed_at: std::time::system_from_unix(0, 0),
    owner_id_value: -1,
    group_id_value: -1,
  };
}

fn try_metadata_bytes(path: std::Slice[u8]) -> std::Option[Metadata] {
  let kind = metadata_kind_bytes_raw(path.data, path.len);
  if kind < 0 {
    return std::None<Metadata>();
  }
  let size = metadata_size_bytes_raw(path.data, path.len);
  return metadata_from_bytes(
    path,
    kind,
    size,
    metadata_accessed_nanos_bytes_raw(path.data, path.len),
    metadata_modified_nanos_bytes_raw(path.data, path.len),
    metadata_changed_nanos_bytes_raw(path.data, path.len),
    metadata_owner_bytes_raw(path.data, path.len),
    metadata_group_bytes_raw(path.data, path.len)
  );
}

fn metadata_bytes_raw(path: std::Slice[u8]) -> std::Result[Metadata, i64] {
  let kind = metadata_kind_bytes_raw(path.data, path.len);
  if kind < 0 {
    return std::Err<Metadata, i64>(last_errno_error_raw());
  }
  let size = metadata_size_bytes_raw(path.data, path.len);
  if size < 0 {
    return std::Err<Metadata, i64>(last_errno_error_raw());
  }
  let accessed = metadata_accessed_nanos_bytes_raw(path.data, path.len);
  if accessed < 0 {
    return std::Err<Metadata, i64>(last_errno_error_raw());
  }
  let modified = metadata_modified_nanos_bytes_raw(path.data, path.len);
  if modified < 0 {
    return std::Err<Metadata, i64>(last_errno_error_raw());
  }
  let changed = metadata_changed_nanos_bytes_raw(path.data, path.len);
  if changed < 0 {
    return std::Err<Metadata, i64>(last_errno_error_raw());
  }
  let owner_id = metadata_owner_bytes_raw(path.data, path.len);
  if owner_id < 0 {
    return std::Err<Metadata, i64>(last_errno_error_raw());
  }
  let group_id = metadata_group_bytes_raw(path.data, path.len);
  if group_id < 0 {
    return std::Err<Metadata, i64>(last_errno_error_raw());
  }
  match metadata_from_bytes(path, kind, size, accessed, modified, changed, owner_id, group_id) {
    std::Some(value) => {
      return std::Ok<Metadata, i64>(value);
    }
    std::None => {}
  }
  return std::Err<Metadata, i64>(last_errno_error_raw());
}

fn try_symlink_metadata_bytes(path: std::Slice[u8]) -> std::Option[Metadata] {
  let kind = symlink_metadata_kind_bytes_raw(path.data, path.len);
  if kind < 0 {
    return std::None<Metadata>();
  }
  let size = symlink_metadata_size_bytes_raw(path.data, path.len);
  return metadata_from_bytes(
    path,
    kind,
    size,
    symlink_metadata_accessed_nanos_bytes_raw(path.data, path.len),
    symlink_metadata_modified_nanos_bytes_raw(path.data, path.len),
    symlink_metadata_changed_nanos_bytes_raw(path.data, path.len),
    symlink_metadata_owner_bytes_raw(path.data, path.len),
    symlink_metadata_group_bytes_raw(path.data, path.len)
  );
}

fn symlink_metadata_bytes_raw(path: std::Slice[u8]) -> std::Result[Metadata, i64] {
  let kind = symlink_metadata_kind_bytes_raw(path.data, path.len);
  if kind < 0 {
    return std::Err<Metadata, i64>(last_errno_error_raw());
  }
  let size = symlink_metadata_size_bytes_raw(path.data, path.len);
  if size < 0 {
    return std::Err<Metadata, i64>(last_errno_error_raw());
  }
  let accessed = symlink_metadata_accessed_nanos_bytes_raw(path.data, path.len);
  if accessed < 0 {
    return std::Err<Metadata, i64>(last_errno_error_raw());
  }
  let modified = symlink_metadata_modified_nanos_bytes_raw(path.data, path.len);
  if modified < 0 {
    return std::Err<Metadata, i64>(last_errno_error_raw());
  }
  let changed = symlink_metadata_changed_nanos_bytes_raw(path.data, path.len);
  if changed < 0 {
    return std::Err<Metadata, i64>(last_errno_error_raw());
  }
  let owner_id = symlink_metadata_owner_bytes_raw(path.data, path.len);
  if owner_id < 0 {
    return std::Err<Metadata, i64>(last_errno_error_raw());
  }
  let group_id = symlink_metadata_group_bytes_raw(path.data, path.len);
  if group_id < 0 {
    return std::Err<Metadata, i64>(last_errno_error_raw());
  }
  match metadata_from_bytes(path, kind, size, accessed, modified, changed, owner_id, group_id) {
    std::Some(value) => {
      return std::Ok<Metadata, i64>(value);
    }
    std::None => {}
  }
  return std::Err<Metadata, i64>(last_errno_error_raw());
}

pub fn try_file_type(path: ref std::string::String) -> std::Option[FileKind] {
  return file_type_optional(path);
}

pub fn file_type_raw(path: ref std::string::String) -> std::Result[FileKind, i64] {
  let data = path.as_slice();
  let kind = metadata_kind_bytes_raw(data.data, data.len);
  if kind < 0 {
    return std::Err<FileKind, i64>(last_errno_error_raw());
  }
  return std::Ok<FileKind, i64>(file_kind_from_raw(kind));
}

pub fn file_type(path: ref std::string::String) -> std::Result[FileKind, std::error::Error] {
  return std::error::map_raw<FileKind>(file_type_raw(path));
}

pub fn file_type_optional(path: ref std::string::String) -> std::Option[FileKind] {
  match file_type(path) {
    std::Ok(value) => {
      return std::Some<FileKind>(value);
    }
    std::Err(_) => {}
  }
  return std::None<FileKind>();
}

pub fn file_type_unchecked(path: ref std::string::String) -> FileKind {
  match file_type(path) {
    std::Ok(value) => {
      return value;
    }
    std::Err(_) => {}
  }
  std::panic();
  return Other;
}

fn file_type_bytes_raw(path: std::Slice[u8]) -> std::Result[FileKind, i64] {
  let kind = metadata_kind_bytes_raw(path.data, path.len);
  if kind < 0 {
    return std::Err<FileKind, i64>(last_errno_error_raw());
  }
  return std::Ok<FileKind, i64>(file_kind_from_raw(kind));
}

pub fn is_file(path: ref std::string::String) -> bool {
  match file_type_optional(path) {
    std::Some(kind) => {
      match kind {
        Regular => {
          return true;
        }
        _ => {}
      }
    }
    std::None => {}
  }
  return false;
}

pub fn is_dir(path: ref std::string::String) -> bool {
  match file_type_optional(path) {
    std::Some(kind) => {
      match kind {
        Directory => {
          return true;
        }
        _ => {}
      }
    }
    std::None => {}
  }
  return false;
}

pub fn is_symlink(path: ref std::string::String) -> bool {
  match symlink_metadata_optional(path) {
    std::Some(info) => {
      return info.is_symlink();
    }
    std::None => {}
  }
  return false;
}

pub fn is_other(path: ref std::string::String) -> bool {
  match file_type_optional(path) {
    std::Some(kind) => {
      match kind {
        Other => {
          return true;
        }
        _ => {}
      }
    }
    std::None => {}
  }
  return false;
}

pub fn try_mode(path: ref std::string::String) -> std::Option[i64] {
  return mode_optional(path);
}

pub fn mode_raw(path: ref std::string::String) -> std::Result[i64, i64] {
  let data = path.as_slice();
  let mode = metadata_mode_bytes_raw(data.data, data.len);
  if mode < 0 {
    return std::Err<i64, i64>(last_errno_error_raw());
  }
  return std::Ok<i64, i64>(mode & 511);
}

pub fn mode(path: ref std::string::String) -> std::Result[i64, std::error::Error] {
  return std::error::map_raw<i64>(mode_raw(path));
}

pub fn mode_optional(path: ref std::string::String) -> std::Option[i64] {
  match mode(path) {
    std::Ok(value) => {
      return std::Some<i64>(value);
    }
    std::Err(_) => {}
  }
  return std::None<i64>();
}

pub fn mode_unchecked(path: ref std::string::String) -> i64 {
  match mode(path) {
    std::Ok(value) => {
      return value;
    }
    std::Err(_) => {}
  }
  std::panic();
  return -1;
}

pub fn set_mode(path: ref std::string::String, mode: i64) -> bool {
  if mode < 0 || mode > 511 {
    return false;
  }
  let data = path.as_slice();
  return set_mode_bytes_raw(data.data, data.len, mode);
}

pub fn set_permissions(path: ref std::string::String, permissions: Permissions) -> bool {
  return set_mode(path, permissions.to_mode());
}

pub fn ensure_dir(path: ref std::string::String) -> bool {
  if is_dir(path) {
    return true;
  }
  if exists(path) {
    return false;
  }
  return create_dir(path).is_ok();
}

pub fn ensure_dir_all(path: ref std::string::String) -> bool {
  return create_dir_all(path).is_ok();
}

// Keep setup code rerunnable without truncating existing regular files.
pub fn ensure_file(path: ref std::string::String) -> bool {
  if is_file(path) {
    return true;
  }
  if exists(path) {
    return false;
  }

  let file = try_create(path).unwrap_or(File::invalid());
  if !file.is_open() {
    return false;
  }
  return file.close().is_ok();
}

pub fn open_dir_raw(path: ref std::string::String) -> std::Result[Dir, i64] {
  let dir = open_dir_unchecked(path);
  if dir.is_open() {
    return std::Ok<Dir, i64>(dir);
  }
  return std::Err<Dir, i64>(last_errno_error_raw());
}

pub fn open_dir(path: ref std::string::String) -> std::Result[Dir, std::error::Error] {
  return std::error::map_raw<Dir>(open_dir_raw(path));
}

pub fn open_dir_unchecked(path: ref std::string::String) -> Dir {
  let data = path.as_slice();
  return open_dir_bytes_raw(data.data, data.len);
}

pub fn try_open_dir(path: ref std::string::String) -> std::Option[Dir] {
  let dir = open_dir_unchecked(path);
  if dir.is_open() {
    return std::Some<Dir>(dir);
  }
  return std::None<Dir>();
}

pub fn read_dir_next(zone: ref mut Zone, dir: Dir) -> std::Option[std::string::String] {
  let name = read_dir_next_raw(dir);
  if source_text_bytes(name).len == 0 {
    return std::None<std::string::String>();
  }
  return std::Some<std::string::String>(source_text_string(zone, name));
}

pub fn try_read_dir(zone: ref mut Zone, path: ref std::string::String) -> std::Option[std::vec::Vec[std::string::String]] {
  match try_open_dir(path) {
    std::Some(dir) => {
      var entries = std::vec::new<std::string::String>(zone, 8);
      var reading = true;
      while reading {
        match dir.next(zone) {
          std::Some(name) => {
            entries.push_in(zone, name);
          }
          std::None => {
            reading = false;
          }
        }
      }

      if dir.close().is_err() {
        return std::None<std::vec::Vec[std::string::String]>();
      }
      return std::Some<std::vec::Vec[std::string::String]>(entries);
    }
    std::None => {}
  }
  return std::None<std::vec::Vec[std::string::String]>();
}

pub fn read_dir_names(zone: ref mut Zone, path: ref std::string::String) -> std::Result[std::vec::Vec[std::string::String], std::error::Error] {
  match open_dir(path) {
    std::Ok(dir) => {
      var entries = std::vec::new<std::string::String>(zone, 8);
      var reading = true;
      while reading {
        match dir.next(zone) {
          std::Some(name) => {
            entries.push_in(zone, name);
          }
          std::None => {
            reading = false;
          }
        }
      }

      match dir.close() {
        std::Ok(_) => {
          return std::Ok<std::vec::Vec[std::string::String], std::error::Error>(entries);
        }
        std::Err(close_reason) => {
          return std::Err<std::vec::Vec[std::string::String], std::error::Error>(close_reason);
        }
      }
    }
    std::Err(open_reason) => {
      return std::Err<std::vec::Vec[std::string::String], std::error::Error>(open_reason);
    }
  }
}

pub fn read_dir_names_optional(zone: ref mut Zone, path: ref std::string::String) -> std::Option[std::vec::Vec[std::string::String]] {
  return try_read_dir(zone, path);
}

pub fn try_read_dir_names(zone: ref mut Zone, path: ref std::string::String) -> std::Option[std::vec::Vec[std::string::String]] {
  return try_read_dir(zone, path);
}

pub fn read_dir_names_unchecked(zone: ref mut Zone, path: ref std::string::String) -> std::vec::Vec[std::string::String] {
  match read_dir_names(zone, path) {
    std::Ok(entries) => {
      return entries;
    }
    std::Err(_) => {}
  }
  std::panic();
  return std::vec::new<std::string::String>(zone, 0);
}

fn try_open_dir_bytes(path: std::Slice[u8]) -> std::Option[Dir] {
  let dir = open_dir_bytes_raw(path.data, path.len);
  if dir.is_open() {
    return std::Some<Dir>(dir);
  }
  return std::None<Dir>();
}

// DirEntry stores both strings in the caller's zone so listing results stay
// valid until that zone is reset or destroyed.
fn make_dir_entry_bytes(zone: ref mut Zone, base: std::Slice[u8], name: std::string::String) -> DirEntry {
  let full_path = std::path::join_in(zone, base, name.as_slice());
  let entry_name = name;
  let entry_path = full_path;
  return DirEntry { name_value: entry_name, path_value: entry_path };
}

fn make_dir_entry(zone: ref mut Zone, base: ref std::string::String, name: std::string::String) -> DirEntry {
  return make_dir_entry_bytes(zone, base.as_slice(), name);
}

pub fn try_read_dir_entries(zone: ref mut Zone, path: ref std::string::String) -> std::Option[std::vec::Vec[DirEntry]] {
  match try_open_dir(path) {
    std::Some(dir) => {
      var entries = std::vec::new<DirEntry>(zone, 8);
      var reading = true;
      while reading {
        match dir.next(zone) {
          std::Some(name) => {
            entries.push_in(zone, make_dir_entry(zone, path, name));
          }
          std::None => {
            reading = false;
          }
        }
      }

      if dir.close().is_err() {
        return std::None<std::vec::Vec[DirEntry]>();
      }
      return std::Some<std::vec::Vec[DirEntry]>(entries);
    }
    std::None => {}
  }
  return std::None<std::vec::Vec[DirEntry]>();
}

pub fn read_dir_entries(zone: ref mut Zone, path: ref std::string::String) -> std::Result[std::vec::Vec[DirEntry], std::error::Error] {
  match open_dir(path) {
    std::Ok(dir) => {
      var entries = std::vec::new<DirEntry>(zone, 8);
      var reading = true;
      while reading {
        match dir.next(zone) {
          std::Some(name) => {
            entries.push_in(zone, make_dir_entry(zone, path, name));
          }
          std::None => {
            reading = false;
          }
        }
      }

      match dir.close() {
        std::Ok(_) => {
          return std::Ok<std::vec::Vec[DirEntry], std::error::Error>(entries);
        }
        std::Err(close_reason) => {
          return std::Err<std::vec::Vec[DirEntry], std::error::Error>(close_reason);
        }
      }
    }
    std::Err(open_reason) => {
      return std::Err<std::vec::Vec[DirEntry], std::error::Error>(open_reason);
    }
  }
}

pub fn read_dir_entries_optional(zone: ref mut Zone, path: ref std::string::String) -> std::Option[std::vec::Vec[DirEntry]] {
  return try_read_dir_entries(zone, path);
}

pub fn read_dir(zone: ref mut Zone, path: ref std::string::String) -> std::Result[std::vec::Vec[DirEntry], std::error::Error] {
  return read_dir_entries(zone, path);
}

pub fn read_dir_optional(zone: ref mut Zone, path: ref std::string::String) -> std::Option[std::vec::Vec[DirEntry]] {
  return try_read_dir_entries(zone, path);
}

pub fn read_dir_unchecked(zone: ref mut Zone, path: ref std::string::String) -> std::vec::Vec[DirEntry] {
  match read_dir(zone, path) {
    std::Ok(entries) => {
      return entries;
    }
    std::Err(_) => {}
  }
  std::panic();
  return std::vec::new<DirEntry>(zone, 0);
}

fn try_read_dir_entries_bytes(zone: ref mut Zone, path: std::Slice[u8]) -> std::Option[std::vec::Vec[DirEntry]] {
  match try_open_dir_bytes(path) {
    std::Some(dir) => {
      var entries = std::vec::new<DirEntry>(zone, 8);
      var reading = true;
      while reading {
        match dir.next(zone) {
          std::Some(name) => {
            entries.push_in(zone, make_dir_entry_bytes(zone, path, name));
          }
          std::None => {
            reading = false;
          }
        }
      }

      if dir.close().is_err() {
        return std::None<std::vec::Vec[DirEntry]>();
      }
      return std::Some<std::vec::Vec[DirEntry]>(entries);
    }
    std::None => {}
  }
  return std::None<std::vec::Vec[DirEntry]>();
}

pub fn read_dir_entries_unchecked(zone: ref mut Zone, path: ref std::string::String) -> std::vec::Vec[DirEntry] {
  match read_dir_entries(zone, path) {
    std::Ok(entries) => {
      return entries;
    }
    std::Err(_) => {}
  }
  std::panic();
  return std::vec::new<DirEntry>(zone, 0);
}

fn make_dir_entry_info(entry: DirEntry) -> DirEntryInfo {
  let metadata_result = entry.metadata();
  let symlink_metadata_result = entry.symlink_metadata();
  let file_type_result = entry.file_type();
  return DirEntryInfo {
    entry_value: entry,
    metadata_result_value: metadata_result,
    symlink_metadata_result_value: symlink_metadata_result,
    file_type_result_value: file_type_result,
  };
}

pub fn read_dir_info(zone: ref mut Zone, path: ref std::string::String) -> std::Result[std::vec::Vec[DirEntryInfo], std::error::Error] {
  match read_dir_entries(zone, path) {
    std::Ok(entries) => {
      var output = std::vec::new<DirEntryInfo>(zone, entries.len());
      var index = 0;
      while index < entries.len() {
        output.push_in(zone, make_dir_entry_info(entries.get(index)));
        index = index + 1;
      }
      return std::Ok<std::vec::Vec[DirEntryInfo], std::error::Error>(output);
    }
    std::Err(reason) => {
      return std::Err<std::vec::Vec[DirEntryInfo], std::error::Error>(reason);
    }
  }
}

pub fn read_dir_info_detailed(
  zone: ref mut Zone,
  path: ref std::string::String
) -> std::Result[std::vec::Vec[DirEntryInfo], PathError] {
  return map_path_error<std::vec::Vec[DirEntryInfo]>(FsReadDir, path, read_dir_info(zone, path));
}

pub fn read_dir_info_optional(zone: ref mut Zone, path: ref std::string::String) -> std::Option[std::vec::Vec[DirEntryInfo]] {
  match read_dir_info(zone, path) {
    std::Ok(entries) => {
      return std::Some<std::vec::Vec[DirEntryInfo]>(entries);
    }
    std::Err(_) => {}
  }
  return std::None<std::vec::Vec[DirEntryInfo]>();
}

pub fn try_read_dir_info(zone: ref mut Zone, path: ref std::string::String) -> std::Option[std::vec::Vec[DirEntryInfo]] {
  return read_dir_info_optional(zone, path);
}

pub fn read_dir_info_unchecked(zone: ref mut Zone, path: ref std::string::String) -> std::vec::Vec[DirEntryInfo] {
  match read_dir_info(zone, path) {
    std::Ok(entries) => {
      return entries;
    }
    std::Err(_) => {}
  }
  std::panic();
  return std::vec::new<DirEntryInfo>(zone, 0);
}

fn remove_dir_all_entry_bytes(zone: ref mut Zone, path: std::Slice[u8]) -> bool {
  match try_symlink_metadata_bytes(path) {
    std::Some(info) => {
      if info.is_symlink() || info.is_file() || info.is_other() {
        return remove_bytes_raw(path.data, path.len);
      }
      if info.is_dir() {
        return remove_dir_all_bytes(zone, path);
      }
    }
    std::None => {}
  }
  return false;
}

fn remove_dir_all_bytes(zone: ref mut Zone, path: std::Slice[u8]) -> bool {
  match try_symlink_metadata_bytes(path) {
    std::Some(info) => {
      if !info.is_dir() || info.is_symlink() {
        return false;
      }
    }
    std::None => {
      return false;
    }
  }

  match try_read_dir_entries_bytes(zone, path) {
    std::Some(entries) => {
      var index = 0;
      while index < entries.len() {
        let entry = entries.get(index);
        if !remove_dir_all_entry_bytes(zone, entry.path_value.as_slice()) {
          return false;
        }
        index = index + 1;
      }
    }
    std::None => {
      return false;
    }
  }
  return remove_dir_bytes_raw(path.data, path.len);
}

pub fn remove_dir_all_bool(path: ref std::string::String) -> bool {
  var zone = std::zone::create(4096);
  let ok = remove_dir_all_bytes(ref mut zone, path.as_slice());
  std::zone::destroy(zone);
  return ok;
}

pub fn remove_dir_all(path: ref std::string::String) -> std::Result[(), std::error::Error] {
  if remove_dir_all_bool(path) {
    return std::Ok<(), std::error::Error>(());
  }
  return std::Err<(), std::error::Error>(std::error::from_raw(last_errno_error_raw()));
}

pub fn try_canonicalize(zone: ref mut Zone, path: ref std::string::String) -> std::Option[std::string::String] {
  let data = path.as_slice();
  let resolved = canonicalize_bytes_raw(data.data, data.len);
  if source_text_bytes(resolved).len == 0 {
    return std::None<std::string::String>();
  }
  return std::Some<std::string::String>(source_text_string(zone, resolved));
}

pub fn canonicalize(zone: ref mut Zone, path: ref std::string::String) -> std::Result[std::string::String, std::error::Error] {
  let data = path.as_slice();
  let resolved = canonicalize_bytes_raw(data.data, data.len);
  if source_text_bytes(resolved).len == 0 {
    return std::Err<std::string::String, std::error::Error>(std::error::from_raw(last_errno_error_raw()));
  }
  return std::Ok<std::string::String, std::error::Error>(source_text_string(zone, resolved));
}

pub fn canonicalize_optional(zone: ref mut Zone, path: ref std::string::String) -> std::Option[std::string::String] {
  return try_canonicalize(zone, path);
}

pub fn canonicalize_unchecked(zone: ref mut Zone, path: ref std::string::String) -> std::string::String {
  match canonicalize(zone, path) {
    std::Ok(value) => {
      return value;
    }
    std::Err(_) => {}
  }
  std::panic();
  return std::string::empty(zone);
}

pub fn try_read_link(zone: ref mut Zone, path: ref std::string::String) -> std::Option[std::string::String] {
  let data = path.as_slice();
  let target = read_link_bytes_raw(data.data, data.len);
  if source_text_bytes(target).len == 0 {
    return std::None<std::string::String>();
  }
  return std::Some<std::string::String>(source_text_string(zone, target));
}

pub fn read_link(zone: ref mut Zone, path: ref std::string::String) -> std::Result[std::string::String, std::error::Error] {
  let data = path.as_slice();
  let target = read_link_bytes_raw(data.data, data.len);
  if source_text_bytes(target).len == 0 {
    return std::Err<std::string::String, std::error::Error>(std::error::from_raw(last_errno_error_raw()));
  }
  return std::Ok<std::string::String, std::error::Error>(source_text_string(zone, target));
}

pub fn read_link_optional(zone: ref mut Zone, path: ref std::string::String) -> std::Option[std::string::String] {
  return try_read_link(zone, path);
}

pub fn read_link_unchecked(zone: ref mut Zone, path: ref std::string::String) -> std::string::String {
  match read_link(zone, path) {
    std::Ok(value) => {
      return value;
    }
    std::Err(_) => {}
  }
  std::panic();
  return std::string::empty(zone);
}

pub fn open_optional(path: ref std::string::String, mode: ref std::string::String) -> std::Option[File] {
  let file = open_unchecked(path, mode);
  if file.is_open() {
    return std::Some<File>(file);
  }
  return std::None<File>();
}

pub fn try_open(path: ref std::string::String, mode: ref std::string::String) -> std::Option[File] {
  return open_optional(path, mode);
}

pub fn open_raw(path: ref std::string::String, mode: ref std::string::String) -> std::Result[File, i64] {
  return open_raw_with_mode_bytes(path, mode.as_slice());
}

fn open_raw_with_mode_bytes(path: ref std::string::String, mode: std::Slice[u8]) -> std::Result[File, i64] {
  if !supported_open_mode(mode) {
    return std::Err<File, i64>(invalid_input_error_raw());
  }
  let file = open_unchecked_bytes(path.as_slice(), mode);
  if file.is_open() {
    return std::Ok<File, i64>(file);
  }
  return std::Err<File, i64>(last_errno_error_raw());
}

fn open_raw_with_mode_literal(path: ref std::string::String, mode: string) -> std::Result[File, i64] {
  return open_raw_with_mode_bytes(path, source_text_bytes(mode));
}

pub fn open(path: ref std::string::String, mode: ref std::string::String) -> std::Result[File, std::error::Error] {
  return std::error::map_raw<File>(open_raw(path, mode));
}

fn open_with_mode_literal(path: ref std::string::String, mode: string) -> std::Result[File, std::error::Error] {
  return std::error::map_raw<File>(open_raw_with_mode_literal(path, mode));
}

pub fn open_options() -> OpenOptions {
  return OpenOptions::new();
}

pub fn create_unchecked(path: ref std::string::String) -> File {
  return open_unchecked_bytes(path.as_slice(), std::string::bytes("w"));
}

pub fn create(path: ref std::string::String) -> std::Result[File, std::error::Error] {
  return open_with_mode_literal(path, "w");
}

pub fn create_optional(path: ref std::string::String) -> std::Option[File] {
  let file = create_unchecked(path);
  if file.is_open() {
    return std::Some<File>(file);
  }
  return std::None<File>();
}

pub fn try_create(path: ref std::string::String) -> std::Option[File] {
  return create_optional(path);
}

pub fn create_raw(path: ref std::string::String) -> std::Result[File, i64] {
  return open_raw_with_mode_literal(path, "w");
}

pub fn open_read_unchecked(path: ref std::string::String) -> File {
  return open_unchecked_bytes(path.as_slice(), std::string::bytes("r"));
}

pub fn open_read(path: ref std::string::String) -> std::Result[File, std::error::Error] {
