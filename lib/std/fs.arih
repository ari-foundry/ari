pub fn open_append_unchecked(path: ref std::string::String) -> File {
  return open_unchecked_bytes(path.as_slice(), std::string::bytes("a"));
}

pub fn open_append(path: ref std::string::String) -> std::Result[File, std::error::Error] {
  return open_with_mode_literal(path, "a");
