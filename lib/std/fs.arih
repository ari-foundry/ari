fn bytes(path: ref std::string::String) -> std::Slice[u8] {
  return path.as_slice();
}

fn source_text_len(value: string) -> i64 {
  let data = value as ptr u8;
  var len = 0;
  while ptr_load(ptr_add(data, len)) != '\x00' {
    len = len + 1;
  }
  return len;
}

fn source_text_bytes(value: string) -> std::Slice[u8] {
  return std::Slice<u8> { data: value as ptr u8, len: source_text_len(value) };
}

fn source_text_string(zone: ref mut Zone, value: string) -> std::string::String {
  return std::string::from_slice_in(zone, source_text_bytes(value));
}

fn mode_equals(mode: std::Slice[u8], value: string) -> bool {
  return mode.equals(source_text_bytes(value));
}

pub fn exists(path: ref std::string::String) -> bool {
  let value = bytes(path);
  return exists_bytes_raw(value.data, value.len);
}

pub fn can_read(path: ref std::string::String) -> bool {
  let value = bytes(path);
  return can_read_bytes_raw(value.data, value.len);
}

pub fn can_write(path: ref std::string::String) -> bool {
  let value = bytes(path);
  return can_write_bytes_raw(value.data, value.len);
}

pub fn can_execute(path: ref std::string::String) -> bool {
  let value = bytes(path);
  return can_execute_bytes_raw(value.data, value.len);
}

pub fn remove_unchecked(path: ref std::string::String) -> bool {
  let value = bytes(path);
  return remove_bytes_raw(value.data, value.len);
}

pub fn rename_unchecked(source: ref std::string::String, target: ref std::string::String) -> bool {
  let source_bytes = bytes(source);
  let target_bytes = bytes(target);
  return rename_bytes_raw(source_bytes.data, source_bytes.len, target_bytes.data, target_bytes.len);
}

pub fn hard_link_unchecked(existing: ref std::string::String, link_path: ref std::string::String) -> bool {
  let existing_bytes = bytes(existing);
  let link_bytes = bytes(link_path);
  return hard_link_bytes_raw(existing_bytes.data, existing_bytes.len, link_bytes.data, link_bytes.len);
}

pub fn symbolic_link_unchecked(target: ref std::string::String, link_path: ref std::string::String) -> bool {
  let target_bytes = bytes(target);
  let link_bytes = bytes(link_path);
  return symbolic_link_bytes_raw(target_bytes.data, target_bytes.len, link_bytes.data, link_bytes.len);
}

pub fn create_dir_unchecked(path: ref std::string::String) -> bool {
  let value = bytes(path);
  return create_dir_bytes_raw(value.data, value.len);
}

pub fn create_dir_all_unchecked(path: ref std::string::String) -> bool {
  let value = bytes(path);
  return create_dir_all_bytes_raw(value.data, value.len);
}

pub fn remove_dir_unchecked(path: ref std::string::String) -> bool {
  let value = bytes(path);
  return remove_dir_bytes_raw(value.data, value.len);
}

fn open_unchecked_bytes(path_bytes: std::Slice[u8], mode_bytes: std::Slice[u8]) -> File {
  if mode_equals(mode_bytes, "r") {
    return open_options_bytes_raw(path_bytes.data, path_bytes.len, true, false, false, false, false, false);
  }
  if mode_equals(mode_bytes, "w") {
    return open_options_bytes_raw(path_bytes.data, path_bytes.len, false, true, false, true, true, false);
  }
  if mode_equals(mode_bytes, "a") {
    return open_options_bytes_raw(path_bytes.data, path_bytes.len, false, false, true, false, true, false);
  }
  if mode_equals(mode_bytes, "rw") || mode_equals(mode_bytes, "r+") {
    return open_options_bytes_raw(path_bytes.data, path_bytes.len, true, true, false, false, false, false);
  }
  if mode_equals(mode_bytes, "w+") {
    return open_options_bytes_raw(path_bytes.data, path_bytes.len, true, true, false, true, true, false);
  }
  if mode_equals(mode_bytes, "a+") {
    return open_options_bytes_raw(path_bytes.data, path_bytes.len, true, false, true, false, true, false);
  }
  return File::invalid();
}

pub fn open_unchecked(path: ref std::string::String, mode: ref std::string::String) -> File {
  return open_unchecked_bytes(bytes(path), mode.as_slice());
}

pub fn permissions(path: ref std::string::String) -> Permissions {
  return Permissions {
    readable: can_read(path),
    writable: can_write(path),
    executable: can_execute(path),
  };
}

pub fn temp_file(zone: ref mut Zone) -> std::Result[std::fs::TempFile, std::error::Error] {
  return std::process::temp_file(zone);
}

pub fn temp_file_in(zone: ref mut Zone, prefix: ref std::string::String) -> std::Result[std::fs::TempFile, std::error::Error] {
  return std::process::temp_file_in(zone, prefix);
}

pub fn temp_dir(zone: ref mut Zone) -> std::Result[std::fs::TempDir, std::error::Error] {
  return std::process::temp_dir(zone);
}

pub fn temp_dir_in(zone: ref mut Zone, prefix: ref std::string::String) -> std::Result[std::fs::TempDir, std::error::Error] {
  return std::process::temp_dir_in(zone, prefix);
}

fn file_kind_from_raw(kind: i64) -> FileKind {
  if kind == 1 {
    return Regular;
  }
  if kind == 2 {
    return Directory;
  }
  if kind == 3 {
    return Symlink;
  }
  return Other;
}

fn invalid_input_error_raw() -> i64 {
  let error = std::error::from_errno(22);
  return error.raw();
}

fn last_errno_error_raw() -> i64 {
  let error = std::c::error();
  return error.raw();
}

fn unit_raw(ok: bool) -> std::Result[(), i64] {
  if ok {
    return std::Ok<(), i64>(());
  }
  return std::Err<(), i64>(last_errno_error_raw());
}

fn byte_count_option(value: std::Result[i64, i64]) -> std::Option[i64] {
  match value {
    std::Ok(count) => {
      return std::Some<i64>(count);
    }
    std::Err(_) => {}
  }
  return std::None<i64>();
}

fn supported_open_mode(mode: std::Slice[u8]) -> bool {
  if mode.equals("r") {
    return true;
  }
  if mode.equals("w") {
    return true;
  }
  if mode.equals("a") {
    return true;
  }
  if mode.equals("rw") {
    return true;
  }
  if mode.equals("r+") {
    return true;
  }
  if mode.equals("w+") {
    return true;
  }
  return mode.equals("a+");
}

fn open_options_valid(options: ref OpenOptions) -> bool {
  let writable = options.write_enabled || options.append_enabled;
  if !(options.read_enabled || writable) {
    return false;
  }
  if (options.create_enabled || options.create_new_enabled) && !writable {
    return false;
  }
  if options.truncate_enabled && !writable {
    return false;
  }
  return !(options.append_enabled && options.truncate_enabled);
}

fn system_time_from_nanos(nanos: i64) -> std::time::SystemTime {
  return std::time::system_from_unix(nanos / 1000000000, nanos % 1000000000);
}

fn path_error(operation: Operation, path: std::Slice[u8], reason: Error) -> PathError {
  return PathError {
    operation_value: operation,
    path_value: path,
    reason_value: reason,
  };
}

fn two_path_error(
  operation: Operation,
  source: std::Slice[u8],
  target: std::Slice[u8],
  reason: Error
) -> TwoPathError {
  return TwoPathError {
    operation_value: operation,
    source_value: source,
    target_value: target,
    reason_value: reason,
  };
}

fn map_path_error[T](
  operation: Operation,
  path: ref std::string::String,
  value: std::Result[T, Error]
) -> std::Result[T, PathError] {
  match value {
    std::Ok(payload) => {
      return std::Ok<T, PathError>(payload);
    }
    std::Err(reason) => {
      return std::Err<T, PathError>(path_error(operation, path.as_slice(), reason));
    }
  }
}

fn map_two_path_error[T](
  operation: Operation,
  source: ref std::string::String,
  target: ref std::string::String,
  value: std::Result[T, Error]
) -> std::Result[T, TwoPathError] {
  match value {
    std::Ok(payload) => {
      return std::Ok<T, TwoPathError>(payload);
    }
    std::Err(reason) => {
      return std::Err<T, TwoPathError>(two_path_error(operation, source.as_slice(), target.as_slice(), reason));
    }
  }
}

pub fn remove_raw(path: ref std::string::String) -> std::Result[(), i64] {
  return unit_raw(remove_unchecked(path));
}

pub fn remove(path: ref std::string::String) -> std::Result[(), std::error::Error] {
  return std::error::map_raw<()>(remove_raw(path));
}

pub fn remove_file(path: ref std::string::String) -> std::Result[(), std::error::Error] {
  return remove(path);
}

pub fn remove_bool(path: ref std::string::String) -> bool {
  return remove_unchecked(path);
}

pub fn remove_file_bool(path: ref std::string::String) -> bool {
  return remove_bool(path);
}

pub fn rename_raw(source: ref std::string::String, target: ref std::string::String) -> std::Result[(), i64] {
  return unit_raw(rename_unchecked(source, target));
}

pub fn rename(source: ref std::string::String, target: ref std::string::String) -> std::Result[(), std::error::Error] {
  return std::error::map_raw<()>(rename_raw(source, target));
}

pub fn rename_bool(source: ref std::string::String, target: ref std::string::String) -> bool {
  return rename_unchecked(source, target);
}

pub fn hard_link_raw(existing: ref std::string::String, link_path: ref std::string::String) -> std::Result[(), i64] {
