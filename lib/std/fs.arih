pub impl std::fs::Permissions {
  fn all() -> Permissions {
    return Permissions {
      readable: true,
      writable: true,
      executable: true,
    };
  }

  fn none() -> Permissions {
    return Permissions {
      readable: false,
      writable: false,
      executable: false,
    };
  }

  fn read_only() -> Permissions {
    return Permissions {
      readable: true,
      writable: false,
      executable: false,
    };
  }

  fn can_read(self: ref Self) -> bool {
    return self.readable;
  }

  fn can_write(self: ref Self) -> bool {
    return self.writable;
  }

  fn can_execute(self: ref Self) -> bool {
    return self.executable;
  }

  fn any(self: ref Self) -> bool {
    return self.readable || self.writable || self.executable;
  }

  fn to_mode(self: ref Self) -> i64 {
    var mode = 0;
    if self.readable {
      mode = mode + 292;
    }
    if self.writable {
      mode = mode + 146;
    }
    if self.executable {
      mode = mode + 73;
    }
    return mode;
  }
}

pub impl std::fs::PathError {
  fn operation(self: ref Self) -> Operation {
    return self.operation_value;
  }

  fn path(self: ref Self) -> std::Slice[u8] {
    return self.path_value;
  }

  fn reason(self: ref Self) -> Error {
    return self.reason_value;
  }

  fn kind(self: ref Self) -> ErrorKind {
    return self.reason_value.kind();
  }

  fn code(self: ref Self) -> i64 {
    return self.reason_value.code();
  }

  fn path_equals(self: ref Self, value: ref std::string::String) -> bool {
    return self.path_value.equals(value.as_slice());
  }
}

pub impl std::fs::TwoPathError {
  fn operation(self: ref Self) -> Operation {
    return self.operation_value;
  }

  fn source(self: ref Self) -> std::Slice[u8] {
    return self.source_value;
  }

  fn target(self: ref Self) -> std::Slice[u8] {
    return self.target_value;
  }

  fn reason(self: ref Self) -> Error {
    return self.reason_value;
  }

  fn kind(self: ref Self) -> ErrorKind {
    return self.reason_value.kind();
  }

  fn code(self: ref Self) -> i64 {
    return self.reason_value.code();
  }

  fn source_equals(self: ref Self, value: ref std::string::String) -> bool {
    return self.source_value.equals(value.as_slice());
  }

  fn target_equals(self: ref Self, value: ref std::string::String) -> bool {
    return self.target_value.equals(value.as_slice());
  }
}

pub impl std::fs::Metadata {
  fn len(self: ref Self) -> i64 {
    return self.byte_len;
  }

  fn file_type(self: ref Self) -> FileKind {
    return self.kind;
  }

  fn permissions(self: ref Self) -> Permissions {
    return self.permissions;
  }

  fn accessed(self: ref Self) -> std::time::SystemTime {
    return self.accessed_at;
  }

  fn modified(self: ref Self) -> std::time::SystemTime {
    return self.modified_at;
  }

  fn changed(self: ref Self) -> std::time::SystemTime {
    return self.changed_at;
  }

  fn created(self: ref Self) -> std::Option[std::time::SystemTime] {
    // Portable hosted POSIX metadata does not expose file birth time.
    return std::None<std::time::SystemTime>();
  }

  fn birth_time(self: ref Self) -> std::Option[std::time::SystemTime] {
    return self.created();
  }

  fn created_or_changed(self: ref Self) -> std::time::SystemTime {
    return self.changed_at;
  }

  fn owner(self: ref Self) -> i64 {
    return self.owner_id_value;
  }

  fn group(self: ref Self) -> i64 {
    return self.group_id_value;
  }

  fn owner_id(self: ref Self) -> i64 {
    return self.owner_id_value;
  }

  fn group_id(self: ref Self) -> i64 {
    return self.group_id_value;
  }

  fn uid(self: ref Self) -> i64 {
    return self.owner_id_value;
  }

  fn gid(self: ref Self) -> i64 {
    return self.group_id_value;
  }

  fn is_file(self: ref Self) -> bool {
    match self.kind {
      Regular => {
        return true;
      }
      _ => {
        return false;
      }
    }
  }

  fn is_dir(self: ref Self) -> bool {
    match self.kind {
      Directory => {
        return true;
      }
      _ => {
        return false;
      }
    }
  }

  fn is_symlink(self: ref Self) -> bool {
    match self.kind {
      Symlink => {
        return true;
      }
      _ => {
        return false;
      }
    }
  }

  fn is_other(self: ref Self) -> bool {
    match self.kind {
      Other => {
        return true;
      }
      _ => {
        return false;
      }
    }
  }
}

pub impl std::fs::File {
  fn invalid() -> File {
    return File { fd: -1 };
  }

  fn descriptor(self: ref Self) -> std::os::Fd {
    return std::os::fd(self.fd);
  }

  fn is_open(self) -> bool {
    return self.fd >= 0;
  }

  fn close(self) -> std::Result[(), std::error::Error] {
    return close(self);
  }

  fn close_unchecked(self) -> bool {
    return close_unchecked(self);
  }

  fn lock_shared(self) -> std::Result[(), std::error::Error] {
    return lock_shared(self);
  }

  fn try_lock_shared(self) -> std::Result[bool, std::error::Error] {
    return try_lock_shared(self);
  }

  fn lock_exclusive(self) -> std::Result[(), std::error::Error] {
    return lock_exclusive(self);
  }

  fn try_lock_exclusive(self) -> std::Result[bool, std::error::Error] {
    return try_lock_exclusive(self);
  }

  fn unlock(self) -> std::Result[(), std::error::Error] {
    return unlock(self);
  }

  fn read_byte(self) -> i64 {
    return read_byte(self);
  }

  fn try_read_byte(self) -> std::Option[u8] {
    return try_read_byte(self);
  }

  fn write_byte(self, value: u8) -> std::Result[(), std::error::Error] {
    return write_byte(self, value);
  }

  fn write_byte_unchecked(self, value: u8) -> bool {
    return write_byte_unchecked(self, value);
  }

  fn write_bytes(self, values: std::Slice[u8]) -> std::Result[i64, std::error::Error] {
    return write_bytes(self, values);
  }

  fn write_bytes_unchecked(self, values: std::Slice[u8]) -> i64 {
    return write_bytes_unchecked(self, values);
  }

  fn position(self) -> std::Result[i64, std::error::Error] {
    return position(self);
  }

  fn position_or(self, fallback: i64) -> i64 {
    return position_or(self, fallback);
  }

  fn seek(self, position: i64) -> std::Result[(), std::error::Error] {
    return seek(self, position);
  }

  fn seek_unchecked(self, position: i64) -> bool {
    return seek_unchecked(self, position);
  }
}

pub impl std::fs::OpenOptions {
  fn new() -> OpenOptions {
    return OpenOptions {
      read_enabled: false,
      write_enabled: false,
      append_enabled: false,
      truncate_enabled: false,
      create_enabled: false,
      create_new_enabled: false,
    };
  }

  fn read(self, enabled: bool) -> OpenOptions {
    return OpenOptions {
      read_enabled: enabled,
      write_enabled: self.write_enabled,
      append_enabled: self.append_enabled,
      truncate_enabled: self.truncate_enabled,
      create_enabled: self.create_enabled,
      create_new_enabled: self.create_new_enabled,
    };
  }

  fn write(self, enabled: bool) -> OpenOptions {
    return OpenOptions {
      read_enabled: self.read_enabled,
      write_enabled: enabled,
      append_enabled: self.append_enabled,
      truncate_enabled: self.truncate_enabled,
      create_enabled: self.create_enabled,
      create_new_enabled: self.create_new_enabled,
    };
  }

  fn append(self, enabled: bool) -> OpenOptions {
    return OpenOptions {
      read_enabled: self.read_enabled,
      write_enabled: self.write_enabled,
      append_enabled: enabled,
      truncate_enabled: self.truncate_enabled,
      create_enabled: self.create_enabled,
      create_new_enabled: self.create_new_enabled,
    };
  }

  fn truncate(self, enabled: bool) -> OpenOptions {
    return OpenOptions {
      read_enabled: self.read_enabled,
      write_enabled: self.write_enabled,
      append_enabled: self.append_enabled,
      truncate_enabled: enabled,
      create_enabled: self.create_enabled,
      create_new_enabled: self.create_new_enabled,
    };
  }

  fn create(self, enabled: bool) -> OpenOptions {
    return OpenOptions {
      read_enabled: self.read_enabled,
      write_enabled: self.write_enabled,
      append_enabled: self.append_enabled,
      truncate_enabled: self.truncate_enabled,
      create_enabled: enabled,
      create_new_enabled: self.create_new_enabled,
    };
  }

  fn create_new(self, enabled: bool) -> OpenOptions {
    return OpenOptions {
      read_enabled: self.read_enabled,
      write_enabled: self.write_enabled,
      append_enabled: self.append_enabled,
      truncate_enabled: self.truncate_enabled,
      create_enabled: self.create_enabled,
      create_new_enabled: enabled,
    };
  }

  fn open_unchecked(self: ref Self, path: ref std::string::String) -> File {
    let data = path.as_slice();
    return open_options_bytes_raw(
      data.data,
      data.len,
      self.read_enabled,
      self.write_enabled,
      self.append_enabled,
      self.truncate_enabled,
      self.create_enabled,
      self.create_new_enabled
    );
  }

  fn open_raw(self: ref Self, path: ref std::string::String) -> std::Result[File, i64] {
    if !open_options_valid(self) {
      return std::Err<File, i64>(invalid_input_error_raw());
    }
    let file = self.open_unchecked(path);
    if file.is_open() {
      return std::Ok<File, i64>(file);
    }
    return std::Err<File, i64>(last_errno_error_raw());
  }

  fn open(self: ref Self, path: ref std::string::String) -> std::Result[File, std::error::Error] {
    return std::error::map_raw<File>(self.open_raw(path));
  }

  fn open_optional(self: ref Self, path: ref std::string::String) -> std::Option[File] {
    let file = self.open_unchecked(path);
    if file.is_open() {
      return std::Some<File>(file);
    }
    return std::None<File>();
  }

  fn try_open(self: ref Self, path: ref std::string::String) -> std::Option[File] {
    return self.open_optional(path);
  }
}

impl std::io::Reader for std::fs::File {
  pub fn read_byte(self: ref mut Self) -> i64 {
    if self.fd < 0 {
      return -2;
    }
    return std::fs::read_byte(std::fs::File { fd: self.fd });
  }
}

impl std::io::Writer for std::fs::File {
  pub fn write_byte(self: ref mut Self, value: u8) -> bool {
    if self.fd < 0 {
      return false;
    }
    return std::fs::write_byte_unchecked(std::fs::File { fd: self.fd }, value);
  }

  pub fn write(self: ref mut Self, values: std::Slice[u8]) -> std::Result[i64, std::error::Error] {
    return std::io::write<std::fs::File>(self, values);
  }

  pub fn write_all(self: ref mut Self, values: std::Slice[u8]) -> std::Result[(), std::error::Error] {
    return std::io::write_all<std::fs::File>(self, values);
  }

  pub fn flush(self: ref mut Self) -> std::Result[(), std::error::Error] {
    // File writes currently go straight through the runtime descriptor hook.
    // This keeps std::io::copy usable for File without inventing buffering.
    if self.fd >= 0 {
      return std::Ok<(), std::error::Error>(());
    }
    return std::Err<(), std::error::Error>(std::error::new(std::error::InvalidInput));
  }
}

impl std::io::Seek for std::fs::File {
  pub fn position(self: ref Self) -> i64 {
    if self.fd < 0 {
      return -1;
    }
    return std::fs::position_or(std::fs::File { fd: self.fd }, -1);
  }

  pub fn seek(self: ref mut Self, position: i64) -> bool {
    if self.fd < 0 {
      return false;
    }
    return std::fs::seek_unchecked(std::fs::File { fd: self.fd }, position);
  }
}

pub impl std::fs::Dir {
  fn invalid() -> Dir {
    let handle: ptr c_void = null;
    return Dir { handle: handle };
  }

  fn is_open(self: ref Self) -> bool {
    return (self.handle as u64) != 0u64;
  }

  fn close(self) -> std::Result[(), std::error::Error] {
    return close_dir(self);
  }

  fn close_unchecked(self) -> bool {
    return close_dir_unchecked(self);
  }

  fn next(self, zone: ref mut Zone) -> std::Option[std::string::String] {
    return read_dir_next(zone, self);
  }
}

pub impl std::fs::DirEntry {
  fn name(self: ref Self) -> ref std::string::String {
    return ref self.name_value;
  }

  fn path(self: ref Self) -> ref std::string::String {
    return ref self.path_value;
  }

  fn name_equals(self: ref Self, value: ref std::string::String) -> bool {
    return self.name_value.equals(value.as_slice());
  }

  fn path_equals(self: ref Self, value: ref std::string::String) -> bool {
    return self.path_value.equals(value.as_slice());
  }

  fn try_metadata(self: ref Self) -> std::Option[Metadata] {
    return self.metadata_optional();
  }

  fn metadata(self: ref Self) -> std::Result[Metadata, std::error::Error] {
    return std::error::map_raw<Metadata>(metadata_bytes_raw(self.path_value.as_slice()));
  }

  fn metadata_optional(self: ref Self) -> std::Option[Metadata] {
    match self.metadata() {
      std::Ok(value) => {
        return std::Some<Metadata>(value);
      }
      std::Err(_) => {}
    }
    return std::None<Metadata>();
  }

  fn metadata_unchecked(self: ref Self) -> Metadata {
    match self.metadata() {
      std::Ok(value) => {
        return value;
      }
      std::Err(_) => {}
    }
    std::panic();
    return Metadata {
      byte_len: 0,
      kind: Other,
      permissions: Permissions::none(),
      accessed_at: std::time::system_from_unix(0, 0),
      modified_at: std::time::system_from_unix(0, 0),
      changed_at: std::time::system_from_unix(0, 0),
      owner_id_value: -1,
      group_id_value: -1,
    };
  }

  fn try_symlink_metadata(self: ref Self) -> std::Option[Metadata] {
    return self.symlink_metadata_optional();
  }

  fn symlink_metadata(self: ref Self) -> std::Result[Metadata, std::error::Error] {
    return std::error::map_raw<Metadata>(symlink_metadata_bytes_raw(self.path_value.as_slice()));
  }

  fn symlink_metadata_optional(self: ref Self) -> std::Option[Metadata] {
    match self.symlink_metadata() {
      std::Ok(value) => {
        return std::Some<Metadata>(value);
      }
      std::Err(_) => {}
    }
    return std::None<Metadata>();
  }

  fn symlink_metadata_unchecked(self: ref Self) -> Metadata {
    match self.symlink_metadata() {
      std::Ok(value) => {
        return value;
      }
      std::Err(_) => {}
    }
    std::panic();
    return Metadata {
      byte_len: 0,
      kind: Other,
      permissions: Permissions::none(),
      accessed_at: std::time::system_from_unix(0, 0),
      modified_at: std::time::system_from_unix(0, 0),
      changed_at: std::time::system_from_unix(0, 0),
      owner_id_value: -1,
      group_id_value: -1,
    };
  }

  fn try_file_type(self: ref Self) -> std::Option[FileKind] {
    return self.file_type_optional();
  }

  fn file_type(self: ref Self) -> std::Result[FileKind, std::error::Error] {
    return std::error::map_raw<FileKind>(file_type_bytes_raw(self.path_value.as_slice()));
  }

  fn file_type_optional(self: ref Self) -> std::Option[FileKind] {
    match self.file_type() {
      std::Ok(value) => {
        return std::Some<FileKind>(value);
      }
      std::Err(_) => {}
    }
    return std::None<FileKind>();
  }

  fn file_type_unchecked(self: ref Self) -> FileKind {
    match self.file_type() {
      std::Ok(value) => {
        return value;
      }
      std::Err(_) => {}
    }
    std::panic();
    return Other;
  }

  fn is_file(self: ref Self) -> bool {
    match self.metadata_optional() {
      std::Some(value) => {
        return value.is_file();
      }
      std::None => {}
    }
    return false;
  }

  fn is_dir(self: ref Self) -> bool {
    match self.metadata_optional() {
      std::Some(value) => {
        return value.is_dir();
      }
      std::None => {}
    }
    return false;
  }

  fn is_symlink(self: ref Self) -> bool {
    match self.symlink_metadata_optional() {
      std::Some(value) => {
        return value.is_symlink();
      }
      std::None => {}
    }
    return false;
  }

  fn is_other(self: ref Self) -> bool {
    match self.metadata_optional() {
      std::Some(value) => {
        return value.is_other();
      }
      std::None => {}
    }
    return false;
  }
}

pub impl std::fs::DirEntryInfo {
  fn entry(self: ref Self) -> ref DirEntry {
    return ref self.entry_value;
  }

  fn name(self: ref Self) -> ref std::string::String {
    return ref self.entry_value.name_value;
  }

  fn path(self: ref Self) -> ref std::string::String {
    return ref self.entry_value.path_value;
  }

  fn metadata(self: ref Self) -> ref std::Result[Metadata, Error] {
    return ref self.metadata_result_value;
  }

  fn symlink_metadata(self: ref Self) -> ref std::Result[Metadata, Error] {
    return ref self.symlink_metadata_result_value;
  }

  fn file_type(self: ref Self) -> ref std::Result[FileKind, Error] {
    return ref self.file_type_result_value;
  }

  fn metadata_ok(self: ref Self) -> bool {
    return self.metadata_result_value.is_ok();
  }

  fn symlink_metadata_ok(self: ref Self) -> bool {
    return self.symlink_metadata_result_value.is_ok();
  }

  fn file_type_ok(self: ref Self) -> bool {
    return self.file_type_result_value.is_ok();
  }

  fn metadata_err(self: ref Self) -> bool {
    return self.metadata_result_value.is_err();
  }

  fn symlink_metadata_err(self: ref Self) -> bool {
    return self.symlink_metadata_result_value.is_err();
  }

  fn file_type_err(self: ref Self) -> bool {
    return self.file_type_result_value.is_err();
  }

  fn name_equals(self: ref Self, value: ref std::string::String) -> bool {
    return self.entry_value.name_equals(value);
  }

  fn path_equals(self: ref Self, value: ref std::string::String) -> bool {
    return self.entry_value.path_equals(value);
  }
}

impl std::zone::ZoneBacked for std::fs::DirEntry {
  pub fn zone(self: ref Self) -> std::zone::ZoneMetadata {
    return std::zone::of<std::string::String>(ref self.path_value);
  }
}

impl std::zone::ZoneBacked for std::fs::DirEntryInfo {
  pub fn zone(self: ref Self) -> std::zone::ZoneMetadata {
    return std::zone::of<DirEntry>(ref self.entry_value);
  }
}
