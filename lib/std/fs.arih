pub fn open_append_optional(path: ref std::string::String) -> std::Option[File] {
  let file = open_append_unchecked(path);
  if file.is_open() {
    return std::Some<File>(file);
  }
  return std::None<File>();
}

pub fn try_open_read(path: ref std::string::String) -> std::Option[File] {
  return open_read_optional(path);
}

pub fn try_open_write(path: ref std::string::String) -> std::Option[File] {
  return open_write_optional(path);
}

pub fn try_open_append(path: ref std::string::String) -> std::Option[File] {
  return open_append_optional(path);
}

pub fn write_bytes_unchecked(file: File, values: std::Slice[u8]) -> i64 {
  var index = 0;
  while index < values.len {
    if !write_byte_unchecked(file, values[index]) {
      return index;
    }
    index = index + 1;
  }
  return index;
}

pub fn close_raw(file: File) -> std::Result[(), i64] {
  if !file.is_open() {
    return std::Err<(), i64>(invalid_input_error_raw());
  }
  return unit_raw(close_unchecked(file));
}

pub fn close(file: File) -> std::Result[(), std::error::Error] {
  return std::error::map_raw<()>(close_raw(file));
}

fn lock_operation_raw(file: File, operation: i64) -> std::Result[(), i64] {
  if !file.is_open() {
    return std::Err<(), i64>(invalid_input_error_raw());
  }
  if raw_flock(file.fd as c_int, operation as c_int) == 0 {
    return std::Ok<(), i64>(());
  }
  return std::Err<(), i64>(last_errno_error_raw());
}

fn try_lock_operation(file: File, operation: i64) -> std::Result[bool, std::error::Error] {
  match lock_operation_raw(file, operation + 4) {
    std::Ok(_) => {
      return std::Ok<bool, std::error::Error>(true);
    }
    std::Err(raw) => {
      let reason = std::error::from_raw(raw);
      if reason.is_kind(std::error::WouldBlock) {
        return std::Ok<bool, std::error::Error>(false);
      }
      return std::Err<bool, std::error::Error>(reason);
    }
  }
}

pub fn lock_shared_raw(file: File) -> std::Result[(), i64] {
  return lock_operation_raw(file, 1);
}

pub fn lock_shared(file: File) -> std::Result[(), std::error::Error] {
  return std::error::map_raw<()>(lock_shared_raw(file));
}

pub fn try_lock_shared(file: File) -> std::Result[bool, std::error::Error] {
  return try_lock_operation(file, 1);
}

pub fn lock_exclusive_raw(file: File) -> std::Result[(), i64] {
  return lock_operation_raw(file, 2);
}

pub fn lock_exclusive(file: File) -> std::Result[(), std::error::Error] {
  return std::error::map_raw<()>(lock_exclusive_raw(file));
}

pub fn try_lock_exclusive(file: File) -> std::Result[bool, std::error::Error] {
  return try_lock_operation(file, 2);
}

pub fn unlock_raw(file: File) -> std::Result[(), i64] {
  return lock_operation_raw(file, 8);
}

pub fn unlock(file: File) -> std::Result[(), std::error::Error] {
  return std::error::map_raw<()>(unlock_raw(file));
}

pub fn write_byte_raw(file: File, value: u8) -> std::Result[(), i64] {
  if !file.is_open() {
    return std::Err<(), i64>(invalid_input_error_raw());
  }
  return unit_raw(write_byte_unchecked(file, value));
}

pub fn write_byte(file: File, value: u8) -> std::Result[(), std::error::Error] {
  return std::error::map_raw<()>(write_byte_raw(file, value));
}

pub fn write_bytes_raw(file: File, values: std::Slice[u8]) -> std::Result[i64, i64] {
  if !file.is_open() {
    return std::Err<i64, i64>(invalid_input_error_raw());
  }

  var index = 0;
  while index < values.len {
    match write_byte_raw(file, values[index]) {
      std::Ok(_) => {}
      std::Err(raw) => {
        return std::Err<i64, i64>(raw);
      }
    }
    index = index + 1;
  }
  return std::Ok<i64, i64>(index);
}

pub fn write_bytes(file: File, values: std::Slice[u8]) -> std::Result[i64, std::error::Error] {
  return std::error::map_raw<i64>(write_bytes_raw(file, values));
}

pub fn position_raw(file: File) -> std::Result[i64, i64] {
  if !file.is_open() {
    return std::Err<i64, i64>(invalid_input_error_raw());
  }
  let offset = position_unchecked(file);
  if offset < 0 {
    return std::Err<i64, i64>(last_errno_error_raw());
  }
  return std::Ok<i64, i64>(offset);
}

pub fn position(file: File) -> std::Result[i64, std::error::Error] {
  return std::error::map_raw<i64>(position_raw(file));
}

pub fn position_or(file: File, fallback: i64) -> i64 {
  return position(file).unwrap_or(fallback);
}

pub fn seek_raw(file: File, offset: i64) -> std::Result[(), i64] {
  if !file.is_open() || offset < 0 {
    return std::Err<(), i64>(invalid_input_error_raw());
  }
  return unit_raw(seek_unchecked(file, offset));
}

pub fn seek(file: File, offset: i64) -> std::Result[(), std::error::Error] {
  return std::error::map_raw<()>(seek_raw(file, offset));
}

pub fn try_read_byte(file: File) -> std::Option[u8] {
  let byte = read_byte(file);
  if byte < 0 {
    return std::None<u8>();
  }
  return std::Some<u8>(byte as u8);
}

fn write_all_raw_with_mode(path: ref std::string::String, mode: string, values: std::Slice[u8]) -> std::Result[i64, i64] {
  match open_raw_with_mode_literal(path, mode) {
    std::Ok(file) => {
      match write_bytes_raw(file, values) {
        std::Ok(written) => {
          match close_raw(file) {
            std::Ok(_) => {
              return std::Ok<i64, i64>(written);
            }
            std::Err(close_raw_error) => {
              return std::Err<i64, i64>(close_raw_error);
            }
          }
        }
        std::Err(write_raw_error) => {
          file.close_unchecked();
          return std::Err<i64, i64>(write_raw_error);
        }
      }
    }
    std::Err(open_raw) => {
      return std::Err<i64, i64>(open_raw);
    }
  }
}

pub fn write(path: ref std::string::String, values: std::Slice[u8]) -> std::Result[i64, std::error::Error] {
  return std::error::map_raw<i64>(write_raw(path, values));
}

pub fn write_bool(path: ref std::string::String, values: std::Slice[u8]) -> bool {
  return try_write(path, values).is_some();
}

pub fn append(path: ref std::string::String, values: std::Slice[u8]) -> std::Result[i64, std::error::Error] {
  return std::error::map_raw<i64>(append_raw(path, values));
}

pub fn append_bool(path: ref std::string::String, values: std::Slice[u8]) -> bool {
  return try_append(path, values).is_some();
}

pub fn write_raw(path: ref std::string::String, values: std::Slice[u8]) -> std::Result[i64, i64] {
  return write_all_raw_with_mode(path, "w", values);
}

pub fn append_raw(path: ref std::string::String, values: std::Slice[u8]) -> std::Result[i64, i64] {
  return write_all_raw_with_mode(path, "a", values);
}

pub fn write_string(path: ref std::string::String, text: ref std::string::String) -> std::Result[(), std::error::Error] {
  match write(path, text.as_slice()) {
    std::Ok(_) => {
      return std::Ok<(), std::error::Error>(());
    }
    std::Err(reason) => {
      return std::Err<(), std::error::Error>(reason);
    }
  }
}

pub fn try_write(path: ref std::string::String, values: std::Slice[u8]) -> std::Option[i64] {
  return byte_count_option(write_raw(path, values));
}

pub fn try_append(path: ref std::string::String, values: std::Slice[u8]) -> std::Option[i64] {
  return byte_count_option(append_raw(path, values));
}

pub fn read_to_string(zone: ref mut Zone, path: ref std::string::String) -> std::Result[std::string::String, std::error::Error] {
  match open_read(path) {
    std::Err(reason) => {
      return std::Err<std::string::String, std::error::Error>(reason);
    }
    std::Ok(file) => {
      var output = std::string::new(zone, 64);
      var byte = file.read_byte();
      while byte >= 0 {
        output.push_in(zone, byte as u8);
        byte = file.read_byte();
      }
      if byte < -1 {
        let read_raw_error = last_errno_error_raw();
        file.close_unchecked();
        drop output;
        return std::Err<std::string::String, std::error::Error>(std::error::from_raw(read_raw_error));
      }
      if file.close().is_ok() {
        return std::Ok<std::string::String, std::error::Error>(output);
      }
      return std::Err<std::string::String, std::error::Error>(std::error::new(std::error::Other));
    }
  }
}

pub fn read_to_string_optional(zone: ref mut Zone, path: ref std::string::String) -> std::Option[std::string::String] {
  return try_read_to_string(zone, path);
}

pub fn read_to_string_or_default(zone: ref mut Zone, path: ref std::string::String) -> std::string::String {
  match try_read_to_string(zone, path) {
    std::Some(output) => {
      return output;
    }
    std::None => {}
  }
  return std::string::new(zone, 64);
}

pub fn read_to_string_unchecked(zone: ref mut Zone, path: ref std::string::String) -> std::string::String {
  match read_to_string(zone, path) {
    std::Ok(output) => {
      return output;
    }
    std::Err(_) => {}
  }
  std::panic();
  return std::string::new(zone, 64);
}

pub fn try_read_to_string(zone: ref mut Zone, path: ref std::string::String) -> std::Option[std::string::String] {
  var output = std::string::new(zone, 64);
  let file = try_open_read(path).unwrap_or(File::invalid());
  if !file.is_open() {
    return std::None<std::string::String>();
  }

  // The current String is byte-oriented; this compatibility helper preserves
  // bytes and discards the reason when a read error interrupts collection.
  var byte = file.read_byte();
  while byte >= 0 {
    output.push_in(zone, byte as u8);
    byte = file.read_byte();
  }
  if byte < -1 {
    file.close_unchecked();
    drop output;
    return std::None<std::string::String>();
  }
  file.close_unchecked();
  return std::Some<std::string::String>(output);
}

pub fn read(zone: ref mut Zone, path: ref std::string::String) -> std::Result[std::string::String, std::error::Error] {
  return read_to_string(zone, path);
}

pub fn read_bytes(zone: ref mut Zone, path: ref std::string::String) -> std::Result[std::vec::Vec[u8], std::error::Error] {
  match read(zone, path) {
    std::Ok(text) => {
      return std::Ok<std::vec::Vec[u8], std::error::Error>(std::vec::from_slice_in<u8>(zone, text.as_slice()));
    }
    std::Err(reason) => {
      return std::Err<std::vec::Vec[u8], std::error::Error>(reason);
    }
  }
}

pub fn read_optional(zone: ref mut Zone, path: ref std::string::String) -> std::Option[std::string::String] {
  return try_read(zone, path);
}

pub fn read_or_default(zone: ref mut Zone, path: ref std::string::String) -> std::string::String {
  return read_to_string_or_default(zone, path);
}

pub fn read_unchecked(zone: ref mut Zone, path: ref std::string::String) -> std::string::String {
  return read_to_string_unchecked(zone, path);
}

pub fn try_read(zone: ref mut Zone, path: ref std::string::String) -> std::Option[std::string::String] {
  return try_read_to_string(zone, path);
}

pub fn truncate(path: ref std::string::String) -> bool {
  let file = try_create(path).unwrap_or(File::invalid());
  if !file.is_open() {
    return false;
  }
  return file.close().is_ok();
}

pub fn copy_bool(source: ref std::string::String, target: ref std::string::String) -> bool {
  match try_copy(source, target) {
    std::Some(_bytes) => {
      return true;
    }
    std::None => {}
  }
  return false;
}

pub fn copy_raw(source: ref std::string::String, target: ref std::string::String) -> std::Result[i64, i64] {
  match open_raw_with_mode_literal(source, "r") {
    std::Ok(reader) => {
      match open_raw_with_mode_literal(target, "w") {
        std::Ok(writer) => {
          var copied = 0;
          var byte = reader.read_byte();
          while byte >= 0 {
            match write_byte_raw(writer, byte as u8) {
              std::Ok(_) => {
                copied = copied + 1;
                byte = reader.read_byte();
              }
              std::Err(write_raw) => {
                reader.close_unchecked();
                writer.close_unchecked();
                return std::Err<i64, i64>(write_raw);
              }
            }
          }
          if byte < -1 {
            let read_raw_error = last_errno_error_raw();
            reader.close_unchecked();
            writer.close_unchecked();
            return std::Err<i64, i64>(read_raw_error);
          }

          match close_raw(reader) {
            std::Ok(_) => {}
            std::Err(read_close_raw) => {
              writer.close_unchecked();
              return std::Err<i64, i64>(read_close_raw);
            }
          }
          match close_raw(writer) {
            std::Ok(_) => {
              return std::Ok<i64, i64>(copied);
            }
            std::Err(write_close_raw) => {
              return std::Err<i64, i64>(write_close_raw);
            }
          }
        }
        std::Err(target_open_raw) => {
          reader.close_unchecked();
          return std::Err<i64, i64>(target_open_raw);
        }
      }
    }
    std::Err(source_open_raw) => {
      return std::Err<i64, i64>(source_open_raw);
    }
  }
}

pub fn copy(source: ref std::string::String, target: ref std::string::String) -> std::Result[i64, std::error::Error] {
  return std::error::map_raw<i64>(copy_raw(source, target));
}

pub fn try_copy(source: ref std::string::String, target: ref std::string::String) -> std::Option[i64] {
  return byte_count_option(copy_raw(source, target));
}

pub fn open_detailed(path: ref std::string::String, mode: ref std::string::String) -> std::Result[File, PathError] {
  return map_path_error<File>(FsOpen, path, open(path, mode));
}

pub fn create_detailed(path: ref std::string::String) -> std::Result[File, PathError] {
  return map_path_error<File>(FsCreate, path, create(path));
}

pub fn read_detailed(
  zone: ref mut Zone,
  path: ref std::string::String
) -> std::Result[std::string::String, PathError] {
  return map_path_error<std::string::String>(FsRead, path, read(zone, path));
}

pub fn read_bytes_detailed(
  zone: ref mut Zone,
  path: ref std::string::String
) -> std::Result[std::vec::Vec[u8], PathError] {
  return map_path_error<std::vec::Vec[u8]>(FsRead, path, read_bytes(zone, path));
}

pub fn write_detailed(
  path: ref std::string::String,
  values: std::Slice[u8]
) -> std::Result[i64, PathError] {
  return map_path_error<i64>(FsWrite, path, write(path, values));
}

pub fn write_string_detailed(
  path: ref std::string::String,
  text: ref std::string::String
) -> std::Result[(), PathError] {
  return map_path_error<()>(FsWrite, path, write_string(path, text));
}

pub fn append_detailed(
  path: ref std::string::String,
  values: std::Slice[u8]
) -> std::Result[i64, PathError] {
  return map_path_error<i64>(FsAppend, path, append(path, values));
}

pub fn remove_file_detailed(path: ref std::string::String) -> std::Result[(), PathError] {
  return map_path_error<()>(FsRemove, path, remove_file(path));
}

pub fn remove_dir_detailed(path: ref std::string::String) -> std::Result[(), PathError] {
  return map_path_error<()>(FsRemoveDir, path, remove_dir(path));
}

pub fn remove_dir_all_detailed(path: ref std::string::String) -> std::Result[(), PathError] {
  return map_path_error<()>(FsRemoveDir, path, remove_dir_all(path));
