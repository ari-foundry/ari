  while index != values.len {
    var first = 0;
    var second = 0;
    var third = 0;
    var fourth = 0;
    match base64_value(values[index]) {
      std::Some(first_value) => { first = first_value; }
      std::None => { std::panic(); }
    }
    match base64_value(values[index + 1]) {
      std::Some(second_value) => { second = second_value; }
      std::None => { std::panic(); }
    }
    output.push_in(zone, ((first * 4) + (second / 16)) as u8);

    if !is_base64_padding(values[index + 2]) {
      match base64_value(values[index + 2]) {
        std::Some(third_value) => { third = third_value; }
        std::None => { std::panic(); }
      }
      output.push_in(zone, (((second % 16) * 16) + (third / 4)) as u8);
    }

    if !is_base64_padding(values[index + 3]) {
      match base64_value(values[index + 3]) {
        std::Some(fourth_value) => { fourth = fourth_value; }
        std::None => { std::panic(); }
      }
      output.push_in(zone, (((third % 4) * 64) + fourth) as u8);
    }
    index = index + 4;
  }
  return output;
}

pub fn decode_base64_url_unchecked_in(zone: ref mut Zone, values: std::Slice[u8]) -> std::string::String {
  var length = 0;
  match base64_url_decoded_len_optional(values) {
    std::Some(decoded_length) => {
      length = decoded_length;
    }
    std::None => {
      std::panic();
    }
  }

  var output = std::string::new(zone, length);
  var index = 0;
  while index + 4 <= values.len {
    let first = base64_url_value_unchecked(values[index]);
    let second = base64_url_value_unchecked(values[index + 1]);
    var third = 0;
    var fourth = 0;
    output.push_in(zone, ((first * 4) + (second / 16)) as u8);

    if !is_base64_padding(values[index + 2]) {
      third = base64_url_value_unchecked(values[index + 2]);
      output.push_in(zone, (((second % 16) * 16) + (third / 4)) as u8);
    }

    if !is_base64_padding(values[index + 3]) {
      fourth = base64_url_value_unchecked(values[index + 3]);
      output.push_in(zone, (((third % 4) * 64) + fourth) as u8);
    }
    index = index + 4;
  }

  if index < values.len {
    let first_partial = base64_url_value_unchecked(values[index]);
    let second_partial = base64_url_value_unchecked(values[index + 1]);
    output.push_in(zone, ((first_partial * 4) + (second_partial / 16)) as u8);
    if index + 2 < values.len {
      let third_partial = base64_url_value_unchecked(values[index + 2]);
      output.push_in(zone, (((second_partial % 16) * 16) + (third_partial / 4)) as u8);
    }
  }
  return output;
}

