    }
  }

  var output = std::string::new(zone, length);
  if value <= 127u32 {
    output.push_in(zone, value as u8);
    return output;
  }
  if value <= 2047u32 {
    output.push_in(zone, ((value / 64u32) + 192u32) as u8);
    output.push_in(zone, ((value % 64u32) + 128u32) as u8);
