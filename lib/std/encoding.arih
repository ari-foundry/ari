// Byte encoding and validation helpers.
//
// `String` results are byte strings allocated in the caller-provided zone.
// The validation routines avoid allocation and return Option counts when a
// caller needs both validation and decoded code-point length.

pub struct Utf8Char {
  scalar: u32,
  len: i64,
}

pub enum Utf8ErrorKind {
  InvalidLead,
  UnexpectedEnd,
  InvalidContinuation,
  OverlongEncoding,
  SurrogateCodePoint,
  OutOfRangeCodePoint,
}

pub enum CodecErrorKind {
  InvalidLength,
  InvalidByte,
  InvalidPadding,
}

pub struct CodecError {
  index_value: i64,
  byte_value: u8,
  kind_id: i64,
}

pub struct Utf8Error {
  index: i64,
  byte: u8,
  kind_id: i64,
}

pub impl std::encoding::CodecError {
  fn index(self: ref Self) -> i64 {
    return self.index_value;
  }

  fn byte(self: ref Self) -> u8 {
    return self.byte_value;
  }

  fn kind(self: ref Self) -> std::encoding::CodecErrorKind {
    return codec_error_kind_from_id(self.kind_id);
  }

  fn is_invalid_length(self: ref Self) -> bool {
    return self.kind_id == codec_error_kind_id(std::encoding::InvalidLength);
  }

  fn is_invalid_byte(self: ref Self) -> bool {
    return self.kind_id == codec_error_kind_id(std::encoding::InvalidByte);
  }

  fn is_invalid_padding(self: ref Self) -> bool {
    return self.kind_id == codec_error_kind_id(std::encoding::InvalidPadding);
  }
}

pub impl std::encoding::Utf8Char {
  fn scalar(self: ref Self) -> u32 {
    return self.scalar;
  }

  fn len(self: ref Self) -> i64 {
    return self.len;
  }

  fn next_index(self: ref Self, index: i64) -> i64 {
    return index + self.len;
  }
}

pub impl std::encoding::Utf8Error {
  fn index(self: ref Self) -> i64 {
    return self.index;
  }

  fn byte(self: ref Self) -> u8 {
    return self.byte;
  }

  fn kind(self: ref Self) -> std::encoding::Utf8ErrorKind {
    return utf8_error_kind_from_id(self.kind_id);
  }

  fn is_invalid_lead(self: ref Self) -> bool {
    return self.kind_id == utf8_error_kind_id(std::encoding::InvalidLead);
  }

  fn is_unexpected_end(self: ref Self) -> bool {
    return self.kind_id == utf8_error_kind_id(std::encoding::UnexpectedEnd);
  }

  fn is_invalid_continuation(self: ref Self) -> bool {
    return self.kind_id == utf8_error_kind_id(std::encoding::InvalidContinuation);
  }

  fn is_overlong(self: ref Self) -> bool {
    return self.kind_id == utf8_error_kind_id(std::encoding::OverlongEncoding);
  }

  fn is_surrogate(self: ref Self) -> bool {
    return self.kind_id == utf8_error_kind_id(std::encoding::SurrogateCodePoint);
  }

  fn is_out_of_range(self: ref Self) -> bool {
    return self.kind_id == utf8_error_kind_id(std::encoding::OutOfRangeCodePoint);
  }
}

fn utf8_error_kind_id(kind: std::encoding::Utf8ErrorKind) -> i64 {
  match kind {
    InvalidLead => { return 1; }
    UnexpectedEnd => { return 2; }
    InvalidContinuation => { return 3; }
    OverlongEncoding => { return 4; }
    SurrogateCodePoint => { return 5; }
    OutOfRangeCodePoint => { return 6; }
  }
}

fn utf8_error_kind_from_id(id: i64) -> std::encoding::Utf8ErrorKind {
  if id == 1 { return InvalidLead; }
  if id == 2 { return UnexpectedEnd; }
  if id == 3 { return InvalidContinuation; }
  if id == 4 { return OverlongEncoding; }
  if id == 5 { return SurrogateCodePoint; }
  return OutOfRangeCodePoint;
}

fn codec_error_kind_id(kind: std::encoding::CodecErrorKind) -> i64 {
  match kind {
    InvalidLength => { return 1; }
    InvalidByte => { return 2; }
    InvalidPadding => { return 3; }
  }
}

fn codec_error_kind_from_id(id: i64) -> std::encoding::CodecErrorKind {
  if id == 1 { return InvalidLength; }
  if id == 2 { return InvalidByte; }
  return InvalidPadding;
}

fn codec_error_at(index: i64, byte: u8, kind: std::encoding::CodecErrorKind) -> std::encoding::CodecError {
  return std::encoding::CodecError {
    index_value: index,
    byte_value: byte,
    kind_id: codec_error_kind_id(kind),
  };
}

fn codec_length_error(index: i64) -> std::encoding::CodecError {
  return codec_error_at(index, 0u8, std::encoding::InvalidLength);
}

fn utf8_error_at(index: i64, byte: u8, kind: std::encoding::Utf8ErrorKind) -> std::encoding::Utf8Error {
  return std::encoding::Utf8Error {
    index: index,
    byte: byte,
    kind_id: utf8_error_kind_id(kind),
  };
}

fn invalid_data_error() -> std::error::Error {
  return std::error::new(std::error::InvalidData);
}

fn utf8_scalar_error(value: u32) -> std::encoding::Utf8Error {
  if is_surrogate_scalar(value) {
    return utf8_error_at(0, 0u8, std::encoding::SurrogateCodePoint);
  }
  return utf8_error_at(0, 0u8, std::encoding::OutOfRangeCodePoint);
}

fn hex_digit(value: i64) -> u8 {
  if value < 10 {
    return (value + ('0' as i64)) as u8;
  }
  return ((value - 10) + ('a' as i64)) as u8;
}

fn is_base64_padding(value: u8) -> bool {
  return value == '=';
}

fn base64_digit(value: i64) -> u8 {
  if value < 26 {
    return (value + ('A' as i64)) as u8;
  }
  if value < 52 {
    return ((value - 26) + ('a' as i64)) as u8;
  }
  if value < 62 {
    return ((value - 52) + ('0' as i64)) as u8;
  }
  if value == 62 {
    return '+';
  }
  return '/';
}

fn base64_value(value: u8) -> std::Option[i64] {
  if value >= 'A' && value <= 'Z' {
    return std::Some<i64>((value as i64) - ('A' as i64));
  }
  if value >= 'a' && value <= 'z' {
    return std::Some<i64>(((value as i64) - ('a' as i64)) + 26);
  }
  if value >= '0' && value <= '9' {
    return std::Some<i64>(((value as i64) - ('0' as i64)) + 52);
  }
  if value == '+' {
    return std::Some<i64>(62);
  }
  if value == '/' {
    return std::Some<i64>(63);
  }
  return std::None<i64>();
}

fn base64_url_digit(value: i64) -> u8 {
  if value < 26 {
    return (value + ('A' as i64)) as u8;
  }
  if value < 52 {
    return ((value - 26) + ('a' as i64)) as u8;
  }
  if value < 62 {
    return ((value - 52) + ('0' as i64)) as u8;
  }
  if value == 62 {
    return '-';
  }
  return '_';
}

fn base64_url_value(value: u8) -> std::Option[i64] {
  if value >= 'A' && value <= 'Z' {
    return std::Some<i64>((value as i64) - ('A' as i64));
  }
  if value >= 'a' && value <= 'z' {
    return std::Some<i64>(((value as i64) - ('a' as i64)) + 26);
  }
  if value >= '0' && value <= '9' {
    return std::Some<i64>(((value as i64) - ('0' as i64)) + 52);
  }
  if value == '-' {
    return std::Some<i64>(62);
  }
  if value == '_' {
    return std::Some<i64>(63);
  }
  return std::None<i64>();
}

fn base64_url_value_unchecked(value: u8) -> i64 {
  match base64_url_value(value) {
    std::Some(decoded) => {
      return decoded;
    }
    std::None => {
      std::panic();
    }
  }
  return 0;
}

fn is_base64_mime_ignored(value: u8) -> bool {
  if value == '\r' {
    return true;
  }
  if value == '\n' {
    return true;
  }
  if value == ' ' {
    return true;
  }
  return value == '\t';
}

fn push_base64_mime_byte(
  output: ref mut std::string::String,
  line_len: i64,
  value: u8
) -> i64 {
  var next_line_len = line_len;
  if next_line_len == 76 {
    output.push('\r');
    output.push('\n');
    next_line_len = 0;
  }
  output.push(value);
  return next_line_len + 1;
}

fn is_utf8_continuation(value: u8) -> bool {
  if value < (128 as u8) {
    return false;
  }
  return value <= (191 as u8);
}

fn is_surrogate_scalar(value: u32) -> bool {
  if value < 55296u32 {
    return false;
  }
  return value <= 57343u32;
}

fn is_high_surrogate(value: u16) -> bool {
  if value < (55296 as u16) {
    return false;
  }
  return value <= (56319 as u16);
}

fn is_low_surrogate(value: u16) -> bool {
  if value < (56320 as u16) {
    return false;
  }
  return value <= (57343 as u16);
}

pub fn is_ascii(values: std::Slice[u8]) -> bool {
  var index = 0;
  while index != values.len {
    if values[index] > (127 as u8) {
      return false;
    }
    index = index + 1;
  }
  return true;
}

pub fn is_unicode_scalar(value: u32) -> bool {
  return value <= 1114111u32 && !is_surrogate_scalar(value);
}

pub fn utf8_error(values: std::Slice[u8]) -> std::Option[std::encoding::Utf8Error] {
  var index = 0;
  while index != values.len {
    let first = values[index];
    if first <= (127 as u8) {
      index = index + 1;
    } else if first >= (194 as u8) && first <= (223 as u8) {
      if index + 1 >= values.len {
        return std::Some<std::encoding::Utf8Error>(
          utf8_error_at(index, first, std::encoding::UnexpectedEnd)
        );
      }
      let second2 = values[index + 1];
      if !is_utf8_continuation(second2) {
        return std::Some<std::encoding::Utf8Error>(
          utf8_error_at(index + 1, second2, std::encoding::InvalidContinuation)
        );
      }
      index = index + 2;
    } else if first >= (224 as u8) && first <= (239 as u8) {
      if index + 1 >= values.len {
        return std::Some<std::encoding::Utf8Error>(
          utf8_error_at(index, first, std::encoding::UnexpectedEnd)
        );
      }
      let second3 = values[index + 1];
      if !is_utf8_continuation(second3) {
        return std::Some<std::encoding::Utf8Error>(
          utf8_error_at(index + 1, second3, std::encoding::InvalidContinuation)
        );
      }
      if first == (224 as u8) && second3 < (160 as u8) {
        return std::Some<std::encoding::Utf8Error>(
          utf8_error_at(index, first, std::encoding::OverlongEncoding)
        );
      }
      if first == (237 as u8) && second3 >= (160 as u8) {
        return std::Some<std::encoding::Utf8Error>(
          utf8_error_at(index, first, std::encoding::SurrogateCodePoint)
        );
      }
      if index + 2 >= values.len {
        return std::Some<std::encoding::Utf8Error>(
          utf8_error_at(index, first, std::encoding::UnexpectedEnd)
        );
      }
      let third3 = values[index + 2];
      if !is_utf8_continuation(third3) {
        return std::Some<std::encoding::Utf8Error>(
          utf8_error_at(index + 2, third3, std::encoding::InvalidContinuation)
        );
      }
      index = index + 3;
    } else if first >= (240 as u8) && first <= (244 as u8) {
      if index + 1 >= values.len {
        return std::Some<std::encoding::Utf8Error>(
          utf8_error_at(index, first, std::encoding::UnexpectedEnd)
        );
      }
      let second4 = values[index + 1];
      if !is_utf8_continuation(second4) {
        return std::Some<std::encoding::Utf8Error>(
          utf8_error_at(index + 1, second4, std::encoding::InvalidContinuation)
        );
      }
      if first == (240 as u8) && second4 < (144 as u8) {
        return std::Some<std::encoding::Utf8Error>(
          utf8_error_at(index, first, std::encoding::OverlongEncoding)
        );
      }
      if first == (244 as u8) && second4 >= (144 as u8) {
        return std::Some<std::encoding::Utf8Error>(
          utf8_error_at(index, first, std::encoding::OutOfRangeCodePoint)
        );
      }
      if index + 2 >= values.len {
        return std::Some<std::encoding::Utf8Error>(
          utf8_error_at(index, first, std::encoding::UnexpectedEnd)
        );
      }
      let third4 = values[index + 2];
      if !is_utf8_continuation(third4) {
        return std::Some<std::encoding::Utf8Error>(
          utf8_error_at(index + 2, third4, std::encoding::InvalidContinuation)
        );
      }
      if index + 3 >= values.len {
        return std::Some<std::encoding::Utf8Error>(
          utf8_error_at(index, first, std::encoding::UnexpectedEnd)
        );
      }
      let fourth4 = values[index + 3];
      if !is_utf8_continuation(fourth4) {
        return std::Some<std::encoding::Utf8Error>(
          utf8_error_at(index + 3, fourth4, std::encoding::InvalidContinuation)
        );
      }
      index = index + 4;
    } else if first == (192 as u8) || first == (193 as u8) {
      return std::Some<std::encoding::Utf8Error>(
        utf8_error_at(index, first, std::encoding::OverlongEncoding)
      );
    } else if first >= (245 as u8) {
      return std::Some<std::encoding::Utf8Error>(
        utf8_error_at(index, first, std::encoding::OutOfRangeCodePoint)
      );
    } else {
      return std::Some<std::encoding::Utf8Error>(
        utf8_error_at(index, first, std::encoding::InvalidLead)
      );
    }
  }
  return std::None<std::encoding::Utf8Error>();
}

pub fn validate_utf8_optional(values: std::Slice[u8]) -> std::Option[std::encoding::Utf8Error] {
  return utf8_error(values);
}

pub fn validate_utf8(values: std::Slice[u8]) -> std::Result[(), std::encoding::Utf8Error] {
  match utf8_error(values) {
    std::Some(reason) => {
      return std::Err<(), std::encoding::Utf8Error>(reason);
    }
    std::None => {
      return std::Ok<(), std::encoding::Utf8Error>(());
    }
  }
}

pub fn decode_utf8(zone: ref mut Zone, values: std::Slice[u8]) -> std::Result[std::string::String, std::encoding::Utf8Error] {
  match validate_utf8(values) {
    std::Err(reason) => {
      return std::Err<std::string::String, std::encoding::Utf8Error>(reason);
    }
    std::Ok(_) => {
      return std::Ok<std::string::String, std::encoding::Utf8Error>(
        std::string::from_slice_in(zone, values)
      );
    }
  }
}

pub fn decode_utf8_in(zone: ref mut Zone, values: std::Slice[u8]) -> std::Result[std::string::String, std::encoding::Utf8Error] {
  return decode_utf8(zone, values);
}

pub fn decode_utf8_optional_in(zone: ref mut Zone, values: std::Slice[u8]) -> std::Option[std::string::String] {
  match decode_utf8(zone, values) {
    std::Ok(text) => {
      return std::Some<std::string::String>(text);
    }
    std::Err(_) => {
      return std::None<std::string::String>();
    }
  }
}

pub fn decode_utf8_unchecked_in(zone: ref mut Zone, values: std::Slice[u8]) -> std::string::String {
  match decode_utf8(zone, values) {
    std::Ok(text) => {
      return text;
    }
    std::Err(_) => {
      std::panic();
    }
  }
}

pub fn utf8_width(first: u8) -> std::Option[i64] {
  if first <= (127 as u8) {
    return std::Some<i64>(1);
  }
  if first >= (194 as u8) && first <= (223 as u8) {
    return std::Some<i64>(2);
  }
  if first >= (224 as u8) && first <= (239 as u8) {
    return std::Some<i64>(3);
  }
  if first >= (240 as u8) && first <= (244 as u8) {
    return std::Some<i64>(4);
  }
  return std::None<i64>();
}

pub fn utf8_encoded_len(value: u32) -> std::Option[i64] {
  if !is_unicode_scalar(value) {
    return std::None<i64>();
  }
  if value <= 127u32 {
    return std::Some<i64>(1);
  }
  if value <= 2047u32 {
    return std::Some<i64>(2);
  }
  if value <= 65535u32 {
    return std::Some<i64>(3);
  }
  return std::Some<i64>(4);
}

pub fn utf8_at(values: std::Slice[u8], index: i64) -> std::Option[std::encoding::Utf8Char] {
  if index < 0 {
    return std::None<std::encoding::Utf8Char>();
  }
  if index >= values.len {
    return std::None<std::encoding::Utf8Char>();
  }

  let first = values[index];
  if first <= (127 as u8) {
    return std::Some<std::encoding::Utf8Char>(Utf8Char { scalar: first as u32, len: 1 });
  }

  if first >= (194 as u8) && first <= (223 as u8) {
    if index + 1 >= values.len {
      return std::None<std::encoding::Utf8Char>();
    }
    let second2 = values[index + 1];
    if !is_utf8_continuation(second2) {
      return std::None<std::encoding::Utf8Char>();
    }
    let scalar2 = (((first as u32) - 192u32) * 64u32) + ((second2 as u32) - 128u32);
    return std::Some<std::encoding::Utf8Char>(Utf8Char { scalar: scalar2, len: 2 });
  }

  if first >= (224 as u8) && first <= (239 as u8) {
    if index + 2 >= values.len {
      return std::None<std::encoding::Utf8Char>();
    }
    let second3 = values[index + 1];
    let third3 = values[index + 2];
    if !is_utf8_continuation(second3) {
      return std::None<std::encoding::Utf8Char>();
    }
    if !is_utf8_continuation(third3) {
      return std::None<std::encoding::Utf8Char>();
    }
    if first == (224 as u8) {
      if second3 < (160 as u8) {
        return std::None<std::encoding::Utf8Char>();
      }
    }
    if first == (237 as u8) {
      if second3 >= (160 as u8) {
        return std::None<std::encoding::Utf8Char>();
      }
    }
    let scalar3 =
      (((first as u32) - 224u32) * 4096u32) +
      (((second3 as u32) - 128u32) * 64u32) +
      ((third3 as u32) - 128u32);
    return std::Some<std::encoding::Utf8Char>(Utf8Char { scalar: scalar3, len: 3 });
  }

  if first >= (240 as u8) && first <= (244 as u8) {
    if index + 3 >= values.len {
      return std::None<std::encoding::Utf8Char>();
    }
    let second4 = values[index + 1];
    let third4 = values[index + 2];
    let fourth4 = values[index + 3];
    if !is_utf8_continuation(second4) {
      return std::None<std::encoding::Utf8Char>();
    }
    if !is_utf8_continuation(third4) {
      return std::None<std::encoding::Utf8Char>();
    }
    if !is_utf8_continuation(fourth4) {
      return std::None<std::encoding::Utf8Char>();
    }
    if first == (240 as u8) {
      if second4 < (144 as u8) {
        return std::None<std::encoding::Utf8Char>();
      }
    }
    if first == (244 as u8) {
      if second4 >= (144 as u8) {
        return std::None<std::encoding::Utf8Char>();
      }
    }
    let scalar4 =
      (((first as u32) - 240u32) * 262144u32) +
      (((second4 as u32) - 128u32) * 4096u32) +
      (((third4 as u32) - 128u32) * 64u32) +
      ((fourth4 as u32) - 128u32);
    return std::Some<std::encoding::Utf8Char>(Utf8Char { scalar: scalar4, len: 4 });
  }

  return std::None<std::encoding::Utf8Char>();
}

pub fn utf8_next_index(values: std::Slice[u8], index: i64) -> std::Option[i64] {
  match utf8_at(values, index) {
    std::Some(value) => {
      return std::Some<i64>(value.next_index(index));
    }
    std::None => {}
  }
  return std::None<i64>();
}

pub fn utf8_count_optional(values: std::Slice[u8]) -> std::Option[i64] {
  var index = 0;
  var count = 0;
  while index != values.len {
    let first = values[index];
    if first <= (127 as u8) {
      index = index + 1;
      count = count + 1;
    } else if first >= (194 as u8) && first <= (223 as u8) {
      if index + 1 >= values.len {
        return std::None<i64>();
      }
      if !is_utf8_continuation(values[index + 1]) {
        return std::None<i64>();
      }
      index = index + 2;
      count = count + 1;
    } else if first >= (224 as u8) && first <= (239 as u8) {
      if index + 2 >= values.len {
        return std::None<i64>();
      }
      let second3 = values[index + 1];
      let third3 = values[index + 2];
      if !is_utf8_continuation(second3) {
        return std::None<i64>();
      }
      if !is_utf8_continuation(third3) {
        return std::None<i64>();
      }
      if first == (224 as u8) {
        if second3 < (160 as u8) {
          return std::None<i64>();
        }
      }
      if first == (237 as u8) {
        if second3 >= (160 as u8) {
          return std::None<i64>();
        }
      }
      index = index + 3;
      count = count + 1;
    } else if first >= (240 as u8) && first <= (244 as u8) {
      if index + 3 >= values.len {
        return std::None<i64>();
      }
      let second4 = values[index + 1];
      let third4 = values[index + 2];
      let fourth4 = values[index + 3];
      if !is_utf8_continuation(second4) {
        return std::None<i64>();
      }
      if !is_utf8_continuation(third4) {
        return std::None<i64>();
      }
      if !is_utf8_continuation(fourth4) {
        return std::None<i64>();
      }
      if first == (240 as u8) {
        if second4 < (144 as u8) {
          return std::None<i64>();
        }
      }
      if first == (244 as u8) {
        if second4 >= (144 as u8) {
          return std::None<i64>();
        }
      }
      index = index + 4;
      count = count + 1;
    } else {
      return std::None<i64>();
    }
  }
  return std::Some<i64>(count);
}

pub fn utf8_count(values: std::Slice[u8]) -> std::Result[i64, std::error::Error] {
  match utf8_count_optional(values) {
    std::Some(value) => {
      return std::Ok<i64, std::error::Error>(value);
    }
    std::None => {
      return std::Err<i64, std::error::Error>(invalid_data_error());
    }
  }
}

pub fn is_utf8(values: std::Slice[u8]) -> bool {
  match utf8_count_optional(values) {
    std::Some(_) => {
      return true;
    }
    std::None => {
      return false;
    }
  }
}

pub fn utf16_count_optional(values: std::Slice[u16]) -> std::Option[i64] {
  var index = 0;
  var count = 0;
  while index != values.len {
    let first = values[index];
    if is_high_surrogate(first) {
      if index + 1 >= values.len {
        return std::None<i64>();
      }
      if !is_low_surrogate(values[index + 1]) {
        return std::None<i64>();
      }
      index = index + 2;
      count = count + 1;
    } else if is_low_surrogate(first) {
      return std::None<i64>();
    } else {
      index = index + 1;
      count = count + 1;
    }
  }
