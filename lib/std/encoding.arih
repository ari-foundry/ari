  output.push_in(zone, ((value / 262144u32) + 240u32) as u8);
  output.push_in(zone, (((value / 4096u32) % 64u32) + 128u32) as u8);
  output.push_in(zone, (((value / 64u32) % 64u32) + 128u32) as u8);
