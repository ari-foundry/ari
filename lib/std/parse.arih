pub fn boolean_optional(values: std::Slice[u8]) -> std::Option[bool] {
  let input = std::ascii::trim(values);
  var true_bytes = ['t', 'r', 'u', 'e'];
  var false_bytes = ['f', 'a', 'l', 's', 'e'];

  if input.equals(true_bytes.as_slice()) {
    return std::Some<bool>(true);
  }
  if input.equals(false_bytes.as_slice()) {
    return std::Some<bool>(false);
  }
  return std::None<bool>();
}

pub fn boolean(values: std::Slice[u8]) -> std::Result[bool, std::error::Error] {
  match boolean_optional(values) {
    std::Some(value) => {
      return std::Ok<bool, std::error::Error>(value);
    }
    std::None => {
      return std::Err<bool, std::error::Error>(invalid_data_error());
    }
  }
}

