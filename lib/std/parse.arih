fn unsigned_radix_error_with_separator_policy(
  values: std::Slice[u8],
  radix: i64,
  allow_separators: bool
) -> std::Option[std::parse::ParseError] {
  let input = std::ascii::trim(values);
  if input.len == 0 {
    return std::Some<std::parse::ParseError>(std::parse::parse_error(EmptyInput, 0));
  }
  if radix < 2 || radix > 36 {
    return std::Some<std::parse::ParseError>(std::parse::parse_error(InvalidRadix, 0));
  }

  var index = 0;
  if input[0] == '+' {
    index = 1;
  } else if input[0] == '-' {
    return std::Some<std::parse::ParseError>(std::parse::parse_error(InvalidSign, 0));
  }

  if index >= input.len {
    return std::Some<std::parse::ParseError>(std::parse::parse_error(ExpectedDigit, index));
  }

  let limit = u64_max_value();
  let radix_value = radix as u64;
  var result = 0u64;
  var seen_digit = false;
  var previous_digit = false;
  while index < input.len {
    let value = input[index];
    if value == '_' {
      if !allow_separators {
        return std::Some<std::parse::ParseError>(std::parse::parse_error(InvalidSeparator, index));
      }
      if !previous_digit {
        return std::Some<std::parse::ParseError>(std::parse::parse_error(InvalidSeparator, index));
      }
      if index + 1 >= input.len {
        return std::Some<std::parse::ParseError>(std::parse::parse_error(InvalidSeparator, index));
      }
      match radix_digit_value(input[index + 1], radix) {
        std::Some(_) => {}
        std::None => {
          return std::Some<std::parse::ParseError>(std::parse::parse_error(InvalidSeparator, index));
        }
      }
      previous_digit = false;
    } else {
      match radix_digit_value(value, radix) {
        std::Some(digit_value) => {
          let digit = digit_value as u64;
          if result > (limit - digit) / radix_value {
            return std::Some<std::parse::ParseError>(std::parse::parse_error(Overflow, index));
          }
          result = (result * radix_value) + digit;
          seen_digit = true;
          previous_digit = true;
        }
        std::None => {
          return std::Some<std::parse::ParseError>(std::parse::parse_error(InvalidDigit, index));
        }
      }
    }
    index = index + 1;
  }

  if !seen_digit {
    return std::Some<std::parse::ParseError>(std::parse::parse_error(ExpectedDigit, index));
  }
  if allow_separators && !previous_digit {
    return std::Some<std::parse::ParseError>(std::parse::parse_error(InvalidSeparator, input.len - 1));
  }
