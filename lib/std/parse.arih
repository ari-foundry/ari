// Text-to-value parsers over borrowed byte slices.
//
// These helpers are intentionally ASCII based. They trim ASCII whitespace for
// ergonomic input handling, then require the remaining bytes to form exactly
// one value so callers do not accidentally ignore trailing garbage.

fn pow10(exponent: i64) -> f64 {
  var result = 1.0f64;
  if exponent >= 0 {
    var index = 0;
    while index < exponent {
      result = result * 10.0f64;
      index = index + 1;
    }
    return result;
  }

  var negative_index = 0;
  while negative_index < (0 - exponent) {
    result = result / 10.0f64;
    negative_index = negative_index + 1;
  }
  return result;
}

fn i64_max_magnitude() -> u64 {
  return 9223372036854775807u64;
}

fn i64_min_magnitude() -> u64 {
  return 9223372036854775808u64;
}

fn i64_min_value() -> i64 {
  return -9223372036854775807 - 1;
}

fn u64_max_value() -> u64 {
  return 18446744073709551615u64;
}

fn radix_digit_value(value: char, radix: i64) -> std::Option[i64] {
  if radix < 2 || radix > 36 {
    return std::None<i64>();
  }

  var digit = -1;
  if value >= '0' && value <= '9' {
    digit = (value as i64) - ('0' as i64);
  } else if value >= 'A' && value <= 'Z' {
    digit = ((value as i64) - ('A' as i64)) + 10;
  } else if value >= 'a' && value <= 'z' {
    digit = ((value as i64) - ('a' as i64)) + 10;
  }

  if digit >= 0 && digit < radix {
    return std::Some<i64>(digit);
  }
  return std::None<i64>();
}

fn invalid_input_error() -> std::error::Error {
  return std::error::new(std::error::InvalidInput);
}

fn invalid_data_error() -> std::error::Error {
  return std::error::new(std::error::InvalidData);
}

pub enum ParseErrorKind {
  EmptyInput,
  ExpectedDigit,
  InvalidRadix,
  InvalidDigit,
  InvalidSign,
  InvalidSeparator,
  Overflow,
  Underflow,
}

pub struct ParseError {
  kind_value: std::parse::ParseErrorKind,
  offset_value: i64,
}

fn parse_error(kind: std::parse::ParseErrorKind, offset: i64) -> std::parse::ParseError {
  return std::parse::ParseError {
    kind_value: kind,
    offset_value: offset,
  };
}

pub impl std::parse::ParseError {
  fn kind(self: ref Self) -> std::parse::ParseErrorKind {
    return self.kind_value;
  }

  fn offset(self: ref Self) -> i64 {
    return self.offset_value;
  }

  fn name(self: ref Self) -> string {
    match self.kind_value {
      EmptyInput => { return "empty input"; }
      ExpectedDigit => { return "expected digit"; }
      InvalidRadix => { return "invalid radix"; }
      InvalidDigit => { return "invalid digit"; }
      InvalidSign => { return "invalid sign"; }
      InvalidSeparator => { return "invalid separator"; }
      Overflow => { return "overflow"; }
      Underflow => { return "underflow"; }
    }
  }

  fn message(self: ref Self) -> string {
    match self.kind_value {
      EmptyInput => { return "input is empty after ASCII trim"; }
      ExpectedDigit => { return "expected a digit at this offset"; }
      InvalidRadix => { return "radix must be between 2 and 36"; }
      InvalidDigit => { return "input contains a byte that is not valid here"; }
      InvalidSign => { return "sign is not accepted by this parser"; }
      InvalidSeparator => { return "digit separator is missing a digit neighbor or is not allowed"; }
      Overflow => { return "parsed value is above the accepted range"; }
      Underflow => { return "parsed value is below the accepted nonzero range"; }
    }
  }

  fn is_empty_input(self: ref Self) -> bool {
    match self.kind_value {
      EmptyInput => { return true; }
      _ => { return false; }
    }
  }

  fn is_expected_digit(self: ref Self) -> bool {
    match self.kind_value {
      ExpectedDigit => { return true; }
      _ => { return false; }
    }
  }

  fn is_invalid_radix(self: ref Self) -> bool {
    match self.kind_value {
      InvalidRadix => { return true; }
      _ => { return false; }
    }
  }

  fn is_invalid_digit(self: ref Self) -> bool {
    match self.kind_value {
      InvalidDigit => { return true; }
      _ => { return false; }
    }
  }

  fn is_invalid_sign(self: ref Self) -> bool {
    match self.kind_value {
      InvalidSign => { return true; }
      _ => { return false; }
    }
  }

  fn is_invalid_separator(self: ref Self) -> bool {
    match self.kind_value {
      InvalidSeparator => { return true; }
      _ => { return false; }
    }
  }

  fn is_overflow(self: ref Self) -> bool {
    match self.kind_value {
      Overflow => { return true; }
      _ => { return false; }
    }
  }

  fn is_underflow(self: ref Self) -> bool {
    match self.kind_value {
      Underflow => { return true; }
      _ => { return false; }
    }
  }
}

pub trait Parse {
  fn parse(values: std::Slice[u8]) -> Self;
  fn parse_or(values: std::Slice[u8], fallback: Self) -> Self;
  fn is_parse(values: std::Slice[u8]) -> bool;
}

pub fn parse[T: std::parse::Parse](values: std::Slice[u8]) -> T {
  return std::parse::Parse::parse<T>(values);
}

pub fn parse_or[T: std::parse::Parse](values: std::Slice[u8], fallback: T) -> T {
  return std::parse::Parse::parse_or<T>(values, fallback);
}

pub fn is_parse[T: std::parse::Parse](values: std::Slice[u8]) -> bool {
  return std::parse::Parse::is_parse<T>(values);
}

pub fn integer_radix_optional(values: std::Slice[u8], radix: i64) -> std::Option[i64] {
  let input = std::ascii::trim(values);
  if input.len == 0 {
    return std::None<i64>();
  }
  if radix < 2 || radix > 36 {
    return std::None<i64>();
  }

  var sign = 1;
  var index = 0;
  if input[0] == '-' {
    sign = -1;
    index = 1;
  } else if input[0] == '+' {
    index = 1;
  }

  if index >= input.len {
    return std::None<i64>();
  }

  let limit = if sign < 0 { i64_min_magnitude() } else { i64_max_magnitude() };
  let radix_value = radix as u64;
  var result = 0u64;
  while index < input.len {
    match radix_digit_value(input[index], radix) {
      std::Some(value) => {
        let digit = value as u64;
        if result > (limit - digit) / radix_value {
          return std::None<i64>();
        }
        result = (result * radix_value) + digit;
      }
      std::None => {
        return std::None<i64>();
      }
    }
    index = index + 1;
  }
  if sign < 0 {
    if result == i64_min_magnitude() {
      return std::Some<i64>(i64_min_value());
    }
    return std::Some<i64>(0 - (result as i64));
  }
  return std::Some<i64>(result as i64);
}

fn integer_radix_error_with_separator_policy(
  values: std::Slice[u8],
  radix: i64,
  allow_separators: bool
) -> std::Option[std::parse::ParseError] {
  let input = std::ascii::trim(values);
  if input.len == 0 {
    return std::Some<std::parse::ParseError>(std::parse::parse_error(EmptyInput, 0));
  }
  if radix < 2 || radix > 36 {
    return std::Some<std::parse::ParseError>(std::parse::parse_error(InvalidRadix, 0));
  }

  var sign = 1;
  var index = 0;
  if input[0] == '-' {
    sign = -1;
    index = 1;
  } else if input[0] == '+' {
    index = 1;
  }

  if index >= input.len {
    return std::Some<std::parse::ParseError>(std::parse::parse_error(ExpectedDigit, index));
  }

  let limit = if sign < 0 { i64_min_magnitude() } else { i64_max_magnitude() };
  let radix_value = radix as u64;
  var result = 0u64;
  var seen_digit = false;
  var previous_digit = false;
  while index < input.len {
    let value = input[index];
    if value == '_' {
      if !allow_separators {
        return std::Some<std::parse::ParseError>(std::parse::parse_error(InvalidSeparator, index));
      }
      if !previous_digit {
        return std::Some<std::parse::ParseError>(std::parse::parse_error(InvalidSeparator, index));
      }
      if index + 1 >= input.len {
        return std::Some<std::parse::ParseError>(std::parse::parse_error(InvalidSeparator, index));
      }
      match radix_digit_value(input[index + 1], radix) {
        std::Some(_) => {}
        std::None => {
          return std::Some<std::parse::ParseError>(std::parse::parse_error(InvalidSeparator, index));
        }
      }
      previous_digit = false;
    } else {
      match radix_digit_value(value, radix) {
        std::Some(digit_value) => {
          let digit = digit_value as u64;
          if result > (limit - digit) / radix_value {
            return std::Some<std::parse::ParseError>(std::parse::parse_error(Overflow, index));
          }
          result = (result * radix_value) + digit;
          seen_digit = true;
          previous_digit = true;
        }
        std::None => {
          return std::Some<std::parse::ParseError>(std::parse::parse_error(InvalidDigit, index));
        }
      }
    }
    index = index + 1;
  }

  if !seen_digit {
    return std::Some<std::parse::ParseError>(std::parse::parse_error(ExpectedDigit, index));
  }
  if allow_separators && !previous_digit {
    return std::Some<std::parse::ParseError>(std::parse::parse_error(InvalidSeparator, input.len - 1));
  }
  return std::None<std::parse::ParseError>();
}

pub fn integer_radix_error(values: std::Slice[u8], radix: i64) -> std::Option[std::parse::ParseError] {
  return std::parse::integer_radix_error_with_separator_policy(values, radix, false);
}

pub fn integer_radix(values: std::Slice[u8], radix: i64) -> std::Result[i64, std::error::Error] {
  if radix < 2 || radix > 36 {
    return std::Err<i64, std::error::Error>(invalid_input_error());
  }
  match integer_radix_optional(values, radix) {
    std::Some(value) => {
      return std::Ok<i64, std::error::Error>(value);
    }
    std::None => {
      return std::Err<i64, std::error::Error>(invalid_data_error());
    }
  }
}

pub fn integer_radix_with_underscores_optional(values: std::Slice[u8], radix: i64) -> std::Option[i64] {
  let input = std::ascii::trim(values);
  if input.len == 0 {
    return std::None<i64>();
  }
  if radix < 2 || radix > 36 {
    return std::None<i64>();
  }

  var sign = 1;
  var index = 0;
  if input[0] == '-' {
    sign = -1;
    index = 1;
  } else if input[0] == '+' {
    index = 1;
  }

  if index >= input.len {
    return std::None<i64>();
  }

  let limit = if sign < 0 { i64_min_magnitude() } else { i64_max_magnitude() };
  let radix_value = radix as u64;
  var result = 0u64;
  var seen_digit = false;
  var previous_digit = false;
  while index < input.len {
    let integer_byte = input[index];
    if integer_byte == '_' {
      if !previous_digit {
        return std::None<i64>();
      }
      if index + 1 >= input.len {
        return std::None<i64>();
      }
      match radix_digit_value(input[index + 1], radix) {
        std::Some(_) => {}
        std::None => {
          return std::None<i64>();
        }
      }
      previous_digit = false;
    } else {
      match radix_digit_value(integer_byte, radix) {
        std::Some(value) => {
          let digit = value as u64;
          if result > (limit - digit) / radix_value {
            return std::None<i64>();
          }
          result = (result * radix_value) + digit;
          seen_digit = true;
          previous_digit = true;
        }
        std::None => {
          return std::None<i64>();
        }
      }
    }
    index = index + 1;
  }

  if !seen_digit || !previous_digit {
    return std::None<i64>();
  }
  if sign < 0 {
    if result == i64_min_magnitude() {
      return std::Some<i64>(i64_min_value());
    }
    return std::Some<i64>(0 - (result as i64));
  }
  return std::Some<i64>(result as i64);
}

pub fn integer_radix_with_underscores_error(values: std::Slice[u8], radix: i64) -> std::Option[std::parse::ParseError] {
  return std::parse::integer_radix_error_with_separator_policy(values, radix, true);
}

pub fn integer_radix_with_underscores(values: std::Slice[u8], radix: i64) -> std::Result[i64, std::error::Error] {
  if radix < 2 || radix > 36 {
    return std::Err<i64, std::error::Error>(invalid_input_error());
  }
  match integer_radix_with_underscores_optional(values, radix) {
    std::Some(value) => {
      return std::Ok<i64, std::error::Error>(value);
    }
    std::None => {
      return std::Err<i64, std::error::Error>(invalid_data_error());
    }
  }
}

