pub fn integer_optional(values: std::Slice[u8]) -> std::Option[i64] {
  return integer_radix_optional(values, 10);
}

pub fn integer_error(values: std::Slice[u8]) -> std::Option[std::parse::ParseError] {
  return integer_radix_error(values, 10);
}

pub fn integer(values: std::Slice[u8]) -> std::Result[i64, std::error::Error] {
  return integer_radix(values, 10);
}

