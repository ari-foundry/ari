fn float_range_error_with_separator_policy(
  values: std::Slice[u8],
  allow_separators: bool
) -> std::Option[std::parse::ParseError] {
  let input = std::ascii::trim(values);
  if input.len == 0 {
    return std::None<std::parse::ParseError>();
  }

  var index = 0;
  if input[0] == '-' {
    index = 1;
  } else if input[0] == '+' {
    index = 1;
  }

  var first_significant_offset = -1;
  var first_fraction_significant_offset = -1;
  var integer_significant_digits = 0;
  var integer_overflow_offset = -1;
  while index < input.len {
    let integer_byte = input[index];
    if integer_byte == '_' {
      index = index + 1;
    } else {
      match std::ascii::digit_value(integer_byte) {
        std::Some(integer_digit) => {
          if integer_digit != 0 || first_significant_offset >= 0 {
            if first_significant_offset < 0 {
              first_significant_offset = index;
            }
            integer_significant_digits = integer_significant_digits + 1;
            if integer_significant_digits == 310 {
              integer_overflow_offset = index;
            }
          }
          index = index + 1;
        }
        std::None => {
          break;
        }
      }
    }
  }

  var fraction_base_exponent = 0;
  if index < input.len {
    if input[index] == '.' {
      index = index + 1;
      var fraction_digit_count = 0;
      while index < input.len {
        let fraction_byte = input[index];
        if fraction_byte == '_' {
          index = index + 1;
        } else {
          match std::ascii::digit_value(fraction_byte) {
            std::Some(fraction_digit) => {
              fraction_digit_count = fraction_digit_count + 1;
              if first_significant_offset < 0 && fraction_digit != 0 {
                first_significant_offset = index;
                first_fraction_significant_offset = index;
                fraction_base_exponent = 0 - fraction_digit_count;
              }
              index = index + 1;
            }
            std::None => {
              break;
            }
          }
        }
      }
    }
  }

  if first_significant_offset < 0 {
    return std::None<std::parse::ParseError>();
  }

  var base_exponent = fraction_base_exponent;
  if integer_significant_digits > 0 {
    base_exponent = integer_significant_digits - 1;
  }
  if first_fraction_significant_offset >= 0 && base_exponent < -324 {
    return std::Some<std::parse::ParseError>(
      std::parse::parse_error(Underflow, first_fraction_significant_offset)
    );
  }

  var exponent_offset = -1;
  var exponent_sign = 1;
  var exponent_value = 0;
  if index < input.len {
    if input[index] == 'e' || input[index] == 'E' {
      index = index + 1;
      if input[index] == '-' {
        exponent_sign = -1;
        index = index + 1;
      } else if input[index] == '+' {
        index = index + 1;
      }

      while index < input.len {
        let exponent_byte = input[index];
        if exponent_byte == '_' {
          index = index + 1;
        } else {
          match std::ascii::digit_value(exponent_byte) {
            std::Some(exponent_digit) => {
              if exponent_offset < 0 {
                exponent_offset = index;
              }
              if exponent_value < 10000 {
                exponent_value = (exponent_value * 10) + exponent_digit;
              }
              let signed_exponent = exponent_value * exponent_sign;
              let effective_exponent = base_exponent + signed_exponent;
              if effective_exponent > 308 {
                return std::Some<std::parse::ParseError>(
                  std::parse::parse_error(Overflow, index)
                );
              }
              if effective_exponent < -324 {
                return std::Some<std::parse::ParseError>(
                  std::parse::parse_error(Underflow, index)
                );
              }
            }
            std::None => {
              return std::None<std::parse::ParseError>();
            }
          }
          index = index + 1;
        }
      }
    }
  }

  let final_exponent = base_exponent + (exponent_value * exponent_sign);
  if final_exponent > 308 {
    let overflow_offset = if exponent_offset >= 0 { exponent_offset } else { integer_overflow_offset };
    return std::Some<std::parse::ParseError>(std::parse::parse_error(Overflow, overflow_offset));
  }
  if final_exponent < -324 {
    let underflow_offset = if exponent_offset >= 0 { exponent_offset } else { first_significant_offset };
    return std::Some<std::parse::ParseError>(std::parse::parse_error(Underflow, underflow_offset));
  }
  return std::None<std::parse::ParseError>();
}

fn float_error_with_separator_policy(
  values: std::Slice[u8],
  allow_separators: bool
) -> std::Option[std::parse::ParseError] {
  let input = std::ascii::trim(values);
  if input.len == 0 {
    return std::Some<std::parse::ParseError>(std::parse::parse_error(EmptyInput, 0));
  }

  var index = 0;
  if input[0] == '-' {
    index = 1;
  } else if input[0] == '+' {
    index = 1;
  }

  if index >= input.len {
    return std::Some<std::parse::ParseError>(std::parse::parse_error(ExpectedDigit, index));
  }

  var seen_digit = false;
  var previous_digit = false;
  while index < input.len {
    let integer_byte = input[index];
    if integer_byte == '_' {
      if !allow_separators {
        return std::Some<std::parse::ParseError>(std::parse::parse_error(InvalidSeparator, index));
      }
      if !previous_digit {
        return std::Some<std::parse::ParseError>(std::parse::parse_error(InvalidSeparator, index));
      }
      if index + 1 >= input.len {
        return std::Some<std::parse::ParseError>(std::parse::parse_error(InvalidSeparator, index));
      }
      match std::ascii::digit_value(input[index + 1]) {
        std::Some(_) => {}
        std::None => {
          return std::Some<std::parse::ParseError>(std::parse::parse_error(InvalidSeparator, index));
        }
      }
      previous_digit = false;
      index = index + 1;
    } else {
      match std::ascii::digit_value(integer_byte) {
        std::Some(_) => {
          seen_digit = true;
          previous_digit = true;
          index = index + 1;
        }
        std::None => {
          break;
        }
      }
    }
  }

  if index < input.len {
    if input[index] == '.' {
      index = index + 1;
      var previous_fraction_digit = false;
      while index < input.len {
        let fraction_byte = input[index];
        if fraction_byte == '_' {
          if !allow_separators {
            return std::Some<std::parse::ParseError>(std::parse::parse_error(InvalidSeparator, index));
          }
          if !previous_fraction_digit {
            return std::Some<std::parse::ParseError>(std::parse::parse_error(InvalidSeparator, index));
          }
          if index + 1 >= input.len {
            return std::Some<std::parse::ParseError>(std::parse::parse_error(InvalidSeparator, index));
          }
          match std::ascii::digit_value(input[index + 1]) {
            std::Some(_) => {}
            std::None => {
              return std::Some<std::parse::ParseError>(std::parse::parse_error(InvalidSeparator, index));
            }
          }
          previous_fraction_digit = false;
          index = index + 1;
        } else {
          match std::ascii::digit_value(fraction_byte) {
            std::Some(_) => {
              seen_digit = true;
              previous_fraction_digit = true;
              index = index + 1;
            }
            std::None => {
              break;
            }
          }
        }
      }
    }
  }

  if !seen_digit {
    return std::Some<std::parse::ParseError>(std::parse::parse_error(ExpectedDigit, index));
  }

  if index < input.len {
    if input[index] == 'e' || input[index] == 'E' {
      index = index + 1;
      if index >= input.len {
        return std::Some<std::parse::ParseError>(std::parse::parse_error(ExpectedDigit, index));
      }

      if input[index] == '-' {
        index = index + 1;
      } else if input[index] == '+' {
        index = index + 1;
      }

      if index >= input.len {
        return std::Some<std::parse::ParseError>(std::parse::parse_error(ExpectedDigit, index));
      }

      var seen_exponent_digit = false;
      var previous_exponent_digit = false;
      while index < input.len {
        let exponent_byte = input[index];
        if exponent_byte == '_' {
          if !allow_separators {
            return std::Some<std::parse::ParseError>(std::parse::parse_error(InvalidSeparator, index));
          }
          if !previous_exponent_digit {
            return std::Some<std::parse::ParseError>(std::parse::parse_error(InvalidSeparator, index));
          }
          if index + 1 >= input.len {
            return std::Some<std::parse::ParseError>(std::parse::parse_error(InvalidSeparator, index));
          }
          match std::ascii::digit_value(input[index + 1]) {
            std::Some(_) => {}
            std::None => {
              return std::Some<std::parse::ParseError>(std::parse::parse_error(InvalidSeparator, index));
            }
          }
          previous_exponent_digit = false;
          index = index + 1;
        } else {
          match std::ascii::digit_value(exponent_byte) {
            std::Some(_) => {
              seen_exponent_digit = true;
              previous_exponent_digit = true;
            }
            std::None => {
              return std::Some<std::parse::ParseError>(std::parse::parse_error(InvalidDigit, index));
            }
          }
          index = index + 1;
        }
      }
      if !seen_exponent_digit {
        return std::Some<std::parse::ParseError>(std::parse::parse_error(ExpectedDigit, index));
      }
      if allow_separators && !previous_exponent_digit {
        return std::Some<std::parse::ParseError>(std::parse::parse_error(InvalidSeparator, input.len - 1));
      }
    }
  }

  if index != input.len {
    if input[index] == '_' {
      return std::Some<std::parse::ParseError>(std::parse::parse_error(InvalidSeparator, index));
    }
    return std::Some<std::parse::ParseError>(std::parse::parse_error(InvalidDigit, index));
  }
  match std::parse::float_range_error_with_separator_policy(values, allow_separators) {
    std::Some(range_error) => {
      return std::Some<std::parse::ParseError>(range_error);
    }
    std::None => {}
  }
  return std::None<std::parse::ParseError>();
}

pub fn float_error(values: std::Slice[u8]) -> std::Option[std::parse::ParseError] {
  return std::parse::float_error_with_separator_policy(values, false);
}

pub fn float_with_underscores_error(values: std::Slice[u8]) -> std::Option[std::parse::ParseError] {
  return std::parse::float_error_with_separator_policy(values, true);
}

pub fn float_or(values: std::Slice[u8], fallback: f64) -> f64 {
  if !is_float(values) {
    return fallback;
  }

  let input = std::ascii::trim(values);
  if input.len == 0 {
    return fallback;
  }

  var sign = 1.0f64;
  var index = 0;
  if input[0] == '-' {
    sign = -1.0f64;
    index = 1;
  } else if input[0] == '+' {
    index = 1;
  }

  var value = 0.0f64;
  var seen_digit = false;
  while index < input.len {
    match std::ascii::digit_value(input[index]) {
      std::Some(integer_digit) => {
        value = (value * 10.0f64) + (integer_digit as f64);
        seen_digit = true;
        index = index + 1;
      }
      std::None => {
        break;
      }
    }
  }

  if index < input.len {
    if input[index] == '.' {
      index = index + 1;
      var scale = 0.1f64;
      while index < input.len {
        match std::ascii::digit_value(input[index]) {
          std::Some(fraction_digit) => {
            value = value + ((fraction_digit as f64) * scale);
            scale = scale / 10.0f64;
            seen_digit = true;
            index = index + 1;
          }
          std::None => {
            break;
          }
        }
      }
    }
  }

  if !seen_digit {
    return fallback;
  }

  if index < input.len {
    if input[index] == 'e' || input[index] == 'E' {
      index = index + 1;
      if index >= input.len {
        return fallback;
      }

      var exponent_sign = 1;
      if input[index] == '-' {
        exponent_sign = -1;
        index = index + 1;
      } else if input[index] == '+' {
        index = index + 1;
      }

      if index >= input.len {
        return fallback;
      }

      var exponent = 0;
      var seen_exponent_digit = false;
      while index < input.len {
        match std::ascii::digit_value(input[index]) {
          std::Some(exponent_digit) => {
            exponent = (exponent * 10) + exponent_digit;
            seen_exponent_digit = true;
          }
          std::None => {
            return fallback;
          }
        }
        index = index + 1;
      }
      if !seen_exponent_digit {
        return fallback;
      }
      value = value * pow10(exponent * exponent_sign);
    }
  }

  if index != input.len {
    return fallback;
  }
  return value * sign;
}

pub fn float_with_underscores_or(values: std::Slice[u8], fallback: f64) -> f64 {
  if !is_float_with_underscores(values) {
    return fallback;
  }

  let input = std::ascii::trim(values);
  var sign = 1.0f64;
  var index = 0;
  if input[0] == '-' {
    sign = -1.0f64;
    index = 1;
  } else if input[0] == '+' {
    index = 1;
  }

  var value = 0.0f64;
  while index < input.len {
    let integer_byte = input[index];
    if integer_byte == '_' {
      index = index + 1;
    } else {
      match std::ascii::digit_value(integer_byte) {
        std::Some(integer_digit) => {
          value = (value * 10.0f64) + (integer_digit as f64);
          index = index + 1;
        }
        std::None => {
          break;
        }
      }
    }
  }

  if index < input.len {
    if input[index] == '.' {
      index = index + 1;
      var scale = 0.1f64;
      while index < input.len {
        let fraction_byte = input[index];
        if fraction_byte == '_' {
          index = index + 1;
        } else {
          match std::ascii::digit_value(fraction_byte) {
            std::Some(fraction_digit) => {
              value = value + ((fraction_digit as f64) * scale);
              scale = scale / 10.0f64;
              index = index + 1;
            }
            std::None => {
              break;
            }
          }
        }
      }
    }
  }

  if index < input.len {
    if input[index] == 'e' || input[index] == 'E' {
      index = index + 1;
      var exponent_sign = 1;
      if input[index] == '-' {
        exponent_sign = -1;
        index = index + 1;
      } else if input[index] == '+' {
        index = index + 1;
      }

      var exponent = 0;
      while index < input.len {
        let exponent_byte = input[index];
        if exponent_byte == '_' {
          index = index + 1;
        } else {
          match std::ascii::digit_value(exponent_byte) {
            std::Some(exponent_digit) => {
              exponent = (exponent * 10) + exponent_digit;
            }
            std::None => {
              return fallback;
            }
          }
          index = index + 1;
        }
      }
      value = value * pow10(exponent * exponent_sign);
    }
  }

  return value * sign;
}

pub fn float_optional(values: std::Slice[u8]) -> std::Option[f64] {
  if !is_float(values) {
    return std::None<f64>();
  }
  return std::Some<f64>(float_or(values, 0.0f64));
}

pub fn float_with_underscores_optional(values: std::Slice[u8]) -> std::Option[f64] {
  if !is_float_with_underscores(values) {
    return std::None<f64>();
  }
  return std::Some<f64>(float_with_underscores_or(values, 0.0f64));
}

pub fn float(values: std::Slice[u8]) -> std::Result[f64, std::error::Error] {
  match float_optional(values) {
    std::Some(value) => {
      return std::Ok<f64, std::error::Error>(value);
    }
    std::None => {
      return std::Err<f64, std::error::Error>(invalid_data_error());
    }
  }
}

pub fn float_with_underscores(values: std::Slice[u8]) -> std::Result[f64, std::error::Error] {
  match float_with_underscores_optional(values) {
    std::Some(value) => {
      return std::Ok<f64, std::error::Error>(value);
    }
    std::None => {
      return std::Err<f64, std::error::Error>(invalid_data_error());
    }
  }
}

pub fn float_unchecked(values: std::Slice[u8]) -> f64 {
  match float(values) {
    std::Ok(value) => {
      return value;
    }
    std::Err(_) => {
      std::panic();
    }
  }
}

impl std::parse::Parse for i64 {
  fn parse(values: std::Slice[u8]) -> i64 {
    match std::parse::integer(values) {
      std::Ok(value) => {
        return value;
      }
      std::Err(_) => {
        std::panic();
      }
    }
  }

  fn parse_or(values: std::Slice[u8], fallback: i64) -> i64 {
    return std::parse::integer_or(values, fallback);
  }

  fn is_parse(values: std::Slice[u8]) -> bool {
    return std::parse::is_integer(values);
  }
}

impl std::parse::Parse for u64 {
  fn parse(values: std::Slice[u8]) -> u64 {
    match std::parse::unsigned(values) {
      std::Ok(value) => {
        return value;
      }
      std::Err(_) => {
        std::panic();
      }
    }
  }

  fn parse_or(values: std::Slice[u8], fallback: u64) -> u64 {
    return std::parse::unsigned_or(values, fallback);
  }

  fn is_parse(values: std::Slice[u8]) -> bool {
    return std::parse::is_unsigned(values);
  }
}

impl std::parse::Parse for bool {
  fn parse(values: std::Slice[u8]) -> bool {
    match std::parse::boolean(values) {
      std::Ok(value) => {
        return value;
      }
      std::Err(_) => {
        std::panic();
      }
    }
  }

  fn parse_or(values: std::Slice[u8], fallback: bool) -> bool {
    return std::parse::boolean_or(values, fallback);
  }

  fn is_parse(values: std::Slice[u8]) -> bool {
    return std::parse::is_boolean(values);
  }
}

impl std::parse::Parse for f64 {
  fn parse(values: std::Slice[u8]) -> f64 {
    return std::parse::float_unchecked(values);
  }

  fn parse_or(values: std::Slice[u8], fallback: f64) -> f64 {
    return std::parse::float_or(values, fallback);
  }

  fn is_parse(values: std::Slice[u8]) -> bool {
    return std::parse::is_float(values);
  }
}
