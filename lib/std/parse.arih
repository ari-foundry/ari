  match integer_optional(values) {
    std::Some(_) => {
      return true;
    }
    std::None => {
      return false;
    }
  }
}

pub fn is_integer_with_underscores(values: std::Slice[u8]) -> bool {
  return is_integer_radix_with_underscores(values, 10);
}

pub fn integer_or(values: std::Slice[u8], fallback: i64) -> i64 {
  match integer_optional(values) {
    std::Some(value) => {
      return value;
    }
    std::None => {
      return fallback;
    }
  }
}

