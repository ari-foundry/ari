pub impl std::sync::Once {
  fn new() -> Once {
    return Once { state: AtomicI64::new(0) };
  }

  fn call_once(self: ref mut Self, action: fn() -> void) -> bool {
    return std::sync::call_once(self, action);
  }

  fn is_completed(self: ref Self) -> bool {
    return std::sync::is_completed(self);
  }
}

pub impl std::sync::Condvar {
  fn new() -> std::sync::Condvar {
    return std::sync::Condvar { sequence: AtomicI64::new(0) };
  }

  fn notify_one(self: ref mut Self) -> void {
    self.sequence.fetch_add(1);
  }

  fn notify_all(self: ref mut Self) -> void {
    self.sequence.fetch_add(1);
  }

  fn generation(self: ref Self) -> i64 {
    return self.sequence.load();
  }

  fn wait(self: ref mut Self, lock: ref mut std::sync::RawMutex) -> void {
    let seen = self.sequence.load();
    lock.unlock();
    while self.sequence.load() == seen {
      std::thread::yield_now();
    }
    std::sync::lock(lock);
  }

  fn wait_timeout(
    self: ref mut Self,
    lock: ref mut std::sync::RawMutex,
    duration: std::time::Duration
  ) -> std::Result[std::sync::WaitTimeoutResult, std::error::Error] {
    let seen = self.sequence.load();
    let deadline = std::time::timeout(duration);
    lock.unlock();
    while self.sequence.load() == seen {
      if deadline.has_expired() {
        std::sync::lock(lock);
        return std::Ok<std::sync::WaitTimeoutResult, std::error::Error>(
          std::sync::WaitTimeoutResult { timed_out_value: true }
        );
      }
      std::thread::yield_now();
    }
    std::sync::lock(lock);
    return std::Ok<std::sync::WaitTimeoutResult, std::error::Error>(
      std::sync::WaitTimeoutResult { timed_out_value: false }
    );
  }

  fn wait_while(self: ref mut Self, lock: ref mut std::sync::RawMutex, condition: fn() -> bool) -> void {
    while condition() {
      self.wait(lock);
    }
  }
}

pub impl std::sync::WaitTimeoutResult {
  fn timed_out(self) -> bool {
    return self.timed_out_value;
  }
}

pub impl std::sync::Barrier {
  fn new(parties: i64) -> std::sync::Barrier {
    std::assert(parties > 0);
    return std::sync::Barrier {
      parties: parties,
      arrived: AtomicI64::new(0),
      generation: AtomicI64::new(0),
    };
  }

  fn wait(self: ref mut Self) -> bool {
    let generation = self.generation.load();
    let arrived = self.arrived.fetch_add(1) + 1;
    if arrived >= self.parties {
      self.arrived.store(0);
      self.generation.fetch_add(1);
      return true;
    }
    while self.generation.load() == generation {
      std::thread::yield_now();
    }
    return false;
  }

  fn parties(self: ref Self) -> i64 {
    return self.parties;
  }
}

pub impl std::sync::Semaphore {
  fn new(permits: i64) -> std::sync::Semaphore {
    std::assert(permits >= 0);
    return std::sync::Semaphore { permits: AtomicI64::new(permits) };
  }

  fn available_permits(self: ref Self) -> i64 {
    return self.permits.load();
  }

  fn try_acquire(self: ref mut Self) -> std::Option[std::sync::SemaphorePermit] {
    while true {
      let current = self.permits.load();
      if current <= 0 {
        return std::None<std::sync::SemaphorePermit>();
      }
      if self.permits.compare_exchange_bool(current, current - 1) {
        return std::Some<std::sync::SemaphorePermit>(
          std::sync::SemaphorePermit {
            semaphore: self as ptr std::sync::Semaphore,
            active: true,
          }
        );
      }
    }
    return std::None<std::sync::SemaphorePermit>();
  }

  fn acquire(self: ref mut Self) -> std::sync::SemaphorePermit {
    while true {
      match self.try_acquire() {
        std::Some(permit) => {
          return permit;
        }
        std::None => {
          std::thread::yield_now();
        }
      }
    }
    return std::sync::SemaphorePermit {
      semaphore: self as ptr std::sync::Semaphore,
      active: false,
    };
  }

  fn release(self: ref mut Self) -> void {
    self.permits.fetch_add(1);
  }

  fn add_permits(self: ref mut Self, permits: i64) -> void {
    std::assert(permits >= 0);
    self.permits.fetch_add(permits);
  }
}

pub impl std::sync::SemaphorePermit {
  fn release(self: ref mut Self) -> void {
    if self.active {
      (ref mut *self.semaphore).release();
      self.active = false;
    }
  }

  fn is_active(self: ref Self) -> bool {
    return self.active;
  }
}

impl std::Drop for std::sync::SemaphorePermit {
  fn drop(self) -> void {
    if self.active {
      (ref mut *self.semaphore).release();
    }
  }
}

pub impl[T] std::sync::OnceLock[T] {
  fn new() -> std::sync::OnceLock[T] {
    return std::sync::OnceLock<T> { state: AtomicI64::new(0), value: std::None<T>() };
  }

  fn is_initialized(self: ref Self) -> bool {
    return self.state.load() == 2;
  }

  fn is_empty(self: ref Self) -> bool {
    return !self.is_initialized();
  }

  fn set_bool(self: ref mut Self, value: T) -> bool {
    if self.state.compare_exchange_bool(0, 1) {
      let previous = self.value.replace(value);
      drop previous;
      self.state.store(2);
      return true;
    }
    drop value;
    return false;
  }

  fn set(self: ref mut Self, value: T) -> std::Result[(), T] {
    if self.state.compare_exchange_bool(0, 1) {
      let previous = self.value.replace(value);
      drop previous;
      self.state.store(2);
      return std::Ok<(), T>(());
    }
    return std::Err<(), T>(value);
  }

  fn get(self: ref Self) -> std::option::OptionRef[T] {
    if self.is_initialized() {
      return self.value.as_ref();
    }
    return std::option::NoneRef<T>();
  }

  fn get_mut(self: ref mut Self) -> std::option::OptionMut[T] {
    if self.is_initialized() {
      return self.value.as_mut();
    }
    return std::option::NoneMut<T>();
  }

  fn get_or_init(self: ref mut Self, initializer: fn() -> T) -> ref T {
    while true {
      if self.state.load() == 2 {
        return ref *((ref (*((ref self.value) as ptr std::Option[T])).0) as ptr T);
      }
      if self.state.load() == 0 && self.state.compare_exchange_bool(0, 1) {
        let previous = self.value.replace(initializer());
        drop previous;
        self.state.store(2);
        return ref *((ref (*((ref self.value) as ptr std::Option[T])).0) as ptr T);
      }
      std::thread::yield_now();
    }
    return ref *((ref (*((ref self.value) as ptr std::Option[T])).0) as ptr T);
  }

  fn get_or_try_init(
    self: ref mut Self,
    initializer: fn() -> std::Result[T, std::error::Error]
  ) -> std::Result[(), std::error::Error] {
    while true {
      if self.state.load() == 2 {
        return std::Ok<(), std::error::Error>(());
      }
      if self.state.load() == 0 && self.state.compare_exchange_bool(0, 1) {
        match initializer() {
          std::Ok(value) => {
            let previous = self.value.replace(value);
            drop previous;
            self.state.store(2);
            return std::Ok<(), std::error::Error>(());
          }
          std::Err(reason) => {
            self.state.store(0);
            return std::Err<(), std::error::Error>(reason);
          }
        }
      }
      std::thread::yield_now();
    }
    return std::Err<(), std::error::Error>(std::error::new(std::error::Other));
  }

  fn take(self: ref mut Self) -> std::Option[T] {
    if self.state.load() == 2 {
      self.state.store(0);
      return self.value.take();
    }
    return std::None<T>();
  }
}

pub impl[T] std::sync::Sender[T] {
  fn clone(self) -> std::sync::Sender[T] {
    return self;
  }

  fn capacity(self: ref Self) -> i64 {
    let state: ref std::sync::MpscState[T] = ref *self.state;
    return state.capacity;
  }

  fn try_send(self: ref mut Self, value: T) -> std::Result[(), std::sync::TrySendError[T]] {
    let state: ref mut std::sync::MpscState[T] = ref mut *self.state;
    std::sync::lock(ref mut state.lock_value);
    if state.closed.load() != 0 {
      std::sync::unlock(ref mut state.lock_value);
      return std::Err<(), std::sync::TrySendError[T]>(std::sync::TrySendClosed<T>(value));
    }
    if state.len >= state.capacity {
      std::sync::unlock(ref mut state.lock_value);
      return std::Err<(), std::sync::TrySendError[T]>(std::sync::TrySendFull<T>(value));
    }

    let buffer = state.buffer as ptr std::Option[T];
    let previous = (ref mut *ptr_add(buffer, state.tail)).replace(value);
    drop previous;
    state.tail = state.tail + 1;
    if state.tail >= state.capacity {
      state.tail = 0;
    }
    state.len = state.len + 1;
    std::sync::unlock(ref mut state.lock_value);
    return std::Ok<(), std::sync::TrySendError[T]>(());
  }

  fn send(self: ref mut Self, value: T) -> std::Result[(), std::sync::SendError[T]] {
    var pending = value;
    while true {
      match self.try_send(pending) {
        std::Ok(_) => {
          return std::Ok<(), std::sync::SendError[T]>(());
        }
        std::Err(reason) => {
          match reason {
            std::sync::TrySendClosed(closed_value) => {
              return std::Err<(), std::sync::SendError[T]>(std::sync::SendClosed<T>(closed_value));
            }
            std::sync::TrySendFull(full_value) => {
              pending = full_value;
            }
          }
        }
      }
      std::thread::yield_now();
    }
    return std::Err<(), std::sync::SendError[T]>(std::sync::SendClosed<T>(pending));
  }

  fn send_bool(self: ref mut Self, value: T) -> bool {
    match self.try_send(value) {
      std::Ok(_) => {
        return true;
      }
      std::Err(_) => {
        return false;
      }
    }
  }

  fn close(self: ref mut Self) -> void {
    let state: ref mut std::sync::MpscState[T] = ref mut *self.state;
    state.closed.store(1);
  }

  fn is_closed(self: ref Self) -> bool {
    let state: ref std::sync::MpscState[T] = ref *self.state;
    return state.closed.load() != 0;
  }
}

pub impl[T] std::sync::Receiver[T] {
  fn capacity(self: ref Self) -> i64 {
    let state: ref std::sync::MpscState[T] = ref *self.state;
    return state.capacity;
  }

  fn len(self: ref Self) -> i64 {
    let state: ref std::sync::MpscState[T] = ref *self.state;
    return state.len;
  }

  fn try_recv(self: ref mut Self) -> std::Result[T, std::sync::TryRecvError] {
    let state: ref mut std::sync::MpscState[T] = ref mut *self.state;
    std::sync::lock(ref mut state.lock_value);
    if state.len > 0 {
      let buffer = state.buffer as ptr std::Option[T];
      let value = (ref mut *ptr_add(buffer, state.head)).take();
      state.head = state.head + 1;
      if state.head >= state.capacity {
        state.head = 0;
      }
      state.len = state.len - 1;
      std::sync::unlock(ref mut state.lock_value);
      return std::Ok<T, std::sync::TryRecvError>(value.unwrap());
    }
    if state.closed.load() != 0 {
      std::sync::unlock(ref mut state.lock_value);
      return std::Err<T, std::sync::TryRecvError>(std::sync::TryRecvClosed);
    }
    std::sync::unlock(ref mut state.lock_value);
    return std::Err<T, std::sync::TryRecvError>(std::sync::TryRecvEmpty);
  }

  fn try_recv_optional(self: ref mut Self) -> std::Option[T] {
    match self.try_recv() {
      std::Ok(value) => {
        return std::Some<T>(value);
      }
      std::Err(_) => {
        return std::None<T>();
      }
    }
  }

  fn recv(self: ref mut Self) -> std::Result[T, std::sync::RecvError] {
    while true {
      match self.try_recv() {
        std::Ok(value) => {
          return std::Ok<T, std::sync::RecvError>(value);
        }
        std::Err(reason) => {
          match reason {
            std::sync::TryRecvClosed => {
              return std::Err<T, std::sync::RecvError>(std::sync::RecvClosed);
            }
            std::sync::TryRecvEmpty => {}
          }
        }
      }
      std::thread::yield_now();
    }
    return std::Err<T, std::sync::RecvError>(std::sync::RecvClosed);
  }

  fn recv_timeout(
    self: ref mut Self,
    duration: std::time::Duration
  ) -> std::Result[T, std::sync::RecvTimeoutError] {
    let deadline = std::time::timeout(duration);
    while true {
      match self.try_recv() {
        std::Ok(value) => {
          return std::Ok<T, std::sync::RecvTimeoutError>(value);
        }
        std::Err(reason) => {
          match reason {
            std::sync::TryRecvClosed => {
              return std::Err<T, std::sync::RecvTimeoutError>(std::sync::RecvTimeoutClosed);
            }
            std::sync::TryRecvEmpty => {}
          }
        }
      }
      if deadline.has_expired() {
        return std::Err<T, std::sync::RecvTimeoutError>(std::sync::RecvTimedOut);
      }
      std::thread::yield_now();
    }
    return std::Err<T, std::sync::RecvTimeoutError>(std::sync::RecvTimeoutClosed);
  }

  fn recv_optional(self: ref mut Self) -> std::Option[T] {
    match self.recv() {
      std::Ok(value) => {
        return std::Some<T>(value);
      }
      std::Err(_) => {
        return std::None<T>();
      }
    }
  }

  fn close(self: ref mut Self) -> void {
    let state: ref mut std::sync::MpscState[T] = ref mut *self.state;
    state.closed.store(1);
  }

  fn is_closed(self: ref Self) -> bool {
    let state: ref std::sync::MpscState[T] = ref *self.state;
    return state.closed.load() != 0;
  }

  fn is_empty(self: ref Self) -> bool {
    return self.len() == 0;
  }
}

pub impl[T] std::sync::Channel[T] {
  fn split(self) -> std::sync::Channel[T] {
    return self;
  }

  fn capacity(self: ref Self) -> i64 {
    return self.sender.capacity();
  }

  fn sender(self: ref Self) -> std::sync::Sender[T] {
    return self.sender;
  }

  fn receiver(self: ref Self) -> std::sync::Receiver[T] {
    return self.receiver;
  }
}
