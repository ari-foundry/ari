// Small synchronization primitives.
//
// Atomics are sequentially consistent by default. The explicit Ordering
// overloads are accepted now so concurrent APIs can name their memory contract
// before Ari grows target-specific relaxed lowering.
pub enum Ordering {
  Relaxed,
  Acquire,
  Release,
  AcqRel,
  SeqCst,
}

pub struct AtomicI64 {
  mut value: i64,
}

pub struct AtomicBool {
  mut bits: AtomicI64,
}

pub struct AtomicUsize {
  mut bits: AtomicI64,
}

pub struct AtomicPtr[T] {
  mut bits: AtomicUsize,
}

pub struct RawMutex {
  mut state: AtomicI64,
}

pub struct RawMutexGuard {
  lock: ptr std::sync::RawMutex,
  mut active: bool,
}

pub struct Mutex[T] {
  mut lock_value: std::sync::RawMutex,
  mut value: T,
}

pub struct MutexGuard[T] {
  lock: ptr std::sync::RawMutex,
  value: ptr T,
  mut active: bool,
}

pub struct RawRwLock {
  mut state: AtomicI64,
}

pub struct RawRwLockReadGuard {
  lock: ptr std::sync::RawRwLock,
  mut active: bool,
}

pub struct RawRwLockWriteGuard {
  lock: ptr std::sync::RawRwLock,
  mut active: bool,
}

pub struct RwLock[T] {
  mut lock_value: std::sync::RawRwLock,
  mut value: T,
}

pub struct RwLockReadGuard[T] {
  lock: ptr std::sync::RawRwLock,
  value: ptr T,
  mut active: bool,
}

pub struct RwLockWriteGuard[T] {
  lock: ptr std::sync::RawRwLock,
  value: ptr T,
  mut active: bool,
}

pub struct Once {
  mut state: AtomicI64,
}

pub struct Condvar {
  mut sequence: AtomicI64,
}

pub struct WaitTimeoutResult {
  timed_out_value: bool,
}

pub struct Barrier {
  parties: i64,
  mut arrived: AtomicI64,
  mut generation: AtomicI64,
}

pub struct Semaphore {
  mut permits: AtomicI64,
}

pub struct SemaphorePermit {
  semaphore: ptr std::sync::Semaphore,
  mut active: bool,
}

pub struct OnceLock[T] {
  mut state: AtomicI64,
  mut value: std::Option[T],
}

pub enum SendError[T] {
  SendClosed(T),
}

pub enum TrySendError[T] {
  TrySendClosed(T),
  TrySendFull(T),
}

pub enum RecvError {
  RecvClosed,
}

pub enum RecvTimeoutError {
  RecvTimeoutClosed,
  RecvTimedOut,
}

pub enum TryRecvError {
  TryRecvEmpty,
  TryRecvClosed,
}

struct MpscState[T] {
  mut lock_value: std::sync::RawMutex,
  mut closed: AtomicI64,
  capacity: i64,
  mut len: i64,
  mut head: i64,
  mut tail: i64,
  // Address of a zone-backed Option[T] ring buffer. Keep this private until
  // aggregate pointer escape checks can express owned backing buffers directly.
  buffer: u64,
}

pub struct Sender[T] {
  state: ptr std::sync::MpscState[T],
}

pub struct Receiver[T] {
  state: ptr std::sync::MpscState[T],
}

pub struct Channel[T] {
  sender: std::sync::Sender[T],
  receiver: std::sync::Receiver[T],
}

pub extern "ari" fn load(value: ref AtomicI64) -> i64 = "ari_builtin_sync_atomic_i64_load";
pub extern "ari" fn store(value: ref mut AtomicI64, replacement: i64) -> void = "ari_builtin_sync_atomic_i64_store";
pub extern "ari" fn swap(value: ref mut AtomicI64, replacement: i64) -> i64 = "ari_builtin_sync_atomic_i64_swap";
pub extern "ari" fn fetch_add(value: ref mut AtomicI64, amount: i64) -> i64 = "ari_builtin_sync_atomic_i64_fetch_add";
pub extern "ari" fn compare_exchange(value: ref mut AtomicI64, expected: i64, replacement: i64) -> bool = "ari_builtin_sync_atomic_i64_compare_exchange";
extern "ari" fn load_order_raw(value: ref AtomicI64, ordering: i64) -> i64 = "ari_builtin_sync_atomic_i64_load_order";
extern "ari" fn store_order_raw(value: ref mut AtomicI64, replacement: i64, ordering: i64) -> void = "ari_builtin_sync_atomic_i64_store_order";
extern "ari" fn swap_order_raw(value: ref mut AtomicI64, replacement: i64, ordering: i64) -> i64 = "ari_builtin_sync_atomic_i64_swap_order";
extern "ari" fn fetch_add_order_raw(value: ref mut AtomicI64, amount: i64, ordering: i64) -> i64 = "ari_builtin_sync_atomic_i64_fetch_add_order";
extern "ari" fn compare_exchange_order_raw(
  value: ref mut AtomicI64,
  expected: i64,
  replacement: i64,
  success: i64,
  failure: i64
) -> bool = "ari_builtin_sync_atomic_i64_compare_exchange_order";

fn ordering_code(ordering: std::sync::Ordering) -> i64 {
  match ordering {
    std::sync::Relaxed => { return 0; }
    std::sync::Acquire => { return 1; }
    std::sync::Release => { return 2; }
    std::sync::AcqRel => { return 3; }
    std::sync::SeqCst => { return 4; }
  }
}

pub fn seq_cst() -> std::sync::Ordering {
  return std::sync::SeqCst;
}

pub fn is_load_order(ordering: std::sync::Ordering) -> bool {
  match ordering {
    std::sync::Relaxed => { return true; }
    std::sync::Acquire => { return true; }
    std::sync::Release => { return false; }
    std::sync::AcqRel => { return false; }
    std::sync::SeqCst => { return true; }
  }
}

pub fn is_store_order(ordering: std::sync::Ordering) -> bool {
  match ordering {
    std::sync::Relaxed => { return true; }
    std::sync::Acquire => { return false; }
    std::sync::Release => { return true; }
    std::sync::AcqRel => { return false; }
    std::sync::SeqCst => { return true; }
  }
}

pub fn is_rmw_order(ordering: std::sync::Ordering) -> bool {
  return true;
}

pub fn is_compare_exchange_order(success: std::sync::Ordering, failure: std::sync::Ordering) -> bool {
  if !std::sync::is_rmw_order(success) || !std::sync::is_load_order(failure) {
    return false;
  }
  match failure {
    std::sync::Relaxed => { return true; }
    std::sync::Acquire => {
      return success == std::sync::Acquire ||
             success == std::sync::AcqRel ||
             success == std::sync::SeqCst;
    }
    std::sync::SeqCst => {
      return success == std::sync::SeqCst;
    }
    std::sync::Release => { return false; }
    std::sync::AcqRel => { return false; }
  }
}

pub fn try_lock(lock: ref mut std::sync::RawMutex) -> bool {
  return lock.state.compare_exchange_bool(0, 1);
}

pub fn lock(lock: ref mut std::sync::RawMutex) -> void {
  while !std::sync::try_lock(lock) {
    std::thread::yield_now();
  }
}

pub fn unlock(lock: ref mut std::sync::RawMutex) -> void {
  lock.state.store(0);
}

pub fn is_locked(lock: ref std::sync::RawMutex) -> bool {
  return lock.state.load() != 0;
}

pub fn try_read_lock(lock: ref mut std::sync::RawRwLock) -> bool {
  let current = lock.state.load();
  if current < 0 {
    return false;
  }
  return lock.state.compare_exchange_bool(current, current + 1);
}

pub fn read_lock(lock: ref mut std::sync::RawRwLock) -> void {
  while !std::sync::try_read_lock(lock) {
    std::thread::yield_now();
  }
}

pub fn read_unlock(lock: ref mut std::sync::RawRwLock) -> void {
  let previous = lock.state.fetch_add(-1);
  if previous <= 0 {
    lock.state.fetch_add(1);
    std::assert(false);
  }
}

pub fn try_write_lock(lock: ref mut std::sync::RawRwLock) -> bool {
  return lock.state.compare_exchange_bool(0, -1);
}

pub fn write_lock(lock: ref mut std::sync::RawRwLock) -> void {
  while !std::sync::try_write_lock(lock) {
    std::thread::yield_now();
  }
}

pub fn write_unlock(lock: ref mut std::sync::RawRwLock) -> void {
  std::assert(lock.state.load() < 0);
  lock.state.store(0);
}

pub fn reader_count(lock: ref std::sync::RawRwLock) -> i64 {
  let current = lock.state.load();
  if current < 0 {
    return 0;
  }
  return current;
}

pub fn is_read_locked(lock: ref std::sync::RawRwLock) -> bool {
  return lock.state.load() > 0;
}

pub fn is_write_locked(lock: ref std::sync::RawRwLock) -> bool {
  return lock.state.load() < 0;
}

pub fn call_once(once: ref mut std::sync::Once, action: fn() -> void) -> bool {
  if once.state.load() == 2 {
    return false;
  }
  if once.state.compare_exchange_bool(0, 1) {
    action();
    once.state.store(2);
    return true;
  }
  while once.state.load() == 1 {
    std::thread::yield_now();
  }
  return false;
}

pub fn is_completed(once: ref std::sync::Once) -> bool {
  return once.state.load() == 2;
}

fn new_mpsc_state[T](zone: ref mut Zone, capacity: i64) -> ptr std::sync::MpscState[T] {
  std::assert(capacity > 0);
  let metadata = std::zone::from_zone(zone);
  let buffer = metadata.alloc_array<std::Option[T]>(capacity);
  var index = 0;
  while index < capacity {
    ptr_store(ptr_add(buffer, index), std::None<T>());
    index = index + 1;
  }
  return std::zone::new<std::sync::MpscState[T]>(
    zone,
    std::sync::MpscState<T> {
      lock_value: std::sync::RawMutex::new(),
      closed: AtomicI64::new(0),
      capacity: capacity,
      len: 0,
      head: 0,
      tail: 0,
      buffer: buffer as u64,
    }
  );
}

pub fn bounded_channel[T](
  zone: ref mut Zone,
  capacity: i64
) -> std::Result[std::sync::Channel[T], std::error::Error] {
  if capacity <= 0 {
    return std::Err<std::sync::Channel[T], std::error::Error>(
      std::error::new(std::error::InvalidInput)
    );
  }
  let state = std::sync::new_mpsc_state<T>(zone, capacity);
  let sender = std::sync::Sender<T> { state: state };
  let receiver = std::sync::Receiver<T> { state: state };
  return std::Ok<std::sync::Channel[T], std::error::Error>(
    std::sync::Channel<T> { sender: sender, receiver: receiver }
  );
}

pub fn channel[T](zone: ref mut Zone) -> std::sync::Channel[T] {
  let state = std::sync::new_mpsc_state<T>(zone, 1);
  let sender = std::sync::Sender<T> { state: state };
  let receiver = std::sync::Receiver<T> { state: state };
  return std::sync::Channel<T> { sender: sender, receiver: receiver };
}

pub fn mpsc_channel[T](zone: ref mut Zone) -> std::sync::Channel[T] {
  return std::sync::channel<T>(zone);
}

pub impl std::sync::AtomicI64 {
  fn new(value: i64) -> AtomicI64 {
    return AtomicI64 { value: value };
  }

  fn load(self: ref Self) -> i64 {
    return std::sync::load(self);
  }

  fn load_order(self: ref Self, ordering: std::sync::Ordering) -> i64 {
    std::assert(std::sync::is_load_order(ordering));
    return std::sync::load_order_raw(self, std::sync::ordering_code(ordering));
  }

  fn store(self: ref mut Self, replacement: i64) -> void {
    std::sync::store(self, replacement);
  }

  fn store_order(self: ref mut Self, replacement: i64, ordering: std::sync::Ordering) -> void {
    std::assert(std::sync::is_store_order(ordering));
    std::sync::store_order_raw(self, replacement, std::sync::ordering_code(ordering));
  }

  fn swap(self: ref mut Self, replacement: i64) -> i64 {
    return std::sync::swap(self, replacement);
  }

  fn swap_order(self: ref mut Self, replacement: i64, ordering: std::sync::Ordering) -> i64 {
    std::assert(std::sync::is_rmw_order(ordering));
    return std::sync::swap_order_raw(self, replacement, std::sync::ordering_code(ordering));
  }

  fn fetch_add(self: ref mut Self, amount: i64) -> i64 {
    return std::sync::fetch_add(self, amount);
  }

  fn fetch_add_order(self: ref mut Self, amount: i64, ordering: std::sync::Ordering) -> i64 {
    std::assert(std::sync::is_rmw_order(ordering));
    return std::sync::fetch_add_order_raw(self, amount, std::sync::ordering_code(ordering));
  }

  fn compare_exchange_bool(self: ref mut Self, expected: i64, replacement: i64) -> bool {
    return std::sync::compare_exchange(self, expected, replacement);
  }

  fn compare_exchange(self: ref mut Self, expected: i64, replacement: i64) -> std::Result[i64, i64] {
    if self.compare_exchange_bool(expected, replacement) {
      return std::Ok<i64, i64>(expected);
    }
    return std::Err<i64, i64>(self.load());
  }

  fn compare_exchange_order_bool(
    self: ref mut Self,
    expected: i64,
    replacement: i64,
    success: std::sync::Ordering,
    failure: std::sync::Ordering
  ) -> bool {
    std::assert(std::sync::is_compare_exchange_order(success, failure));
    return std::sync::compare_exchange_order_raw(
      self,
      expected,
      replacement,
      std::sync::ordering_code(success),
      std::sync::ordering_code(failure)
    );
  }

  fn compare_exchange_order(
    self: ref mut Self,
    expected: i64,
    replacement: i64,
    success: std::sync::Ordering,
    failure: std::sync::Ordering
  ) -> std::Result[i64, i64] {
    std::assert(std::sync::is_compare_exchange_order(success, failure));
    if std::sync::compare_exchange_order_raw(
      self,
      expected,
      replacement,
      std::sync::ordering_code(success),
      std::sync::ordering_code(failure)
    ) {
      return std::Ok<i64, i64>(expected);
    }
    return std::Err<i64, i64>(self.load_order(failure));
  }
}

pub impl std::sync::AtomicBool {
  fn new(value: bool) -> std::sync::AtomicBool {
    if value {
      return std::sync::AtomicBool { bits: AtomicI64::new(1) };
    }
    return std::sync::AtomicBool { bits: AtomicI64::new(0) };
  }

  fn load(self: ref Self) -> bool {
    return self.bits.load() != 0;
  }

  fn load_order(self: ref Self, ordering: std::sync::Ordering) -> bool {
    std::assert(std::sync::is_load_order(ordering));
    return self.load();
  }

  fn store(self: ref mut Self, replacement: bool) -> void {
    if replacement {
      self.bits.store(1);
    } else {
      self.bits.store(0);
    }
  }

  fn store_order(self: ref mut Self, replacement: bool, ordering: std::sync::Ordering) -> void {
    std::assert(std::sync::is_store_order(ordering));
    self.store(replacement);
  }

  fn swap(self: ref mut Self, replacement: bool) -> bool {
    var raw = 0;
    if replacement {
      raw = 1;
    }
    return self.bits.swap(raw) != 0;
  }

  fn swap_order(self: ref mut Self, replacement: bool, ordering: std::sync::Ordering) -> bool {
    std::assert(std::sync::is_rmw_order(ordering));
    return self.swap(replacement);
  }

  fn compare_exchange_bool(self: ref mut Self, expected: bool, replacement: bool) -> bool {
    var expected_raw = 0;
    var replacement_raw = 0;
    if expected {
      expected_raw = 1;
    }
    if replacement {
      replacement_raw = 1;
    }
    return self.bits.compare_exchange_bool(expected_raw, replacement_raw);
  }

  fn compare_exchange(self: ref mut Self, expected: bool, replacement: bool) -> std::Result[bool, bool] {
    if self.compare_exchange_bool(expected, replacement) {
      return std::Ok<bool, bool>(expected);
    }
    return std::Err<bool, bool>(self.load());
  }

  fn compare_exchange_order_bool(
    self: ref mut Self,
    expected: bool,
    replacement: bool,
    success: std::sync::Ordering,
    failure: std::sync::Ordering
  ) -> bool {
    std::assert(std::sync::is_compare_exchange_order(success, failure));
    var expected_raw = 0;
    var replacement_raw = 0;
    if expected {
      expected_raw = 1;
    }
    if replacement {
      replacement_raw = 1;
    }
    return self.bits.compare_exchange_order_bool(expected_raw, replacement_raw, success, failure);
  }

  fn compare_exchange_order(
    self: ref mut Self,
    expected: bool,
    replacement: bool,
    success: std::sync::Ordering,
    failure: std::sync::Ordering
  ) -> std::Result[bool, bool] {
    if self.compare_exchange_order_bool(expected, replacement, success, failure) {
      return std::Ok<bool, bool>(expected);
    }
    return std::Err<bool, bool>(self.load_order(failure));
  }
}

pub impl std::sync::AtomicUsize {
  fn new(value: u64) -> std::sync::AtomicUsize {
    return std::sync::AtomicUsize { bits: AtomicI64::new(value as i64) };
  }

  fn load(self: ref Self) -> u64 {
    return self.bits.load() as u64;
  }

  fn load_order(self: ref Self, ordering: std::sync::Ordering) -> u64 {
    std::assert(std::sync::is_load_order(ordering));
    return self.load();
  }

  fn store(self: ref mut Self, replacement: u64) -> void {
    self.bits.store(replacement as i64);
  }

  fn store_order(self: ref mut Self, replacement: u64, ordering: std::sync::Ordering) -> void {
    std::assert(std::sync::is_store_order(ordering));
    self.store(replacement);
  }

  fn swap(self: ref mut Self, replacement: u64) -> u64 {
    return self.bits.swap(replacement as i64) as u64;
  }

  fn swap_order(self: ref mut Self, replacement: u64, ordering: std::sync::Ordering) -> u64 {
    std::assert(std::sync::is_rmw_order(ordering));
    return self.swap(replacement);
  }

  fn fetch_add(self: ref mut Self, amount: u64) -> u64 {
    return self.bits.fetch_add(amount as i64) as u64;
  }

  fn fetch_add_order(self: ref mut Self, amount: u64, ordering: std::sync::Ordering) -> u64 {
    std::assert(std::sync::is_rmw_order(ordering));
    return self.fetch_add(amount);
  }

  fn compare_exchange_bool(self: ref mut Self, expected: u64, replacement: u64) -> bool {
    return self.bits.compare_exchange_bool(expected as i64, replacement as i64);
  }

  fn compare_exchange(self: ref mut Self, expected: u64, replacement: u64) -> std::Result[u64, u64] {
    if self.compare_exchange_bool(expected, replacement) {
      return std::Ok<u64, u64>(expected);
    }
    return std::Err<u64, u64>(self.load());
  }

  fn compare_exchange_order_bool(
    self: ref mut Self,
    expected: u64,
    replacement: u64,
    success: std::sync::Ordering,
    failure: std::sync::Ordering
  ) -> bool {
    std::assert(std::sync::is_compare_exchange_order(success, failure));
    return self.bits.compare_exchange_order_bool(expected as i64, replacement as i64, success, failure);
  }

  fn compare_exchange_order(
    self: ref mut Self,
    expected: u64,
    replacement: u64,
    success: std::sync::Ordering,
    failure: std::sync::Ordering
  ) -> std::Result[u64, u64] {
    if self.compare_exchange_order_bool(expected, replacement, success, failure) {
      return std::Ok<u64, u64>(expected);
    }
    return std::Err<u64, u64>(self.load_order(failure));
  }
}

pub impl[T] std::sync::AtomicPtr[T] {
  fn new(value: ptr T) -> std::sync::AtomicPtr[T] {
    return std::sync::AtomicPtr<T> { bits: AtomicUsize::new(value as u64) };
  }

  fn null_ptr() -> std::sync::AtomicPtr[T] {
    return std::sync::AtomicPtr<T>::new(0u64 as ptr T);
  }

  fn load(self: ref Self) -> ptr T {
    return self.bits.load() as ptr T;
  }

  fn load_order(self: ref Self, ordering: std::sync::Ordering) -> ptr T {
    std::assert(std::sync::is_load_order(ordering));
    return self.load();
  }

  fn store(self: ref mut Self, replacement: ptr T) -> void {
    self.bits.store(replacement as u64);
  }

  fn store_order(self: ref mut Self, replacement: ptr T, ordering: std::sync::Ordering) -> void {
    std::assert(std::sync::is_store_order(ordering));
    self.store(replacement);
  }

  fn swap(self: ref mut Self, replacement: ptr T) -> ptr T {
    return self.bits.swap(replacement as u64) as ptr T;
  }

  fn swap_order(self: ref mut Self, replacement: ptr T, ordering: std::sync::Ordering) -> ptr T {
    std::assert(std::sync::is_rmw_order(ordering));
    return self.swap(replacement);
  }

  fn compare_exchange_bool(self: ref mut Self, expected: ptr T, replacement: ptr T) -> bool {
    return self.bits.compare_exchange_bool(expected as u64, replacement as u64);
  }

  fn compare_exchange(self: ref mut Self, expected: ptr T, replacement: ptr T) -> std::Result[u64, u64] {
    if self.compare_exchange_bool(expected, replacement) {
      return std::Ok<u64, u64>(expected as u64);
    }
    return std::Err<u64, u64>(self.load() as u64);
  }

  fn compare_exchange_order_bool(
    self: ref mut Self,
    expected: ptr T,
    replacement: ptr T,
    success: std::sync::Ordering,
    failure: std::sync::Ordering
  ) -> bool {
    std::assert(std::sync::is_compare_exchange_order(success, failure));
    return self.bits.compare_exchange_order_bool(expected as u64, replacement as u64, success, failure);
  }

  fn compare_exchange_order(
    self: ref mut Self,
    expected: ptr T,
    replacement: ptr T,
    success: std::sync::Ordering,
    failure: std::sync::Ordering
  ) -> std::Result[u64, u64] {
    if self.compare_exchange_order_bool(expected, replacement, success, failure) {
      return std::Ok<u64, u64>(expected as u64);
    }
    return std::Err<u64, u64>(self.load_order(failure) as u64);
  }
}

pub impl std::sync::RawMutex {
  fn new() -> RawMutex {
    return RawMutex { state: AtomicI64::new(0) };
  }

  fn try_lock_bool(self: ref mut Self) -> bool {
    return std::sync::try_lock(self);
  }

  fn lock_raw(self: ref mut Self) -> void {
    std::sync::lock(self);
  }

  fn try_lock(self: ref mut Self) -> std::Option[std::sync::RawMutexGuard] {
    if std::sync::try_lock(self) {
      return std::Some<std::sync::RawMutexGuard>(
        std::sync::RawMutexGuard { lock: self as ptr std::sync::RawMutex, active: true }
      );
    }
    return std::None<std::sync::RawMutexGuard>();
  }

  fn lock(self: ref mut Self) -> std::sync::RawMutexGuard {
    std::sync::lock(self);
    return std::sync::RawMutexGuard { lock: self as ptr std::sync::RawMutex, active: true };
  }

  fn unlock(self: ref mut Self) -> void {
    std::sync::unlock(self);
  }

  fn is_locked(self: ref Self) -> bool {
    return std::sync::is_locked(self);
  }
}

pub impl std::sync::RawMutexGuard {
  fn unlock(self: ref mut Self) -> void {
    if self.active {
      std::sync::unlock(ref mut *self.lock);
      self.active = false;
    }
  }

  fn is_active(self: ref Self) -> bool {
    return self.active;
  }
}

impl std::Drop for std::sync::RawMutexGuard {
  fn drop(self) -> void {
    if self.active {
      std::sync::unlock(ref mut *self.lock);
    }
  }
}

pub impl[T] std::sync::Mutex[T] {
  fn new(value: T) -> std::sync::Mutex[T] {
    return std::sync::Mutex<T> {
      lock_value: std::sync::RawMutex::new(),
      value: value,
    };
  }

  fn try_lock(self: ref mut Self) -> std::Option[std::sync::MutexGuard[T]] {
    if std::sync::try_lock(ref mut self.lock_value) {
      return std::Some<std::sync::MutexGuard[T]>(
        std::sync::MutexGuard<T> {
          lock: (ref mut self.lock_value) as ptr std::sync::RawMutex,
          value: (ref mut self.value) as ptr T,
          active: true,
        }
      );
    }
    return std::None<std::sync::MutexGuard[T]>();
  }

  fn lock(self: ref mut Self) -> std::sync::MutexGuard[T] {
    std::sync::lock(ref mut self.lock_value);
    return std::sync::MutexGuard<T> {
      lock: (ref mut self.lock_value) as ptr std::sync::RawMutex,
      value: (ref mut self.value) as ptr T,
      active: true,
    };
  }

  fn get_mut(self: ref mut Self) -> ref mut T {
    return ref mut self.value;
  }

  fn into_inner(self) -> T {
    return self.value;
  }

  fn is_locked(self: ref Self) -> bool {
    return self.lock_value.is_locked();
  }
}

pub impl[T] std::sync::MutexGuard[T] {
  fn value(self: ref Self) -> T {
    return ptr_load(self.value);
  }

  fn value_ref(self: ref Self) -> ref T {
    return ref *self.value;
  }

  fn value_mut(self: ref mut Self) -> ref mut T {
    return ref mut *self.value;
  }

  fn set(self: ref mut Self, value: T) -> void {
    let previous = ptr_load(self.value);
    ptr_store(self.value, value);
    drop previous;
  }

  fn replace(self: ref mut Self, value: T) -> T {
    let previous = ptr_load(self.value);
    ptr_store(self.value, value);
    return previous;
  }

  fn unlock(self: ref mut Self) -> void {
    if self.active {
      std::sync::unlock(ref mut *self.lock);
      self.active = false;
    }
  }

  fn is_active(self: ref Self) -> bool {
    return self.active;
  }
}

impl[T] std::Drop for std::sync::MutexGuard[T] {
  fn drop(self) -> void {
    if self.active {
      std::sync::unlock(ref mut *self.lock);
    }
  }
}

