      }
      let following = bytes[index + 1];
      if following == '{' {
        output.push_in(zone, '{');
        index = index + 2;
      } else if following == '}' {
        if used >= values.len {
          return std::Err<std::string::String, std::error::Error>(std::fmt::template_error());
        }
        output.append_string_in(zone, values[used]);
        used = used + 1;
        index = index + 2;
      } else {
        return std::Err<std::string::String, std::error::Error>(std::fmt::template_error());
      }
    } else if byte == '}' {
      if index + 1 < bytes.len && bytes[index + 1] == '}' {
        output.push_in(zone, '}');
        index = index + 2;
      } else {
        return std::Err<std::string::String, std::error::Error>(std::fmt::template_error());
      }
    } else {
      output.push_in(zone, byte);
      index = index + 1;
    }
  }
  if used != values.len {
    return std::Err<std::string::String, std::error::Error>(std::fmt::template_error());
  }
  return std::Ok<std::string::String, std::error::Error>(output);
}

