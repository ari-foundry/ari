pub fn write_concat_all[W: std::io::Writer](
  writer: ref mut W,
  parts: std::Slice[string]
) -> std::Result[(), std::error::Error] {
  var index = 0;
  while index < parts.len {
    match std::io::write_all<W>(writer, std::string::bytes(parts[index])) {
      std::Err(reason) => {
        return std::Err<(), std::error::Error>(reason);
      }
      std::Ok(_) => {}
    }
    index = index + 1;
  }
  return std::Ok<(), std::error::Error>(());
}

pub fn write_concat_all_bool[W: std::io::Writer](
  writer: ref mut W,
  parts: std::Slice[string]
) -> bool {
  return std::fmt::write_concat_all<W>(writer, parts).is_ok();
}

pub fn write_concat_strings[W: std::io::Writer](
  writer: ref mut W,
  parts: std::Slice[std::string::String]
) -> std::Result[(), std::error::Error] {
  var index = 0;
  while index < parts.len {
    let part = parts[index];
    match std::io::write_all<W>(writer, part.as_slice()) {
      std::Err(reason) => {
        return std::Err<(), std::error::Error>(reason);
      }
      std::Ok(_) => {}
    }
    index = index + 1;
  }
  return std::Ok<(), std::error::Error>(());
}

pub fn write_concat_strings_bool[W: std::io::Writer](
  writer: ref mut W,
  parts: std::Slice[std::string::String]
) -> bool {
  return std::fmt::write_concat_strings<W>(writer, parts).is_ok();
}

pub fn write_format[
  W: std::io::Writer,
  T: std::fmt::Display
](
  writer: ref mut W,
  zone: ref mut Zone,
  template: string,
  value: T
) -> std::Result[(), std::error::Error] {
  let bytes = std::string::bytes(template);
  var index = 0;
  var used = false;
  while index < bytes.len {
    let byte = bytes[index];
    if byte == '{' {
      if index + 1 >= bytes.len {
        return std::Err<(), std::error::Error>(std::fmt::template_error());
      }
      let following = bytes[index + 1];
      if following == '{' {
        match std::fmt::write_template_byte<W>(writer, '{') {
          std::Err(open_brace_reason) => {
            return std::Err<(), std::error::Error>(open_brace_reason);
          }
          std::Ok(_) => {}
        }
        index = index + 2;
      } else if following == '}' {
        if used {
          return std::Err<(), std::error::Error>(std::fmt::template_error());
        }
        let value_text = value.format_in(zone);
        match std::io::write_all<W>(writer, value_text.as_slice()) {
          std::Err(value_reason) => {
            return std::Err<(), std::error::Error>(value_reason);
          }
          std::Ok(_) => {}
        }
        used = true;
        index = index + 2;
      } else {
        return std::Err<(), std::error::Error>(std::fmt::template_error());
      }
    } else if byte == '}' {
      if index + 1 < bytes.len && bytes[index + 1] == '}' {
        match std::fmt::write_template_byte<W>(writer, '}') {
          std::Err(close_brace_reason) => {
            return std::Err<(), std::error::Error>(close_brace_reason);
          }
          std::Ok(_) => {}
        }
        index = index + 2;
      } else {
        return std::Err<(), std::error::Error>(std::fmt::template_error());
      }
    } else {
      match std::fmt::write_template_byte<W>(writer, byte) {
        std::Err(literal_reason) => {
          return std::Err<(), std::error::Error>(literal_reason);
        }
        std::Ok(_) => {}
      }
      index = index + 1;
    }
  }
  if !used {
    return std::Err<(), std::error::Error>(std::fmt::template_error());
  }
  return std::Ok<(), std::error::Error>(());
}

pub fn write_format2[
  W: std::io::Writer,
  A: std::fmt::Display,
  B: std::fmt::Display
](
  writer: ref mut W,
  zone: ref mut Zone,
  template: string,
  first: A,
  second: B
) -> std::Result[(), std::error::Error] {
  let bytes = std::string::bytes(template);
  var index = 0;
  var used = 0;
  while index < bytes.len {
    let byte = bytes[index];
    if byte == '{' {
      if index + 1 >= bytes.len {
        return std::Err<(), std::error::Error>(std::fmt::template_error());
      }
      let following = bytes[index + 1];
      if following == '{' {
        match std::fmt::write_template_byte<W>(writer, '{') {
          std::Err(f2_open_brace_reason) => {
            return std::Err<(), std::error::Error>(f2_open_brace_reason);
          }
          std::Ok(_) => {}
        }
        index = index + 2;
      } else if following == '}' {
        if used == 0 {
          let first_text = first.format_in(zone);
          match std::io::write_all<W>(writer, first_text.as_slice()) {
            std::Err(f2_first_reason) => {
              return std::Err<(), std::error::Error>(f2_first_reason);
            }
            std::Ok(_) => {}
          }
        } else if used == 1 {
          let second_text = second.format_in(zone);
          match std::io::write_all<W>(writer, second_text.as_slice()) {
            std::Err(f2_second_reason) => {
              return std::Err<(), std::error::Error>(f2_second_reason);
            }
            std::Ok(_) => {}
          }
        } else {
          return std::Err<(), std::error::Error>(std::fmt::template_error());
        }
        used = used + 1;
        index = index + 2;
      } else {
        return std::Err<(), std::error::Error>(std::fmt::template_error());
      }
    } else if byte == '}' {
      if index + 1 < bytes.len && bytes[index + 1] == '}' {
        match std::fmt::write_template_byte<W>(writer, '}') {
          std::Err(f2_close_brace_reason) => {
            return std::Err<(), std::error::Error>(f2_close_brace_reason);
          }
          std::Ok(_) => {}
        }
        index = index + 2;
      } else {
        return std::Err<(), std::error::Error>(std::fmt::template_error());
      }
    } else {
      match std::fmt::write_template_byte<W>(writer, byte) {
        std::Err(f2_literal_reason) => {
          return std::Err<(), std::error::Error>(f2_literal_reason);
        }
        std::Ok(_) => {}
      }
      index = index + 1;
    }
  }
  if used != 2 {
    return std::Err<(), std::error::Error>(std::fmt::template_error());
  }
  return std::Ok<(), std::error::Error>(());
}

