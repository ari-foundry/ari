pub fn format_texts(
  zone: ref mut Zone,
  template: string,
  values: std::Slice[string]
) -> std::Result[std::string::String, std::error::Error] {
  let bytes = std::string::bytes(template);
  var output = std::string::new(zone, bytes.len);
  var index = 0;
  var used = 0;
  while index < bytes.len {
    let byte = bytes[index];
    if byte == '{' {
      if index + 1 >= bytes.len {
