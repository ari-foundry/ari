      if index + 1 < bytes.len && bytes[index + 1] == '}' {
        match std::fmt::write_template_byte<W>(writer, '}') {
          std::Err(f3_close_brace_reason) => {
            return std::Err<(), std::error::Error>(f3_close_brace_reason);
          }
          std::Ok(_) => {}
        }
        index = index + 2;
      } else {
        return std::Err<(), std::error::Error>(std::fmt::template_error());
      }
    } else {
      match std::fmt::write_template_byte<W>(writer, byte) {
        std::Err(f3_literal_reason) => {
          return std::Err<(), std::error::Error>(f3_literal_reason);
        }
        std::Ok(_) => {}
      }
      index = index + 1;
    }
  }
  if used != 3 {
    return std::Err<(), std::error::Error>(std::fmt::template_error());
  }
  return std::Ok<(), std::error::Error>(());
}

pub fn write_format4[
  W: std::io::Writer,
  A: std::fmt::Display,
  B: std::fmt::Display,
  C: std::fmt::Display,
  D: std::fmt::Display
](
  writer: ref mut W,
  zone: ref mut Zone,
  template: string,
  first: A,
  second: B,
  third: C,
  fourth: D
) -> std::Result[(), std::error::Error] {
  let bytes = std::string::bytes(template);
  var index = 0;
  var used = 0;
  while index < bytes.len {
    let byte = bytes[index];
    if byte == '{' {
      if index + 1 >= bytes.len {
        return std::Err<(), std::error::Error>(std::fmt::template_error());
      }
      let following = bytes[index + 1];
      if following == '{' {
        match std::fmt::write_template_byte<W>(writer, '{') {
          std::Err(f4_open_brace_reason) => {
            return std::Err<(), std::error::Error>(f4_open_brace_reason);
          }
          std::Ok(_) => {}
        }
        index = index + 2;
      } else if following == '}' {
        if used == 0 {
          let first_text = first.format_in(zone);
          match std::io::write_all<W>(writer, first_text.as_slice()) {
            std::Err(f4_first_reason) => {
              return std::Err<(), std::error::Error>(f4_first_reason);
