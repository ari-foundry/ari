          match std::io::write_all<W>(writer, third_text.as_slice()) {
            std::Err(f4_third_reason) => {
              return std::Err<(), std::error::Error>(f4_third_reason);
            }
            std::Ok(_) => {}
          }
        } else if used == 3 {
          let fourth_text = fourth.format_in(zone);
          match std::io::write_all<W>(writer, fourth_text.as_slice()) {
            std::Err(f4_fourth_reason) => {
              return std::Err<(), std::error::Error>(f4_fourth_reason);
            }
            std::Ok(_) => {}
          }
        } else {
          return std::Err<(), std::error::Error>(std::fmt::template_error());
        }
        used = used + 1;
        index = index + 2;
      } else {
        return std::Err<(), std::error::Error>(std::fmt::template_error());
      }
    } else if byte == '}' {
      if index + 1 < bytes.len && bytes[index + 1] == '}' {
        match std::fmt::write_template_byte<W>(writer, '}') {
          std::Err(f4_close_brace_reason) => {
