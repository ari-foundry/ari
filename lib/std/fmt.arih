pub fn write_debug[W: std::io::Writer, T: std::fmt::Debug](writer: ref mut W, zone: ref mut Zone, value: T) -> std::Result[(), std::error::Error] {
  var text = value.debug_in(zone);
  return std::io::write_all<W>(writer, text.as_slice());
}

pub fn write_debug_bool[W: std::io::Writer, T: std::fmt::Debug](writer: ref mut W, zone: ref mut Zone, value: T) -> bool {
  return std::fmt::write_debug<W, T>(writer, zone, value).is_ok();
}

pub fn write_line_debug[W: std::io::Writer, T: std::fmt::Debug](writer: ref mut W, zone: ref mut Zone, value: T) -> std::Result[(), std::error::Error] {
  match std::fmt::write_debug<W, T>(writer, zone, value) {
    std::Ok(_) => {}
    std::Err(reason) => {
      return std::Err<(), std::error::Error>(reason);
    }
  }
  return std::fmt::write_newline<W>(writer);
}

pub fn write_line_debug_bool[W: std::io::Writer, T: std::fmt::Debug](writer: ref mut W, zone: ref mut Zone, value: T) -> bool {
  return std::fmt::write_line_debug<W, T>(writer, zone, value).is_ok();
}

pub fn print_value[T: std::fmt::Display](zone: ref mut Zone, value: T) -> i64 {
  var text = value.format_in(zone);
  return std::io::write_bytes(text.as_slice());
}

pub fn println_value[T: std::fmt::Display](zone: ref mut Zone, value: T) -> i64 {
  let written = std::fmt::print_value<T>(zone, value);
  std::io::newline();
  return written + 1;
}

pub fn print_debug[T: std::fmt::Debug](zone: ref mut Zone, value: T) -> i64 {
  var text = value.debug_in(zone);
  return std::io::write_bytes(text.as_slice());
}

pub fn println_debug[T: std::fmt::Debug](zone: ref mut Zone, value: T) -> i64 {
  let written = std::fmt::print_debug<T>(zone, value);
  std::io::newline();
  return written + 1;
}
