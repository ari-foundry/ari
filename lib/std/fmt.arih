pub fn concat_all(zone: ref mut Zone, parts: std::Slice[string]) -> std::string::String {
  var output = std::string::new(zone, 0);
  var index = 0;
  while index < parts.len {
    output.append_string_in(zone, parts[index]);
    index = index + 1;
  }
  return output;
}

pub fn concat_strings(zone: ref mut Zone, parts: std::Slice[std::string::String]) -> std::string::String {
  var output = std::string::new(zone, 0);
  var index = 0;
  while index < parts.len {
    let part = parts[index];
    output.append_bytes(zone, part.as_slice());
    index = index + 1;
  }
  return output;
}

pub fn concat2[A: std::fmt::Display, B: std::fmt::Display](
  zone: ref mut Zone,
  first: A,
  second: B
) -> std::string::String {
  var output = std::string::new(zone, 0);
  let first_text = first.format_in(zone);
  output.append_bytes(zone, first_text.as_slice());
  let second_text = second.format_in(zone);
  output.append_bytes(zone, second_text.as_slice());
  return output;
}

pub fn concat3[A: std::fmt::Display, B: std::fmt::Display, C: std::fmt::Display](
  zone: ref mut Zone,
  first: A,
  second: B,
  third: C
) -> std::string::String {
  var output = std::fmt::concat2<A, B>(zone, first, second);
  let third_text = third.format_in(zone);
  output.append_bytes(zone, third_text.as_slice());
  return output;
}

pub fn write_concat2[
  W: std::io::Writer,
  A: std::fmt::Display,
  B: std::fmt::Display
](
  writer: ref mut W,
  zone: ref mut Zone,
  first: A,
  second: B
) -> std::Result[(), std::error::Error] {
  match std::fmt::write_value<W, A>(writer, zone, first) {
    std::Ok(_) => {}
    std::Err(reason) => {
      return std::Err<(), std::error::Error>(reason);
    }
  }
  return std::fmt::write_value<W, B>(writer, zone, second);
}

pub fn write_concat2_bool[
  W: std::io::Writer,
  A: std::fmt::Display,
  B: std::fmt::Display
](
  writer: ref mut W,
  zone: ref mut Zone,
  first: A,
  second: B
) -> bool {
  return std::fmt::write_concat2<W, A, B>(writer, zone, first, second).is_ok();
}

