      }
      let following = bytes[index + 1];
      if following == '{' {
        output.push_in(zone, '{');
        index = index + 2;
      } else if following == '}' {
        if used == 0 {
          let first_text = first.format_in(zone);
          output.append_bytes(zone, first_text.as_slice());
        } else if used == 1 {
          let second_text = second.format_in(zone);
          output.append_bytes(zone, second_text.as_slice());
        } else {
          return std::Err<std::string::String, std::error::Error>(std::fmt::template_error());
        }
        used = used + 1;
        index = index + 2;
      } else {
        return std::Err<std::string::String, std::error::Error>(std::fmt::template_error());
      }
    } else if byte == '}' {
      if index + 1 < bytes.len && bytes[index + 1] == '}' {
        output.push_in(zone, '}');
        index = index + 2;
      } else {
        return std::Err<std::string::String, std::error::Error>(std::fmt::template_error());
      }
    } else {
      output.push_in(zone, byte);
      index = index + 1;
    }
  }
  if used != 2 {
    return std::Err<std::string::String, std::error::Error>(std::fmt::template_error());
  }
  return std::Ok<std::string::String, std::error::Error>(output);
}

