pub struct Slice[T] {
  data: ptr T,
  len: i64,
}

pub struct SlicePair[T] {
  left: Slice[T],
  right: Slice[T],
}

pub struct SliceChunks[T] {
  data: ptr T,
  len: i64,
  mut index: i64,
  size: i64,
}

pub struct SliceWindows[T] {
  data: ptr T,
  len: i64,
  mut index: i64,
  size: i64,
}

pub struct SliceSplit[T] {
  data: ptr T,
  len: i64,
  mut index: i64,
  delimiter: T,
  mut finished: bool,
}

pub fn slice[T](data: ptr T, len: i64) -> Slice[T] {
  return Slice<T> { data: data, len: len };
}

pub fn move[T](value: T) -> T;
pub fn take[T](place: T) -> T;

