pub extern "ari" fn assert_ne_bool(left: bool, right: bool) -> i64 = "ari_builtin_assert_ne_bool";

pub fn assert_equal[T](left: T, right: T) -> i64 {
  return assert(left == right);
}

pub fn assert_not_equal[T](left: T, right: T) -> i64 {
  return assert(left != right);
}

