pub fn return_value() -> i64 {
  return 14 + 5;
}

pub fn final_value() -> i64 {
  3
}

pub fn expression_statement() -> i64 {
  1;
  return 2;
}

pub fn local_flow(flag: bool) -> i64 {
  let base: i64 = 6;
  var total = base;
  if flag {
    total = total + 2;
  } else {
    total = total + 4;
  }
  return total;
}

pub fn labeled_block(flag: bool) -> i64 {
  var total = 1;
  adjust: {
    if flag {
      total = total + 10;
      break adjust;
    }
    total = total + 20;
  }
  return total;
}
