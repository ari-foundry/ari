pub fn return_value() -> i64 {
  return 14 + 5;
}

pub fn final_value() -> i64 {
  3
}

pub fn expression_statement() -> i64 {
  1;
  return 2;
}

pub fn local_flow(flag: bool) -> i64 {
  let base: i64 = 6;
  var total = base;
  if flag {
    total = total + 2;
  } else {
    total = total + 4;
  }
  return total;
}

pub fn labeled_block(flag: bool) -> i64 {
  var total = 1;
  adjust: {
    if flag {
      total = total + 10;
      break adjust;
    }
    total = total + 20;
  }
  return total;
}

pub fn loop_flow() -> i64 {
  var total = 0;
  var i = 0;
  while i < 4 {
    i = i + 1;
    total = total + i;
  }
  for value in range(0, 3) {
    total = total + value;
  }
  init n = 0, carry = total while n < 3 {
    if n == 1 {
      continue n + 1, carry + 20;
    }
    carry = carry + n;
  } next n + 1, carry
  return carry;
}

pub fn match_statement(value: i64) -> i64 {
  var total = 0;
  match value {
    0 => {
      total = 5;
    },
    1..=2 => {
      total = 7;
    },
    _ => {
      total = 9;
    },
  }
  return total;
}

pub struct Counter {
  base: i64,
}

pub impl Counter {
  fn add(self, value: i64) -> i64 {
    self.base + value
  }
}

pub fn method_flow() -> i64 {
  let counter = Counter { base: 10 };
  return counter.add(5);
}

pub fn drop_statement() -> i64 {
  let value = 1;
  drop value;
  return 2;
}

pub fn expression_flow(flag: bool, value: i64) -> i64 {
  let base = if flag {
    let left = 4;
    left
  } else {
    6
  };
  let from_block = {
    let bonus = base + value;
    bonus
  };
  let from_match = match value {
    0 => 1,
    1..=2 => 2,
    _ => 3,
  };
  return from_block + from_match;
}

pub fn scalar_literal_flow() -> i64 {
  let raw: ptr c_void = null;
  let value: f64 = 1.5f64 + 2.0f64;
  if value == 3.5f64 {
    return 6;
  }
  return 1;
}

pub fn borrow_pointer_flow() -> i64 {
  var value: i64 = 3;
  let raw: ptr i64 = (ref mut value) as ptr i64;
  ptr_store(raw, ptr_load(raw) + 9);
  return value;
}

pub fn maybe_cached(flag: bool) -> Option[i64] {
  if flag {
    return Some(9);
  }
  return None<i64>();
}

pub fn try_cached(flag: bool) -> Option[i64] {
  let inner = maybe_cached(flag)?;
  return Some(inner + 1);
}

pub fn coalesce_flow() -> i64 {
  return (try_cached(true) ?? 0) + (try_cached(false) ?? 5);
}

pub fn macro_flow() -> i64 {
  assert_eq!(1 + 2, 3);
  assert_ne!(false, true);
  return 4;
}

trait CacheSelect[T] {
  fn select(value: T) -> Self
}

struct CacheBox[T] {
  value: T,
}

impl[T] CacheSelect[T] for CacheBox[T] {
  fn select(value: T) -> CacheBox[T] {
    CacheBox { value: value }
  }
}

pub fn receiver_type_arg_flow() -> i64 {
  let explicit = CacheSelect<i64>::select<CacheBox[i64]>(12);
  let inferred: CacheBox[i64] = CacheSelect<i64>::select(30);
  return explicit.value + inferred.value;
}

pub fn parameter_pattern_flow((left, right): (i64, i64)) -> i64 {
  return left * 10 + right;
}

pub fn local_binding_pattern_flow() -> i64 {
  let (left, right): (i64, i64) = (1, 0);
  var [first, .., last]: [i64, 4] = [1, 2, 3, 1];
  return left + right + first + last;
}

struct PayloadPair {
  left: i64,
  right: i64,
}

enum PayloadStructPacket {
  PairPayload(PayloadPair),
  EmptyStructPayload,
}

enum PayloadTuplePacket {
  TuplePayload((i64, i64)),
  EmptyTuplePayload,
}

enum PayloadArrayPacket {
  ArrayPayload([i64, 3]),
  EmptyArrayPayload,
}

fn payload_struct_score(value: PayloadStructPacket) -> i64 {
  return match value {
    PairPayload(PayloadPair { left: left, right: right }) => left + right,
    EmptyStructPayload => 0;
  };
}

fn payload_tuple_score(value: PayloadTuplePacket) -> i64 {
  return match value {
    TuplePayload((left, right)) => left + right,
    EmptyTuplePayload => 0;
  };
}

fn payload_array_score(value: PayloadArrayPacket) -> i64 {
  return match value {
    ArrayPayload([first, second, third]) => first + second + third,
    EmptyArrayPayload => 0;
  };
}

pub fn aggregate_payload_pattern_flow() -> i64 {
  return payload_struct_score(PairPayload(PayloadPair { left: 2, right: 3 })) +
         payload_tuple_score(TuplePayload((4, 5))) +
         payload_array_score(ArrayPayload([1, 1, 1]));
}

pub fn vector_body_flow() -> i64 {
  var values: Vec[i64] = [];
  values.reserve(4);
  values.push(2);
  values.push(5);
  values.insert(1, 3);
  values.set(0, 4);
  values.swap(1, 2);
  let removed = values.remove(1);
  let popped = values.pop();
  return values[0] + len(values) + removed + popped + values.capacity();
}

pub fn pointer_deref_flow() -> i64 {
  var value: i64 = 2;
  let raw: ptr i64 = (ref mut value) as ptr i64;
  *raw = *raw + 1;
  return *raw - 1;
}

pub fn empty_unit_cached() {
}

pub fn empty_body_flow() -> i64 {
  empty_unit_cached();
  return 0;
}
