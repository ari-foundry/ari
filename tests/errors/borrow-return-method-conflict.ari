struct Cell {
  mut value: i64,
}

impl Cell {
  fn borrow_value(self: ref mut Self) -> ref mut i64 {
    return ref mut self.value;
  }
}

fn touch(value: ref mut i64) -> i64 {
  return 0;
}

fn main() -> i64 {
  var cell = Cell { value: 1 };
  let value: ref mut i64 = cell.borrow_value();
  let shared: ref i64 = ref cell.value;
  return touch(value);
}
