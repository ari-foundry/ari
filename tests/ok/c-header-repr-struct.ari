@repr(C)
pub enum ApiStatus {
  Ready,
  Busy,
  Done,
}

@repr(C)
pub enum WireStatus[T] {
  Offline,
  Online,
}

@repr(C)
enum HiddenStatus {
  Secret,
}

@repr(C)
pub struct ApiSlots {
  value: i64,
  flag: bool,
  status: ApiStatus,
  raw: ptr c_void,
  shared: ref i64,
  unique: ref mut i64,
}

@repr(C)
pub struct ApiPair {
  left: i64,
  right: i64,
}

@repr(C)
pub struct GenericHandle[T] {
  raw: ptr T,
}

@repr(C)
struct HiddenSlots {
  value: i64,
}

@export("ari_ping")
pub fn ping(value: i64) -> i64 {
  return value;
}

@export("ari_observe")
pub fn observe(slots: ptr ApiSlots) -> i64 {
  return 0;
}

@export("ari_observe_ref")
pub fn observe_ref(value: ref i64) -> i64 {
  return 0;
}

@export("ari_observe_generic")
pub fn observe_generic(handle: ptr GenericHandle[i64]) -> i64 {
  return 0;
}

@export("ari_sum_pair")
pub fn sum_pair(pair: ApiPair) -> i64 {
  return pair.left + pair.right;
}

@export("ari_make_pair")
pub fn make_pair(value: i64) -> ApiPair {
  return ApiPair { left: value, right: value + 1 };
}

@export("ari_status_code")
pub fn status_code(status: ApiStatus) -> i64 {
  return 1;
}

@export("ari_wire_status_code")
pub fn wire_status_code(status: WireStatus[i64]) -> i64 {
  return 2;
}
