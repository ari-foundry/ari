@repr(C)
pub enum ApiStatus {
  Ready,
  Busy,
  Done,
}

@repr(C)
pub enum WireStatus[T] {
  Offline,
  Online,
}

@repr(C)
enum HiddenStatus {
  Secret,
}

@repr(C)
pub struct ApiSlots {
  value: i64,
  flag: bool,
  status: ApiStatus,
  raw: ptr c_void,
  shared: ref i64,
  unique: ref mut i64,
}

@repr(C)
pub struct GenericHandle[T] {
  raw: ptr T,
}

@repr(C)
struct HiddenSlots {
  value: i64,
}

@export("ari_ping")
pub fn ping(value: i64) -> i64 {
  return value;
}

@export("ari_observe")
pub fn observe(slots: ptr ApiSlots) -> i64 {
  return 0;
}

@export("ari_observe_ref")
pub fn observe_ref(value: ref i64) -> i64 {
  return 0;
}

@export("ari_observe_generic")
pub fn observe_generic(handle: ptr GenericHandle[i64]) -> i64 {
  return 0;
}

@export("ari_status_code")
pub fn status_code(status: ApiStatus) -> i64 {
  return 1;
}

@export("ari_wire_status_code")
pub fn wire_status_code(status: WireStatus[i64]) -> i64 {
  return 2;
}
