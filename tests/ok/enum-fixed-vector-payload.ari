enum VecPacket {
  Values(Vec[i64; 3]),
  Empty,
}

fn score(value: VecPacket) -> i64 {
  return match value {
    Values(values) => len(values) + values[0] + values[1] + values[2],
    Empty => 0;
  };
}

fn direct_slot() -> i64 {
  let value: VecPacket = Values([4, 5, 6]);
  let payload: Vec[i64; 3] = value.0;
  return len(payload) + payload[0] + payload[1] + payload[2];
}

fn destructure(value: VecPacket) -> i64 {
  return match value {
    Values([first, second, third]) => first + second + third,
    Values([short_first, short_second]) => short_first * 10 + short_second,
    Values(_) => 1,
    Empty => 0;
  };
}

fn main() -> i64 {
  return score(Values([1, 2, 3])) + direct_slot() +
    destructure(Values([7, 8, 9])) + destructure(Values([4, 5]));
}
