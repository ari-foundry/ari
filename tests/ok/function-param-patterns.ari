struct Point {
  x: i64,
  y: i64,
}

enum OptionI64 {
  Some(i64),
  None,
}

fn sum_pair((left, right): (i64, i64)) -> i64 {
  return left + right;
}

fn sum_point(Point { x, y }: Point) -> i64 {
  return x + y;
}

fn take_some(Some(value): OptionI64) -> i64 {
  return value;
}

fn ignore_first(_: i64, value: i64) -> i64 {
  return value;
}

fn main() -> i64 {
  return sum_pair((3, 4)) +
         sum_point(Point { x: 5, y: 6 }) +
         take_some(Some(7)) +
         ignore_first(99, 8);
}
