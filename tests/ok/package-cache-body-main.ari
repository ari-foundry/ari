mod cache_bodies;

fn main() -> i64 {
  cache_bodies::return_value() +
    cache_bodies::final_value() +
    cache_bodies::expression_statement() +
    cache_bodies::local_flow(true) +
    cache_bodies::local_flow(false) +
    cache_bodies::labeled_block(true) +
    cache_bodies::labeled_block(false) +
    cache_bodies::loop_flow() +
    cache_bodies::match_statement(0) +
    cache_bodies::match_statement(2) +
    cache_bodies::match_statement(4) +
    cache_bodies::method_flow() +
    cache_bodies::drop_statement() +
    cache_bodies::expression_flow(true, 2) +
    cache_bodies::scalar_literal_flow() +
    cache_bodies::borrow_pointer_flow() +
    cache_bodies::macro_flow() +
    cache_bodies::receiver_type_arg_flow() +
    cache_bodies::parameter_pattern_flow((2, 9)) +
    cache_bodies::local_binding_pattern_flow() +
    cache_bodies::pointer_deref_flow()
}
