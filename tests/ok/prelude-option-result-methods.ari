fn maybe(flag: bool) -> Option[i64] {
  if flag {
    return Some(21);
  }
  return None<i64>();
}

fn result(flag: bool) -> Result[i64, i32] {
  if flag {
    return Ok<i64, i32>(8);
  }
  return Err<i64, i32>(3i32);
}

fn main() -> i64 {
  let option_flags =
    (if maybe(true).is_some() { 1 } else { 0 }) +
    (if maybe(false).is_none() { 2 } else { 0 });
  let option_values =
    maybe(true).unwrap_or(5) +
    maybe(false).unwrap_or(7);

  let result_flags =
    (if result(true).is_ok() { 4 } else { 0 }) +
    (if result(false).is_err() { 8 } else { 0 });
  let result_values =
    result(true).unwrap_or(9) +
    result(false).unwrap_or(11);

  let qualified: std::Option[i64] = std::Some(13);
  return option_flags + option_values + result_flags + result_values + qualified.unwrap_or(17);
}
