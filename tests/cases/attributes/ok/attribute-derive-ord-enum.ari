impl Ord[i64] for i64 {
  fn lt(self, other: i64) -> bool {
    return self < other;
  }
}

impl Ord[bool] for bool {
  fn lt(self, other: bool) -> bool {
    return !self && other;
  }
}

@derive(Ord)
enum Value {
  Empty,
  Number(i64),
  Pair(i64, bool),
}

@derive(Ord)
enum Boxed[T] {
  Missing,
  Full(T),
}

fn less[T: Ord[T]](left: T, right: T) -> i64 {
  if left.lt(right) {
    return 11;
  }
  return 3;
}

fn main() -> i64 {
  return less<Value>(Empty, Number(0)) +
         less<Value>(Number(0), Empty) +
         less<Value>(Number(4), Number(5)) +
         less<Value>(Number(5), Number(4)) +
         less<Value>(Pair(5, false), Pair(5, true)) +
         less<Value>(Pair(5, true), Pair(6, false)) +
         less<Value>(Pair(5, true), Pair(5, true)) +
         less<Boxed[i64]>(Missing<i64>(), Full<i64>(0)) +
         less<Boxed[i64]>(Full<i64>(1), Full<i64>(2)) +
         less<Boxed[i64]>(Full<i64>(2), Missing<i64>());
}
