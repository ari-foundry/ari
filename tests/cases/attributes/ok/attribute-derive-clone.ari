@derive(Clone)
struct Point {
  x: i64,
  y: i64,
}

@derive(std::Clone)
enum Flag {
  Off,
  On,
}

@derive(Clone)
enum Payload {
  Empty,
  Value(i64),
}

@derive(Debug, Copy, Clone)
struct Box[T] {
  value: T,
}

fn clone_value[T: Clone](value: T) -> T {
  return value.clone();
}

fn flag_score(flag: Flag) -> i64 {
  match flag {
    Off => {
      return 1;
    }
    On => {
      return 4;
    }
  }
}

fn payload_score(payload: Payload) -> i64 {
  match payload {
    Empty => {
      return 0;
    }
    Value(value) => {
      return value;
    }
  }
}

fn main() -> i64 {
  let point = Point { x: 1, y: 2 };
  let flag: Flag = On;
  let payload: Payload = Value(6);
  let boxed = Box { value: 9 };
  let cloned_point = clone_value<Point>(point);
  let cloned_flag = clone_value<Flag>(flag);
  let cloned_payload = clone_value<Payload>(payload);
  let cloned_box = clone_value<Box[i64]>(boxed);
  return cloned_point.x + cloned_point.y + flag_score(cloned_flag) + payload_score(cloned_payload) + cloned_box.value;
}
