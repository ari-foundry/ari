// Covers module/project authoring policy as ordinary Ari data. This models
// hosted compiler project flow, not bootstrap implementation.
type ProjectScore = i64;

enum ModuleSurface {
  Entry(i64),
  FileModule(i64),
  HeaderSurface(i64),
  Metadata(i64),
  Cache(i64),
  ModuleGraph(i64),
}

enum ProjectState {
  Required(i64),
  Reviewable(i64),
  Planned(i64),
}

struct ProjectRule {
  surface: ModuleSurface,
  state: ProjectState,
  weight: ProjectScore,
  marker: char,
}

fn surface_rank(surface: ModuleSurface) -> i64 {
  match surface {
    Entry(entry_score) => entry_score + 1,
    FileModule(file_module_score) => file_module_score + 2,
    HeaderSurface(header_score) => header_score + 3,
    Metadata(metadata_score) => metadata_score + 5,
    Cache(cache_score) => cache_score + 7,
    ModuleGraph(graph_score) => graph_score + 11,
  }
}

fn state_score(state: ProjectState) -> i64 {
  match state {
    Required(required_score) => required_score,
    Reviewable(reviewable_score) => reviewable_score,
    Planned(planned_score) => planned_score,
  }
}

fn marker_score(marker: char) -> i64 {
  if marker == 'E' {
    return 3;
  }
  if marker == 'F' {
    return 5;
  }
  if marker == 'H' {
    return 7;
  }
  if marker == 'M' {
    return 11;
  }
  if marker == 'C' {
    return 13;
  }
  if marker == 'G' {
    return 17;
  }
  return 0;
}

fn project_rule_score(rule: ProjectRule) -> i64 {
  return surface_rank(rule.surface) + state_score(rule.state) + rule.weight +
    marker_score(rule.marker);
}

fn main() -> i64 {
  var zone = zone::create(1024);
  var rules = std::vec::new<ProjectRule>(ref mut zone, 6);

  rules.push(ProjectRule {
    surface: Entry(10),
    state: Required(8),
    weight: 0,
    marker: 'E',
  });
  rules.push(ProjectRule {
    surface: FileModule(8),
    state: Required(9),
    weight: 0,
    marker: 'F',
  });
  rules.push(ProjectRule {
    surface: HeaderSurface(6),
    state: Planned(4),
    weight: 0,
    marker: 'H',
  });
  rules.push(ProjectRule {
    surface: Metadata(5),
    state: Reviewable(7),
    weight: 0,
    marker: 'M',
  });
  rules.push(ProjectRule {
    surface: Cache(4),
    state: Planned(5),
    weight: 0,
    marker: 'C',
  });
  rules.push(ProjectRule {
    surface: ModuleGraph(7),
    state: Reviewable(8),
    weight: 0,
    marker: 'G',
  });

  let readiness_seed = 40;
  let total = project_rule_score(rules.get(0)) + project_rule_score(rules.get(1)) +
    project_rule_score(rules.get(2)) + project_rule_score(rules.get(3)) +
    project_rule_score(rules.get(4)) + project_rule_score(rules.get(5)) +
    rules.len() + readiness_seed;

  zone::destroy(zone);
  return total;
}
