// Covers compiler test authoring policy as ordinary Ari data. This is not
// bootstrap code; it models normal compiler-development checks.
type TestScore = i64;

enum TestBucket {
  Model,
  ArtifactOk,
  ArtifactError,
  ErrorSource,
  FeatureOk,
  FeatureError,
}

enum CheckKind {
  CheckOnly(i64),
  EmitArtifact(i64),
  LinkRun(i64),
  DocSmoke(i64),
}

struct TestRule {
  bucket: TestBucket,
  check: CheckKind,
  weight: TestScore,
  marker: char,
}

fn bucket_rank(bucket: TestBucket) -> i64 {
  match bucket {
    Model => 1,
    ArtifactOk => 2,
    ArtifactError => 3,
    ErrorSource => 5,
    FeatureOk => 7,
    FeatureError => 11,
  }
}

fn check_score(check: CheckKind) -> i64 {
  match check {
    CheckOnly(check_only_score) => check_only_score,
    EmitArtifact(emit_score) => emit_score,
    LinkRun(link_score) => link_score,
    DocSmoke(doc_score) => doc_score,
  }
}

fn marker_score(marker: char) -> i64 {
  if marker == 'M' {
    return 3;
  }
  if marker == 'A' {
    return 5;
  }
  if marker == 'E' {
    return 7;
  }
  if marker == 'S' {
    return 11;
  }
  if marker == 'O' {
    return 13;
  }
  if marker == 'F' {
    return 17;
  }
  return 0;
}

fn rule_score(rule: TestRule) -> i64 {
  return bucket_rank(rule.bucket) + check_score(rule.check) + rule.weight +
    marker_score(rule.marker);
}

fn main() -> i64 {
  var zone = zone::create(1024);
  var rules = std::vec::new<TestRule>(ref mut zone, 6);

  rules.push(TestRule {
    bucket: Model,
    check: CheckOnly(10),
    weight: 1,
    marker: 'M',
  });
  rules.push(TestRule {
    bucket: ArtifactOk,
    check: EmitArtifact(12),
    weight: 2,
    marker: 'A',
  });
  rules.push(TestRule {
    bucket: ArtifactError,
    check: EmitArtifact(9),
    weight: 3,
    marker: 'E',
  });
  rules.push(TestRule {
    bucket: ErrorSource,
    check: CheckOnly(8),
    weight: 5,
    marker: 'S',
  });
  rules.push(TestRule {
    bucket: FeatureOk,
    check: LinkRun(14),
    weight: 8,
    marker: 'O',
  });
  rules.push(TestRule {
    bucket: FeatureError,
    check: DocSmoke(6),
    weight: 13,
    marker: 'F',
  });

  let readiness_seed = 40;
  let total = rule_score(rules.get(0)) + rule_score(rules.get(1)) +
    rule_score(rules.get(2)) + rule_score(rules.get(3)) +
    rule_score(rules.get(4)) + rule_score(rules.get(5)) + rules.len() +
    readiness_seed;

  zone::destroy(zone);
  return total;
}
