// Covers the near-term compiler-development queue as ordinary Ari data.
// These are normal hosted-compiler slices, not bootstrap implementation steps.
type Effort = i64;

enum NextSliceArea {
  SourceSpans,
  DiagnosticCodes,
  ModuleMetadata,
  GenericAggregates,
  HirArtifact,
}

enum SliceStatus {
  Ready(i64),
  Seeded(i64),
  Blocked(i64),
}

struct NextSlice {
  effort: Effort,
  area: NextSliceArea,
  status: SliceStatus,
  marker: char,
}

fn area_rank(area: NextSliceArea) -> i64 {
  match area {
    SourceSpans => 3,
    DiagnosticCodes => 5,
    ModuleMetadata => 7,
    GenericAggregates => 11,
    HirArtifact => 13,
  }
}

fn status_score(status: SliceStatus) -> i64 {
  match status {
    Ready(ready_score) => ready_score,
    Seeded(seed_score) => seed_score,
    Blocked(blocked_score) => blocked_score,
  }
}

fn marker_score(marker: char) -> i64 {
  if marker == 'S' {
    return 5;
  }
  if marker == 'D' {
    return 7;
  }
  if marker == 'M' {
    return 11;
  }
  if marker == 'G' {
    return 13;
  }
  if marker == 'H' {
    return 17;
  }
  return 1;
}

fn slice_score(slice: NextSlice) -> i64 {
  return slice.effort + area_rank(slice.area) + status_score(slice.status) +
    marker_score(slice.marker);
}

fn main() -> i64 {
  var zone = zone::create(1024);
  var slices = std::vec::new<NextSlice>(ref mut zone, 5);

  slices.push(NextSlice {
    effort: 1,
    area: SourceSpans,
    status: Ready(10),
    marker: 'S',
  });
  slices.push(NextSlice {
    effort: 2,
    area: DiagnosticCodes,
    status: Ready(12),
    marker: 'D',
  });
  slices.push(NextSlice {
    effort: 3,
    area: ModuleMetadata,
    status: Seeded(8),
    marker: 'M',
  });
  slices.push(NextSlice {
    effort: 5,
    area: GenericAggregates,
    status: Blocked(6),
    marker: 'G',
  });
  slices.push(NextSlice {
    effort: 8,
    area: HirArtifact,
    status: Seeded(9),
    marker: 'H',
  });

  let total = slice_score(slices.get(0)) + slice_score(slices.get(1)) +
    slice_score(slices.get(2)) + slice_score(slices.get(3)) +
    slice_score(slices.get(4)) + slices.len();

  zone::destroy(zone);
  return total;
}
