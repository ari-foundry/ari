// Compiler-shaped generic aggregate fixture. This models normal compiler data
// structures without implementing a bootstrap compiler or special-casing std.
type NodeId = i64;
type SymbolId = i64;

struct Span {
  start: i64,
  end: i64,
}

struct Token {
  kind: i64,
  span: Span,
}

struct Symbol {
  id: SymbolId,
}

struct SymbolEntry[K, V] {
  key: K,
  value: V,
}

struct SymbolTable[K, V] {
  first: SymbolEntry[K, V],
  len: i64,
}

struct TokenStream[T] {
  first: T,
  second: T,
  mut cursor: i64,
}

enum AstNode[T] {
  Missing,
  Leaf(T),
  Binary(T, T),
}

struct AstArena[T] {
  first: AstNode[T],
  second: AstNode[T],
  next_id: NodeId,
}

struct DiagnosticBuilder[T] {
  primary: Span,
  detail: Option[T],
}

struct WorkItem {
  pass: i64,
  node: NodeId,
}

struct PassWorklist[T] {
  first: T,
  len: i64,
}

enum PassError[T] {
  Blocked(WorkItem),
  Diagnostic(DiagnosticBuilder[T]),
}

enum PassOutput[T, E] {
  Failed(E),
  Finished(T),
}

struct ParserState[T, E] {
  stream: TokenStream[T],
  arena: AstArena[T],
  diagnostic: DiagnosticBuilder[E],
  symbols: SymbolTable[i64, Symbol],
  worklist: PassWorklist[WorkItem],
}

struct OwnedWork[T] {
  payload: T,
  ticket: own i64,
}

fn make_owned(value: i64) -> own i64 {
  return value;
}

fn span_len(span: Span) -> i64 {
  return span.end - span.start;
}

fn token(kind: i64, start: i64, end: i64) -> Token {
  return Token { kind: kind, span: Span { start: start, end: end } };
}

fn token_score(value: Token) -> i64 {
  return value.kind + span_len(value.span);
}

fn ast_node_score(node: AstNode[Token]) -> i64 {
  match node {
    Missing => {
      return 0;
    }
    Leaf(token_value) => {
      return token_score(token_value);
    }
    Binary(left, right) => {
      return token_score(left) + token_score(right);
    }
  }
}

fn diagnostic_score(value: DiagnosticBuilder[Symbol]) -> i64 {
  return span_len(value.primary) + match value.detail {
    Some(symbol) => symbol.id,
    None => 0,
  };
}

fn work_score(value: WorkItem) -> i64 {
  return value.pass + value.node;
}

fn stream_score(stream: ref TokenStream[Token]) -> i64 {
  return stream.cursor + token_score(stream.first) + token_score(stream.second);
}

fn arena_score(arena: AstArena[Token]) -> i64 {
  return arena.next_id + ast_node_score(arena.first) + ast_node_score(arena.second);
}

fn symbol_table_score(table: SymbolTable[i64, Symbol]) -> i64 {
  return table.len + table.first.key + table.first.value.id;
}

fn worklist_score(worklist: PassWorklist[WorkItem]) -> i64 {
  return worklist.len + work_score(worklist.first);
}

fn build_state() -> ParserState[Token, Symbol] {
  return ParserState<Token, Symbol> {
    stream: TokenStream<Token> {
      first: token(3, 10, 14),
      second: token(5, 20, 23),
      cursor: 2,
    },
    arena: AstArena<Token> {
      first: Leaf<Token>(token(7, 30, 33)),
      second: Binary<Token>(token(11, 40, 42), token(13, 50, 54)),
      next_id: 37,
    },
    diagnostic: DiagnosticBuilder<Symbol> {
      primary: Span { start: 60, end: 66 },
      detail: Some<Symbol>(Symbol { id: 17 }),
    },
    symbols: SymbolTable<i64, Symbol> {
      first: SymbolEntry<i64, Symbol> {
        key: 19,
        value: Symbol { id: 23 },
      },
      len: 1,
    },
    worklist: PassWorklist<WorkItem> {
      first: WorkItem { pass: 29, node: 31 },
      len: 1,
    },
  };
}

fn advance(state: ref mut ParserState[Token, Symbol]) -> void {
  state.stream.cursor = state.stream.cursor + 1;
}

fn run_pass(state: ParserState[Token, Symbol]) -> PassOutput[AstArena[Token], PassError[Symbol]] {
  return Failed<AstArena[Token], PassError[Symbol]>(
    Diagnostic<Symbol>(state.diagnostic)
  );
}

fn output_score(value: PassOutput[AstArena[Token], PassError[Symbol]]) -> i64 {
  match value {
    Finished(arena) => {
      return arena_score(arena);
    }
    Failed(error) => {
      match error {
        Blocked(item) => {
          return work_score(item);
        }
        Diagnostic(builder) => {
          return diagnostic_score(builder);
        }
      }
    }
  }
}

fn consume_owned_work(value: OwnedWork[WorkItem]) -> i64 {
  let ticket = value.ticket;
  drop ticket;
  drop value;
  return 41;
}

fn main() -> i64 {
  var state = build_state();
  advance(ref mut state);

  let stream_total = stream_score(ref state.stream);
  let arena_total = arena_score(state.arena);
  let symbol_total = symbol_table_score(state.symbols);
  let work_total = worklist_score(state.worklist);
  let output_total = output_score(run_pass(state));
  let owned_total = consume_owned_work(OwnedWork<WorkItem> {
    payload: WorkItem { pass: 43, node: 47 },
    ticket: make_owned(1),
  });

  return stream_total + arena_total + symbol_total + work_total + output_total + owned_total - 171;
}
