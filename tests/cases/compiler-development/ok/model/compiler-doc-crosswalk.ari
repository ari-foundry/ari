// Covers the language-docs crosswalk as ordinary Ari data. This keeps
// docs-to-tests navigation executable without adding bootstrap-only behavior.
type CoverageScore = i64;

enum FeatureFamily {
  Core,
  Data,
  Module,
  Trait,
  Ownership,
  Ffi,
  Tooling,
}

enum DocState {
  Readable(CoverageScore),
  Partial(CoverageScore),
  Planned(CoverageScore),
}

enum TestBucket {
  Ok,
  Error,
  Artifact,
  Model,
}

struct FeatureDocLink {
  family: FeatureFamily,
  docs: DocState,
  bucket: TestBucket,
  has_example: bool,
  has_small_check: bool,
  marker: char,
}

fn family_bias(family: FeatureFamily) -> i64 {
  match family {
    Core => 1,
    Data => 2,
    Module => 3,
    Trait => 4,
    Ownership => 5,
    Ffi => 6,
    Tooling => 7,
  }
}

fn doc_score(state: DocState) -> i64 {
  match state {
    Readable(readable_score) => readable_score,
    Partial(partial_score) => partial_score,
    Planned(planned_score) => planned_score,
  }
}

fn bucket_score(bucket: TestBucket) -> i64 {
  match bucket {
    Ok => 10,
    Error => 20,
    Artifact => 30,
    Model => 40,
  }
}

fn bool_score(value: bool, yes: i64) -> i64 {
  if value {
    return yes;
  }
  return 0;
}

fn marker_score(marker: char) -> i64 {
  if marker == 'L' {
    return 3;
  }
  if marker == 'T' {
    return 4;
  }
  if marker == 'C' {
    return 5;
  }
  if marker == 'A' {
    return 6;
  }
  return 1;
}

fn coverage(link: FeatureDocLink) -> i64 {
  return family_bias(link.family) + doc_score(link.docs) +
    bucket_score(link.bucket) + bool_score(link.has_example, 5) +
    bool_score(link.has_small_check, 7) + marker_score(link.marker);
}

fn main() -> i64 {
  let core = FeatureDocLink {
    family: Core,
    docs: Readable(20),
    bucket: Ok,
    has_example: true,
    has_small_check: true,
    marker: 'L',
  };
  let module = FeatureDocLink {
    family: Module,
    docs: Partial(14),
    bucket: Error,
    has_example: true,
    has_small_check: true,
    marker: 'T',
  };
  let trait_link = FeatureDocLink {
    family: Trait,
    docs: Partial(12),
    bucket: Model,
    has_example: false,
    has_small_check: true,
    marker: 'C',
  };
  let tooling = FeatureDocLink {
    family: Tooling,
    docs: Readable(10),
    bucket: Artifact,
    has_example: true,
    has_small_check: false,
    marker: 'A',
  };

  let total = coverage(core) + coverage(module) + coverage(trait_link) +
    coverage(tooling) + 4;
  return total;
}
