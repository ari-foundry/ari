// Covers compiler-development readiness gates as ordinary Ari data. This is a
// production compiler planning fixture, not a bootstrap implementation.
type GateId = i64;
type Percent = i64;
type Weight = i64;

enum GateState {
  Green,
  Yellow(Percent),
  Red(Percent),
}

enum GateError {
  MissingGate(GateId),
  NotReady(Percent),
}

struct CompilerGate {
  id: GateId,
  weight: Weight,
  state: GateState,
  marker: char,
}

fn marker_score(marker: char) -> i64 {
  if marker == 'S' {
    return 1;
  }
  if marker == 'D' {
    return 2;
  }
  if marker == 'A' {
    return 3;
  }
  return 0;
}

fn state_score(state: GateState) -> i64 {
  match state {
    Green => 0,
    Yellow(yellow_percent) => yellow_percent,
    Red(red_percent) => red_percent + 20,
  }
}

fn gate_score(gate: CompilerGate) -> i64 {
  return gate.weight + state_score(gate.state) + marker_score(gate.marker);
}

fn next_green_gate(gate: CompilerGate) -> Result[GateId, GateError] {
  match gate.state {
    Green => Ok(gate.id),
    Yellow(yellow_percent) => Err(NotReady(yellow_percent)),
    Red(red_percent) => Err(NotReady(red_percent + gate.id)),
  }
}

fn gate_result_score(result: Result[GateId, GateError]) -> i64 {
  match result {
    Ok(green_id) => green_id,
    Err(error) => match error {
      MissingGate(missing_id) => 30 + missing_id,
      NotReady(not_ready_percent) => 40 + not_ready_percent,
    },
  }
}

fn readiness_window(low: Percent, high: Percent) -> (Percent, Percent) {
  return (low, high);
}

fn main() -> i64 {
  var zone = zone::create(1024);
  var gates = std::vec::new<CompilerGate>(ref mut zone, 3);

  gates.push(CompilerGate { id: 1, weight: 4, state: Yellow(18), marker: 'S' });
  gates.push(CompilerGate { id: 2, weight: 5, state: Red(12), marker: 'D' });
  gates.push(CompilerGate { id: 3, weight: 6, state: Green, marker: 'A' });

  let first = gate_score(gates.get(0));
  let second = gate_score(gates.get(1));
  let third = gate_score(gates.get(2));
  let first_result = gate_result_score(next_green_gate(gates.get(0)));
  let second_result = gate_result_score(next_green_gate(gates.get(1)));
  let third_result = gate_result_score(next_green_gate(gates.get(2)));
  let readiness = readiness_window(38, 42);
  let window_width = readiness.1 - readiness.0;
  let total = first + second + third + first_result + second_result +
    third_result + window_width + gates.len();

  zone::destroy(zone);
  return total;
}
