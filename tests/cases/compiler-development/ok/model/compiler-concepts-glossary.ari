// Covers the compiler concepts glossary as ordinary Ari data. The goal is to
// model layer ownership and review vocabulary, not to implement bootstrapping.
type ConceptScore = i64;

enum CompilerConcept {
  Source,
  Token,
  Ast,
  Sema,
  Ir,
  Artifact,
  Diagnostic,
}

enum ConceptState {
  Existing(i64),
  Seeded(i64),
  Planned(i64),
}

struct ConceptItem {
  concept: CompilerConcept,
  state: ConceptState,
  weight: ConceptScore,
  marker: char,
}

fn concept_rank(concept: CompilerConcept) -> i64 {
  match concept {
    Source => 1,
    Token => 2,
    Ast => 3,
    Sema => 4,
    Ir => 5,
    Artifact => 6,
    Diagnostic => 7,
  }
}

fn state_score(state: ConceptState) -> i64 {
  match state {
    Existing(existing_score) => existing_score,
    Seeded(seeded_score) => seeded_score,
    Planned(planned_score) => planned_score,
  }
}

fn marker_score(marker: char) -> i64 {
  if marker == 'S' {
    return 1;
  }
  if marker == 'T' {
    return 2;
  }
  if marker == 'A' {
    return 3;
  }
  if marker == 'M' {
    return 4;
  }
  if marker == 'I' {
    return 5;
  }
  if marker == 'R' {
    return 6;
  }
  if marker == 'D' {
    return 7;
  }
  return 0;
}

fn concept_item_score(item: ConceptItem) -> i64 {
  return item.weight + concept_rank(item.concept) + state_score(item.state) +
    marker_score(item.marker);
}

fn main() -> i64 {
  var zone = zone::create(1024);
  var concepts = std::vec::new<ConceptItem>(ref mut zone, 7);

  concepts.push(ConceptItem {
    concept: Source,
    state: Existing(10),
    weight: 1,
    marker: 'S',
  });
  concepts.push(ConceptItem {
    concept: Token,
    state: Existing(10),
    weight: 1,
    marker: 'T',
  });
  concepts.push(ConceptItem {
    concept: Ast,
    state: Seeded(8),
    weight: 2,
    marker: 'A',
  });
  concepts.push(ConceptItem {
    concept: Sema,
    state: Existing(10),
    weight: 2,
    marker: 'M',
  });
  concepts.push(ConceptItem {
    concept: Ir,
    state: Seeded(8),
    weight: 3,
    marker: 'I',
  });
  concepts.push(ConceptItem {
    concept: Artifact,
    state: Planned(5),
    weight: 3,
    marker: 'R',
  });
  concepts.push(ConceptItem {
    concept: Diagnostic,
    state: Seeded(8),
    weight: 5,
    marker: 'D',
  });

  let readiness_seed = 40;
  let total = concept_item_score(concepts.get(0)) +
    concept_item_score(concepts.get(1)) +
    concept_item_score(concepts.get(2)) +
    concept_item_score(concepts.get(3)) +
    concept_item_score(concepts.get(4)) +
    concept_item_score(concepts.get(5)) +
    concept_item_score(concepts.get(6)) + concepts.len() + readiness_seed;

  zone::destroy(zone);
  return total;
}
