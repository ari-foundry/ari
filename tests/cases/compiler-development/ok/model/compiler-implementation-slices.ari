// Covers the implementation playbook as ordinary Ari data: small compiler
// slices, first-check choice, and review readiness. This is not bootstrap code.
type Priority = i64;

enum SliceArea {
  SourceIdentity,
  Diagnostics,
  ModuleFlow,
  GenericModels,
  ArtifactTesting,
  BackendContract,
}

enum CheckKind {
  Docs,
  CheckOnly,
  Artifact,
  Llvm,
  Executable,
}

struct ImplementationSlice {
  priority: Priority,
  area: SliceArea,
  check: CheckKind,
  marker: char,
}

fn area_rank(area: SliceArea) -> i64 {
  match area {
    SourceIdentity => 10,
    Diagnostics => 20,
    ModuleFlow => 30,
    GenericModels => 40,
    ArtifactTesting => 50,
    BackendContract => 60,
  }
}

fn check_rank(check: CheckKind) -> i64 {
  match check {
    Docs => 1,
    CheckOnly => 2,
    Artifact => 3,
    Llvm => 4,
    Executable => 5,
  }
}

fn marker_score(marker: char) -> i64 {
  if marker == 'S' {
    return 7;
  }
  if marker == 'D' {
    return 11;
  }
  if marker == 'M' {
    return 13;
  }
  if marker == 'A' {
    return 17;
  }
  return 1;
}

fn slice_score(slice: ImplementationSlice) -> i64 {
  return slice.priority + area_rank(slice.area) + check_rank(slice.check) +
    marker_score(slice.marker);
}

fn main() -> i64 {
  var zone = zone::create(1024);
  var slices = std::vec::new<ImplementationSlice>(ref mut zone, 4);

  slices.push(ImplementationSlice {
    priority: 1,
    area: SourceIdentity,
    check: Artifact,
    marker: 'S',
  });
  slices.push(ImplementationSlice {
    priority: 1,
    area: Diagnostics,
    check: Artifact,
    marker: 'D',
  });
  slices.push(ImplementationSlice {
    priority: 2,
    area: ModuleFlow,
    check: CheckOnly,
    marker: 'M',
  });
  slices.push(ImplementationSlice {
    priority: 2,
    area: ArtifactTesting,
    check: Llvm,
    marker: 'A',
  });

  let total = slice_score(slices.get(0)) + slice_score(slices.get(1)) +
    slice_score(slices.get(2)) + slice_score(slices.get(3)) + slices.len();

  zone::destroy(zone);
  return total;
}
