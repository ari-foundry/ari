// Covers the compiler-development readiness estimate as ordinary Ari data.
// This is a scorecard model for planning, not a bootstrap implementation.
type Percent = i64;
type Weight = i64;

enum ReadinessGate {
  Frontend,
  SourceIdentity,
  Diagnostics,
  ModuleProjects,
  DataModels,
  TraitSelection,
  Artifacts,
  ToolBuildFlow,
}

enum ReadinessState {
  Strong(Percent),
  Partial(Percent),
  Seeded(Percent),
  Planned(Percent),
}

struct GateScore {
  gate: ReadinessGate,
  state: ReadinessState,
  weight: Weight,
  marker: char,
}

fn state_percent(state: ReadinessState) -> Percent {
  match state {
    Strong(strong_percent) => strong_percent,
    Partial(partial_percent) => partial_percent,
    Seeded(seeded_percent) => seeded_percent,
    Planned(planned_percent) => planned_percent,
  }
}

fn gate_bias(gate: ReadinessGate) -> i64 {
  match gate {
    Frontend => 1,
    SourceIdentity => 2,
    Diagnostics => 3,
    ModuleProjects => 4,
    DataModels => 5,
    TraitSelection => 6,
    Artifacts => 7,
    ToolBuildFlow => 8,
  }
}

fn marker_is_known(marker: char) -> bool {
  return marker == 'F' || marker == 'S' || marker == 'D' ||
    marker == 'M' || marker == 'A' || marker == 'T' ||
    marker == 'R' || marker == 'B';
}

fn contribution(score: GateScore) -> i64 {
  if !marker_is_known(score.marker) {
    return gate_bias(score.gate);
  }
  return state_percent(score.state) * score.weight;
}

fn main() -> i64 {
  var zone = zone::create(1024);
  var gates = std::vec::new<GateScore>(ref mut zone, 8);

  gates.push(GateScore {
    gate: Frontend,
    state: Partial(55),
    weight: 10,
    marker: 'F',
  });
  gates.push(GateScore {
    gate: SourceIdentity,
    state: Seeded(30),
    weight: 12,
    marker: 'S',
  });
  gates.push(GateScore {
    gate: Diagnostics,
    state: Seeded(30),
    weight: 13,
    marker: 'D',
  });
  gates.push(GateScore {
    gate: ModuleProjects,
    state: Partial(45),
    weight: 12,
    marker: 'M',
  });
  gates.push(GateScore {
    gate: DataModels,
    state: Partial(50),
    weight: 15,
    marker: 'A',
  });
  gates.push(GateScore {
    gate: TraitSelection,
    state: Partial(35),
    weight: 12,
    marker: 'T',
  });
  gates.push(GateScore {
    gate: Artifacts,
    state: Partial(45),
    weight: 16,
    marker: 'R',
  });
  gates.push(GateScore {
    gate: ToolBuildFlow,
    state: Planned(35),
    weight: 10,
    marker: 'B',
  });

  let weighted_total = contribution(gates.get(0)) + contribution(gates.get(1)) +
    contribution(gates.get(2)) + contribution(gates.get(3)) +
    contribution(gates.get(4)) + contribution(gates.get(5)) +
    contribution(gates.get(6)) + contribution(gates.get(7));
  let weight_total = gates.get(0).weight + gates.get(1).weight +
    gates.get(2).weight + gates.get(3).weight + gates.get(4).weight +
    gates.get(5).weight + gates.get(6).weight + gates.get(7).weight;
  let readiness = weighted_total / weight_total;

  zone::destroy(zone);
  return readiness;
}
