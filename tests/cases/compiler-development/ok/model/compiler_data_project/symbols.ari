pub struct Symbol {
  id: i64,
  name: i64,
  declared_at: super::diag::Span,
}

pub struct SymbolEntry {
  key: i64,
  value: Symbol,
}

pub struct SymbolTable {
  first: SymbolEntry,
  len: i64,
}

pub fn symbol(id: i64, name: i64, declared_at: super::diag::Span) -> Symbol {
  return Symbol { id: id, name: name, declared_at: declared_at };
}

pub fn symbol_score(symbol: Symbol) -> i64 {
  return symbol.id + symbol.name + super::diag::span_len(symbol.declared_at);
}

pub fn table(key: i64, symbol: Symbol) -> SymbolTable {
  return SymbolTable {
    first: SymbolEntry { key: key, value: symbol },
    len: 1,
  };
}

pub fn table_score(table: SymbolTable) -> i64 {
  return table.len + table.first.key + symbol_score(table.first.value);
}
