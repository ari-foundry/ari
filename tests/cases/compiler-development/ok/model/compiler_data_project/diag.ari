pub struct Span {
  source: i64,
  start: i64,
  end: i64,
}

pub enum Severity {
  Error(i64),
  Warning(i64),
}

pub struct Diagnostic {
  span: Span,
  severity: Severity,
}

pub fn span(source: i64, start: i64, end: i64) -> Span {
  return Span { source: source, start: start, end: end };
}

pub fn span_len(span: Span) -> i64 {
  return span.end - span.start;
}

pub fn diagnostic(span: Span, code: i64) -> Diagnostic {
  return Diagnostic { span: span, severity: Error(code) };
}

pub fn diagnostic_score(diagnostic: Diagnostic) -> i64 {
  return span_len(diagnostic.span) + match diagnostic.severity {
    Error(error_code) => error_code + 10,
    Warning(warning_code) => warning_code + 20,
  };
}
