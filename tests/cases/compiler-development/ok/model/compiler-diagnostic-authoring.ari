// Covers diagnostic authoring policy as ordinary Ari data. It models normal
// compiler diagnostics, not bootstrap implementation.
type DiagnosticScore = i64;

enum DiagnosticFamily {
  Lexer,
  Parser,
  Module,
  TypeTrait,
  Ownership,
  Ir,
  Backend,
}

enum DiagnosticPart {
  Code(i64),
  PrimaryLabel(i64),
  SecondaryLabel(i64),
  Note(i64),
  Help(i64),
  SourceSpan(i64),
  GoldenText(i64),
}

struct DiagnosticRule {
  family: DiagnosticFamily,
  part: DiagnosticPart,
  weight: DiagnosticScore,
  marker: char,
}

fn family_rank(family: DiagnosticFamily) -> i64 {
  match family {
    Lexer => 1,
    Parser => 2,
    Module => 3,
    TypeTrait => 5,
    Ownership => 7,
    Ir => 11,
    Backend => 13,
  }
}

fn part_score(part: DiagnosticPart) -> i64 {
  match part {
    Code(code_score) => code_score,
    PrimaryLabel(primary_score) => primary_score,
    SecondaryLabel(secondary_score) => secondary_score,
    Note(note_score) => note_score,
    Help(help_score) => help_score,
    SourceSpan(source_span_score) => source_span_score,
    GoldenText(golden_score) => golden_score,
  }
}

fn marker_score(marker: char) -> i64 {
  if marker == 'L' {
    return 2;
  }
  if marker == 'P' {
    return 3;
  }
  if marker == 'M' {
    return 5;
  }
  if marker == 'T' {
    return 7;
  }
  if marker == 'O' {
    return 11;
  }
  if marker == 'I' {
    return 13;
  }
  if marker == 'B' {
    return 17;
  }
  return 0;
}

fn diagnostic_rule_score(rule: DiagnosticRule) -> i64 {
  return family_rank(rule.family) + part_score(rule.part) + rule.weight +
    marker_score(rule.marker);
}

fn main() -> i64 {
  var zone = zone::create(1024);
  var rules = std::vec::new<DiagnosticRule>(ref mut zone, 7);

  rules.push(DiagnosticRule {
    family: Lexer,
    part: Code(10),
    weight: 1,
    marker: 'L',
  });
  rules.push(DiagnosticRule {
    family: Parser,
    part: PrimaryLabel(12),
    weight: 1,
    marker: 'P',
  });
  rules.push(DiagnosticRule {
    family: Module,
    part: SourceSpan(9),
    weight: 2,
    marker: 'M',
  });
  rules.push(DiagnosticRule {
    family: TypeTrait,
    part: SecondaryLabel(8),
    weight: 3,
    marker: 'T',
  });
  rules.push(DiagnosticRule {
    family: Ownership,
    part: Note(7),
    weight: 5,
    marker: 'O',
  });
  rules.push(DiagnosticRule {
    family: Ir,
    part: GoldenText(6),
    weight: 8,
    marker: 'I',
  });
  rules.push(DiagnosticRule {
    family: Backend,
    part: Help(5),
    weight: 13,
    marker: 'B',
  });

  let readiness_seed = 40;
  let total = diagnostic_rule_score(rules.get(0)) +
    diagnostic_rule_score(rules.get(1)) +
    diagnostic_rule_score(rules.get(2)) +
    diagnostic_rule_score(rules.get(3)) +
    diagnostic_rule_score(rules.get(4)) +
    diagnostic_rule_score(rules.get(5)) +
    diagnostic_rule_score(rules.get(6)) + rules.len() + readiness_seed;

  zone::destroy(zone);
  return total;
}
