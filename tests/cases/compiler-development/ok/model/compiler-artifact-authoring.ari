// Covers artifact authoring policy as ordinary Ari data. This models artifact
// review order for hosted compiler work, not bootstrap implementation.
type ArtifactScore = i64;

enum ArtifactStage {
  SourceMap(i64),
  Tokens(i64),
  Diagnostics(i64),
  Syntax(i64),
  TypedIr(i64),
  Llvm(i64),
  Executable(i64),
}

enum ArtifactState {
  FirstProof(i64),
  Golden(i64),
  Handoff(i64),
}

struct ArtifactRule {
  stage: ArtifactStage,
  state: ArtifactState,
  weight: ArtifactScore,
  marker: char,
}

fn stage_rank(stage: ArtifactStage) -> i64 {
  match stage {
    SourceMap(source_score) => source_score + 1,
    Tokens(token_score) => token_score + 2,
    Diagnostics(diagnostic_score) => diagnostic_score + 3,
    Syntax(syntax_score) => syntax_score + 5,
    TypedIr(ir_score) => ir_score + 7,
    Llvm(llvm_score) => llvm_score + 11,
    Executable(executable_score) => executable_score + 13,
  }
}

fn state_score(state: ArtifactState) -> i64 {
  match state {
    FirstProof(first_score) => first_score,
    Golden(golden_score) => golden_score,
    Handoff(handoff_score) => handoff_score,
  }
}

fn marker_score(marker: char) -> i64 {
  if marker == 'S' {
    return 2;
  }
  if marker == 'T' {
    return 3;
  }
  if marker == 'D' {
    return 5;
  }
  if marker == 'Y' {
    return 7;
  }
  if marker == 'I' {
    return 11;
  }
  if marker == 'L' {
    return 13;
  }
  if marker == 'E' {
    return 17;
  }
  return 0;
}

fn artifact_rule_score(rule: ArtifactRule) -> i64 {
  return stage_rank(rule.stage) + state_score(rule.state) + rule.weight +
    marker_score(rule.marker);
}

fn main() -> i64 {
  var zone = zone::create(1024);
  var rules = std::vec::new<ArtifactRule>(ref mut zone, 7);

  rules.push(ArtifactRule {
    stage: SourceMap(8),
    state: FirstProof(10),
    weight: 0,
    marker: 'S',
  });
  rules.push(ArtifactRule {
    stage: Tokens(7),
    state: Golden(9),
    weight: 0,
    marker: 'T',
  });
  rules.push(ArtifactRule {
    stage: Diagnostics(6),
    state: Golden(8),
    weight: 0,
    marker: 'D',
  });
  rules.push(ArtifactRule {
    stage: Syntax(5),
    state: Golden(7),
    weight: 0,
    marker: 'Y',
  });
  rules.push(ArtifactRule {
    stage: TypedIr(4),
    state: Golden(6),
    weight: 0,
    marker: 'I',
  });
  rules.push(ArtifactRule {
    stage: Llvm(3),
    state: Handoff(5),
    weight: 0,
    marker: 'L',
  });
  rules.push(ArtifactRule {
    stage: Executable(2),
    state: Handoff(4),
    weight: 0,
    marker: 'E',
  });

  let readiness_seed = 40;
  let total = artifact_rule_score(rules.get(0)) +
    artifact_rule_score(rules.get(1)) +
    artifact_rule_score(rules.get(2)) +
    artifact_rule_score(rules.get(3)) +
    artifact_rule_score(rules.get(4)) +
    artifact_rule_score(rules.get(5)) +
    artifact_rule_score(rules.get(6)) + rules.len() + readiness_seed;

  zone::destroy(zone);
  return total;
}
