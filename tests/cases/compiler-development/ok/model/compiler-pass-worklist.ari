// Covers normal Ari data modeling for compiler-development code: aliases,
// structs, enum payloads, Result flow, Vec storage, and char literals. This is
// intentionally not a bootstrap compiler implementation.
type PassId = i64;
type SourceId = i64;

enum PassKind {
  Lex,
  Parse,
  Resolve,
  TypeCheck,
  Lower,
  Emit,
}

enum PassError {
  MissingSource(SourceId),
  Blocked(PassId),
}

struct WorkItem {
  id: PassId,
  source: SourceId,
  kind: PassKind,
  depends_on: PassId,
  marker: char,
}

fn kind_rank(kind: PassKind) -> i64 {
  match kind {
    Lex => 1,
    Parse => 2,
    Resolve => 3,
    TypeCheck => 4,
    Lower => 5,
    Emit => 6,
  }
}

fn marker_score(marker: char) -> i64 {
  if marker == 'L' {
    return 5;
  }
  return 0;
}

fn is_ready(item: WorkItem, completed: PassId) -> bool {
  return item.depends_on <= completed;
}

fn run_stage(item: WorkItem, completed: PassId) -> Result[i64, PassError] {
  if item.source < 0 {
    return Err(MissingSource(item.source));
  }
  if !is_ready(item, completed) {
    return Err(Blocked(item.depends_on));
  }
  return Ok(kind_rank(item.kind) + item.id + marker_score(item.marker));
}

fn error_score(error: PassError) -> i64 {
  match error {
    MissingSource(source) => 30 + source,
    Blocked(pass) => 40 + pass,
  }
}

fn result_score(result: Result[i64, PassError]) -> i64 {
  match result {
    Ok(value) => value,
    Err(error) => error_score(error),
  }
}

fn main() -> i64 {
  var zone = zone::create(1024);
  var work = std::vec::new<WorkItem>(ref mut zone, 3);
  work.push(WorkItem { id: 1, source: 7, kind: Lex, depends_on: 0, marker: 'L' });
  work.push(WorkItem { id: 2, source: 7, kind: Parse, depends_on: 1, marker: 'P' });
  work.push(WorkItem { id: 3, source: -1, kind: Resolve, depends_on: 2, marker: 'R' });

  let first = result_score(run_stage(work.get(0), 0));
  let second = result_score(run_stage(work.get(1), 0));
  let third = result_score(run_stage(work.get(2), 2));
  let total = first + second + third + work.len();

  zone::destroy(zone);
  return total;
}
