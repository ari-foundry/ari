// Covers compiler layer ownership as ordinary Ari data. This models source
// file, artifact, and focused-check routing for hosted compiler development,
// not a bootstrap implementation.
type LayerScore = i64;

enum CompilerLayer {
  Driver,
  Lexer,
  Parser,
  Resolver,
  Sema,
  Ir,
  Backend,
}

enum LayerArtifact {
  SourceText,
  Tokens,
  Ast,
  ModuleGraph,
  TypedIr,
  LlvmText,
  Executable,
}

struct LayerEntry {
  layer: CompilerLayer,
  artifact: LayerArtifact,
  owns_diagnostics: bool,
  has_focused_check: bool,
  marker: char,
}

fn layer_score(layer: CompilerLayer) -> i64 {
  match layer {
    Driver => 1,
    Lexer => 2,
    Parser => 3,
    Resolver => 4,
    Sema => 5,
    Ir => 6,
    Backend => 7,
  }
}

fn artifact_score(artifact: LayerArtifact) -> i64 {
  match artifact {
    SourceText => 3,
    Tokens => 5,
    Ast => 7,
    ModuleGraph => 11,
    TypedIr => 13,
    LlvmText => 17,
    Executable => 19,
  }
}

fn bool_score(value: bool, amount: i64) -> i64 {
  if value {
    return amount;
  }
  return 0;
}

fn marker_score(marker: char) -> i64 {
  if marker == 'D' {
    return 1;
  }
  if marker == 'L' {
    return 2;
  }
  if marker == 'P' {
    return 3;
  }
  if marker == 'R' {
    return 4;
  }
  if marker == 'S' {
    return 5;
  }
  if marker == 'I' {
    return 6;
  }
  if marker == 'B' {
    return 7;
  }
  return 0;
}

fn entry_score(entry: LayerEntry) -> i64 {
  return layer_score(entry.layer) + artifact_score(entry.artifact) +
    bool_score(entry.owns_diagnostics, 2) +
    bool_score(entry.has_focused_check, 3) + marker_score(entry.marker);
}

fn main() -> i64 {
  let driver = LayerEntry {
    layer: Driver,
    artifact: SourceText,
    owns_diagnostics: false,
    has_focused_check: true,
    marker: 'D',
  };
  let lexer = LayerEntry {
    layer: Lexer,
    artifact: Tokens,
    owns_diagnostics: true,
    has_focused_check: true,
    marker: 'L',
  };
  let parser = LayerEntry {
    layer: Parser,
    artifact: Ast,
    owns_diagnostics: true,
    has_focused_check: true,
    marker: 'P',
  };
  let resolver = LayerEntry {
    layer: Resolver,
    artifact: ModuleGraph,
    owns_diagnostics: true,
    has_focused_check: true,
    marker: 'R',
  };
  let sema = LayerEntry {
    layer: Sema,
    artifact: TypedIr,
    owns_diagnostics: true,
    has_focused_check: true,
    marker: 'S',
  };
  let ir = LayerEntry {
    layer: Ir,
    artifact: TypedIr,
    owns_diagnostics: false,
    has_focused_check: true,
    marker: 'I',
  };
  let backend = LayerEntry {
    layer: Backend,
    artifact: Executable,
    owns_diagnostics: false,
    has_focused_check: true,
    marker: 'B',
  };

  let total = entry_score(driver) + entry_score(lexer) +
    entry_score(parser) + entry_score(resolver) + entry_score(sema) +
    entry_score(ir) + entry_score(backend) + 7;
  return total;
}
