// Covers compiler triage routing as ordinary Ari data. This models how a
// symptom chooses the first compiler layer, artifact, and focused check without
// becoming a bootstrap implementation.
type Priority = i64;

enum TriageSymptom {
  TokenIssue,
  ModuleIssue,
  TypeIssue,
  OwnershipIssue,
  BackendIssue,
}

enum TriageCheck {
  TokenDump,
  ModuleGraph,
  TypedIr,
  CompilerDevelopment,
  LlvmText,
}

struct TriageCase {
  symptom: TriageSymptom,
  check: TriageCheck,
  blocks_start_gate: bool,
  priority: Priority,
  marker: char,
}

fn symptom_score(symptom: TriageSymptom) -> i64 {
  match symptom {
    TokenIssue => 2,
    ModuleIssue => 4,
    TypeIssue => 5,
    OwnershipIssue => 7,
    BackendIssue => 9,
  }
}

fn check_score(check: TriageCheck) -> i64 {
  match check {
    TokenDump => 13,
    ModuleGraph => 19,
    TypedIr => 23,
    CompilerDevelopment => 31,
    LlvmText => 29,
  }
}

fn bool_score(value: bool) -> i64 {
  if value {
    return 5;
  }
  return 0;
}

fn marker_score(marker: char) -> i64 {
  if marker == 'L' {
    return 2;
  }
  if marker == 'M' {
    return 4;
  }
  if marker == 'T' {
    return 5;
  }
  if marker == 'O' {
    return 6;
  }
  if marker == 'B' {
    return 8;
  }
  return 0;
}

fn triage_score(entry: TriageCase) -> i64 {
  return symptom_score(entry.symptom) + check_score(entry.check) +
    bool_score(entry.blocks_start_gate) + entry.priority +
    marker_score(entry.marker);
}

fn main() -> i64 {
  let token_case = TriageCase {
    symptom: TokenIssue,
    check: TokenDump,
    blocks_start_gate: false,
    priority: 3,
    marker: 'L',
  };
  let module_case = TriageCase {
    symptom: ModuleIssue,
    check: ModuleGraph,
    blocks_start_gate: true,
    priority: 4,
    marker: 'M',
  };
  let type_case = TriageCase {
    symptom: TypeIssue,
    check: TypedIr,
    blocks_start_gate: true,
    priority: 5,
    marker: 'T',
  };
  let ownership_case = TriageCase {
    symptom: OwnershipIssue,
    check: CompilerDevelopment,
    blocks_start_gate: true,
    priority: 6,
    marker: 'O',
  };
  let backend_case = TriageCase {
    symptom: BackendIssue,
    check: LlvmText,
    blocks_start_gate: false,
    priority: 7,
    marker: 'B',
  };

  return triage_score(token_case) + triage_score(module_case) +
    triage_score(type_case) + triage_score(ownership_case) +
    triage_score(backend_case) + 5;
}
