// Covers first-day compiler onboarding as ordinary Ari data. The fixture keeps
// the compiler path focused on docs, layers, buckets, and small checks.
type StepScore = i64;

enum OnboardingStep {
  ReadDocs(StepScore),
  PickLayer(StepScore),
  ChooseFixture(StepScore),
  RunCheck(StepScore),
  Handoff(StepScore),
}

enum CompilerLayer {
  Source,
  Lexer,
  Parser,
  Sema,
  Ir,
  Backend,
  Diagnostics,
  Tests,
}

enum TestBucket {
  Model,
  ArtifactOk,
  ArtifactError,
  Error,
  FeatureOk,
}

struct OnboardingTask {
  step: OnboardingStep,
  layer: CompilerLayer,
  bucket: TestBucket,
  focused: bool,
  bootstrap_only: bool,
  marker: char,
}

fn step_score(step: OnboardingStep) -> i64 {
  match step {
    ReadDocs(read_score) => read_score + 1,
    PickLayer(layer_score_value) => layer_score_value + 2,
    ChooseFixture(fixture_score) => fixture_score + 3,
    RunCheck(check_score) => check_score + 4,
    Handoff(handoff_score) => handoff_score + 5,
  }
}

fn layer_score(layer: CompilerLayer) -> i64 {
  match layer {
    Source => 2,
    Lexer => 3,
    Parser => 5,
    Sema => 7,
    Ir => 11,
    Backend => 13,
    Diagnostics => 17,
    Tests => 19,
  }
}

fn bucket_score(bucket: TestBucket) -> i64 {
  match bucket {
    Model => 23,
    ArtifactOk => 29,
    ArtifactError => 31,
    Error => 37,
    FeatureOk => 41,
  }
}

fn focused_score(focused: bool) -> i64 {
  if focused {
    return 6;
  }
  return 0;
}

fn scope_score(bootstrap_only: bool) -> i64 {
  if bootstrap_only {
    return -20;
  }
  return 0;
}

fn marker_score(marker: char) -> i64 {
  if marker == 'D' {
    return 3;
  }
  if marker == 'L' {
    return 5;
  }
  if marker == 'F' {
    return 7;
  }
  if marker == 'H' {
    return 11;
  }
  return 1;
}

fn task_score(task: OnboardingTask) -> i64 {
  return step_score(task.step) + layer_score(task.layer) +
    bucket_score(task.bucket) + focused_score(task.focused) +
    scope_score(task.bootstrap_only) + marker_score(task.marker);
}

fn main() -> i64 {
  var zone = zone::create(1024);
  var tasks = std::vec::new<OnboardingTask>(ref mut zone, 4);

  tasks.push(OnboardingTask {
    step: ReadDocs(4),
    layer: Source,
    bucket: Model,
    focused: true,
    bootstrap_only: false,
    marker: 'D',
  });
  tasks.push(OnboardingTask {
    step: PickLayer(5),
    layer: Diagnostics,
    bucket: ArtifactError,
    focused: true,
    bootstrap_only: false,
    marker: 'L',
  });
  tasks.push(OnboardingTask {
    step: ChooseFixture(6),
    layer: Sema,
    bucket: FeatureOk,
    focused: true,
    bootstrap_only: false,
    marker: 'F',
  });
  tasks.push(OnboardingTask {
    step: Handoff(7),
    layer: Backend,
    bucket: ArtifactOk,
    focused: true,
    bootstrap_only: false,
    marker: 'H',
  });

  let total = task_score(tasks.get(0)) + task_score(tasks.get(1)) +
    task_score(tasks.get(2)) + task_score(tasks.get(3)) + tasks.len();

  zone::destroy(zone);
  return total;
}
