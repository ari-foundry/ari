// Models HIR blocks with fixed node storage, TypeRef arguments, and nested
// Expr/Stmt payloads.
type NodeId = i64;
type TypeId = i64;

struct Span {
  source: i64,
  start: i64,
  end: i64,
}

struct NodeRef {
  id: NodeId,
  span: Span,
}

struct TypeRef {
  name: TypeId,
  first_arg: TypeId,
  second_arg: TypeId,
  span: Span,
}

enum Expr {
  Literal(i64, Span),
  Load(NodeRef),
  Call(NodeRef, TypeRef),
}

enum Stmt {
  Assign(NodeRef, Expr),
  Return(Expr),
  If(NodeRef, NodeRef, NodeRef),
}

struct HirBlock {
  nodes: Vec[NodeRef; 3],
  tail: Stmt,
}

fn span_len(span: Span) -> i64 {
  return span.end - span.start;
}

fn node_score(node: NodeRef) -> i64 {
  return node.id + span_len(node.span);
}

fn type_score(ty: TypeRef) -> i64 {
  return ty.name + ty.first_arg + ty.second_arg + span_len(ty.span);
}

fn expr_score(expr: Expr) -> i64 {
  match expr {
    Literal(value, span) => {
      return value + span_len(span);
    }
    Load(node) => {
      return 20 + node_score(node);
    }
    Call(callee, ty) => {
      return 40 + node_score(callee) + type_score(ty);
    }
  }
}

fn stmt_score(stmt: Stmt) -> i64 {
  match stmt {
    Assign(target, assigned_expr) => {
      return 60 + node_score(target) + expr_score(assigned_expr);
    }
    Return(return_expr) => {
      return 70 + expr_score(return_expr);
    }
    If(condition, then_node, else_node) => {
      return 80 + node_score(condition) + node_score(then_node) +
        node_score(else_node);
    }
  }
}

fn block_score(block: HirBlock) -> i64 {
  let HirBlock {
    nodes: [entry, middle, exit],
    tail: tail,
  } = block;
  return node_score(entry) + node_score(middle) + node_score(exit) +
    stmt_score(tail);
}

fn main() -> i64 {
  let first = NodeRef { id: 3, span: Span { source: 1, start: 0, end: 2 } };
  let second = NodeRef { id: 5, span: Span { source: 1, start: 3, end: 7 } };
  let third = NodeRef { id: 8, span: Span { source: 1, start: 8, end: 13 } };
  let ty = TypeRef {
    name: 11,
    first_arg: 13,
    second_arg: 17,
    span: Span { source: 1, start: 14, end: 20 },
  };
  let block = HirBlock {
    nodes: [first, second, third],
    tail: Assign(second, Call(first, ty)),
  };

  return block_score(block) - 40;
}
