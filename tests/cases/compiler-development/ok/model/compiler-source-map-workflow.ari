// Covers source identity as ordinary compiler-development data: source ids,
// byte spans, line/column lookup, structured errors, and tuple returns.
type SourceId = i64;
type ByteOffset = i64;
type Line = i64;
type Column = i64;

struct SourceFile {
  id: SourceId,
  byte_len: ByteOffset,
  line0: ByteOffset,
  line1: ByteOffset,
  line2: ByteOffset,
}

struct Span {
  source: SourceId,
  start: ByteOffset,
  end: ByteOffset,
}

struct Location {
  line: Line,
  column: Column,
}

struct LineColumnRange {
  start: Location,
  end: Location,
}

enum SourceError {
  WrongSource(SourceId),
  OutOfBounds(ByteOffset),
  ReversedSpan(Span),
}

fn span_len(span: Span) -> ByteOffset {
  return span.end - span.start;
}

fn locate(file: SourceFile, byte: ByteOffset) -> Result[Location, SourceError] {
  if byte < 0 || byte > file.byte_len {
    return Err(OutOfBounds(byte));
  }
  if byte >= file.line2 {
    return Ok(Location { line: 3, column: byte - file.line2 + 1 });
  }
  if byte >= file.line1 {
    return Ok(Location { line: 2, column: byte - file.line1 + 1 });
  }
  return Ok(Location { line: 1, column: byte - file.line0 + 1 });
}

fn validate_span(file: SourceFile, span: Span) -> Result[Span, SourceError] {
  if span.source != file.id {
    return Err(WrongSource(span.source));
  }
  if span.start < 0 {
    return Err(OutOfBounds(span.start));
  }
  if span.end > file.byte_len {
    return Err(OutOfBounds(span.end));
  }
  if span.end < span.start {
    return Err(ReversedSpan(span));
  }
  return Ok(span);
}

fn span_range(file: SourceFile, span: Span) -> Result[LineColumnRange, SourceError] {
  let checked_result = validate_span(file, span);
  return match checked_result {
    Ok(checked) => {
      let start_result = locate(file, checked.start);
      match start_result {
        Ok(start) => {
          let end_result = locate(file, checked.end);
          match end_result {
            Ok(end) => Ok(LineColumnRange { start: start, end: end }),
            Err(end_error) => Err(end_error),
          }
        },
        Err(start_error) => Err(start_error),
      }
    },
    Err(validate_error) => Err(validate_error),
  };
}

fn error_score(error: SourceError) -> i64 {
  match error {
    WrongSource(source) => 40 + source,
    OutOfBounds(byte) => 50 + byte,
    ReversedSpan(span) => 60 + span_len(span),
  }
}

fn range_score(result: Result[LineColumnRange, SourceError]) -> i64 {
  match result {
    Ok(range) => range.start.line * 100 + range.start.column * 10 + range.end.line + range.end.column,
    Err(error) => error_score(error),
  }
}

fn line_pair(file: SourceFile, byte: ByteOffset) -> (Line, Column) {
  let located = locate(file, byte).unwrap();
  return (located.line, located.column);
}

fn main() -> i64 {
  let file = SourceFile { id: 3, byte_len: 18, line0: 0, line1: 6, line2: 13 };
  let good = range_score(span_range(file, Span { source: 3, start: 8, end: 15 }));
  let wrong = range_score(span_range(file, Span { source: 9, start: 1, end: 2 }));
  let bounds = range_score(span_range(file, Span { source: 3, start: 2, end: 30 }));
  let pair = line_pair(file, 14);
  return good + wrong + bounds + pair.0 + pair.1;
}
