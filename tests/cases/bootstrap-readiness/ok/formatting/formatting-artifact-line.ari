// Covers compiler artifact text that combines string labels, numeric spans,
// and char payloads through the public formatting surface.
struct Span {
  start: i64,
  end: i64,
}

fn dump_token(name: string, value: char, span: Span) {
  println("token={} value={} span={}:{}", name, value, span.start, span.end);
}

fn main() -> i64 {
  dump_token("character", 'x', Span { start: 4, end: 5 });
  return 0;
}
