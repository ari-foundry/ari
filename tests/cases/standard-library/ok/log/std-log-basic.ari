// Covers source std::log level helpers and stderr-backed line output.
fn main() -> i64 {
  var score = 0;
  var zone = zone::create(1024);

  if log::rank(log::Trace) == 0 {
    score = score + 1;
  }
  if log::rank(log::Error) == 4 {
    score = score + 1;
  }
  if log::enabled(log::Warn, log::Info) {
    score = score + 1;
  }
  if !log::enabled(log::Debug, log::Info) {
    score = score + 1;
  }
  if log::name(ref mut zone, log::Error).equals_text("error") {
    score = score + 1;
  }

  var bytes = [79u8, 75u8];
  if log::write(log::Info, bytes.as_slice()) {
    score = score + 1;
  }
  var careful = std::string::from(ref mut zone, "careful");
  if log::message(log::Warn, ref careful) {
    score = score + 1;
  }
  var debugging = std::string::from(ref mut zone, "debugging");
  if log::debug(ref debugging) {
    score = score + 1;
  }
  var broken = std::string::from(ref mut zone, "broken");
  if log::error(ref broken) {
    score = score + 1;
  }

  zone::destroy(zone);
  return score;
}
