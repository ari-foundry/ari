// Covers UTC-only calendar conversion from Unix timestamps.
// Timezone databases and local time policy intentionally stay outside this test.
fn expect_utc(
  value: std::time::UtcDateTime,
  year: i64,
  month: i64,
  day: i64,
  hour: i64,
  minute: i64,
  second: i64,
  nanosecond: i64
) -> void {
  assert_eq_i64(value.year(), year);
  assert_eq_i64(value.month(), month);
  assert_eq_i64(value.day(), day);
  assert_eq_i64(value.hour(), hour);
  assert_eq_i64(value.minute(), minute);
  assert_eq_i64(value.second(), second);
  assert_eq_i64(value.nanosecond(), nanosecond);
  return;
}

fn main() -> i64 {
  assert(time::is_leap_year(2000));
  assert(time::is_leap_year(2020));
  assert(!time::is_leap_year(1900));
  assert(!time::is_leap_year(2021));
  assert_eq_i64(time::days_in_month(2020, 2), 29);
  assert_eq_i64(time::days_in_month(2021, 2), 28);
  assert_eq_i64(time::days_in_month(2021, 11), 30);
  assert_eq_i64(time::days_in_month(2021, 12), 31);

  let epoch = time::utc_from_unix(0, 0);
  expect_utc(epoch, 1970, 1, 1, 0, 0, 0, 0);

  let next_day = time::utc_from_unix(86400, 7);
  expect_utc(next_day, 1970, 1, 2, 0, 0, 0, 7);

  let leap_day = time::utc_from_unix(1582934400, 123);
  expect_utc(leap_day, 2020, 2, 29, 0, 0, 0, 123);
  assert(leap_day.is_leap_year());

  let year_end = time::utc_from_unix(1704067199, 999999999);
  expect_utc(year_end, 2023, 12, 31, 23, 59, 59, 999999999);

  let from_system = time::system_from_unix(1704067200, 42);
  assert_eq_i64(from_system.as_unix_seconds(), 1704067200);
  assert_eq_i64(from_system.subsec_nanos(), 42);
  let new_year = from_system.to_utc();
  expect_utc(new_year, 2024, 1, 1, 0, 0, 0, 42);

  let associated = time::SystemTime::from_unix(946684800, 5);
  expect_utc(associated.to_utc(), 2000, 1, 1, 0, 0, 0, 5);

  return 0;
}
