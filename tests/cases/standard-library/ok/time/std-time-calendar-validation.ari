// Covers calendar validation helpers. Invalid month values are common at
// parsing boundaries, so the fallible helper should return None instead of
// relying on the strict days_in_month assertion.
fn has_days(value: std::Option[i64], expected: i64) -> bool {
  match value {
    std::Some(days) => {
      return days == expected;
    }
    std::None => {}
  }
  return false;
}

fn main() -> i64 {
  var score = 0;

  if time::try_days_in_month(2024, 0).is_none() {
    score = score + 1;
  }
  if time::try_days_in_month(2024, 13).is_none() {
    score = score + 2;
  }
  if has_days(time::try_days_in_month(2024, 2), 29) {
    score = score + 3;
  }
  if has_days(time::try_days_in_month(2023, 2), 28) {
    score = score + 4;
  }
  if has_days(time::try_days_in_month(2026, 11), 30) {
    score = score + 5;
  }
  if time::days_in_month(2026, 12) == 31 {
    score = score + 6;
  }

  return score;
}
