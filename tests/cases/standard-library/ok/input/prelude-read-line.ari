fn main() -> i64 {
  var zone = zone::create(1024);

  var first = read_line(ref mut zone);
  var second = io::read_line(ref mut zone);
  var third = input(ref mut zone);
  var fourth = input::line(ref mut zone);

  write_bytes(first.as_slice());
  newline();
  write_bytes(second.as_slice());
  newline();
  write_bytes(third.as_slice());
  newline();
  write_bytes(fourth.as_slice());
  newline();

  zone::destroy(zone);
  return 0;
}
