fn byte_at(text: ptr c_char, index: i64) -> u8 {
  let raw: ptr u8 = text as ptr u8;
  return ptr_load(ptr_add(raw, index));
}

fn literal() -> ptr c_char {
  return "A\n";
}

fn write_text(text: ptr c_char) -> i64 {
  write_byte(byte_at(text, 0));
  write_byte(byte_at(text, 1));
  return byte_at(text, 2) as i64;
}

fn main() -> i64 {
  let text: ptr c_char = literal();
  let nul = write_text(text);
  let other: ptr u8 = "B" as ptr u8;
  write_byte(ptr_load(other));
  return (byte_at(text, 0) as i64) +
    (byte_at(text, 1) as i64) +
    nul +
    (ptr_load(other) as i64);
}
