// Covers source std::fmt FormatSpec helpers, allocator-backed formatting, and
// Writer-backed formatting without relying on compiler format macro lowering.
struct MemoryWriter {
  data: Slice[u8],
  mut position: i64,
}

impl io::Writer for MemoryWriter {
  fn write_byte(self: ref mut Self, value: u8) -> bool {
    if self.position >= self.data.len {
      return false;
    }
    ptr_store(ptr_add(self.data.as_ptr(), self.position), value);
    self.position = self.position + 1;
    return true;
  }

  fn write(self: ref mut Self, values: Slice[u8]) -> Result[i64, error::Error] {
    return io::write<MemoryWriter>(self, values);
  }

  fn write_all(self: ref mut Self, values: Slice[u8]) -> Result[(), error::Error] {
    return io::write_all<MemoryWriter>(self, values);
  }

  fn flush(self: ref mut Self) -> Result[(), error::Error] {
    return Ok(());
  }
}

fn text(zone: ref mut Zone, value: Slice[u8]) -> String {
  return std::string::from(zone, value);
}

fn main() -> i64 {
  var zone = zone::create(256);
  var score = 0;

  var padded = fmt::unsigned_in(ref mut zone, 255u64, fmt::with_width(fmt::hex(), 4));
  if padded.len() == 4 && padded.get(0) == 32u8 && padded.get(2) == 102u8 && padded.get(3) == 102u8 {
    score = score + 1;
  }

  var binary = fmt::unsigned_in(ref mut zone, 10u64, fmt::alternate(fmt::binary()));
  if binary.len() == 6 && binary.get(0) == 48u8 && binary.get(1) == 98u8 && binary.get(5) == 48u8 {
    score = score + 1;
  }

  var upper = fmt::unsigned_in(ref mut zone, 255u64, fmt::uppercase(fmt::hex()));
  if upper.len() == 2 && upper.get(0) == 70u8 && upper.get(1) == 70u8 {
    score = score + 1;
  }

  var precise = fmt::unsigned_in(ref mut zone, 7u64, fmt::with_precision(fmt::octal(), 3));
  if precise.len() == 3 && precise.get(0) == 48u8 && precise.get(1) == 48u8 && precise.get(2) == 55u8 {
    score = score + 1;
  }

  var left = fmt::unsigned_in(ref mut zone, 7u64, fmt::left(fmt::with_width(fmt::decimal(), 3)));
  if left.len() == 3 && left.get(0) == 55u8 && left.get(1) == 32u8 && left.get(2) == 32u8 {
    score = score + 1;
  }

  var integer = fmt::integer_in(ref mut zone, -42);
  if integer.len() == 3 && integer.get(0) == 45u8 && integer.get(2) == 50u8 {
    score = score + 1;
  }

  var ari_text = std::string::from(ref mut zone, "ari");
  var quoted = fmt::debug_text_in(ref mut zone, ref ari_text);
  if quoted.len() == 5 && quoted.get(0) == 34u8 && quoted.get(4) == 34u8 {
    score = score + 1;
  }

  var buffer = [0u8, 0u8, 0u8, 0u8];
  var writer = MemoryWriter { data: buffer.as_slice(), position: 0 };
  if fmt::write_unsigned<MemoryWriter>(ref mut writer, ref mut zone, 31u64, fmt::uppercase(fmt::hex())).is_ok() {
    if buffer[0] == 49u8 && buffer[1] == 70u8 && writer.position == 2 {
      score = score + 1;
    }
  }

  var bool_buffer = [0u8, 0u8];
  var bool_writer = MemoryWriter { data: bool_buffer.as_slice(), position: 0 };
  if fmt::write_unsigned_bool<MemoryWriter>(ref mut bool_writer, ref mut zone, 31u64, fmt::uppercase(fmt::hex())) {
    if bool_buffer[0] == '1' && bool_buffer[1] == 'F' && bool_writer.position == 2 {
      score = score + 1;
    }
  }

  var integer_buffer = [0u8, 0u8, 0u8];
  var integer_writer = MemoryWriter { data: integer_buffer.as_slice(), position: 0 };
  if fmt::write_integer<MemoryWriter>(ref mut integer_writer, ref mut zone, -7).is_ok() {
    if integer_buffer[0] == '-' && integer_buffer[1] == '7' && integer_writer.position == 2 {
      score = score + 1;
    }
  }

  var integer_bool_buffer = [0u8, 0u8];
  var integer_bool_writer = MemoryWriter { data: integer_bool_buffer.as_slice(), position: 0 };
  if fmt::write_integer_bool<MemoryWriter>(ref mut integer_bool_writer, ref mut zone, 42) {
    if integer_bool_buffer[0] == '4' && integer_bool_buffer[1] == '2' && integer_bool_writer.position == 2 {
      score = score + 1;
    }
  }

  var true_buffer = [0u8, 0u8, 0u8, 0u8];
  var true_writer = MemoryWriter { data: true_buffer.as_slice(), position: 0 };
  if fmt::write_boolean<MemoryWriter>(ref mut true_writer, ref mut zone, true).is_ok() {
    if true_buffer[0] == 't' && true_buffer[3] == 'e' && true_writer.position == 4 {
      score = score + 1;
    }
  }

  var false_buffer = [0u8, 0u8, 0u8, 0u8, 0u8];
  var false_writer = MemoryWriter { data: false_buffer.as_slice(), position: 0 };
  if fmt::write_boolean_bool<MemoryWriter>(ref mut false_writer, ref mut zone, false) {
    if false_buffer[0] == 'f' && false_buffer[4] == 'e' && false_writer.position == 5 {
      score = score + 1;
    }
  }

  var text_buffer = [0u8, 0u8];
  var text_writer = MemoryWriter { data: text_buffer.as_slice(), position: 0 };
  var io_text = std::string::from(ref mut zone, "io");
  if fmt::write_text<MemoryWriter>(ref mut text_writer, ref mut zone, ref io_text).is_ok() {
    if text_buffer[0] == 'i' && text_buffer[1] == 'o' && text_writer.position == 2 {
      score = score + 1;
    }
  }

  var text_bool_buffer = [0u8, 0u8, 0u8];
  var text_bool_writer = MemoryWriter { data: text_bool_buffer.as_slice(), position: 0 };
  if fmt::write_text_bool<MemoryWriter>(ref mut text_bool_writer, ref mut zone, ref ari_text) {
    if text_bool_buffer[0] == 'a' && text_bool_buffer[2] == 'i' && text_bool_writer.position == 3 {
      score = score + 1;
    }
  }

  var display_buffer = [0u8, 0u8, 0u8, 0u8, 0u8, 0u8];
  var display_writer = MemoryWriter { data: display_buffer.as_slice(), position: 0 };
  if fmt::write_value<MemoryWriter, i64>(ref mut display_writer, ref mut zone, -128).is_ok() {
    if display_buffer[0] == '-' && display_buffer[1] == '1' && display_buffer[3] == '8' && display_writer.position == 4 {
      score = score + 1;
    }
  }

  var short_buffer = [0u8, 0u8];
  var short_writer = MemoryWriter { data: short_buffer.as_slice(), position: 0 };
  let short_text = text(ref mut zone, "tool");
  if fmt::write_value<MemoryWriter, String>(ref mut short_writer, ref mut zone, short_text).is_err() {
    score = score + 1;
  }

  var short_bool_buffer = [0u8];
  var short_bool_writer = MemoryWriter { data: short_bool_buffer.as_slice(), position: 0 };
  let short_bool_text = text(ref mut zone, "io");
  if !fmt::write_value_bool<MemoryWriter, String>(ref mut short_bool_writer, ref mut zone, short_bool_text) {
    score = score + 1;
  }

  var concat2_buffer = [0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8];
  var concat2_writer = MemoryWriter { data: concat2_buffer.as_slice(), position: 0 };
  let concat_name = std::string::from(ref mut zone, "ari");
  let concat_prefix = text(ref mut zone, "name=");
  if fmt::write_concat2<MemoryWriter, String, String>(ref mut concat2_writer, ref mut zone, concat_prefix, concat_name).is_ok() {
    if concat2_buffer[0] == 'n' && concat2_buffer[4] == '=' && concat2_buffer[7] == 'i' && concat2_writer.position == 8 {
      score = score + 1;
    }
  }

  var concat2_bool_buffer = [0u8, 0u8, 0u8, 0u8];
  var concat2_bool_writer = MemoryWriter { data: concat2_bool_buffer.as_slice(), position: 0 };
  let concat_a = text(ref mut zone, "A");
  let concat_b = text(ref mut zone, "B");
  if fmt::write_concat2_bool<MemoryWriter, String, String>(ref mut concat2_bool_writer, ref mut zone, concat_a, concat_b) {
    if concat2_bool_buffer[0] == 'A' && concat2_bool_buffer[1] == 'B' && concat2_bool_writer.position == 2 {
      score = score + 1;
    }
  }

  var concat3_buffer = [0u8, 0u8, 0u8];
  var concat3_writer = MemoryWriter { data: concat3_buffer.as_slice(), position: 0 };
  let concat_v = text(ref mut zone, "v");
  let concat_bang = text(ref mut zone, "!");
  if fmt::write_concat3_bool<MemoryWriter, String, i64, String>(ref mut concat3_writer, ref mut zone, concat_v, 7, concat_bang) {
    if concat3_buffer[0] == 'v' && concat3_buffer[1] == '7' && concat3_buffer[2] == '!' && concat3_writer.position == 3 {
      score = score + 1;
    }
  }

  var short_concat_buffer = [0u8, 0u8];
  var short_concat_writer = MemoryWriter { data: short_concat_buffer.as_slice(), position: 0 };
  let short_concat_a = text(ref mut zone, "ab");
  let short_concat_b = text(ref mut zone, "c");
  let short_concat_c = text(ref mut zone, "d");
  if fmt::write_concat3<MemoryWriter, String, String, String>(
    ref mut short_concat_writer,
    ref mut zone,
    short_concat_a,
    short_concat_b,
    short_concat_c
  ).is_err() {
    if short_concat_writer.position == 2 && short_concat_buffer[0] == 'a' && short_concat_buffer[1] == 'b' {
      score = score + 1;
    }
  }

  var line_text_buffer = [0u8, 0u8, 0u8];
  var line_text_writer = MemoryWriter { data: line_text_buffer.as_slice(), position: 0 };
  var ok_text = std::string::from(ref mut zone, "ok");
  if fmt::write_line_text<MemoryWriter>(ref mut line_text_writer, ref mut zone, ref ok_text).is_ok() {
    if line_text_buffer[0] == 'o' && line_text_buffer[1] == 'k' && line_text_buffer[2] == 10u8 && line_text_writer.position == 3 {
      score = score + 1;
    }
  }

  var line_text_bool_buffer = [0u8, 0u8, 0u8, 0u8];
  var line_text_bool_writer = MemoryWriter { data: line_text_bool_buffer.as_slice(), position: 0 };
  var yes_text = std::string::from(ref mut zone, "yes");
  if fmt::write_line_text_bool<MemoryWriter>(ref mut line_text_bool_writer, ref mut zone, ref yes_text) {
    if line_text_bool_buffer[0] == 'y' && line_text_bool_buffer[2] == 's' && line_text_bool_buffer[3] == 10u8 && line_text_bool_writer.position == 4 {
      score = score + 1;
    }
  }

  var short_line_text_buffer = [0u8, 0u8];
  var short_line_text_writer = MemoryWriter { data: short_line_text_buffer.as_slice(), position: 0 };
  if fmt::write_line_text<MemoryWriter>(ref mut short_line_text_writer, ref mut zone, ref ok_text).is_err() {
    if short_line_text_writer.position == 2 && short_line_text_buffer[0] == 'o' && short_line_text_buffer[1] == 'k' {
      score = score + 1;
    }
  }

  var line_value_buffer = [0u8, 0u8, 0u8];
  var line_value_writer = MemoryWriter { data: line_value_buffer.as_slice(), position: 0 };
  if fmt::write_line_value<MemoryWriter, i64>(ref mut line_value_writer, ref mut zone, -9).is_ok() {
    if line_value_buffer[0] == '-' && line_value_buffer[1] == '9' && line_value_buffer[2] == 10u8 && line_value_writer.position == 3 {
      score = score + 1;
    }
  }

  var line_value_bool_buffer = [0u8, 0u8, 0u8];
  var line_value_bool_writer = MemoryWriter { data: line_value_bool_buffer.as_slice(), position: 0 };
  let line_value_text = text(ref mut zone, "hi");
  if fmt::write_line_value_bool<MemoryWriter, String>(ref mut line_value_bool_writer, ref mut zone, line_value_text) {
    if line_value_bool_buffer[0] == 'h' && line_value_bool_buffer[1] == 'i' && line_value_bool_buffer[2] == 10u8 && line_value_bool_writer.position == 3 {
      score = score + 1;
    }
  }

  var line_debug_buffer = [0u8, 0u8, 0u8, 0u8];
  var line_debug_writer = MemoryWriter { data: line_debug_buffer.as_slice(), position: 0 };
  let line_debug_text = text(ref mut zone, "x");
  if fmt::write_line_debug<MemoryWriter, String>(ref mut line_debug_writer, ref mut zone, line_debug_text).is_ok() {
    if line_debug_buffer[0] == 34u8 && line_debug_buffer[1] == 'x' && line_debug_buffer[2] == 34u8 && line_debug_buffer[3] == 10u8 && line_debug_writer.position == 4 {
      score = score + 1;
    }
  }

  var short_line_debug_buffer = [0u8, 0u8, 0u8];
  var short_line_debug_writer = MemoryWriter { data: short_line_debug_buffer.as_slice(), position: 0 };
  let short_line_debug_text = text(ref mut zone, "x");
  if !fmt::write_line_debug_bool<MemoryWriter, String>(ref mut short_line_debug_writer, ref mut zone, short_line_debug_text) {
    if short_line_debug_writer.position == 3 && short_line_debug_buffer[0] == 34u8 && short_line_debug_buffer[2] == 34u8 {
      score = score + 1;
    }
  }

  zone::destroy(zone);
  return score;
}
