// Covers byte-character formatting through Display, Debug, and format_in!.
// `char` keeps the same runtime width as u8, while text-shaped APIs preserve
// the source-level character intent for literals and char-typed values.
fn main() -> i64 {
  var zone = zone::create(256);

  var text = std::string::empty(ref mut zone);
  text.append_value('A');
  text.push('-');
  text.append_debug('B');
  assert_equal[bool](text.equals_text("A-'B'"), true);

  var rendered = format_in!(ref mut zone, "c={} dbg={:?} raw={}", 'C', 'D', 65u8);
  assert_equal[bool](rendered.equals_text("c=C dbg='D' raw=65"), true);

  var newline = fmt::debug_char_in(ref mut zone, '\n');
  assert_equal[bool](newline.equals_text("'\\n'"), true);

  let total = text.len() + rendered.len() + newline.len();
  zone::destroy(zone);
  return total;
}
