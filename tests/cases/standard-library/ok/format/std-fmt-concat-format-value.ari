  var buffer11 = [0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8];
  var writer11 = MemoryWriter { data: buffer11.as_slice(), position: 0 };
  let write_x = text(ref mut zone, "X");
  let write_value_a = fmt::format_value<String>(ref mut zone, write_x);
  let write_value_b = fmt::format_value<i64>(ref mut zone, 9);
  let write_z = text(ref mut zone, "Z");
  let write_value_c = fmt::format_value<String>(ref mut zone, write_z);
  var write_value_parts = std::vec::new<std::string::String>(ref mut zone, 3);
  write_value_parts.push(write_value_a);
  write_value_parts.push(write_value_b);
  write_value_parts.push(write_value_c);
  let write_value_template = text(ref mut zone, "{}-{}-{}");
  if !fmt::write_format_values<MemoryWriter>(
