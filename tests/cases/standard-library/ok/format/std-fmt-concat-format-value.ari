    zone::destroy(zone);
    return 38;
  }

  var stream_buffer2 = [0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8];
  var stream_writer2 = MemoryWriter { data: stream_buffer2.as_slice(), position: 0 };
  let stream_template = text(ref mut zone, "a{}{}{}{}");
  let stream_b = text(ref mut zone, "b");
  let stream_bang = text(ref mut zone, "!");
  if !fmt::write_format_stream4<MemoryWriter, String, i64, bool, String>(
