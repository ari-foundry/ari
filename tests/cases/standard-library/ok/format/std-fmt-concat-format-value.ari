// Covers source-level formatting conveniences for ordinary CLI-style messages
// without requiring compiler format macro lowering.
struct Point {
  x: i64,
  y: i64,
}

struct MemoryWriter {
  data: Slice[u8],
  mut position: i64,
}

impl io::Writer for MemoryWriter {
  fn write_byte(self: ref mut Self, value: u8) -> bool {
    if self.position >= self.data.len {
      return false;
    }
    ptr_store(ptr_add(self.data.as_ptr(), self.position), value);
    self.position = self.position + 1;
    return true;
  }

  fn write(self: ref mut Self, values: Slice[u8]) -> Result[i64, error::Error] {
    return io::write<MemoryWriter>(self, values);
  }

  fn write_all(self: ref mut Self, values: Slice[u8]) -> Result[(), error::Error] {
    return io::write_all<MemoryWriter>(self, values);
  }

  fn flush(self: ref mut Self) -> Result[(), error::Error] {
    return Ok(());
  }
}

impl fmt::Display for Point {
  fn format_in(self: ref Self, zone: ref mut Zone) -> std::string::String {
    var output = std::string::new(zone, 8);
    output.append_string_in(zone, "(");
    output.append_i64_in(zone, self.x);
    output.append_string_in(zone, ",");
    output.append_i64_in(zone, self.y);
    output.append_string_in(zone, ")");
    return output;
  }
}

fn text(zone: ref mut Zone, value: Slice[u8]) -> String {
  return std::string::from(zone, value);
}

fn equals_text(value: String, expected: Slice[u8]) -> bool {
  return value.equals(expected);
}

fn unit_error_is(value: Result[(), error::Error], kind: error::Kind) -> bool {
  match value {
    Ok(_) => {
      return false;
    }
    Err(reason) => {
      return reason.is_kind(kind);
    }
  }
}

fn main() -> i64 {
  var zone = zone::create(4096);

  let number = fmt::format_value<i64>(ref mut zone, -42);
  if !equals_text(number, "-42") {
    zone::destroy(zone);
    return 1;
  }

  let name = std::string::from(ref mut zone, "hello");
  let compiling_prefix = text(ref mut zone, "Compiling ");
  let compiling = fmt::concat2<String, String>(ref mut zone, compiling_prefix, name);
  if !equals_text(compiling, "Compiling hello") {
    zone::destroy(zone);
    return 2;
  }

  let target_prefix = text(ref mut zone, "target/debug/");
  let target_suffix = text(ref mut zone, ".ari");
  let target = fmt::concat3<String, i64, String>(ref mut zone, target_prefix, 7, target_suffix);
  if !equals_text(target, "target/debug/7.ari") {
    zone::destroy(zone);
    return 3;
  }

  var text_parts = std::vec::new<std::string::String>(ref mut zone, 5);
  text_parts.push(std::string::from(ref mut zone, "arix"));
  text_parts.push(std::string::from(ref mut zone, " "));
  text_parts.push(std::string::from(ref mut zone, "run"));
  text_parts.push(std::string::from(ref mut zone, " "));
  text_parts.push(std::string::from(ref mut zone, "--release"));
  let text_joined = fmt::concat_all(ref mut zone, text_parts.as_slice());
  if !equals_text(text_joined, "arix run --release") {
    zone::destroy(zone);
    return 44;
  }

  let owned_a = std::string::from(ref mut zone, "target/");
  let owned_b = std::string::from(ref mut zone, "debug/");
  let owned_c = std::string::from(ref mut zone, "hello");
  var owned_parts = std::vec::new<std::string::String>(ref mut zone, 3);
  owned_parts.push(owned_a);
  owned_parts.push(owned_b);
  owned_parts.push(owned_c);
  let owned_joined = fmt::concat_strings(ref mut zone, owned_parts.as_slice());
  if !equals_text(owned_joined, "target/debug/hello") {
    zone::destroy(zone);
    return 45;
  }

  let point = Point { x: 3, y: 5 };
  let display = fmt::format_value<Point>(ref mut zone, point);
  if !equals_text(display, "(3,5)") {
    zone::destroy(zone);
    return 4;
  }

  let other = Point { x: 8, y: 13 };
  let message_prefix = text(ref mut zone, "point=");
  let message_suffix = text(ref mut zone, "!");
  let message = fmt::concat3<String, Point, String>(ref mut zone, message_prefix, other, message_suffix);
  if !equals_text(message, "point=(8,13)!") {
    zone::destroy(zone);
    return 5;
  }

  let template_value_ok = text(ref mut zone, "value={} {{ok}}");
  let template_value = text(ref mut zone, "value={}");
  let template_value_extra = text(ref mut zone, "value={} {}");
  let template_value_open = text(ref mut zone, "value={");
  match fmt::format<i64>(ref mut zone, template_value_ok, 9) {
    Ok(formatted) => {
      if !equals_text(formatted, "value=9 {ok}") {
        zone::destroy(zone);
        return 6;
      }
      if !fmt::format<i64>(ref mut zone, template_value, 1).is_ok() {
        zone::destroy(zone);
        return 7;
      }
      if !fmt::format<i64>(ref mut zone, template_value_extra, 1).is_err() {
        zone::destroy(zone);
        return 8;
      }
      if !fmt::format<i64>(ref mut zone, template_value_open, 1).is_err() {
        zone::destroy(zone);
        return 9;
      }
    }
    Err(_) => {
      zone::destroy(zone);
      return 10;
    }
  }

  let template_eq = text(ref mut zone, "{}={}");
  let template_colon = text(ref mut zone, "{}:{}{}");
  let template_colon_missing = text(ref mut zone, "{}:{}");
  let template_build = text(ref mut zone, "{} {} {}{}");
  let template_build_missing = text(ref mut zone, "{} {} {}");
  let value_n = text(ref mut zone, "n");
  match fmt::format2<String, i64>(ref mut zone, template_eq, value_n, 2) {
    Ok(formatted2) => {
      if !equals_text(formatted2, "n=2") {
        zone::destroy(zone);
        return 11;
      }
      let value_v = text(ref mut zone, "v");
      let value_bang = text(ref mut zone, "!");
      match fmt::format3<String, i64, String>(ref mut zone, template_colon, value_v, 7, value_bang) {
        Ok(formatted3) => {
          if !equals_text(formatted3, "v:7!") {
            zone::destroy(zone);
            return 12;
          }
          let value_n_again = text(ref mut zone, "n");
          if !fmt::format2<String, i64>(ref mut zone, template_eq, value_n_again, 2).is_ok() {
            zone::destroy(zone);
            return 13;
