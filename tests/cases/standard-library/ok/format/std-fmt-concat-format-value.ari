  var buffer6 = [0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8];
  var writer6 = MemoryWriter { data: buffer6.as_slice(), position: 0 };
