            return 14;
          }
          let build_arg0 = text(ref mut zone, "arix");
          let build_arg1 = text(ref mut zone, "build");
          let build_arg2 = text(ref mut zone, "--jobs=");
          match fmt::format4<String, String, String, i64>(
            ref mut zone,
