// Covers source-level formatting conveniences for ordinary CLI-style messages
// without requiring compiler format macro lowering.
struct Point {
  x: i64,
  y: i64,
}

struct MemoryWriter {
  data: Slice[u8],
  mut position: i64,
}

impl io::Writer for MemoryWriter {
  fn write_byte(self: ref mut Self, value: u8) -> bool {
    if self.position >= self.data.len {
      return false;
    }
    ptr_store(ptr_add(self.data.as_ptr(), self.position), value);
    self.position = self.position + 1;
    return true;
  }

  fn write(self: ref mut Self, values: Slice[u8]) -> Result[i64, error::Error] {
    return io::write<MemoryWriter>(self, values);
  }

  fn write_all(self: ref mut Self, values: Slice[u8]) -> Result[(), error::Error] {
    return io::write_all<MemoryWriter>(self, values);
  }

  fn flush(self: ref mut Self) -> Result[(), error::Error] {
    return Ok(());
  }
}

impl fmt::Display for Point {
  fn format_in(self: ref Self, zone: ref mut Zone) -> std::string::String {
    var output = std::string::new(zone, 8);
    output.append_string_in(zone, "(");
    output.append_i64_in(zone, self.x);
    output.append_string_in(zone, ",");
    output.append_i64_in(zone, self.y);
    output.append_string_in(zone, ")");
    return output;
  }
}

fn equals_text(value: String, expected: string) -> bool {
  return value.equals(std::string::bytes(expected));
}

fn unit_error_is(value: Result[(), error::Error], kind: error::Kind) -> bool {
  match value {
    Ok(_) => {
      return false;
    }
    Err(reason) => {
      return reason.is_kind(kind);
    }
  }
}

fn main() -> i64 {
  var zone = zone::create(4096);

  let number = fmt::format_value<i64>(ref mut zone, -42);
  if !equals_text(number, "-42") {
    zone::destroy(zone);
    return 1;
  }

  let name = std::string::from(ref mut zone, "hello");
  let compiling = fmt::concat2<string, String>(ref mut zone, "Compiling ", name);
  if !equals_text(compiling, "Compiling hello") {
    zone::destroy(zone);
    return 2;
  }

  let target = fmt::concat3<string, i64, string>(ref mut zone, "target/debug/", 7, ".ari");
  if !equals_text(target, "target/debug/7.ari") {
    zone::destroy(zone);
    return 3;
  }

  var text_parts = ["arix", " ", "run", " ", "--release"];
  let text_joined = fmt::concat_all(ref mut zone, text_parts.as_slice());
  if !equals_text(text_joined, "arix run --release") {
    zone::destroy(zone);
    return 44;
  }

  let owned_a = std::string::from(ref mut zone, "target/");
  let owned_b = std::string::from(ref mut zone, "debug/");
  let owned_c = std::string::from(ref mut zone, "hello");
  var owned_parts = std::vec::new<std::string::String>(ref mut zone, 3);
  owned_parts.push(owned_a);
  owned_parts.push(owned_b);
  owned_parts.push(owned_c);
  let owned_joined = fmt::concat_strings(ref mut zone, owned_parts.as_slice());
  if !equals_text(owned_joined, "target/debug/hello") {
    zone::destroy(zone);
    return 45;
  }

  let point = Point { x: 3, y: 5 };
  let display = fmt::format_value<Point>(ref mut zone, point);
  if !equals_text(display, "(3,5)") {
    zone::destroy(zone);
    return 4;
  }

  let other = Point { x: 8, y: 13 };
  let message = fmt::concat3<string, Point, string>(ref mut zone, "point=", other, "!");
  if !equals_text(message, "point=(8,13)!") {
    zone::destroy(zone);
    return 5;
  }

  match fmt::format<i64>(ref mut zone, "value={} {{ok}}", 9) {
    Ok(formatted) => {
      if !equals_text(formatted, "value=9 {ok}") {
        zone::destroy(zone);
        return 6;
      }
      if !fmt::format<i64>(ref mut zone, "value={}", 1).is_ok() {
        zone::destroy(zone);
        return 7;
      }
      if !fmt::format<i64>(ref mut zone, "value={} {}", 1).is_err() {
        zone::destroy(zone);
        return 8;
      }
      if !fmt::format<i64>(ref mut zone, "value={", 1).is_err() {
        zone::destroy(zone);
        return 9;
      }
    }
    Err(_) => {
      zone::destroy(zone);
      return 10;
    }
  }

  match fmt::format2<string, i64>(ref mut zone, "{}={}", "n", 2) {
    Ok(formatted2) => {
      if !equals_text(formatted2, "n=2") {
        zone::destroy(zone);
        return 11;
      }
      match fmt::format3<string, i64, string>(ref mut zone, "{}:{}{}", "v", 7, "!") {
        Ok(formatted3) => {
          if !equals_text(formatted3, "v:7!") {
            zone::destroy(zone);
            return 12;
          }
          if !fmt::format2<string, i64>(ref mut zone, "{}={}", "n", 2).is_ok() {
            zone::destroy(zone);
            return 13;
          }
          if !fmt::format3<string, i64, string>(ref mut zone, "{}:{}", "v", 7, "!").is_err() {
            zone::destroy(zone);
            return 14;
          }
          match fmt::format4<string, string, string, i64>(ref mut zone, "{} {} {}{}", "arix", "build", "--jobs=", 4) {
            Ok(formatted4) => {
              if !equals_text(formatted4, "arix build --jobs=4") {
                zone::destroy(zone);
                return 28;
              }
              if !fmt::format4<string, string, string, i64>(ref mut zone, "{} {} {}", "arix", "build", "--jobs=", 4).is_err() {
                zone::destroy(zone);
                return 29;
              }
            }
            Err(_) => {
              zone::destroy(zone);
              return 30;
            }
          }
          var template_texts = ["arix", "build", "--jobs=", "4", "done"];
          match fmt::format_texts(ref mut zone, "{} {} {}{} {}", template_texts.as_slice()) {
            Ok(formatted_texts) => {
              if !equals_text(formatted_texts, "arix build --jobs=4 done") {
                zone::destroy(zone);
                return 46;
              }
            }
            Err(_) => {
              zone::destroy(zone);
              return 47;
            }
          }
          var missing_texts = ["one"];
          if !fmt::format_texts(ref mut zone, "{} {}", missing_texts.as_slice()).is_err() {
            zone::destroy(zone);
            return 48;
          }
          let value_a = fmt::format_value<string>(ref mut zone, "point=");
          let value_b = fmt::format_value<Point>(ref mut zone, other);
          let value_c = fmt::format_value<string>(ref mut zone, "!");
          var template_values = std::vec::new<std::string::String>(ref mut zone, 3);
          template_values.push(value_a);
          template_values.push(value_b);
          template_values.push(value_c);
          match fmt::format_values(ref mut zone, "{}{}{}", template_values.as_slice()) {
            Ok(formatted_values) => {
              if !equals_text(formatted_values, "point=(8,13)!") {
                zone::destroy(zone);
                return 49;
              }
            }
            Err(_) => {
              zone::destroy(zone);
              return 50;
            }
          }
        }
        Err(_) => {
          zone::destroy(zone);
          return 15;
        }
      }
    }
    Err(_) => {
      zone::destroy(zone);
      return 16;
    }
  }

  var buffer = [0u8, 0u8, 0u8, 0u8, 0u8];
  var writer = MemoryWriter { data: buffer.as_slice(), position: 0 };
  if !fmt::write_format<MemoryWriter, i64>(ref mut writer, ref mut zone, "n={}", 4).is_ok() {
    zone::destroy(zone);
    return 17;
  }
  if !(buffer[0] == 'n' && buffer[1] == '=' && buffer[2] == '4' && writer.position == 3) {
    zone::destroy(zone);
    return 18;
  }

  var buffer2 = [0u8, 0u8, 0u8, 0u8, 0u8];
  var writer2 = MemoryWriter { data: buffer2.as_slice(), position: 0 };
  if !fmt::write_format2<MemoryWriter, string, i64>(ref mut writer2, ref mut zone, "{}={}", "x", 5).is_ok() {
    zone::destroy(zone);
    return 19;
  }
  if !(buffer2[0] == 'x' && buffer2[1] == '=' && buffer2[2] == '5' && writer2.position == 3) {
    zone::destroy(zone);
    return 20;
  }

  var buffer3 = [0u8, 0u8, 0u8, 0u8, 0u8];
  var writer3 = MemoryWriter { data: buffer3.as_slice(), position: 0 };
  if !fmt::write_format3<MemoryWriter, string, i64, string>(ref mut writer3, ref mut zone, "{}:{}{}", "v", 8, "!").is_ok() {
    zone::destroy(zone);
    return 21;
  }
  if !(buffer3[0] == 'v' && buffer3[1] == ':' && buffer3[2] == '8' && buffer3[3] == '!' &&
       writer3.position == 4) {
    zone::destroy(zone);
    return 22;
  }

  var buffer6 = [0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8];
  var writer6 = MemoryWriter { data: buffer6.as_slice(), position: 0 };
  if !fmt::write_format4<MemoryWriter, string, string, string, i64>(
    ref mut writer6,
    ref mut zone,
    "{} {} {}{}",
    "arix",
    "build",
    "--jobs=",
    4
  ).is_ok() {
    zone::destroy(zone);
    return 31;
  }
  if !(buffer6[0] == 'a' && buffer6[1] == 'r' && buffer6[2] == 'i' && buffer6[3] == 'x' &&
       buffer6[4] == ' ' && buffer6[5] == 'b' && buffer6[6] == 'u' && buffer6[7] == 'i' &&
       buffer6[8] == 'l' && buffer6[9] == 'd' && buffer6[10] == ' ' && buffer6[11] == '-' &&
       buffer6[12] == '-' && buffer6[13] == 'j' && buffer6[14] == 'o' && buffer6[15] == 'b' &&
       buffer6[16] == 's' && buffer6[17] == '=' && buffer6[18] == '4' && writer6.position == 19) {
    zone::destroy(zone);
    return 32;
  }

  var buffer9 = [0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8];
  var writer9 = MemoryWriter { data: buffer9.as_slice(), position: 0 };
  var write_text_parts = ["a", "b", "3", "?", "!"];
  if !fmt::write_concat_all<MemoryWriter>(ref mut writer9, write_text_parts.as_slice()).is_ok() {
    zone::destroy(zone);
    return 51;
  }
  if !(buffer9[0] == 'a' && buffer9[1] == 'b' && buffer9[2] == '3' &&
       buffer9[3] == '?' && buffer9[4] == '!' && writer9.position == 5) {
    zone::destroy(zone);
    return 52;
  }

  var buffer10 = [0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8];
  var writer10 = MemoryWriter { data: buffer10.as_slice(), position: 0 };
  var write_format_parts = ["A", "B", "C", "D", "E"];
  if !fmt::write_format_texts<MemoryWriter>(ref mut writer10, "{}{}{}{}{}", write_format_parts.as_slice()).is_ok() {
    zone::destroy(zone);
    return 53;
  }
  if !(buffer10[0] == 'A' && buffer10[1] == 'B' && buffer10[2] == 'C' &&
       buffer10[3] == 'D' && buffer10[4] == 'E' && writer10.position == 5) {
    zone::destroy(zone);
    return 54;
  }

  var buffer11 = [0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8];
  var writer11 = MemoryWriter { data: buffer11.as_slice(), position: 0 };
  let write_value_a = fmt::format_value<string>(ref mut zone, "X");
  let write_value_b = fmt::format_value<i64>(ref mut zone, 9);
  let write_value_c = fmt::format_value<string>(ref mut zone, "Z");
  var write_value_parts = std::vec::new<std::string::String>(ref mut zone, 3);
  write_value_parts.push(write_value_a);
  write_value_parts.push(write_value_b);
  write_value_parts.push(write_value_c);
  if !fmt::write_format_values<MemoryWriter>(ref mut writer11, "{}-{}-{}", write_value_parts.as_slice()).is_ok() {
    zone::destroy(zone);
    return 55;
  }
  if !(buffer11[0] == 'X' && buffer11[1] == '-' && buffer11[2] == '9' &&
       buffer11[3] == '-' && buffer11[4] == 'Z' && writer11.position == 5) {
    zone::destroy(zone);
    return 56;
  }

  var buffer4 = [0u8, 0u8, 0u8, 0u8];
  var writer4 = MemoryWriter { data: buffer4.as_slice(), position: 0 };
  if !unit_error_is(fmt::write_format<MemoryWriter, i64>(ref mut writer4, ref mut zone, "a{", 1), error::InvalidInput) {
    zone::destroy(zone);
    return 23;
  }
  if !(writer4.position == 1 && buffer4[0] == 'a') {
    zone::destroy(zone);
    return 24;
  }

  var buffer5 = [0u8, 0u8];
  var writer5 = MemoryWriter { data: buffer5.as_slice(), position: 0 };
  if !unit_error_is(fmt::write_format<MemoryWriter, i64>(ref mut writer5, ref mut zone, "abc{}", 1), error::BrokenPipe) {
    zone::destroy(zone);
    return 25;
  }
  if !(writer5.position == 2 && buffer5[0] == 'a' && buffer5[1] == 'b') {
    zone::destroy(zone);
    return 26;
  }

  var stream_buffer = [0u8, 0u8, 0u8];
  var stream_writer = MemoryWriter { data: stream_buffer.as_slice(), position: 0 };
  if !fmt::write_integer_stream<MemoryWriter>(ref mut stream_writer, -42).is_ok() {
    zone::destroy(zone);
    return 37;
  }
  if !(stream_buffer[0] == '-' && stream_buffer[1] == '4' && stream_buffer[2] == '2' &&
       stream_writer.position == 3) {
    zone::destroy(zone);
    return 38;
  }

  var stream_buffer2 = [0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8];
  var stream_writer2 = MemoryWriter { data: stream_buffer2.as_slice(), position: 0 };
  if !fmt::write_format_stream4<MemoryWriter, string, i64, bool, string>(
    ref mut stream_writer2,
    ref mut zone,
    "a{}{}{}{}",
    "b",
    -3,
    true,
    "!"
  ).is_ok() {
    zone::destroy(zone);
    return 39;
  }
  if !(stream_buffer2[0] == 'a' && stream_buffer2[1] == 'b' && stream_buffer2[2] == '-' &&
       stream_buffer2[3] == '3' && stream_buffer2[4] == 't' && stream_buffer2[5] == 'r' &&
       stream_buffer2[6] == 'u' && stream_buffer2[7] == 'e' && stream_buffer2[8] == '!' &&
       stream_writer2.position == 9) {
    zone::destroy(zone);
    return 40;
  }

  var stream_buffer3 = [0u8, 0u8];
  var stream_writer3 = MemoryWriter { data: stream_buffer3.as_slice(), position: 0 };
  if !unit_error_is(
    fmt::write_format_stream2<MemoryWriter, string, i64>(ref mut stream_writer3, ref mut zone, "{}={}", "x", 7),
    error::BrokenPipe
  ) {
    zone::destroy(zone);
    return 41;
  }
  if !(stream_writer3.position == 2 && stream_buffer3[0] == 'x' && stream_buffer3[1] == '=') {
    zone::destroy(zone);
    return 43;
  }

  zone::destroy(zone);
  return 42;
}
