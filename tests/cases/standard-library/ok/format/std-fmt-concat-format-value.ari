        Err(_) => {
          zone::destroy(zone);
          return 15;
        }
      }
    }
    Err(_) => {
      zone::destroy(zone);
      return 16;
    }
  }

  var buffer = [0u8, 0u8, 0u8, 0u8, 0u8];
  var writer = MemoryWriter { data: buffer.as_slice(), position: 0 };
  let write_template_n = text(ref mut zone, "n={}");
  if !fmt::write_format<MemoryWriter, i64>(ref mut writer, ref mut zone, write_template_n, 4).is_ok() {
    zone::destroy(zone);
    return 17;
  }
  if !(buffer[0] == 'n' && buffer[1] == '=' && buffer[2] == '4' && writer.position == 3) {
    zone::destroy(zone);
    return 18;
  }

  var buffer2 = [0u8, 0u8, 0u8, 0u8, 0u8];
  var writer2 = MemoryWriter { data: buffer2.as_slice(), position: 0 };
  let write_x_arg = text(ref mut zone, "x");
  if !fmt::write_format2<MemoryWriter, String, i64>(
    ref mut writer2,
    ref mut zone,
    template_eq,
    write_x_arg,
    5
  ).is_ok() {
    zone::destroy(zone);
    return 19;
  }
  if !(buffer2[0] == 'x' && buffer2[1] == '=' && buffer2[2] == '5' && writer2.position == 3) {
    zone::destroy(zone);
    return 20;
  }

  var buffer3 = [0u8, 0u8, 0u8, 0u8, 0u8];
  var writer3 = MemoryWriter { data: buffer3.as_slice(), position: 0 };
  let write_v_arg = text(ref mut zone, "v");
  let write_bang_arg = text(ref mut zone, "!");
  if !fmt::write_format3<MemoryWriter, String, i64, String>(
    ref mut writer3,
    ref mut zone,
    template_colon,
    write_v_arg,
    8,
    write_bang_arg
