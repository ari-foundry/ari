    zone::destroy(zone);
    return 31;
  }
  if !(buffer6[0] == 'a' && buffer6[1] == 'r' && buffer6[2] == 'i' && buffer6[3] == 'x' &&
       buffer6[4] == ' ' && buffer6[5] == 'b' && buffer6[6] == 'u' && buffer6[7] == 'i' &&
       buffer6[8] == 'l' && buffer6[9] == 'd' && buffer6[10] == ' ' && buffer6[11] == '-' &&
       buffer6[12] == '-' && buffer6[13] == 'j' && buffer6[14] == 'o' && buffer6[15] == 'b' &&
       buffer6[16] == 's' && buffer6[17] == '=' && buffer6[18] == '4' && writer6.position == 19) {
    zone::destroy(zone);
    return 32;
  }

  var buffer9 = [0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8];
  var writer9 = MemoryWriter { data: buffer9.as_slice(), position: 0 };
  var write_text_parts = std::vec::new<std::string::String>(ref mut zone, 5);
  write_text_parts.push(text(ref mut zone, "a"));
  write_text_parts.push(text(ref mut zone, "b"));
  write_text_parts.push(text(ref mut zone, "3"));
  write_text_parts.push(text(ref mut zone, "?"));
  write_text_parts.push(text(ref mut zone, "!"));
  if !fmt::write_concat_all<MemoryWriter>(ref mut writer9, write_text_parts.as_slice()).is_ok() {
    zone::destroy(zone);
    return 51;
  }
  if !(buffer9[0] == 'a' && buffer9[1] == 'b' && buffer9[2] == '3' &&
       buffer9[3] == '?' && buffer9[4] == '!' && writer9.position == 5) {
    zone::destroy(zone);
    return 52;
  }

  var buffer10 = [0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8, 0u8];
  var writer10 = MemoryWriter { data: buffer10.as_slice(), position: 0 };
  var write_format_parts = std::vec::new<std::string::String>(ref mut zone, 5);
  write_format_parts.push(text(ref mut zone, "A"));
  write_format_parts.push(text(ref mut zone, "B"));
  write_format_parts.push(text(ref mut zone, "C"));
  write_format_parts.push(text(ref mut zone, "D"));
  write_format_parts.push(text(ref mut zone, "E"));
  let write_format_parts_template = text(ref mut zone, "{}{}{}{}{}");
  if !fmt::write_format_texts<MemoryWriter>(
