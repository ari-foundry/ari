  let write_bad_template = text(ref mut zone, "a{");
  if !unit_error_is(fmt::write_format<MemoryWriter, i64>(ref mut writer4, ref mut zone, write_bad_template, 1), error::InvalidInput) {
    zone::destroy(zone);
    return 23;
