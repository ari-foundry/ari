// Covers source std::io Reader/Writer/Seek traits plus Cursor exact reads.
fn main() -> i64 {
  var score = 0;
  var source = [65u8, 66u8, 67u8, 68u8];
  var cursor = io::cursor(source.as_slice());

  if cursor.position() == 0 {
    score = score + 1;
  }
  if cursor.read_byte() == 65 {
    score = score + 1;
  }

  var output = [0u8, 0u8];
  let output_view = output.as_slice();
  let output_raw = output_view.as_ptr();
  if io::read_exact<io::Cursor>(ref mut cursor, output_raw, 2).is_ok() {
    if ptr_load(output_raw) == 66u8 && ptr_load(ptr_add(output_raw, 1)) == 67u8 {
      score = score + 1;
    }
  }
  if cursor.position() == 3 {
    score = score + 1;
  }
  if cursor.seek(1) {
    if cursor.read_byte() == 66 {
      score = score + 1;
    }
  }
  if cursor.seek(3) {
    if io::read_exact<io::Cursor>(ref mut cursor, output_raw, 2).is_err() {
      score = score + 1;
    }
  }

  var stdout = io::stdout();
  var payload = [79u8, 75u8, 10u8];
  if io::write_all<io::Stdout>(ref mut stdout, payload.as_slice()).is_ok() {
    score = score + 1;
  }
  if io::flush<io::Stdout>(ref mut stdout).is_ok() {
    score = score + 1;
  }

  var stdin = io::stdin();
  drop stdin;
  return score;
}
