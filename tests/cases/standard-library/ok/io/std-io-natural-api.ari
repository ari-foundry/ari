// Covers ergonomic Result-returning std::io writer methods and text helpers.
fn unit_ok(value: Result[(), error::Error]) -> bool {
  match value {
    Ok(_) => { return true; }
    Err(_) => { return false; }
  }
}

fn count_ok(value: Result[i64, error::Error], expected: i64) -> bool {
  match value {
    Ok(count) => { return count == expected; }
    Err(_) => { return false; }
  }
}

fn trait_write_ok[W: io::Writer](writer: ref mut W, values: Slice[u8], expected: i64) -> bool {
  return count_ok(writer.write(values), expected);
}

fn trait_write_all_ok[W: io::Writer](writer: ref mut W, values: Slice[u8]) -> bool {
  return unit_ok(writer.write_all(values));
}

fn main() -> i64 {
  var score = 0;
  var zone = zone::create(256);

  var out = io::stdout();
  if count_ok(io::write<io::Stdout>(ref mut out, std::string::bytes("G")), 1) {
    score = score + 1;
  }
  if count_ok(out.write(std::string::bytes("W")), 1) {
    score = score + 2;
  }
  if unit_ok(out.write_all(std::string::bytes("M"))) {
    score = score + 3;
  }
  if unit_ok(io::print("P")) {
    score = score + 4;
  }
  if unit_ok(io::println("L")) {
    score = score + 5;
  }
  var print_lower = std::string::from(ref mut zone, "p");
  if unit_ok(io::print_string(ref print_lower)) {
    score = score + 14;
  }
  var println_lower = std::string::from(ref mut zone, "l");
  if unit_ok(io::println_string(ref println_lower)) {
    score = score + 15;
  }
  if trait_write_ok<io::Stdout>(ref mut out, std::string::bytes("T"), 1) {
    score = score + 10;
  }
  if trait_write_all_ok<io::Stdout>(ref mut out, std::string::bytes("U")) {
    score = score + 11;
  }

  var err = io::stderr();
  if count_ok(err.write(std::string::bytes("E")), 1) {
    score = score + 6;
  }
  if unit_ok(err.write_all(std::string::bytes("A"))) {
    score = score + 7;
  }
  if unit_ok(io::eprint("R")) {
    score = score + 8;
  }
  if unit_ok(io::eprintln("S")) {
    score = score + 9;
  }
  var eprint_lower = std::string::from(ref mut zone, "r");
  if unit_ok(io::eprint_string(ref eprint_lower)) {
    score = score + 16;
  }
  var eprintln_lower = std::string::from(ref mut zone, "s");
  if unit_ok(io::eprintln_string(ref eprintln_lower)) {
    score = score + 17;
  }
  if trait_write_ok<io::Stderr>(ref mut err, std::string::bytes("V"), 1) {
    score = score + 12;
  }
  if trait_write_all_ok<io::Stderr>(ref mut err, std::string::bytes("X")) {
    score = score + 13;
  }

  assert_eq_i64(score, 153);
  zone::destroy(zone);
  return score;
}
