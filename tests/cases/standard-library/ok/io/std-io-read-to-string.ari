// Covers std::io::read_to_string over generic Reader values. The helper
// returns Result[String, Error], preserves EOF behavior, exposes method
// convenience on readers, and keeps an unchecked compatibility helper.
fn string_ok(value: Result[String, error::Error], expected: string) -> bool {
  match value {
    Ok(text) => { return text.equals_text(expected); }
    Err(_) => { return false; }
  }
}

fn main() -> i64 {
  var score = 0;
  var zone = zone::create(256);

  var source = [65u8, 66u8, 67u8, 10u8];
  var cursor = io::cursor(source.as_slice());
  let text = io::read_to_string<io::Cursor>(ref mut zone, ref mut cursor).unwrap();
  if text.equals_text("ABC\n") &&
     text.len() == 4 &&
     text.get(0) == 65u8 &&
     text.get(3) == 10u8 {
    score = score + 1;
  }
  if cursor.read_byte() < 0 {
    score = score + 1;
  }

  var buffered_source = [120u8, 121u8, 122u8];
  var buffered_cursor = io::cursor(buffered_source.as_slice());
  var storage = [0u8, 0u8];
  var reader = io::buf_reader<io::Cursor>(buffered_cursor, storage.as_slice());
  let buffered = io::read_to_string<io::BufReader[io::Cursor]>(ref mut zone, ref mut reader).unwrap();
  if buffered.equals_text("xyz") &&
     buffered.len() == 3 &&
     reader.buffered_len() == 0 {
    score = score + 1;
  }
  if reader.read_byte() < 0 {
    score = score + 1;
  }

  var line_source = [97u8, 98u8, 10u8, 99u8];
  var line_reader = io::cursor(line_source.as_slice());
  if string_ok(line_reader.read_line(ref mut zone), "ab\n") &&
     string_ok(line_reader.read_to_string(ref mut zone), "c") {
    score = score + 1;
  }

  var unchecked_source = [100u8, 101u8];
  var unchecked_reader = io::cursor(unchecked_source.as_slice());
  let unchecked = io::read_to_string_unchecked<io::Cursor>(ref mut zone, ref mut unchecked_reader);
  if unchecked.equals_text("de") {
    score = score + 1;
  }

  zone::destroy(zone);
  return score;
}
