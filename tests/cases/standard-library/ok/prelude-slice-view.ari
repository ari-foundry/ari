use std as core;

fn score(slice: Slice[i64]) -> i64 {
  let zero = 0;
  return slice[zero] + len(slice) + slice.len();
}

fn overwrite(slice: Slice[i64], value: i64) {
  let zero = 0;
  slice[zero] = value;
}

fn qualified(slice: std::Slice[i64]) -> i64 {
  let zero = 0;
  return slice[zero] + len(slice) + slice.len();
}

fn aliased(slice: core::Slice[i64]) -> i64 {
  let zero = 0;
  return slice[zero] + len(slice) + slice.len();
}

fn array_view_score() -> i64 {
  var values = [3, 4, 5];
  let view = values.as_slice();
  view[1] = 6;
  return view[0] + view[1] + view.len() + values[1];
}

fn vector_view_score() -> i64 {
  var values: Vec[i64] = [2, 4, 6];
  let view = values.as_slice();
  view[2] = 7;
  return view[0] + view[2] + view.len() + values[2];
}

fn range_view_score() -> i64 {
  var values = [1, 2, 3, 4];
  let view = values.as_slice();
  let middle = view[1..3];
  middle[1] = 5;
  let tail = view[2..=3];
  return middle[0] + middle[1] + middle.len() + tail[0] + tail[1] + tail.len() + values[2];
}

fn main() -> i64 {
  var first = 5;
  var second = 7;
  var third = 11;
  let one: Slice[i64] = slice((ref mut first) as ptr i64, 1);
  let two: std::Slice[i64] = std::slice((ref mut second) as ptr i64, 2);
  let three: core::Slice[i64] = core::slice((ref mut third) as ptr i64, 3);
  let empty: Slice[i64] = slice((ref mut first) as ptr i64, 0);
  overwrite(one, 6);
  two[0] = 8;
  three[0] = 12;
  let empty_score = if empty.is_empty() { 1 } else { 0 };
  return score(one) + qualified(two) + aliased(three) + empty_score + array_view_score() + vector_view_score() + range_view_score();
}
