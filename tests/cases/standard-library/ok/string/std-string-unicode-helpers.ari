// Covers String convenience methods that reuse std::encoding's UTF-8 policy.
fn expect_char(value: std::Option[std::encoding::Utf8Char], scalar: u32, len: i64, index: i64) -> bool {
  match value {
    std::Some(ch) => {
      return ch.scalar() == scalar && ch.len() == len && ch.next_index(index) == index + len;
    }
    std::None => {}
  }
  return false;
}

fn expect_no_char(value: std::Option[std::encoding::Utf8Char]) -> bool {
  match value {
    std::Some(_) => {}
    std::None => {
      return true;
    }
  }
  return false;
}

fn expect_no_i64(value: std::Option[i64]) -> bool {
  match value {
    std::Some(_) => {}
    std::None => {
      return true;
    }
  }
  return false;
}

fn main() -> i64 {
  var zone = zone::create(48);
  var bytes = [65u8, 195u8, 169u8, 226u8, 130u8, 172u8, 240u8, 159u8, 152u8, 128u8];
  var text = std::string::from_slice_in(ref mut zone, bytes.as_slice());

  var score = 0;
  if text.is_utf8() {
    score = score + 1;
  }
  if text.codepoint_count().unwrap_or(0) == 4 {
    score = score + 1;
  }
  if expect_char(text.codepoint_at(1), 233u32, 2, 1) {
    score = score + 1;
  }
  if expect_char(text.codepoint_at(6), 128512u32, 4, 6) {
    score = score + 1;
  }
  if text.codepoint_next_index(0).unwrap_or(-1) == 1 &&
     text.codepoint_next_index(1).unwrap_or(-1) == 3 &&
     text.codepoint_next_index(3).unwrap_or(-1) == 6 &&
     text.codepoint_next_index(6).unwrap_or(-1) == 10 {
    score = score + 1;
  }
  if expect_no_i64(text.codepoint_next_index(2)) && expect_no_i64(text.codepoint_next_index(10)) {
    score = score + 1;
  }
  let view = text.try_utf8().unwrap();
  if view.next_index(0).unwrap_or(-1) == 1 &&
     view.next_index(1).unwrap_or(-1) == 3 &&
     view.next_index(3).unwrap_or(-1) == 6 &&
     view.next_index(6).unwrap_or(-1) == 10 {
    score = score + 1;
  }
  if expect_no_i64(view.next_index(2)) && expect_no_i64(view.next_index(10)) {
    score = score + 1;
  }
  var view_iter = view.codepoints();
  if view_iter.next().unwrap().scalar() == 65u32 &&
     view_iter.next().unwrap().scalar() == 233u32 &&
     view_iter.next().unwrap().scalar() == 8364u32 &&
     view_iter.next().unwrap().scalar() == 128512u32 &&
     view_iter.next().is_none() {
    score = score + 1;
  }
  var text_iter = text.codepoints().unwrap();
  var total = 0u32;
  var seen = 0;
  var item = text_iter.next();
  while item.is_some() {
    let ch = item.unwrap();
    total = total + ch.scalar();
    seen = seen + 1;
    item = text_iter.next();
  }
  if seen == 4 && total == 137174u32 && text_iter.next().is_none() {
    score = score + 1;
  }
  var slice_iter = std::string::codepoints(bytes.as_slice()).unwrap();
  if slice_iter.next().unwrap().len() == 1 &&
     slice_iter.next().unwrap().len() == 2 &&
     slice_iter.next().unwrap().len() == 3 &&
     slice_iter.next().unwrap().len() == 4 &&
     slice_iter.next().is_none() {
    score = score + 1;
  }

  var built = std::string::new(ref mut zone, 1);
  built.push_codepoint_in(ref mut zone, 65u32);
  built.push_codepoint_in(ref mut zone, 233u32);
  built.push_codepoint_in(ref mut zone, 8364u32);
  built.push_codepoint_in(ref mut zone, 128512u32);
  if built.equals(bytes.as_slice()) {
    score = score + 1;
  }

  var invalid_bytes = [240u8, 40u8, 140u8, 40u8];
  var invalid = std::string::from_slice_in(ref mut zone, invalid_bytes.as_slice());
  if !invalid.is_utf8() && expect_no_i64(invalid.codepoint_count()) {
    score = score + 1;
  }
  if expect_no_char(invalid.codepoint_at(0)) && expect_no_char(text.codepoint_at(2)) {
    score = score + 1;
  }
  if invalid.codepoints().is_none() && std::string::codepoints(invalid.as_slice()).is_none() {
    score = score + 1;
  }

  zone::destroy(zone);
  assert_eq_i64(score, 15);
  return score;
}
