// Covers the preferred Region + Allocator memory model over the zone runtime.
fn main() -> i64 {
  var region = std::region::create(256);
  var score = 0;

  if region.capacity() == 256 &&
     region.remaining() == 256 &&
     region.can_alloc_array<i64>(4) {
    score = score + 1;
  }

  let values = region.alloc_array<i64>(2);
  ptr_store(values, 30);
  ptr_store(ptr_add(values, 1), 12);
  score = score + ptr_load(values) + ptr_load(ptr_add(values, 1));

  let allocator = region.allocator();
  let extra = allocator.alloc_array<i64>(1);
  ptr_store(extra, 23);
  if allocator.used() == region.used() {
    score = score + ptr_load(extra);
  }

  let direct_allocator = std::allocator::from_region(ref mut region);
  let direct_extra = direct_allocator.alloc_array<i64>(1);
  ptr_store(direct_extra, 5);
  if direct_allocator.used() == region.used() {
    score = score + ptr_load(direct_extra);
  }

  let placed = region.new<i64>(11);
  if ptr_load(placed) == 11 && region.can_alloc(8) {
    score = score + 11;
  }

  let text = region.string("ari");
  score = score + text.len();

  let spare_text = region.string_with_capacity(4);
  if spare_text.len() == 0 {
    score = score + 3;
  }

  let copied_text = region.string_copy(ref text);
  score = score + copied_text.len();

  let module_text = std::string::from_slice_with_region(ref mut region, "api");
  score = score + module_text.len();

  let module_empty = std::string::empty_with_region(ref mut region);
  if module_empty.is_empty() {
    score = score + 1;
  }

  let module_copy = module_text.copy_with_region(ref mut region);
  score = score + module_copy.len();

  var mutable_text = region.string("a");
  mutable_text.push('b');
  score = score + mutable_text.len();

  var numbers = region.vec<i64>(2);
  numbers.push(7);
  score = score + numbers.first();

  var grown = region.vec<i64>(1);
  grown.push(4);
  grown.push(6);
  score = score + grown.last();

  var source = region.vec<i64>(2);
  source.push(2);
  source.push(8);

  let copied_from_slice = region.vec_from_slice<i64>(source.as_slice());
  score = score + copied_from_slice.first() + copied_from_slice.last();

  let copied_vec = region.vec_copy<i64>(ref source);
  score = score + copied_vec.len();

  let collected_vec = std::vec::collect_with_region<i64, std::vec::Iter[i64]>(ref mut region, source.iter());
  score = score + collected_vec.len();

  var module_numbers = std::vec::new_with_region<i64>(ref mut region, 1);
  module_numbers.push(9);
  score = score + module_numbers.first();

  let module_numbers_copy = std::vec::from_slice_with_region<i64>(ref mut region, module_numbers.as_slice());
  score = score + module_numbers_copy.first();

  let method_numbers_copy = module_numbers.copy_with_region(ref mut region);
  score = score + method_numbers_copy.len();

  let boxed = region.boxed<i64>(13);
  score = score + boxed.get();

  let copied_box = region.boxed_copy<i64>(ref boxed);
  score = score + copied_box.get();

  match region.cstring("ok") {
    Ok(name) => {
      score = score + name.len();
    }

    Err(_) => {
      score = score - 50;
    }
  }

  region.reset();
  if region.used() == 0 {
    score = score + 4;
  }

  std::region::destroy(region);
  return score;
}
