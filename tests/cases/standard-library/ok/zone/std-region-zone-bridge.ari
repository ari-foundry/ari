// Region borrows bridge to legacy Zone APIs without spelling region::as_zone.
fn main() -> i64 {
  var region = std::region::create(512);
  var score = 0;

  let text = std::string::from_slice_in(ref mut region, "ari");
  score = score + text.len();

  var mutable_text = std::string::from_slice_in(ref mut region, "a");
  mutable_text.push_in(ref mut region, 'b');
  score = score + mutable_text.len();

  var values = std::vec::new<i64>(ref mut region, 1);
  values.push(7);
  values.push_in(ref mut region, 9);
  score = score + values.len() + values.first() + values.last();

  let boxed = std::boxed::new<i64>(ref mut region, 11);
  score = score + boxed.get();

  match std::c::from_slice_in(ref mut region, "cc") {
    Ok(name) => {
      score = score + name.len();
    }

    Err(_) => {
      score = score - 50;
    }
  }

  if std::zone::remaining(ref mut region) > 0 {
    score = score + 5;
  }

  std::region::destroy(region);
  return score;
}
