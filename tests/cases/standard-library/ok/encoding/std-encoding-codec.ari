// Covers hex/base64 encoding helpers that allocate into an explicit zone.
fn check_hex(zone: ref mut Zone) -> bool {
  var bytes = [65u8, 66u8, 255u8];
  var hex_text = [52u8, 49u8, 52u8, 50u8, 102u8, 102u8];
  var invalid_hex = [52u8, 49u8, 122u8];

  var encoded = encoding::encode_hex_in(zone, bytes.as_slice());
  if encoded.len() != 6 {
    return false;
  }
  if encoded.get(0) != (52 as u8) {
    return false;
  }
  if encoded.get(1) != (49 as u8) {
    return false;
  }
  if encoded.get(4) != (102 as u8) {
    return false;
  }
  if encoded.get(5) != (102 as u8) {
    return false;
  }
  if encoding::hex_encoded_len(bytes.as_slice()) != 6 {
    return false;
  }
  if encoding::hex_decoded_len(hex_text.as_slice()).unwrap_or(0) != 3 {
    return false;
  }
  if encoding::hex_decoded_len_optional(hex_text.as_slice()).unwrap_or(0) != 3 {
    return false;
  }
  if encoding::hex_decoded_len(invalid_hex.as_slice()).is_ok() {
    return false;
  }

  var decoded = encoding::decode_hex_unchecked_in(zone, hex_text.as_slice());
  if decoded.len() != 3 {
    return false;
  }
  if decoded.get(0) != (65 as u8) {
    return false;
  }
  if decoded.get(1) != (66 as u8) {
    return false;
  }
  if decoded.get(2) != (255 as u8) {
    return false;
  }
  if encoding::can_decode_hex(invalid_hex.as_slice()) {
    return false;
  }
  match encoding::decode_hex_optional_in(zone, hex_text.as_slice()) {
    std::Some(value) => {
      if value.len() != 3 {
        return false;
      }
      if value.get(0) != (65 as u8) {
        return false;
      }
      if value.get(2) != (255 as u8) {
        return false;
      }
    }
    std::None => {
      return false;
    }
  }
  match encoding::try_decode_hex_in(zone, invalid_hex.as_slice()) {
    std::Some(_) => {
      return false;
    }
    std::None => {}
  }
  match encoding::decode_hex_in(zone, hex_text.as_slice()) {
    std::Ok(hex_result_value) => {
      if hex_result_value.len() != 3 || hex_result_value.get(0) != (65 as u8) {
        return false;
      }
    }
    std::Err(_) => {
      return false;
    }
  }
  match encoding::decode_hex_in(zone, invalid_hex.as_slice()) {
    std::Ok(_) => {
      return false;
    }
    std::Err(reason) => {
      if !reason.is_kind(error::InvalidData) {
        return false;
      }
    }
  }
  match encoding::decode_hex(zone, hex_text.as_slice()) {
    std::Ok(hex_result_natural) => {
      if hex_result_natural.len() != 3 || hex_result_natural.get(2) != (255 as u8) {
        return false;
      }
    }
    std::Err(_) => {
      return false;
    }
  }
  match encoding::decode_hex(zone, invalid_hex.as_slice()) {
    std::Ok(_) => {
      return false;
    }
    std::Err(natural_reason) => {
      if !natural_reason.is_kind(error::InvalidData) {
        return false;
      }
    }
  }
  return true;
}

fn check_base64(zone: ref mut Zone) -> bool {
  var man = [77u8, 97u8, 110u8];
  var ma = [77u8, 97u8];
  var m = [77u8];
  var base64_man = [84u8, 87u8, 70u8, 117u8];
  var base64_ma = [84u8, 87u8, 69u8, 61u8];
  var base64_m = [84u8, 81u8, 61u8, 61u8];
  var invalid_base64 = [84u8, 61u8, 70u8, 117u8];

  var encoded_man = encoding::encode_base64_in(zone, man.as_slice());
  var encoded_ma = encoding::encode_base64_in(zone, ma.as_slice());
  var encoded_m = encoding::encode_base64_in(zone, m.as_slice());
  if encoded_man.len() != 4 {
    return false;
  }
  if encoded_man.get(0) != (84 as u8) {
    return false;
  }
  if encoded_man.get(1) != (87 as u8) {
    return false;
  }
  if encoded_man.get(2) != (70 as u8) {
    return false;
  }
  if encoded_man.get(3) != (117 as u8) {
    return false;
  }
  if encoded_ma.get(2) != (69 as u8) {
    return false;
  }
  if encoded_ma.get(3) != (61 as u8) {
    return false;
  }
  if encoded_m.get(1) != (81 as u8) {
    return false;
  }
  if encoded_m.get(2) != (61 as u8) {
    return false;
  }
  if encoded_m.get(3) != (61 as u8) {
    return false;
  }
  if encoding::base64_encoded_len(m.as_slice()) != 4 {
    return false;
  }
  if encoding::base64_decoded_len(base64_m.as_slice()).unwrap_or(0) != 1 {
    return false;
  }
  if encoding::base64_decoded_len_optional(base64_m.as_slice()).unwrap_or(0) != 1 {
    return false;
  }
  if encoding::base64_decoded_len(invalid_base64.as_slice()).is_ok() {
    return false;
  }

  var decoded_man = encoding::decode_base64_unchecked_in(zone, base64_man.as_slice());
  var decoded_ma = encoding::decode_base64_unchecked_in(zone, base64_ma.as_slice());
  if decoded_man.len() != 3 {
    return false;
  }
  if decoded_man.get(0) != (77 as u8) {
    return false;
  }
  if decoded_man.get(1) != (97 as u8) {
    return false;
  }
  if decoded_man.get(2) != (110 as u8) {
    return false;
  }
  if decoded_ma.len() != 2 {
    return false;
  }
  if decoded_ma.get(0) != (77 as u8) {
    return false;
  }
  if decoded_ma.get(1) != (97 as u8) {
    return false;
  }
  if encoding::can_decode_base64(invalid_base64.as_slice()) {
    return false;
  }
  match encoding::decode_base64_optional_in(zone, base64_ma.as_slice()) {
    std::Some(value) => {
      if value.len() != 2 {
        return false;
      }
      if value.get(0) != (77 as u8) {
        return false;
      }
      if value.get(1) != (97 as u8) {
        return false;
      }
    }
    std::None => {
      return false;
    }
  }
  match encoding::try_decode_base64_in(zone, invalid_base64.as_slice()) {
    std::Some(_) => {
      return false;
    }
    std::None => {}
  }
  match encoding::decode_base64_in(zone, base64_ma.as_slice()) {
    std::Ok(base64_result_value) => {
      if base64_result_value.len() != 2 || base64_result_value.get(1) != (97 as u8) {
        return false;
      }
    }
    std::Err(_) => {
      return false;
    }
  }
  match encoding::decode_base64_in(zone, invalid_base64.as_slice()) {
    std::Ok(_) => {
      return false;
    }
    std::Err(reason) => {
      if !reason.is_kind(error::InvalidData) {
        return false;
      }
    }
  }
  match encoding::decode_base64(zone, base64_ma.as_slice()) {
    std::Ok(base64_result_natural) => {
      if base64_result_natural.len() != 2 || base64_result_natural.get(0) != (77 as u8) {
        return false;
      }
    }
    std::Err(_) => {
      return false;
    }
  }
  match encoding::decode_base64(zone, invalid_base64.as_slice()) {
    std::Ok(_) => {
      return false;
    }
    std::Err(natural_reason) => {
      if !natural_reason.is_kind(error::InvalidData) {
        return false;
      }
    }
  }
  return true;
}

fn check_base64_url(zone: ref mut Zone) -> bool {
  var bytes = [251u8, 255u8, 255u8];
  var two = [251u8, 255u8];
  var one = [251u8];
  var url_full = [45u8, 95u8, 95u8, 95u8];
  var url_two_padded = [45u8, 95u8, 56u8, 61u8];
  var url_two_unpadded = [45u8, 95u8, 56u8];
  var url_one_unpadded = [45u8, 119u8];
  var standard_full = [43u8, 47u8, 47u8, 47u8];
  var invalid_url = [45u8, 61u8, 95u8];

  var encoded = encoding::encode_base64_url_in(zone, bytes.as_slice());
  if !encoded.equals(url_full.as_slice()) {
    return false;
  }

  var encoded_two = encoding::encode_base64_url_in(zone, two.as_slice());
  if !encoded_two.equals(url_two_padded.as_slice()) {
    return false;
  }

  var encoded_unpadded = encoding::encode_base64_url_unpadded_in(zone, two.as_slice());
  if !encoded_unpadded.equals(url_two_unpadded.as_slice()) {
    return false;
  }

  var encoded_one_unpadded = encoding::encode_base64_url_unpadded_in(zone, one.as_slice());
  if !encoded_one_unpadded.equals(url_one_unpadded.as_slice()) {
    return false;
  }

  if encoding::base64_url_encoded_len(one.as_slice()) != 4 {
    return false;
  }
  if encoding::base64_url_unpadded_encoded_len(one.as_slice()) != 2 {
    return false;
  }
  if encoding::base64_url_decoded_len(url_two_padded.as_slice()).unwrap_or(0) != 2 {
    return false;
  }
  if encoding::base64_url_decoded_len_optional(url_two_unpadded.as_slice()).unwrap_or(0) != 2 {
    return false;
  }
  if encoding::base64_url_decoded_len(invalid_url.as_slice()).is_ok() {
    return false;
  }
  if encoding::can_decode_base64_url(standard_full.as_slice()) {
    return false;
  }

  var decoded = encoding::decode_base64_url_unchecked_in(zone, url_full.as_slice());
  if decoded.len() != 3 || decoded.get(0) != (251 as u8) || decoded.get(2) != (255 as u8) {
    return false;
  }

  match encoding::decode_base64_url_optional_in(zone, url_two_unpadded.as_slice()) {
    std::Some(value) => {
      if value.len() != 2 || value.get(0) != (251 as u8) || value.get(1) != (255 as u8) {
        return false;
      }
    }
    std::None => {
      return false;
    }
  }

  match encoding::try_decode_base64_url_in(zone, invalid_url.as_slice()) {
    std::Some(_) => {
      return false;
    }
    std::None => {}
  }

  match encoding::decode_base64_url_in(zone, url_two_padded.as_slice()) {
    std::Ok(value2) => {
      if value2.len() != 2 || value2.get(0) != (251 as u8) || value2.get(1) != (255 as u8) {
        return false;
      }
    }
    std::Err(_) => {
      return false;
    }
  }

  match encoding::decode_base64_url(zone, url_one_unpadded.as_slice()) {
    std::Ok(value3) => {
      if value3.len() != 1 || value3.get(0) != (251 as u8) {
        return false;
      }
    }
    std::Err(_) => {
      return false;
    }
  }

  match encoding::decode_base64_url(zone, invalid_url.as_slice()) {
    std::Ok(_) => {
      return false;
    }
    std::Err(reason) => {
      if !reason.is_kind(error::InvalidData) {
        return false;
      }
    }
  }
  return true;
}

fn check_base64_mime(zone: ref mut Zone) -> bool {
  var bytes = std::string::new(zone, 60);
  var index = 0;
  while index < 60 {
    bytes.push_in(zone, 0u8);
    index = index + 1;
  }

  var encoded = encoding::encode_base64_mime_in(zone, bytes.as_slice());
  if encoding::base64_mime_encoded_len(bytes.as_slice()) != 82 {
    return false;
  }
  if encoded.len() != 82 {
    return false;
  }
  if encoded.get(75) != (65 as u8) {
    return false;
  }
  if encoded.get(76) != (13 as u8) {
    return false;
  }
  if encoded.get(77) != (10 as u8) {
    return false;
  }
  if encoded.get(78) != (65 as u8) {
    return false;
  }

  if encoding::base64_decoded_len(encoded.as_slice()).is_ok() {
    return false;
  }
  if encoding::base64_mime_decoded_len(encoded.as_slice()).unwrap_or(0) != 60 {
    return false;
  }
  if encoding::base64_mime_decoded_len_optional(encoded.as_slice()).unwrap_or(0) != 60 {
    return false;
  }

  var decoded = encoding::decode_base64_mime_unchecked_in(zone, encoded.as_slice());
  if decoded.len() != 60 {
    return false;
  }
  if decoded.get(0) != (0 as u8) || decoded.get(59) != (0 as u8) {
    return false;
  }

  var folded_man = [84u8, 13u8, 10u8, 87u8, 70u8, 117u8];
  match encoding::decode_base64_mime_optional_in(zone, folded_man.as_slice()) {
    std::Some(value) => {
      if value.len() != 3 || value.get(0) != (77 as u8) || value.get(2) != (110 as u8) {
        return false;
      }
    }
    std::None => {
      return false;
    }
  }

  var spaced_ma = [84u8, 87u8, 69u8, 61u8, 13u8, 10u8];
  match encoding::decode_base64_mime_in(zone, spaced_ma.as_slice()) {
    std::Ok(value2) => {
      if value2.len() != 2 || value2.get(0) != (77 as u8) || value2.get(1) != (97 as u8) {
        return false;
      }
    }
    std::Err(_) => {
      return false;
    }
  }

  var invalid_mime = [84u8, 36u8, 87u8, 70u8, 117u8];
  if encoding::can_decode_base64_mime(invalid_mime.as_slice()) {
    return false;
  }
  match encoding::try_decode_base64_mime_in(zone, invalid_mime.as_slice()) {
    std::Some(_) => {
      return false;
    }
    std::None => {}
  }
  match encoding::decode_base64_mime(zone, invalid_mime.as_slice()) {
    std::Ok(_) => {
      return false;
    }
    std::Err(reason) => {
      if !reason.is_kind(error::InvalidData) {
        return false;
      }
    }
  }
  return true;
}

fn main() -> i64 {
  var zone = zone::create(4096);
  if check_hex(ref mut zone) {
    if check_base64(ref mut zone) {
      if check_base64_url(ref mut zone) {
        if check_base64_mime(ref mut zone) {
          zone::destroy(zone);
          return 13;
        }
        zone::destroy(zone);
        return 4;
      }
      zone::destroy(zone);
      return 3;
    }
    zone::destroy(zone);
    return 2;
  }
  zone::destroy(zone);
  return 1;
}
