// Covers SourceFile text helpers that bootstrap diagnostics need for
// byte-offset to human line/column conversion.
fn main() -> i64 {
  let file_id = source::file_id(4);
  let source_file = source::file(file_id, "alpha\nbeta\n");
  var score = 0;

  let stored_id = source_file.id();
  if stored_id.equals(file_id) {
    score = score + 1;
  }
  if source_file.len() == 11 {
    score = score + 2;
  }
  if !source_file.is_empty() {
    score = score + 3;
  }
  if source_file.line_count() == 3 {
    score = score + 4;
  }
  if source_file.line_start(1) == 0 && source_file.line_end(1) == 5 {
    score = score + 5;
  }
  if source_file.line_start(2) == 6 && source_file.line_end(2) == 10 {
    score = score + 6;
  }
  if source_file.line_start(3) == 11 && source_file.line_end(3) == 11 {
    score = score + 7;
  }

  let whole = source_file.full_span();
  if whole.start() == 0 && whole.end() == 11 {
    score = score + 8;
  }

  let beta = source_file.line_span(2);
  if beta.start() == 6 && beta.end() == 10 {
    score = score + 9;
  }

  let first = source_file.locate(0);
  if first.line() == 1 && first.column() == 1 {
    score = score + 10;
  }

  let second_line = source_file.locate(6);
  if second_line.line() == 2 && second_line.column() == 1 {
    score = score + 11;
  }

  let second_newline = source_file.locate(10);
  if second_newline.line() == 2 && second_newline.column() == 5 {
    score = score + 12;
  }

  let eof = source_file.locate(11);
  if eof.line() == 3 && eof.column() == 1 {
    score = score + 13;
  }

  let text = source_file.text();
  if text.len() == 11 && text.get(0) == 'a' {
    score = score + 14;
  }

  let empty = source::file(source::root_file(), "");
  if empty.line_count() == 1 && empty.line_start(1) == 0 && empty.line_end(1) == 0 {
    score = score + 15;
  }

  return score;
}
