// Covers cached SourceFile line tables for compiler-style repeated lookups.
fn main() -> i64 {
  var zone = zone::create(512);
  let file_id = source::file_id(9);
  let input = source::file(file_id, "zero\none\ntwo");
  let map = source::line_map(ref mut zone, input);
  var score = 0;

  if map.line_count() == 3 {
    score = score + 1;
  }
  if map.line_start(1) == 0 && map.line_end(1) == 4 {
    score = score + 2;
  }
  if map.line_start(2) == 5 && map.line_end(2) == 8 {
    score = score + 3;
  }
  if map.line_start(3) == 9 && map.line_end(3) == 12 {
    score = score + 4;
  }

  let one = map.line_span(2);
  if one.start() == 5 && one.end() == 8 {
    score = score + 5;
  }

  let first = map.locate(0);
  if first.line() == 1 && first.column() == 1 {
    score = score + 6;
  }

  let second = map.locate(5);
  if second.line() == 2 && second.column() == 1 {
    score = score + 7;
  }

  let newline = map.locate(8);
  if newline.line() == 2 && newline.column() == 4 {
    score = score + 8;
  }

  let eof = map.locate(12);
  if eof.line() == 3 && eof.column() == 4 {
    score = score + 9;
  }

  let stored = map.file();
  if stored.id().equals(file_id) && map.id().equals(file_id) {
    score = score + 10;
  }

  let whole = map.full_span();
  if whole.start() == 0 && whole.end() == 12 {
    score = score + 11;
  }

  let method_map = input.line_map(ref mut zone);
  let third = method_map.locate(9);
  if third.line() == 3 && third.column() == 1 {
    score = score + 12;
  }

  let empty = source::line_map(ref mut zone, source::file(source::root_file(), ""));
  if empty.line_count() == 1 && empty.line_start(1) == 0 && empty.line_end(1) == 0 {
    score = score + 13;
  }

  zone::destroy(zone);
  return score;
}
