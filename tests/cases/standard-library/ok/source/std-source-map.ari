// Covers SourceMap registration, cached LineMap lookup, and natural methods.
fn main() -> i64 {
  var zone = zone::create(1024);
  var map = source::source_map(ref mut zone, 3);
  var score = 0;

  if map.len() == 0 && map.capacity() == 3 && map.is_empty() {
    score = score + 1;
  }

  let first = map.add(ref mut zone, "alpha\nbeta\n");
  let second = map.add(ref mut zone, "zero\none\ntwo");
  if first.value() == 0 && second.value() == 1 && map.len() == 2 {
    score = score + 2;
  }

  let first_file = map.file(first);
  if first_file.id().equals(first) && first_file.line_count() == 3 {
    score = score + 3;
  }

  let second_file = source::source_file(ref map, second);
  if second_file.id().equals(second) && second_file.len() == 12 {
    score = score + 4;
  }

  let first_lines = map.lines(first);
  let first_place = first_lines.locate(6);
  if first_place.line() == 2 && first_place.column() == 1 {
    score = score + 5;
  }

  let second_lines = source::source_lines(ref map, second);
  let second_span = second_lines.line_span(3);
  if second_span.start() == 9 && second_span.end() == 12 {
    score = score + 6;
  }

  let located = map.locate(source::span(second, 9, 12));
  if located.line() == 3 && located.column() == 1 {
    score = score + 7;
  }

  let located_free = source::source_locate(ref map, source::span(first, 10, 10));
  if located_free.line() == 2 && located_free.column() == 5 {
    score = score + 8;
  }

  zone::destroy(zone);
  return score;
}
