// Covers std::source file ids, byte spans, line/column values, and
// method-style wrappers used by future Ari compiler diagnostics.
fn main() -> i64 {
  let file = source::file_id(2);
  let other_file = source::file_id(3);
  let span = source::span(file, 4, 9);
  let empty = source::empty_span(file, 9);
  let early = source::span(file, 0, 3);
  let disjoint = source::span(other_file, 0, 1);
  let place = source::line_col(3, 7);
  let location = source::location(file, place.line(), place.column());
  var score = 0;

  if file.value() == 2 {
    score = score + 1;
  }
  if file.equals(source::file_id(2)) {
    score = score + 2;
  }

  let span_file = span.file();
  if span_file.equals(file) && span.start() == 4 && span.end() == 9 {
    score = score + 3;
  }
  if span.len() == 5 && !span.is_empty() {
    score = score + 4;
  }
  if span.contains(4) && span.contains(8) && !span.contains(9) && span.touches(9) {
    score = score + 5;
  }
  if empty.is_empty() && empty.touches(9) && !empty.contains(9) {
    score = score + 6;
  }

  let merged = span.merge(ref early);
  if merged.start() == 0 && merged.end() == 9 {
    score = score + 7;
  }
  if span.same_file(ref merged) && !span.same_file(ref disjoint) {
    score = score + 8;
  }
  if early.before(ref span) {
    score = score + 9;
  }
  if place.line() == 3 && place.column() == 7 {
    score = score + 10;
  }

  let location_file = location.file();
  if location_file.equals(file) && location.line() == 3 && location.column() == 7 {
    score = score + 11;
  }
  if source::contains(ref span, 5) && source::touches(ref empty, 9) {
    score = score + 12;
  }

  return score;
}
