// Covers the source-only std::ascii byte classification and conversion slice.
fn main() -> i64 {
  var score = 0;

  if std::ascii::is_digit(48 as u8) {
    score = score + 1;
  }
  if ascii::is_digit(57 as u8) {
    score = score + 2;
  }
  if !ascii::is_digit(58 as u8) {
    score = score + 3;
  }
  if ascii::is_lower(97 as u8) {
    score = score + 4;
  }
  if !ascii::is_lower(65 as u8) {
    score = score + 5;
  }
  if ascii::is_upper(90 as u8) {
    score = score + 6;
  }
  if ascii::is_alpha(113 as u8) {
    score = score + 7;
  }
  if ascii::is_alphanumeric(56 as u8) {
    score = score + 8;
  }
  if !ascii::is_alphanumeric(64 as u8) {
    score = score + 9;
  }
  if ascii::is_hex_digit(70 as u8) {
    score = score + 10;
  }
  if !ascii::is_hex_digit(71 as u8) {
    score = score + 11;
  }
  if ascii::is_whitespace(32 as u8) {
    score = score + 12;
  }
  if ascii::is_whitespace(10 as u8) {
    score = score + 13;
  }
  if !ascii::is_whitespace(65 as u8) {
    score = score + 14;
  }

  assert_eq_i64(ascii::to_lower(65 as u8) as i64, 97);
  assert_eq_i64(ascii::to_upper(122 as u8) as i64, 90);
  assert_eq_i64(ascii::to_lower(63 as u8) as i64, 63);
  assert_eq_i64(ascii::to_upper(33 as u8) as i64, 33);

  let digit = ascii::digit_value(55 as u8).unwrap_or(-1);
  let hex = ascii::hex_value(70 as u8).unwrap_or(-1);
  let not_digit = ascii::digit_value(120 as u8).unwrap_or(20);
  let not_hex = ascii::hex_value(103 as u8).unwrap_or(30);

  return score + digit + hex + not_digit + not_hex;
}
