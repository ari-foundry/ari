// Covers the first Command API slice: argument passing, environment and
// working-directory setup, spawn/status helpers, and non-destructive kill(0).
fn status_is(value: Result[process::ExitStatus, error::Error], expected: i64) -> bool {
  match value {
    Ok(status) => { return status.exited() && status.code_or(-1) == expected; }
    Err(_) => { return false; }
  }
}

fn status_code_is(value: Result[i64, error::Error], expected: i64) -> bool {
  match value {
    Ok(code) => { return code == expected; }
    Err(_) => { return false; }
  }
}

fn unit_ok(value: Result[(), error::Error]) -> bool {
  match value {
    Ok(_) => { return true; }
    Err(_) => { return false; }
  }
}

fn unit_err_with_code(value: Result[(), error::Error]) -> bool {
  match value {
    Ok(_) => { return false; }
    Err(reason) => { return reason.code() > 0; }
  }
}

fn status_err_not_found(value: Result[process::ExitStatus, error::Error]) -> bool {
  match value {
    Ok(_) => { return false; }
    Err(reason) => { return reason.is_not_found() && reason.code() == 2; }
  }
}

fn child_err_not_found(value: Result[process::Child, error::Error]) -> bool {
  match value {
    Ok(_) => { return false; }
    Err(reason) => { return reason.is_not_found() && reason.code() == 2; }
  }
}

fn main() -> i64 {
  var zone = zone::temp(512);
  var score = 0;

  var status_args = [process::arg("-c"), process::arg("exit 17")];
  var status_cmd = process::Command::with_args("sh", status_args.as_slice());
  if status_is(status_cmd.status(), 17) {
    score = score + 11;
  }
  if status_code_is(status_cmd.status_code(), 17) {
    score = score + 2;
  }

  var setter_args = [process::arg("-c"), process::arg("exit 19")];
  var setter_cmd = process::Command::new("sh");
  setter_cmd.args(setter_args.as_slice());
  if status_is(setter_cmd.status(), 19) {
    score = score + 13;
  }

  var module_status_args = [process::arg("-c"), process::arg("exit 7")];
  var module_status_cmd = process::command_with_args("sh", module_status_args.as_slice());
  if status_is(process::status(ref module_status_cmd), 7) {
    score = score + 41;
  }
  var module_status_code_args = [process::arg("-c"), process::arg("exit 8")];
  var module_status_code_cmd = process::command_with_args("sh", module_status_code_args.as_slice());
  if status_code_is(process::status_code(ref module_status_code_cmd), 8) {
    score = score + 3;
  }

  var module_exit_status_args = [process::arg("-c"), process::arg("exit 3")];
  var module_exit_status_cmd = process::command_with_args("sh", module_exit_status_args.as_slice());
  match process::exit_status(ref module_exit_status_cmd) {
    Err(_) => {}
    Ok(status) => {
      if status.code_or(-1) == 3 {
        score = score + 5;
      }
    }
  }

  var env_args = [process::arg("-c"), process::arg("test \"$ARI_COMMAND_TEST\" = yes && pwd | grep -q '/build/prelude$'")];
  var env_cmd = process::command_with_args("sh", env_args.as_slice());
  env_cmd.env(ref mut zone, "ARI_COMMAND_TEST", "yes");
  env_cmd.current_dir("build/prelude");
  if status_is(env_cmd.status(), 0) {
    score = score + 17;
  }

  var spawn_args = [process::arg("-c"), process::arg("exit 23")];
  var spawn_cmd = process::command_with_args("sh", spawn_args.as_slice());
  match spawn_cmd.spawn() {
    Err(_) => {}
    Ok(child) => {
      if child.pid() > 0 && unit_ok(child.kill(0)) && status_code_is(child.wait(), 23) {
        score = score + 29;
      }
    }
  }

  var module_spawn_args = [process::arg("-c"), process::arg("exit 5")];
  var module_spawn_cmd = process::command_with_args("sh", module_spawn_args.as_slice());
  match process::spawn(ref module_spawn_cmd) {
    Err(_) => {}
    Ok(module_child) => {
      if module_child.pid() > 0 && status_code_is(module_child.wait(), 5) {
        score = score + 43;
      }
    }
  }

  if unit_ok(process::kill(process::id(), 0)) {
    score = score + 31;
  }
  if unit_err_with_code(process::kill(-999999, 0)) {
    score = score + 37;
  }

  var missing_status = process::Command::new("__ari_missing_command_for_status__");
  if status_err_not_found(missing_status.status()) {
    score = score + 2;
  }

  var missing_spawn = process::Command::new("__ari_missing_command_for_spawn__");
  if child_err_not_found(missing_spawn.spawn()) {
    score = score + 3;
  }

  assert_eq_i64(score, 237);
  return score;
}
