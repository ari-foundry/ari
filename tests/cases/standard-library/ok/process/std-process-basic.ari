fn main() -> i64 {
  var zone = zone::temp(1024);
  let pid = process::id();
  var score = 0;

  if pid > 0 {
    score = score + 5;
  }
  if process::success() == 0 {
    score = score + 7;
  }
  if process::failure() == 1 {
    score = score + 11;
  }
  if process::is_success(0) {
    score = score + 13;
  }
  if process::is_failure(9) {
    score = score + 17;
  }
  assert(process::current_dir(ref mut zone).is_ok());
  assert(process::current_dir_optional(ref mut zone).is_some());
  assert(!process::current_dir_or_default(ref mut zone).is_empty());
  assert(process::executable_path(ref mut zone).is_ok());
  assert(process::executable_path_optional(ref mut zone).is_some());
  assert(!process::executable_path_or_default(ref mut zone).is_empty());

  return score;
}
