// Covers the first current-process helper slice: pid plus status-code helpers.
fn is_empty_text(value: string) -> bool {
  return std::mem::ptr_load(value as ptr u8) == 0;
}

fn main() -> i64 {
  let pid = process::id();
  var score = 0;

  if pid > 0 {
    score = score + 5;
  }
  if process::success() == 0 {
    score = score + 7;
  }
  if process::failure() == 1 {
    score = score + 11;
  }
  if process::is_success(0) {
    score = score + 13;
  }
  if process::is_failure(9) {
    score = score + 17;
  }
  assert(process::current_dir().is_ok());
  assert(process::current_dir_optional().is_some());
  assert(!is_empty_text(process::current_dir_or_default()));
  assert(process::executable_path().is_ok());
  assert(process::executable_path_optional().is_some());
  assert(!is_empty_text(process::executable_path_or_default()));

  return score;
}
