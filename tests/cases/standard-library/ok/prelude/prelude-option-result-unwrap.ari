fn stop_after_call(flag: bool) -> i64 {
  if flag {
    return 16;
  }
  std::panic();
}

fn main() -> i64 {
  let option_unwrap = Some(10).unwrap();
  let option_expect = Some(11).expect("option");
  let result_unwrap = Ok<i64, i32>(12).unwrap();
  let result_expect = Ok<i64, i32>(13).expect("result");
  let result_unwrap_err = Err<i64, i32>(14i32).unwrap_err() as i64;
  let result_expect_err = Err<i64, i32>(15i32).expect_err("error") as i64;

  return option_unwrap + option_expect + result_unwrap + result_expect +
         result_unwrap_err + result_expect_err + stop_after_call(true);
}
