// Covers source std::fs whole-file conveniences: byte-slice write, append,
// Option-returning byte counts, read-to-byte-string, explicit missing-file
// default reads, and truncating rewrite.
fn main() -> i64 {
  let path = "build/prelude/std-fs-read-write.tmp";
  let missing_path = "build/prelude/std-fs-read-write-missing.tmp";
  if fs::exists(path) {
    fs::remove_bool(path);
  }
  if fs::exists(missing_path) {
    fs::remove_bool(missing_path);
  }

  var zone = zone::create(1024);
  var score = 0;

  let missing = fs::read_to_string_or_default(ref mut zone, missing_path);
  if missing.is_empty() {
    score = score + 1;
  }

  var first = [65 as u8, 66 as u8];
  if fs::write(path, first.as_slice()).is_ok() {
    score = score + 2;
  }
  match fs::try_write(path, first.as_slice()) {
    std::Some(first_count) => {
      if first_count == 2 {
        score = score + 13;
      }
    }
    std::None => {}
  }

  var tail = [67 as u8, 68 as u8];
  if fs::append(path, tail.as_slice()).is_ok() {
    score = score + 3;
  }
  match fs::try_append(path, tail.as_slice()) {
    std::Some(tail_count) => {
      if tail_count == 2 {
        score = score + 14;
      }
    }
    std::None => {}
  }

  let text = fs::read_to_string_unchecked(ref mut zone, path);
  if !text.is_empty() {
    score = score + 4;
  }
  if text.len() == 6 {
    score = score + 5;
  }
  if text.get(0) == 65 as u8 {
    score = score + 6;
  }
  if text.get(3) == 68 as u8 {
    score = score + 7;
  }
  if text.get(5) == 68 as u8 {
    score = score + 15;
  }

  var replacement = [90 as u8];
  match fs::try_write(path, replacement.as_slice()) {
    std::Some(replacement_count) => {
      if replacement_count == 1 {
        score = score + 8;
      }
    }
    std::None => {}
  }
  let after = fs::read_to_string_unchecked(ref mut zone, path);
  if after.len() == 1 {
    score = score + 9;
  }
  if after.get(0) == 90 as u8 {
    score = score + 10;
  }

  if fs::remove_bool(path) {
    score = score + 11;
  }
  if !fs::exists(path) {
    score = score + 12;
  }
  match fs::try_append("build/prelude/std-fs-read-write-no-such-dir/file.tmp", tail.as_slice()) {
    std::Some(_missing_count) => {}
    std::None => {
      score = score + 16;
    }
  }

  zone::destroy(zone);
  return score;
}
