// Covers explicit directory handles: open a directory, read names one by one,
// skip host "."/".." entries, close the handle, and clean up.
fn mark_entry(name: ref std::string::String) -> i64 {
  if name.equals_text("alpha.txt") {
    return 1;
  }
  if name.equals_text("beta.txt") {
    return 2;
  }
  return 0;
}

fn has_entry(entries: ref std::vec::Vec[std::string::String], expected: Slice[u8]) -> bool {
  var index = 0;
  while index < entries.len() {
    let name = entries.get(index);
    if name.equals_text(expected) {
      return true;
    }
    index = index + 1;
  }
  return false;
}

fn has_dir_entry(entries: ref std::vec::Vec[std::fs::DirEntry], expected_name: Slice[u8], expected_path: Slice[u8]) -> bool {
  var index = 0;
  while index < entries.len() {
    let entry = entries.get(index);
    if entry.name_equals(expected_name) && entry.path_equals(expected_path) {
      return true;
    }
    index = index + 1;
  }
  return false;
}

fn main() -> i64 {
  let dir_path: Slice[u8] = "build/prelude/std-fs-read-dir.tmp";
  let alpha_path: Slice[u8] = "build/prelude/std-fs-read-dir.tmp/alpha.txt";
  let beta_path: Slice[u8] = "build/prelude/std-fs-read-dir.tmp/beta.txt";
  if fs::exists(alpha_path) {
    fs::remove_bool(alpha_path);
  }
  if fs::exists(beta_path) {
    fs::remove_bool(beta_path);
  }
  if fs::exists(dir_path) {
    fs::remove_dir_bool(dir_path);
  }

  var score = 0;
  var zone = zone::create(4096);

  if fs::create_dir_bool(dir_path) {
    score = score + 1;
  }
  var alpha = ['A'];
  if fs::write_bool(alpha_path, alpha.as_slice()) {
    score = score + 2;
  }
  var beta = ['B'];
  if fs::write_bool(beta_path, beta.as_slice()) {
    score = score + 3;
  }
  if fs::try_open_dir("build/prelude/std-fs-read-dir-missing.tmp").is_none() {
    score = score + 4;
  }

  let dir = fs::try_open_dir(dir_path).unwrap_or(fs::Dir::invalid());
  if dir.is_open() {
    score = score + 5;
  }

  var seen_alpha = false;
  var seen_beta = false;
  var entries = 0;
  var reading = true;
  while reading {
    match dir.next(ref mut zone) {
      std::Some(name) => {
        entries = entries + 1;
        let mark = mark_entry(ref name);
        if mark == 1 {
          seen_alpha = true;
        }
        if mark == 2 {
          seen_beta = true;
        }
      }
      std::None => {
        reading = false;
      }
    }
  }

  if seen_alpha {
    score = score + 6;
  }
  if seen_beta {
    score = score + 7;
  }
  if entries == 2 {
    score = score + 8;
  }
  if dir.close().is_ok() {
    score = score + 9;
  }

  if fs::try_read_dir(ref mut zone, "build/prelude/std-fs-read-dir-missing.tmp").is_none() {
    score = score + 15;
  }

  match fs::try_read_dir(ref mut zone, dir_path) {
    std::Some(names) => {
      if names.len() == 2 {
        score = score + 16;
      }
      if has_entry(ref names, "alpha.txt") {
        score = score + 17;
      }
      if has_entry(ref names, "beta.txt") {
        score = score + 18;
      }
    }
    std::None => {}
  }

  let listed = fs::read_dir_names_unchecked(ref mut zone, dir_path);
  if listed.len() == 2 {
    score = score + 19;
  }

  if fs::try_read_dir_entries(ref mut zone, "build/prelude/std-fs-read-dir-missing.tmp").is_none() {
    score = score + 20;
  }

  match fs::try_read_dir_entries(ref mut zone, dir_path) {
    std::Some(detail) => {
      if detail.len() == 2 {
        score = score + 21;
      }
    }
    std::None => {}
  }

  let detailed = fs::read_dir_unchecked(ref mut zone, dir_path);
  if has_dir_entry(ref detailed, "alpha.txt", alpha_path) &&
     has_dir_entry(ref detailed, "beta.txt", beta_path) {
    score = score + 22;
  }
  assert(fs::read_dir(ref mut zone, dir_path).is_ok());
  assert(fs::read_dir_entries(ref mut zone, "build/prelude/std-fs-read-dir.tmp").is_ok());
  assert(fs::read_dir_entries_unchecked(ref mut zone, dir_path).len() == 2);

  let invalid = fs::Dir::invalid();
  match invalid.next(ref mut zone) {
    std::Some(_) => {}
    std::None => {
      score = score + 10;
    }
  }
  assert(invalid.close().is_err());

  if fs::remove_bool(alpha_path) {
    score = score + 11;
  }
  if fs::remove_bool(beta_path) {
    score = score + 12;
  }
  if fs::remove_dir_bool(dir_path) {
    score = score + 13;
  }
  if !fs::exists(dir_path) {
    score = score + 14;
  }

  zone::destroy(zone);
  return score;
}
