// Covers hosted advisory file-lock helpers over POSIX flock.
fn main() -> i64 {
  let path = "build/prelude/std-fs-lock.tmp";
  var score = 0;

  match fs::create(path) {
    Ok(file) => {
      if fs::lock_shared(file).is_ok() {
        score = score + 1;
      }
      if fs::unlock(file).is_ok() {
        score = score + 2;
      }
      if file.lock_exclusive().is_ok() {
        score = score + 4;
      }
      match file.try_lock_shared() {
        Ok(acquired) => {
          if acquired {
            score = score + 8;
          }
        }
        Err(_) => {}
      }
      if file.unlock().is_ok() {
        score = score + 16;
      }
      match fs::try_lock_exclusive(file) {
        Ok(exclusive_acquired) => {
          if exclusive_acquired {
            score = score + 32;
          }
        }
        Err(_) => {}
      }
      if fs::unlock(file).is_ok() {
        score = score + 64;
      }
      file.close().unwrap();
      fs::remove_file(path).unwrap();
    }
    Err(_) => {}
  }

  let invalid = fs::File::invalid();
  if fs::lock_shared(invalid).is_err() && invalid.try_lock_exclusive().is_err() {
    score = score + 128;
  }

  return score;
}
