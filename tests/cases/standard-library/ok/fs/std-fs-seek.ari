// Covers std::fs::File as a std::io::Seek adapter. The test checks direct
// module hooks, trait method syntax, negative seek rejection, and generic
// Seek-bound dispatch over the same file handle.
fn cleanup(path: string) -> void {
  if fs::exists(path) {
    fs::remove(path);
  }
}

fn rewind[S: io::Seek](stream: ref mut S) -> bool {
  if stream.position() < 0 {
    return false;
  }
  return stream.seek(0);
}

fn main() -> i64 {
  let path = "build/prelude/std-fs-seek.tmp";
  cleanup(path);

  var score = 0;
  var seed = [65u8, 66u8, 67u8, 68u8];
  if fs::write(path, seed.as_slice()) {
    score = score + 1;
  }

  var file = fs::try_open(path, "r").unwrap_or(fs::File::invalid());
  if file.position_result().unwrap_or(-1) == 0 {
    score = score + 2;
  }
  if file.read_byte() == 65 {
    score = score + 4;
  }
  if fs::position_result(file).unwrap_or(-1) == 1 {
    score = score + 8;
  }
  if file.seek_result(2).is_ok() {
    score = score + 16;
  }
  if file.position_result().unwrap_or(-1) == 2 {
    score = score + 32;
  }
  if file.read_byte() == 67 {
    score = score + 64;
  }
  if file.seek_result(-1).is_err() {
    score = score + 128;
  }
  let invalid = fs::File::invalid();
  assert(fs::position_result(invalid).is_err());
  assert(fs::seek_result(invalid, 0).is_err());

  let generic_ok = rewind<std::fs::File>(ref mut file) &&
                   file.position() == 0 &&
                   file.read_byte() == 65;
  file.close();
  cleanup(path);

  if !generic_ok {
    return 1;
  }
  return score;
}
