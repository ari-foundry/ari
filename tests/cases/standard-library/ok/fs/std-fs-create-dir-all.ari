// Covers recursive directory creation. create_dir_all builds missing parent
// directories, treats existing directories as success, ensure_dir_all is the
// natural idempotent alias, and existing file paths still fail.
fn cleanup_file(path: string) -> void {
  if fs::exists(path) {
    fs::remove(path);
  }
}

fn cleanup_dir(path: string) -> void {
  if fs::exists(path) {
    fs::remove_dir(path);
  }
}

fn main() -> i64 {
  let root = "build/prelude/std-fs-create-dir-all.tmp";
  let first = "build/prelude/std-fs-create-dir-all.tmp/alpha";
  let second = "build/prelude/std-fs-create-dir-all.tmp/alpha/beta";
  let nested = "build/prelude/std-fs-create-dir-all.tmp/alpha/beta/gamma";
  let data_path = "build/prelude/std-fs-create-dir-all.tmp/alpha/beta/gamma/data.txt";
  let file_path = "build/prelude/std-fs-create-dir-all-file.tmp";
  let file_child = "build/prelude/std-fs-create-dir-all-file.tmp/child";

  cleanup_file(data_path);
  cleanup_dir(nested);
  cleanup_dir(second);
  cleanup_dir(first);
  cleanup_dir(root);
  cleanup_file(file_path);

  var score = 0;
  if fs::create_dir_all(nested) {
    score = score + 1;
  }
  if fs::is_dir(root) && fs::is_dir(first) && fs::is_dir(second) && fs::is_dir(nested) {
    score = score + 2;
  }
  if fs::create_dir_all(nested) {
    score = score + 4;
  }
  if fs::ensure_dir_all(nested) {
    score = score + 8;
  }
  if fs::write(data_path, "ok") && fs::is_file(data_path) {
    score = score + 16;
  }
  if fs::write(file_path, "file") {
    score = score + 32;
  }
  if !fs::create_dir_all(file_path) {
    score = score + 64;
  }
  if !fs::create_dir_all(file_child) {
    score = score + 128;
  }

  cleanup_file(data_path);
  cleanup_dir(nested);
  cleanup_dir(second);
  cleanup_dir(first);
  cleanup_dir(root);
  cleanup_file(file_path);

  assert_eq_i64(score, 255);
  return score;
}
