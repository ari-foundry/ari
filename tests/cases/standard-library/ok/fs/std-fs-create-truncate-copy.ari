// Covers source std::fs convenience helpers that build on mode-string opens:
// create/try_create, read aliasing read_to_string, truncate, streaming copy,
// and Option-returning copy byte counts.
fn main() -> i64 {
  let source_path = "build/prelude/std-fs-create-truncate-copy-src.tmp";
  let copy_path = "build/prelude/std-fs-create-truncate-copy-dst.tmp";
  let counted_path = "build/prelude/std-fs-create-truncate-copy-counted.tmp";
  let missing_path = "build/prelude/std-fs-create-truncate-copy-missing.tmp";
  if fs::exists(source_path) {
    fs::remove(source_path);
  }
  if fs::exists(copy_path) {
    fs::remove(copy_path);
  }
  if fs::exists(counted_path) {
    fs::remove(counted_path);
  }
  if fs::exists(missing_path) {
    fs::remove(missing_path);
  }

  var score = 0;
  let created = fs::try_create(source_path).unwrap_or(fs::File::invalid());
  if created.is_open() {
    score = score + 1;
  }

  var seed = [70 as u8, 83 as u8];
  if created.write_bytes(seed.as_slice()).unwrap_or(0) == 2 {
    score = score + 2;
  }
  if created.close().is_ok() {
    score = score + 3;
  }
  if fs::exists(source_path) {
    score = score + 4;
  }

  var zone = zone::create(1024);
  if fs::copy(source_path, copy_path) {
    score = score + 5;
  }

  let copied = fs::read(ref mut zone, copy_path);
  if copied.len() == 2 {
    score = score + 6;
  }
  if copied.get(0) == 70 as u8 {
    score = score + 7;
  }
  if copied.get(1) == 83 as u8 {
    score = score + 8;
  }

  match fs::try_copy(source_path, counted_path) {
    std::Some(byte_count) => {
      if byte_count == 2 {
        score = score + 14;
      }
    }
    std::None => {}
  }
  let counted = fs::read(ref mut zone, counted_path);
  if counted.len() == 2 {
    score = score + 15;
  }

  if fs::truncate(source_path) {
    score = score + 9;
  }
  let truncated = fs::read(ref mut zone, source_path);
  if truncated.is_empty() {
    score = score + 10;
  }
  match fs::try_copy(source_path, counted_path) {
    std::Some(empty_count) => {
      if empty_count == 0 {
        score = score + 16;
      }
    }
    std::None => {}
  }
  if !fs::copy(missing_path, copy_path) {
    score = score + 11;
  }
  match fs::try_copy(missing_path, counted_path) {
    std::Some(_missing_count) => {}
    std::None => {
      score = score + 17;
    }
  }

  if fs::remove(source_path) {
    score = score + 12;
  }
  if fs::remove(copy_path) {
    score = score + 13;
  }
  if fs::remove(counted_path) {
    score = score + 18;
  }

  zone::destroy(zone);
  return score;
}
