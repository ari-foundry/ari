// Covers Option-returning byte reads so callers can avoid EOF sentinels.
fn main() -> i64 {
  let path: Slice[u8] = "build/prelude/std-fs-try-byte.tmp";
  if fs::exists(path) {
    fs::remove_bool(path);
  }

  var score = 0;
  let writer = fs::try_open(path, "w").unwrap_or(fs::File::invalid());
  if writer.is_open() {
    score = score + 1;
  }
  if writer.write_byte('A').is_ok() {
    score = score + 2;
  }
  if writer.write_byte('B').is_ok() {
    score = score + 3;
  }
  if writer.close().is_ok() {
    score = score + 4;
  }

  let reader = fs::try_open(path, "r").unwrap_or(fs::File::invalid());
  if fs::try_read_byte(reader).unwrap_or('?') == 'A' {
    score = score + 5;
  }
  if reader.try_read_byte().unwrap_or('?') == 'B' {
    score = score + 6;
  }
  if reader.try_read_byte().is_none() {
    score = score + 7;
  }
  if reader.close().is_ok() {
    score = score + 8;
  }
  if fs::File::invalid().try_read_byte().is_none() {
    score = score + 9;
  }
  if fs::remove_bool(path) {
    score = score + 10;
  }

  return score;
}
