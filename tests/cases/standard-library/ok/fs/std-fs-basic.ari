// Covers the first std::fs slice: existence checks, mode-string open calls,
// read/write/close, byte-slice writes, deletion, and Option-returning helpers.
fn main() -> i64 {
  let path: Slice[u8] = "build/prelude/std-fs-basic.tmp";
  if fs::exists(path) {
    fs::remove_bool(path);
  }

  var score = 0;
  if !fs::exists(path) {
    score = score + 1;
  }

  let missing = fs::try_open(path, "r");
  if missing.is_none() {
    score = score + 2;
  }

  let writer = fs::try_open(path, "w").unwrap_or(fs::File::invalid());
  if writer.is_open() {
    score = score + 3;
  }
  if writer.write_byte(65 as u8).is_ok() {
    score = score + 4;
  }

  var tail = [66 as u8, 67 as u8];
  if writer.write_bytes(tail.as_slice()).unwrap_or(0) == 2 {
    score = score + 5;
  }
  if writer.close().is_ok() {
    score = score + 6;
  }
  if fs::exists(path) {
    score = score + 7;
  }

  let reader = fs::try_open(path, "r").unwrap_or(fs::File::invalid());
  if reader.is_open() {
    score = score + 8;
  }
  if reader.read_byte() == 65 {
    score = score + 9;
  }
  if fs::read_byte(reader) == 66 {
    score = score + 10;
  }
  if reader.read_byte() == 67 {
    score = score + 11;
  }
  if reader.read_byte() < 0 {
    score = score + 12;
  }
  if fs::close(reader).is_ok() {
    score = score + 13;
  }
  let invalid = fs::File::invalid();
  assert(invalid.close().is_err());
  assert(fs::write_byte(invalid, 1 as u8).is_err());
  assert(fs::write_bytes(invalid, tail.as_slice()).is_err());
  if fs::remove_bool(path) {
    score = score + 14;
  }
  if !fs::exists(path) {
    score = score + 15;
  }

  return score;
}
