// Covers Result-returning filesystem mutation helpers. The success payload is
// unit because callers only need to know that the operation completed; failures
// use direct Error payloads while raw helpers stay available for compatibility.
fn cleanup(dir_path: Slice[u8], source_path: Slice[u8], target_path: Slice[u8]) -> void {
  fs::remove_bool(source_path);
  fs::remove_bool(target_path);
  fs::remove_dir_bool(dir_path);
}

fn error_matches(value: error::Error, kind: error::Kind, code: i64) -> bool {
  return value.is_kind(kind) && value.code() == code;
}

fn raw_error_matches(raw: i64, kind: error::Kind, code: i64) -> bool {
  return error_matches(error::from_raw(raw), kind, code);
}

fn result_error_matches(value: Result[(), error::Error], kind: error::Kind, code: i64) -> bool {
  match value {
    Ok(_) => { return false; }
    Err(reason) => { return error_matches(reason, kind, code); }
  }
}

fn raw_unit_error_matches(value: Result[(), i64], kind: error::Kind, code: i64) -> bool {
  match value {
    Ok(_) => { return false; }
    Err(raw) => { return raw_error_matches(raw, kind, code); }
  }
}

fn result_ok(value: Result[(), error::Error]) -> bool {
  match value {
    Ok(_) => { return true; }
    Err(_) => { return false; }
  }
}

fn main() -> i64 {
  let dir_path: Slice[u8] = "build/prelude/std-fs-mutation-result.dir";
  let source_path: Slice[u8] = "build/prelude/std-fs-mutation-result-source.tmp";
  let target_path: Slice[u8] = "build/prelude/std-fs-mutation-result-target.tmp";
  let missing_path: Slice[u8] = "build/prelude/std-fs-mutation-result-missing.tmp";
  cleanup(dir_path, source_path, target_path);
  fs::remove_bool(missing_path);

  var score = 0;

  if result_error_matches(fs::remove(missing_path), error::NotFound, 2) &&
    result_error_matches(fs::remove(missing_path), error::NotFound, 2) &&
    raw_unit_error_matches(fs::remove_raw(missing_path), error::NotFound, 2) {
    score = score + 1;
  }
  if result_ok(fs::create_dir(dir_path)) && fs::exists(dir_path) {
    score = score + 2;
  }
  if result_error_matches(fs::create_dir(dir_path), error::AlreadyExists, 17) &&
    result_error_matches(fs::create_dir(dir_path), error::AlreadyExists, 17) &&
    raw_unit_error_matches(fs::create_dir_raw(dir_path), error::AlreadyExists, 17) {
    score = score + 4;
  }
  if result_ok(fs::remove_dir(dir_path)) && !fs::exists(dir_path) {
    score = score + 8;
  }
  if result_error_matches(fs::remove_dir(dir_path), error::NotFound, 2) &&
    result_error_matches(fs::remove_dir(dir_path), error::NotFound, 2) &&
    raw_unit_error_matches(fs::remove_dir_raw(dir_path), error::NotFound, 2) {
    score = score + 16;
  }

  assert(fs::write_bool(source_path, "RN"));
  if result_ok(fs::rename(source_path, target_path)) &&
    !fs::exists(source_path) && fs::exists(target_path) {
    score = score + 32;
  }
  assert(fs::rename(target_path, source_path).is_ok());
  assert(fs::rename(source_path, target_path).is_ok());
  if result_error_matches(fs::rename(missing_path, source_path), error::NotFound, 2) &&
    result_error_matches(fs::rename(missing_path, source_path), error::NotFound, 2) &&
    raw_unit_error_matches(fs::rename_raw(missing_path, source_path), error::NotFound, 2) {
    score = score + 64;
  }
  if result_ok(fs::remove_file(target_path)) && !fs::exists(target_path) {
    score = score + 128;
  }

  cleanup(dir_path, source_path, target_path);
  assert_eq_i64(score, 255);
  return score;
}
