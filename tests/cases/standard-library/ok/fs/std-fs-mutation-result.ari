// Covers Result-returning filesystem mutation helpers. The success payload is
// unit because callers only need to know that the operation completed; failures
// keep the compact std::error raw bridge until direct Result[(), Error] is the
// normal filesystem result shape.
fn cleanup(dir_path: string, source_path: string, target_path: string) -> void {
  fs::remove(source_path);
  fs::remove(target_path);
  fs::remove_dir(dir_path);
}

fn error_matches(raw: i64, kind: error::Kind, code: i64) -> bool {
  let value = error::from_raw(raw);
  return value.is_kind(kind) && value.code() == code;
}

fn result_error_matches(value: Result[(), i64], kind: error::Kind, code: i64) -> bool {
  match value {
    Ok(_) => { return false; }
    Err(raw) => { return error_matches(raw, kind, code); }
  }
}

fn result_ok(value: Result[(), i64]) -> bool {
  match value {
    Ok(_) => { return true; }
    Err(_) => { return false; }
  }
}

fn main() -> i64 {
  let dir_path = "build/prelude/std-fs-mutation-result.dir";
  let source_path = "build/prelude/std-fs-mutation-result-source.tmp";
  let target_path = "build/prelude/std-fs-mutation-result-target.tmp";
  let missing_path = "build/prelude/std-fs-mutation-result-missing.tmp";
  cleanup(dir_path, source_path, target_path);
  fs::remove(missing_path);

  var score = 0;

  if result_error_matches(fs::remove_result(missing_path), error::NotFound, 2) {
    score = score + 1;
  }
  if result_ok(fs::create_dir_result(dir_path)) && fs::exists(dir_path) {
    score = score + 2;
  }
  if result_error_matches(fs::create_dir_result(dir_path), error::AlreadyExists, 17) {
    score = score + 4;
  }
  if result_ok(fs::remove_dir_result(dir_path)) && !fs::exists(dir_path) {
    score = score + 8;
  }
  if result_error_matches(fs::remove_dir_result(dir_path), error::NotFound, 2) {
    score = score + 16;
  }

  assert(fs::write(source_path, "RN"));
  if result_ok(fs::rename_result(source_path, target_path)) &&
    !fs::exists(source_path) && fs::exists(target_path) {
    score = score + 32;
  }
  if result_error_matches(fs::rename_result(missing_path, source_path), error::NotFound, 2) {
    score = score + 64;
  }
  if result_ok(fs::remove_result(target_path)) && !fs::exists(target_path) {
    score = score + 128;
  }

  cleanup(dir_path, source_path, target_path);
  assert_eq_i64(score, 255);
  return score;
}
