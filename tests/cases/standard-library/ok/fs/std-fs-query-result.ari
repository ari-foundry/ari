// Covers direct Error-returning filesystem query helpers. The natural names
// return Result values; *_optional, try_*, *_unchecked, and *_result spellings
// remain compatibility forms for non-default behavior and migration.
fn has_name(values: ref std::vec::Vec[std::string::String], expected: string) -> bool {
  var index = 0;
  while index < values.len() {
    let name = values.get(index);
    if name.equals_text(expected) {
      return true;
    }
    index = index + 1;
  }
  return false;
}

fn has_entry(values: ref std::vec::Vec[std::fs::DirEntry], expected: string) -> bool {
  var index = 0;
  while index < values.len() {
    let entry = values.get(index);
    if entry.name_equals(expected) {
      return true;
    }
    index = index + 1;
  }
  return false;
}

fn main() -> i64 {
  let dir_path = "build/prelude/std-fs-query-result-dir.tmp";
  let file_path = "build/prelude/std-fs-query-result-dir.tmp/item.txt";
  let link_path = "build/prelude/std-fs-query-result-dir.tmp/item.link";
  let missing = "build/prelude/std-fs-query-result-missing.tmp";

  fs::remove(link_path);
  fs::remove(file_path);
  fs::remove_dir(dir_path);
  fs::remove(missing);

  var zone = zone::create(4096);
  var bytes = [81u8, 82u8, 89u8];
  var score = 0;

  fs::create_dir(dir_path);
  fs::write_bool(file_path, bytes.as_slice());
  fs::symbolic_link(file_path, link_path);

  match fs::metadata(file_path) {
    std::Ok(file_info) => {
      if file_info.len() == 3 && file_info.is_file() &&
         fs::metadata_result(file_path).is_ok() &&
         fs::metadata_optional(file_path).is_some() &&
         fs::try_metadata(file_path).is_some() &&
         fs::metadata_unchecked(file_path).len() == 3 {
        score = score + 1;
      }
    }
    std::Err(_) => {}
  }

  match fs::file_type(file_path) {
    std::Ok(kind) => {
      match kind {
        fs::Regular => {
          if fs::file_type_result(file_path).is_ok() &&
             fs::file_type_optional(file_path).is_some() &&
             fs::try_file_type(file_path).is_some() {
            match fs::file_type_unchecked(file_path) {
              fs::Regular => {
                score = score + 2;
              }
              _ => {}
            }
          }
        }
        _ => {}
      }
    }
    std::Err(_) => {}
  }

  match fs::mode(file_path) {
    std::Ok(mode) => {
      if mode >= 0 &&
         fs::mode_result(file_path).is_ok() &&
         fs::mode_optional(file_path).is_some() &&
         fs::try_mode(file_path).is_some() &&
         fs::mode_unchecked(file_path) >= 0 {
        score = score + 4;
      }
    }
    std::Err(_) => {}
  }

  match fs::metadata(missing) {
    std::Ok(_) => {}
    std::Err(reason) => {
      if reason.is_kind(error::NotFound) && fs::metadata_result(missing).is_err() {
        score = score + 8;
      }
    }
  }

  match fs::symlink_metadata(link_path) {
    std::Ok(link_info) => {
      if link_info.is_symlink() &&
         fs::symlink_metadata_result(link_path).is_ok() &&
         fs::symlink_metadata_optional(link_path).is_some() &&
         fs::try_symlink_metadata(link_path).is_some() &&
         fs::symlink_metadata_unchecked(link_path).is_symlink() {
        score = score + 16;
      }
    }
    std::Err(_) => {}
  }

  match fs::read_link(ref mut zone, link_path) {
    std::Ok(target) => {
      let unchecked_target = fs::read_link_unchecked(ref mut zone, link_path);
      if target.equals_text(file_path) &&
         fs::read_link_result(ref mut zone, link_path).is_ok() &&
         fs::read_link_optional(ref mut zone, link_path).is_some() &&
         unchecked_target.equals_text(file_path) {
        score = score + 32;
      }
    }
    std::Err(_) => {}
  }

  match fs::canonicalize(ref mut zone, file_path) {
    std::Ok(resolved) => {
      let unchecked_resolved = fs::canonicalize_unchecked(ref mut zone, file_path);
      if path::is_absolute(resolved.as_slice()) &&
         resolved.ends_with("item.txt") &&
         fs::canonicalize_result(ref mut zone, file_path).is_ok() &&
         fs::canonicalize_optional(ref mut zone, file_path).is_some() &&
         path::is_absolute(unchecked_resolved.as_slice()) {
        score = score + 64;
      }
    }
    std::Err(_) => {}
  }

  var directory_results_ok = false;
  match fs::open_dir_result(dir_path) {
    std::Ok(dir) => {
      directory_results_ok = dir.is_open() && dir.close().is_ok();
    }
    std::Err(_) => {}
  }
  match fs::read_dir(ref mut zone, dir_path) {
    std::Ok(names) => {
      let unchecked_names = fs::read_dir_unchecked(ref mut zone, dir_path);
      directory_results_ok = directory_results_ok &&
        has_name(ref names, "item.txt") &&
        fs::read_dir_result(ref mut zone, dir_path).is_ok() &&
        fs::read_dir_optional(ref mut zone, dir_path).is_some() &&
        has_name(ref unchecked_names, "item.txt");
    }
    std::Err(_) => {
      directory_results_ok = false;
    }
  }
  match fs::read_dir_entries(ref mut zone, dir_path) {
    std::Ok(entries) => {
      let unchecked_entries = fs::read_dir_entries_unchecked(ref mut zone, dir_path);
      directory_results_ok = directory_results_ok &&
        has_entry(ref entries, "item.link") &&
        fs::read_dir_entries_result(ref mut zone, dir_path).is_ok() &&
        fs::read_dir_entries_optional(ref mut zone, dir_path).is_some() &&
        has_entry(ref unchecked_entries, "item.link");
    }
    std::Err(_) => {
      directory_results_ok = false;
    }
  }
  if directory_results_ok {
    score = score + 128;
  }

  fs::remove(link_path);
  fs::remove(file_path);
  fs::remove_dir(dir_path);
  zone::destroy(zone);

  assert_eq_i64(score, 255);
  return score;
}
