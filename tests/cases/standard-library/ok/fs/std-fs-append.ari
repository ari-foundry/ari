// Covers append-mode file opens through fs::try_open(path, "a"): preserve
// existing bytes, append new bytes, read back, and surface failures as Option.
fn main() -> i64 {
  let path = "build/prelude/std-fs-append.tmp";
  if fs::exists(path) {
    fs::remove_bool(path);
  }

  var score = 0;

  let writer = fs::try_open(path, "w").unwrap_or(fs::File::invalid());
  if writer.is_open() {
    score = score + 1;
  }
  if writer.write_byte(65 as u8).is_ok() {
    score = score + 2;
  }
  if writer.close().is_ok() {
    score = score + 3;
  }

  let appender = fs::try_open(path, "a").unwrap_or(fs::File::invalid());
  if appender.is_open() {
    score = score + 4;
  }
  if appender.write_byte(66 as u8).is_ok() {
    score = score + 5;
  }
  var tail = [67 as u8, 68 as u8];
  if appender.write_bytes(tail.as_slice()).unwrap_or(0) == 2 {
    score = score + 6;
  }
  if appender.close().is_ok() {
    score = score + 7;
  }

  let reader = fs::try_open(path, "r").unwrap_or(fs::File::invalid());
  if reader.is_open() {
    score = score + 8;
  }
  if reader.read_byte() == 65 {
    score = score + 9;
  }
  if reader.read_byte() == 66 {
    score = score + 10;
  }
  if reader.read_byte() == 67 {
    score = score + 11;
  }
  if reader.read_byte() == 68 {
    score = score + 12;
  }
  if reader.read_byte() < 0 {
    score = score + 13;
  }
  if reader.close().is_ok() {
    score = score + 14;
  }
  if fs::remove_bool(path) {
    score = score + 15;
  }
  if !fs::exists(path) {
    score = score + 16;
  }

  let missing = fs::try_open("build/prelude/std-fs-append-no-such-dir/file.tmp", "a");
  if missing.is_none() {
    score = score + 17;
  }

  return score;
}
