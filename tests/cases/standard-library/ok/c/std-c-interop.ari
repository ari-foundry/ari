extern "C" fn strlen(text: ptr c_char) -> size_t;
extern "C" fn abs(value: c_int) -> c_int;
extern "C" fn posix_open(path: ptr c_char, flags: c_int) -> c_int = "open";

fn same_bytes(left: Slice[u8], right: Slice[u8]) -> bool {
  if left.len != right.len {
    return false;
  }
  var index = 0;
  while index < left.len {
    if left[index] != right[index] {
      return false;
    }
    index = index + 1;
  }
  return true;
}

fn main() -> i64 {
  var score = 0;

  let borrowed = c::from_string("hello");
  let alias_borrowed: CStr = borrowed;
  var hello = [104u8, 101u8, 108u8, 108u8, 111u8];
  assert_eq_i64(borrowed.len(), 5);
  assert(!borrowed.is_empty());
  assert(same_bytes(borrowed.as_slice(), hello.as_slice()));
  assert_eq_i64(alias_borrowed.len(), 5);
  assert_eq_i64(strlen(borrowed.as_ptr()) as i64, 5);
  score = score + 1;

  var zone = zone::create(256);
  var owned = c::from_slice_in(ref mut zone, hello.as_slice());
  assert_eq_i64(owned.len(), 5);
  assert(same_bytes(owned.as_slice(), hello.as_slice()));
  match c::from_slice_result_in(ref mut zone, hello.as_slice()) {
    Ok(result_owned) => {
      assert_eq_i64(result_owned.len(), 5);
      assert(same_bytes(result_owned.as_slice(), hello.as_slice()));
    }
    Err(_) => {
      panic();
    }
  }
  var with_nul = [97u8, 0u8, 98u8];
  match c::from_slice_result_in(ref mut zone, with_nul.as_slice()) {
    Ok(_) => {
      panic();
    }
    Err(slice_reason) => {
      assert(slice_reason.is_kind(error::InvalidInput));
    }
  }
  let nul_bytes = owned.as_bytes_with_nul();
  assert_eq_i64(nul_bytes.len, 6);
  assert(nul_bytes[5] == 0u8);
  let owned_ptr = owned.as_ptr();
  let roundtrip = c::from_ptr(owned_ptr);
  assert(c::from_ptr_result(owned_ptr).is_ok());
  assert(same_bytes(roundtrip.as_slice(), hello.as_slice()));
  let owned_view = owned.as_c_str();
  assert(same_bytes(owned_view.as_slice(), hello.as_slice()));
  let copied = c::from_cstr_in(ref mut zone, borrowed);
  assert(same_bytes(copied.as_slice(), hello.as_slice()));
  assert(c::from_cstr_result_in(ref mut zone, borrowed).is_ok());
  score = score + 1;

  let null_handle: ptr c_void = null;
  let null_text: ptr c_char = null;
  assert(c::is_null(null_handle));
  match c::from_ptr_result(null_text) {
    Ok(_) => {
      panic();
    }
    Err(ptr_reason) => {
      assert(ptr_reason.is_kind(error::InvalidInput));
    }
  }
  assert(!c::is_null(borrowed.as_ptr() as ptr c_void));
  assert_eq_i64(abs(-7i32) as i64, 7);
  score = score + 1;

  let missing = c::from_string("/tmp/ari-c-interop-definitely-missing");
  let fd = posix_open(missing.as_ptr(), 0);
  assert(fd < 0);
  let os_error = c::error();
  assert(os_error.is_not_found());
  assert_eq_i64(os_error.code(), 2);
  score = score + 1;

  let invalid_library: Library = Library::invalid();
  let invalid_symbol: Symbol = Symbol::invalid();
  assert(!invalid_library.is_open());
  assert(!invalid_symbol.is_valid());
  assert_eq_i64(c::local() + c::global(), 256);
  score = score + 1;

  var library = c::open(c::from_string("libc.so.6"), c::lazy());
  assert(library.is_open());
  let strlen_symbol = library.symbol(c::from_string("strlen"));
  assert(strlen_symbol.is_valid());
  match library.symbol_result(c::from_string("strlen")) {
    Ok(result_symbol) => {
      assert(result_symbol.is_valid());
    }
    Err(_) => {
      panic();
    }
  }
  assert(c::symbol_result(ref library, c::from_string("strlen")).is_ok());
  assert(!c::is_null(strlen_symbol.as_ptr()));
  let absent_symbol = c::symbol(ref library, c::from_string("__ari_missing_symbol_for_test__"));
  assert(!absent_symbol.is_valid());
  assert(library.symbol_result(c::from_string("__ari_missing_symbol_for_test__")).is_err());
  let loader_error = c::last_error();
  assert(!loader_error.is_empty());
  assert(library.close_result().is_ok());
  assert(!library.is_open());
  score = score + 1;

  match c::open_result(c::from_string("libc.so.6"), c::lazy()) {
    Ok(result_library) => {
      var closable = result_library;
      assert(closable.close_result().is_ok());
      assert(closable.close_result().is_ok());
    }
    Err(_) => {
      panic();
    }
  }
  assert(c::open_result(c::from_string("/tmp/ari-missing-library-for-result.so"), c::lazy()).is_err());

  let main_library = c::main_program(c::now());
  assert(main_library.is_open());
  assert(c::main_program_result(c::now()).is_ok());
  score = score + 1;

  zone::destroy(zone);
  return score;
}
