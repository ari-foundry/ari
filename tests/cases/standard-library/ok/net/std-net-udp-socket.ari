// Covers hosted UDP sockets: IPv4 bind, local port discovery, single-byte
// datagram send/receive, timeout/nonblocking options, and explicit close. If
// the host forbids socket creation, the test accepts PermissionDenied as an
// environment policy and still verifies the shared error bridge.
fn error_is(raw: i64, kind: error::Kind) -> bool {
  let value = error::from_raw(raw);
  return value.is_kind(kind);
}

fn main() -> i64 {
  let unsupported = net::socket_addr(net::Ipv6Addr::localhost().as_ip(), 0 as u16);
  var score = 0;
  match net::UdpSocket::bind_result(unsupported) {
    Ok(_socket) => {}
    Err(raw) => {
      if error_is(raw, error::Unsupported) {
        score = score + 1;
      }
    }
  }

  let bind_addr = net::SocketAddr::localhost(0 as u16);
  let maybe_server = net::UdpSocket::bind(bind_addr);
  if maybe_server.is_none() {
    match net::UdpSocket::bind_result(bind_addr) {
      Ok(_retry_socket) => {}
      Err(bind_raw) => {
        if error_is(bind_raw, error::PermissionDenied) || error_is(bind_raw, error::Unsupported) {
          score = score + 254;
        }
      }
    }
    assert_eq_i64(score, 255);
    return score;
  }

  var server = maybe_server.unwrap();
  if server.is_open() && server.descriptor().is_valid() {
    score = score + 2;
  }

  let maybe_port = server.local_port();
  assert(maybe_port.is_some());
  let port = maybe_port.unwrap();
  let maybe_server_addr = server.local_addr();
  assert(maybe_server_addr.is_some());
  let server_addr = maybe_server_addr.unwrap();
  if port > 0 as u16 && server_addr.port() == port && server_addr.is_loopback() {
    score = score + 4;
  }

  let maybe_client = net::UdpSocket::bind(bind_addr);
  assert(maybe_client.is_some());
  var client = maybe_client.unwrap();
  if client.is_open() && client.descriptor().is_valid() {
    score = score + 8;
  }

  let timeout = time::milliseconds(1000);
  if server.set_read_timeout(timeout) &&
    server.set_read_timeout_millis(1000) &&
    client.set_write_timeout(timeout) &&
    server.set_nonblocking(false) &&
    client.set_nonblocking(false) &&
    server.is_nonblocking().is_some() &&
    client.is_nonblocking().is_some() {
    score = score + 16;
  }

  if client.send_byte_to(90u8, net::SocketAddr::localhost(port)) && server.recv_byte() == 90 {
    score = score + 32;
  }

  let client_port = client.local_port();
  let client_addr = client.local_addr();
  if client_port.is_some() && client_addr.is_some() &&
    client_addr.unwrap().port() == client_port.unwrap() {
    score = score + 64;
  }

  if client.close() && server.close() {
    score = score + 128;
  }

  assert_eq_i64(score, 255);
  return score;
}
