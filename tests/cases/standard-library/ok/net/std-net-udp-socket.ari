// Covers hosted UDP sockets: IPv4 bind, local port discovery, single-byte
// datagram send/receive, timeout/nonblocking options, and explicit close. If
// the host forbids socket creation, the test accepts PermissionDenied as an
// environment policy and still verifies the shared error bridge.
fn error_is(value: error::Error, kind: error::Kind) -> bool {
  return value.is_kind(kind);
}

fn main() -> i64 {
  var score = 0;

  let bind_addr = net::SocketAddr::localhost(0 as u16);
  let maybe_server = net::udp_bind(bind_addr).ok();
  if maybe_server.is_none() {
    match net::UdpSocket::bind(bind_addr) {
      Ok(_retry_socket) => {}
      Err(bind_error) => {
        if error_is(bind_error, error::PermissionDenied) || error_is(bind_error, error::Unsupported) {
          score = score + 254;
        }
      }
    }
    assert_eq_i64(score, 254);
    return score;
  }

  var server = maybe_server.unwrap();
  if server.is_open() && server.descriptor().is_valid() {
    score = score + 2;
  }

  let maybe_port = server.local_port_optional();
  assert(maybe_port.is_some());
  let port = maybe_port.unwrap();
  assert(server.local_port().unwrap_or(0 as u16) == port);
  let maybe_server_addr = server.local_addr_optional();
  assert(maybe_server_addr.is_some());
  let server_addr = maybe_server_addr.unwrap();
  assert(server.local_addr().is_ok());
  if port > 0 as u16 && server_addr.port() == port && server_addr.is_loopback() {
    score = score + 4;
  }

  let maybe_client = net::UdpSocket::bind_optional(bind_addr);
  assert(maybe_client.is_some());
  var client = maybe_client.unwrap();
  if client.is_open() && client.descriptor().is_valid() {
    score = score + 8;
  }

  let timeout = time::milliseconds(1000);
  if server.set_read_timeout(timeout).is_ok() &&
    server.set_read_timeout_millis(1000).is_ok() &&
    server.set_reuse_addr(true).is_ok() &&
    server.reuse_addr().unwrap_or(false) &&
    client.set_write_timeout(timeout).is_ok() &&
    client.set_reuse_addr(true).is_ok() &&
    client.reuse_addr().unwrap_or(false) &&
    server.set_nonblocking(false).is_ok() &&
    client.set_nonblocking(false).is_ok() &&
    server.is_nonblocking().is_ok() &&
    client.is_nonblocking().is_ok() {
    score = score + 528;
  }

  if client.send_byte_to(90u8, net::SocketAddr::localhost(port)).is_ok() &&
    server.recv_byte().unwrap_or(0u8) == 90u8 {
    score = score + 32;
  }

  let client_port = client.local_port_optional();
  let client_addr = client.local_addr_optional();
  if client_port.is_some() && client_addr.is_some() &&
    client_addr.unwrap().port() == client_port.unwrap() {
    score = score + 64;
  }
  assert(client.local_port().is_ok());
  assert(client.local_addr().is_ok());

  if client.close().is_ok() && server.close().is_ok() {
    score = score + 128;
  }
  assert(client.close().is_err());
  assert(server.close().is_err());

  assert_eq_i64(score, 766);
  return score;
}
