// Covers hosted UDP sockets: IPv4 bind, local port discovery, single-byte
// datagram send/receive, timeout/nonblocking options, and explicit close. If
// the host forbids socket creation, the test accepts PermissionDenied as an
// environment policy and still verifies the shared error bridge.
fn error_is(value: error::Error, kind: error::Kind) -> bool {
  return value.is_kind(kind);
}

fn raw_error_is(raw: i64, kind: error::Kind) -> bool {
  let value = error::from_raw(raw);
  return value.is_kind(kind);
}

fn main() -> i64 {
  let unsupported = net::socket_addr(net::Ipv6Addr::localhost().as_ip(), 0 as u16);
  var score = 0;
  match net::UdpSocket::bind_result(unsupported) {
    Ok(_direct_socket) => {}
    Err(reason) => {
      if error_is(reason, error::Unsupported) {
        score = score + 1;
      }
    }
  }
  match net::udp_bind(unsupported) {
    Ok(_module_socket) => {}
    Err(module_reason) => {
      if error_is(module_reason, error::Unsupported) {
        score = score + 256;
      }
    }
  }
  match net::UdpSocket::bind_raw_result(unsupported) {
    Ok(_raw_socket) => {}
    Err(raw) => {
      if !raw_error_is(raw, error::Unsupported) {
        panic();
      }
    }
  }

  let bind_addr = net::SocketAddr::localhost(0 as u16);
  let maybe_server = net::UdpSocket::bind(bind_addr);
  if maybe_server.is_none() {
    match net::UdpSocket::bind_result(bind_addr) {
      Ok(_retry_socket) => {}
      Err(bind_error) => {
        if error_is(bind_error, error::PermissionDenied) || error_is(bind_error, error::Unsupported) {
          score = score + 254;
        }
      }
    }
    assert_eq_i64(score, 511);
    return score;
  }

  var server = maybe_server.unwrap();
  if server.is_open() && server.descriptor().is_valid() {
    score = score + 2;
  }

  let maybe_port = server.local_port();
  assert(maybe_port.is_some());
  let port = maybe_port.unwrap();
  assert(server.local_port_result().unwrap_or(0 as u16) == port);
  let maybe_server_addr = server.local_addr();
  assert(maybe_server_addr.is_some());
  let server_addr = maybe_server_addr.unwrap();
  assert(server.local_addr_result().is_ok());
  if port > 0 as u16 && server_addr.port() == port && server_addr.is_loopback() {
    score = score + 4;
  }

  let maybe_client = net::UdpSocket::bind(bind_addr);
  assert(maybe_client.is_some());
  var client = maybe_client.unwrap();
  if client.is_open() && client.descriptor().is_valid() {
    score = score + 8;
  }

  let timeout = time::milliseconds(1000);
  if server.set_read_timeout_result(timeout).is_ok() &&
    server.set_read_timeout_millis_result(1000).is_ok() &&
    server.set_reuse_addr_result(true).is_ok() &&
    server.reuse_addr_result().unwrap_or(false) &&
    client.set_write_timeout_result(timeout).is_ok() &&
    client.set_reuse_addr_result(true).is_ok() &&
    client.reuse_addr_result().unwrap_or(false) &&
    server.set_nonblocking_result(false).is_ok() &&
    client.set_nonblocking_result(false).is_ok() &&
    server.is_nonblocking_result().is_ok() &&
    client.is_nonblocking_result().is_ok() {
    score = score + 528;
  }

  if client.send_byte_to_result(90u8, net::SocketAddr::localhost(port)).is_ok() &&
    server.recv_byte_result().unwrap_or(0u8) == 90u8 {
    score = score + 32;
  }

  let client_port = client.local_port();
  let client_addr = client.local_addr();
  if client_port.is_some() && client_addr.is_some() &&
    client_addr.unwrap().port() == client_port.unwrap() {
    score = score + 64;
  }
  assert(client.local_port_result().is_ok());
  assert(client.local_addr_result().is_ok());

  if client.close_result().is_ok() && server.close_result().is_ok() {
    score = score + 128;
  }
  assert(client.close_result().is_err());
  assert(server.close_result().is_err());

  assert_eq_i64(score, 1023);
  return score;
}
