// Covers the first DNS/name-resolution API. Numeric IPv4 hosts keep this
// deterministic while still proving the getaddrinfo-backed lookup path.
fn raw_error_is(raw: i64, kind: error::Kind) -> bool {
  let value = error::from_raw(raw);
  return value.is_kind(kind);
}

fn main() -> i64 {
  var score = 0;

  let loopback = net::lookup_v4("127.0.0.1", 8080 as u16);
  assert(loopback.is_some());
  let addr = loopback.unwrap();
  if addr.is_loopback() {
    score = score + 1;
  }
  if addr.port() == 8080 as u16 {
    score = score + 2;
  }
  let ip = addr.ip();
  if ip.is_v4() && !ip.is_v6() {
    score = score + 4;
  }
  if addr.with_port(8081 as u16).port() == 8081 as u16 {
    score = score + 8;
  }

  match net::lookup_v4_result("127.0.0.1", 80 as u16) {
    Ok(result_addr) => {
      if result_addr.port() == 80 as u16 && result_addr.is_loopback() {
        score = score + 16;
      }
    }
    Err(_reason) => {}
  }

  match net::lookup_v4_raw_result("127.0.0.1", 80 as u16) {
    Ok(raw_addr) => {
      if !(raw_addr.port() == 80 as u16 && raw_addr.is_loopback()) {
        panic();
      }
    }
    Err(_raw) => {
      panic();
    }
  }

  if net::lookup_v4("::1", 80 as u16).is_none() {
    score = score + 32;
  }

  let any = net::lookup_v4("0.0.0.0", 0 as u16);
  if any.is_some() && any.unwrap().is_unspecified() {
    score = score + 64;
  }

  let broadcast = net::lookup_v4("255.255.255.255", 65535 as u16);
  if broadcast.is_some() {
    let full = broadcast.unwrap();
    if full.port() == 65535 as u16 && !full.is_loopback() && !full.is_unspecified() {
      score = score + 128;
    }
  }

  let endpoint = net::resolve("127.0.0.1:8082");
  if endpoint.is_some() {
    let resolved = endpoint.unwrap();
    if resolved.is_loopback() && resolved.port() == 8082 as u16 {
      score = score + 256;
    }
  }

  match net::resolve_result("127.0.0.1:8083") {
    Ok(resolved_result) => {
      if resolved_result.is_loopback() && resolved_result.port() == 8083 as u16 {
        score = score + 512;
      }
    }
    Err(_endpoint_reason) => {}
  }

  match net::ToSocketAddrs::to_socket_addrs("127.0.0.1:8084") {
    Ok(trait_addr) => {
      if trait_addr.is_loopback() && trait_addr.port() == 8084 as u16 {
        score = score + 1024;
      }
    }
    Err(_trait_reason) => {}
  }

  match net::to_socket_addrs("127.0.0.1:8085") {
    Ok(module_addr) => {
      if module_addr.is_loopback() && module_addr.port() == 8085 as u16 {
        score = score + 16384;
      }
    }
    Err(_module_reason) => {}
  }

  match net::connect_host("127.0.0.1") {
    Ok(_unexpected_stream) => {
      panic();
    }
    Err(connect_reason) => {
      if connect_reason.is_kind(error::InvalidInput) {
        score = score + 2048;
      }
    }
  }

  match net::resolve_raw_result("127.0.0.1:bad") {
    Ok(_bad_addr) => {
      panic();
    }
    Err(raw_reason) => {
      if raw_error_is(raw_reason, error::InvalidInput) {
        score = score + 4096;
      }
    }
  }

  match net::tcp_connect_host("127.0.0.1") {
    Ok(_unexpected_explicit_stream) => {
      panic();
    }
    Err(explicit_reason) => {
      if explicit_reason.is_kind(error::InvalidInput) {
        score = score + 8192;
      }
    }
  }

  assert_eq_i64(score, 32767);
  return score;
}
