// Covers Unix domain stream sockets on hosted Unix-like targets. The test uses
// a short pathname socket, transfers bytes through stream byte and buffer
// helpers, and cleans up the path. Restricted hosts may reject socket creation;
// that still proves the std::error bridge.
fn error_is(value: error::Error, kind: error::Kind) -> bool {
  return value.is_kind(kind);
}

fn raw_error_is(raw: i64, kind: error::Kind) -> bool {
  let value = error::from_raw(raw);
  return value.is_kind(kind);
}

fn main() -> i64 {
  let path = "build/prelude/std-net-unix-socket.sock";
  fs::remove(path);

  var score = 0;
  let maybe_listener = net::unix_listen(path);
  if maybe_listener.is_err() {
    match net::UnixListener::bind_result(path) {
      Ok(_retry_listener) => {}
      Err(bind_error) => {
        if error_is(bind_error, error::PermissionDenied) || error_is(bind_error, error::Unsupported) {
          score = 255;
        }
      }
    }
    match net::UnixListener::bind_raw_result(path) {
      Ok(_raw_retry_listener) => {}
      Err(bind_raw) => {
        if !(raw_error_is(bind_raw, error::PermissionDenied) || raw_error_is(bind_raw, error::Unsupported)) {
          panic();
        }
      }
    }
    assert_eq_i64(score, 255);
    return score;
  }

  var listener = maybe_listener.unwrap();
  if listener.is_open() && listener.descriptor().is_valid() {
    score = score + 1;
  }

  let maybe_client = net::unix_connect(path);
  assert(maybe_client.is_ok());
  var client = maybe_client.unwrap();
  if client.is_open() && client.descriptor().is_valid() {
    score = score + 2;
  }

  let maybe_server = listener.accept();
  assert(maybe_server.is_some());
  var server = maybe_server.unwrap();
  if server.is_open() && server.descriptor().is_valid() {
    score = score + 4;
  }

  let timeout = time::milliseconds(1000);
  if listener.set_nonblocking_result(false).is_ok() &&
    client.set_nonblocking_result(false).is_ok() &&
    server.set_nonblocking_result(false).is_ok() &&
    client.set_read_timeout_result(timeout).is_ok() &&
    client.set_write_timeout_result(timeout).is_ok() &&
    server.set_read_timeout_result(timeout).is_ok() &&
    server.set_write_timeout_result(timeout).is_ok() &&
    client.set_read_timeout_millis_result(1000).is_ok() {
    score = score + 8;
  }

  if client.write_byte(81u8) && server.read_byte_result().unwrap_or(0u8) == 81u8 {
    score = score + 16;
  }

  var reply = [82u8, 83u8];
  if server.write_all_result(reply.as_slice()).is_ok() {
    var output = [0u8, 0u8];
    let output_raw = output.as_slice().as_ptr();
    if client.read_exact_result(output_raw, 2).is_ok() {
      if ptr_load(output_raw) == 82u8 && ptr_load(ptr_add(output_raw, 1)) == 83u8 {
        score = score + 32;
      }
    }
  }

  if client.shutdown_result(net::Write).is_ok() {
    score = score + 64;
  }

  if server.close_result().is_ok() && client.close_result().is_ok() && listener.close_result().is_ok() && fs::remove(path) {
    score = score + 128;
  }
  assert(server.close_result().is_err());
  assert(client.close_result().is_err());
  assert(listener.close_result().is_err());

  assert_eq_i64(score, 255);
  return score;
}
