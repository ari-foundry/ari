// Covers the runtime-backed std::net TCP socket slice. A listener binds an
// ephemeral IPv4 loopback port when the host permits sockets. Restricted test
// sandboxes may reject socket creation with PermissionDenied; that path still
// verifies the std::error bridge instead of making check depend on host policy.
fn error_is(value: error::Error, kind: error::Kind) -> bool {
  return value.is_kind(kind);
}

fn main() -> i64 {
  var score = 0;

  let bind_addr = net::SocketAddr::localhost(0 as u16);
  let maybe_listener = net::listen(bind_addr).ok();
  if maybe_listener.is_none() {
    match net::tcp_listen(bind_addr) {
      Ok(_retry_listener) => {}
      Err(bind_error) => {
        if bind_error.is_kind(error::PermissionDenied) || bind_error.is_kind(error::Unsupported) {
          score = score + 510;
        }
      }
    }
    assert_eq_i64(score, 510);
    return score;
  }
  assert(maybe_listener.is_some());
  var listener = maybe_listener.unwrap();
  if listener.is_open() && listener.descriptor().is_valid() {
    score = score + 2;
  }

  let maybe_port = listener.local_port_optional();
  assert(maybe_port.is_some());
  let port = maybe_port.unwrap();
  assert(listener.local_port().unwrap_or(0 as u16) == port);
  let maybe_listener_addr = listener.local_addr_optional();
  assert(maybe_listener_addr.is_some());
  let listener_addr = maybe_listener_addr.unwrap();
  assert(listener.local_addr().is_ok());
  if port > 0 as u16 && listener_addr.port() == port && listener_addr.is_loopback() {
    score = score + 4;
  }

  let connect_addr = net::SocketAddr::localhost(port);
  if false {
    let _unused_bind_optional = net::TcpListener::bind_optional(bind_addr);
    let _unused_tcp_connect = net::tcp_connect(connect_addr);
    let _unused_connect_optional = net::TcpStream::connect_optional(connect_addr);
  }
  let maybe_client = net::connect(connect_addr);
  assert(maybe_client.is_ok());
  var client = maybe_client.unwrap();
  let maybe_client_addr = client.local_addr_optional();
  assert(maybe_client_addr.is_some());
  let client_addr = maybe_client_addr.unwrap();
  let maybe_client_peer = client.peer_addr_optional();
  assert(maybe_client_peer.is_some());
  let client_peer = maybe_client_peer.unwrap();
  assert(client.local_addr().is_ok());
  assert(client.peer_addr().is_ok());
  if client.is_open() && client.descriptor().is_valid() && client_addr.port() > 0 as u16 &&
    client_addr.is_loopback() && client_peer.port() == port && client_peer.is_loopback() {
    score = score + 8;
  }

  let maybe_server = listener.accept_optional();
  assert(maybe_server.is_some());
  var server = maybe_server.unwrap();
  let maybe_server_addr = server.local_addr_optional();
  assert(maybe_server_addr.is_some());
  let server_addr = maybe_server_addr.unwrap();
  let maybe_server_peer = server.peer_addr_optional();
  assert(maybe_server_peer.is_some());
  let server_peer = maybe_server_peer.unwrap();
  if server.is_open() && server.descriptor().is_valid() && server_addr.port() == port &&
    server_addr.is_loopback() {
    score = score + 16;
  }

  if server_peer.port() == client_addr.port() && server_peer.is_loopback() {
    score = score + 512;
  }

  if client.write_byte(65u8) && server.try_read_byte().unwrap_or(0u8) == 65u8 {
    score = score + 32;
  }

  var reply = [66u8, 67u8];
  if server.write_all(reply.as_slice()).is_ok() {
    var output = [0u8, 0u8];
    let view = output.as_slice();
    let output_raw = view.as_ptr();
    if client.read_exact(output_raw, 2).is_ok() {
      if ptr_load(output_raw) == 66u8 && ptr_load(ptr_add(output_raw, 1)) == 67u8 {
        score = score + 64;
      }
    }
  }

  var more = [68u8, 69u8, 70u8];
  if server.write(more.as_slice()).unwrap_or(0) == 3 {
    var read_output = [0u8, 0u8, 0u8];
    let read_view = read_output.as_slice();
    if client.read(read_view).unwrap_or(0) == 3 &&
      read_output[0] == 68u8 &&
      read_output[1] == 69u8 &&
      read_output[2] == 70u8 {
      score = score + 16384;
    }
  }

  let timeout = time::milliseconds(1000);
  if listener.set_accept_timeout(timeout).is_ok() &&
    listener.set_accept_timeout_millis(1000).is_ok() &&
    listener.set_reuse_addr(true).is_ok() &&
    listener.reuse_addr().unwrap_or(false) &&
    client.set_read_timeout(timeout).is_ok() &&
    client.set_write_timeout(timeout).is_ok() &&
    client.set_nodelay(true).is_ok() &&
    client.nodelay().unwrap_or(false) &&
    server.set_read_timeout(timeout).is_ok() &&
    server.set_write_timeout(timeout).is_ok() &&
    listener.set_nonblocking(false).is_ok() &&
    client.set_nonblocking(false).is_ok() &&
    server.set_nonblocking(false).is_ok() &&
    client.shutdown(net::Write).is_ok() {
    score = score + 256;
  }

  if client.close_on_exec().unwrap_or(false) &&
    client.set_close_on_exec(true).is_ok() &&
    client.set_keepalive(true).is_ok() &&
    client.keepalive().unwrap_or(false) &&
    client.set_send_buffer_size(4096).is_ok() &&
    client.send_buffer_size().unwrap_or(0) > 0 &&
    client.set_recv_buffer_size(4096).is_ok() &&
    client.recv_buffer_size().unwrap_or(0) > 0 &&
    listener.set_reuse_port(true).is_ok() {
    score = score + 32768;
  }

  if server.set_nodelay(true).is_ok() && server.nodelay().unwrap_or(false) {
    score = score + 8192;
  }

  if server.close().is_ok() && client.close().is_ok() && listener.close().is_ok() {
    score = score + 128;
  }
  assert(server.close().is_err());
  assert(client.close().is_err());
  assert(listener.close().is_err());

  assert_eq_i64(score, 58366);
  return score;
}
