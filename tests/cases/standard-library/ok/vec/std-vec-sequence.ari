// Covers std::vec::Vec[T] wrappers around borrowed Slice[T] sequence helpers.
// Vec owns the storage; these APIs return or iterate borrowed views. The
// compare() wrapper is kept for compatibility, while ordering() is the
// preferred cmp::Ordering shape for new lexicographic checks.

fn expect_slice(values: Slice[i64], expected: Slice[i64]) -> void {
  assert(values.equals(expected));
}

fn even(value: ref i64) -> bool {
  let raw = (ref value) as ptr i64;
  return (*raw % 2) == 0;
}

fn less_than_four(value: ref i64) -> bool {
  let raw = (ref value) as ptr i64;
  return (*raw) < 4;
}

fn partition_ok(values: Slice[i64], split: i64) -> bool {
  var index = 0;
  while index < split {
    if (values[index] % 2) != 0 {
      return false;
    }
    index = index + 1;
  }
  while index < values.len {
    if (values[index] % 2) == 0 {
      return false;
    }
    index = index + 1;
  }
  return true;
}

fn main() -> i64 {
  var zone = zone::create(512);
  var values = std::vec::new<i64>(ref mut zone, 8);
  values.push(1);
  values.push(2);
  values.push(3);
  values.push(2);
  values.push(4);
  values.push(2);

  var expected_middle = [2, 3, 2];
  var expected_left = [1, 2, 3];
  var expected_right = [2, 4, 2];
  var needle = [3, 2];
  var missing = [4, 4];
  var same = [1, 2, 3, 2, 4, 2];
  var shorter = [1, 2, 3, 2, 4];
  var larger_at_index = [1, 2, 9];

  expect_slice(values.slice(1, 4), expected_middle.as_slice());

  let halves = values.split_at(3);
  expect_slice(halves.left(), expected_left.as_slice());
  expect_slice(halves.right(), expected_right.as_slice());

  assert_eq_i64(values.find(needle.as_slice()), 2);
  assert_eq_i64(values.find(values.slice(0, 0)), 0);
  assert_eq_i64(values.find(missing.as_slice()), -1);
  assert(values.contains_slice(needle.as_slice()));
  assert(!values.contains_slice(missing.as_slice()));

  assert_eq_i64(values.compare(same.as_slice()), 0);
  assert_eq_i64(values.compare(shorter.as_slice()), 1);
  assert_eq_i64(values.compare(larger_at_index.as_slice()), -1);
  assert(values.ordering(same.as_slice()).is_equal());
  assert(values.ordering(shorter.as_slice()).is_greater());
  assert(values.ordering(larger_at_index.as_slice()).is_less());

  var chunks = values.chunks(2);
  var chunk_score = 0;
  for chunk in ref mut chunks {
    chunk_score = chunk_score + chunk.len + chunk[0];
  }
  assert_eq_i64(chunk_score, 14);

  var windows = values.windows(3);
  var window_score = 0;
  for window in ref mut windows {
    window_score = window_score + window[0] + window[2];
  }
  assert_eq_i64(window_score, 19);

  var split = values.split(2);
  expect_slice(split.next().unwrap(), values.slice(0, 1));
  expect_slice(split.next().unwrap(), values.slice(2, 3));
  expect_slice(split.next().unwrap(), values.slice(4, 5));
  assert_eq_i64(split.next().unwrap().len, 0);
  let no_more = split.next();
  assert(no_more.is_none());

  var reversed = [2, 4, 2, 3, 2, 1];
  values.reverse();
  expect_slice(values.as_slice(), reversed.as_slice());

  var rotated_left = [2, 3, 2, 1, 2, 4];
  values.rotate_left(2);
  expect_slice(values.as_slice(), rotated_left.as_slice());

  values.rotate_right(2);
  expect_slice(values.as_slice(), reversed.as_slice());

  var unsorted = std::vec::new<i64>(ref mut zone, 6);
  unsorted.push(5);
  unsorted.push(1);
  unsorted.push(4);
  unsorted.push(3);
  unsorted.push(2);
  assert(!unsorted.is_sorted());
  unsorted.sort();

  var sorted = [1, 2, 3, 4, 5];
  expect_slice(unsorted.as_slice(), sorted.as_slice());
  assert(unsorted.is_sorted());
  assert_eq_i64(unsorted.binary_search(4).unwrap_or(-1), 3);
  assert(unsorted.binary_search(9).is_none());
  assert_eq_i64(unsorted.lower_bound(3), 2);
  assert_eq_i64(unsorted.upper_bound(3), 3);
  assert_eq_i64(unsorted.lower_bound(6), 5);
  let range = unsorted.equal_range(3);
  assert_eq_i64(range.0, 2);
  assert_eq_i64(range.1, 3);
  assert_eq_i64(unsorted.partition_point(less_than_four), 3);
  assert_eq_i64(unsorted.min().unwrap_or(0), 1);
  assert_eq_i64(unsorted.max().unwrap_or(0), 5);

  var stable = std::vec::new<i64>(ref mut zone, 4);
  stable.push(3);
  stable.push(1);
  stable.push(2);
  stable.push(1);
  stable.stable_sort();

  var stable_sorted = [1, 1, 2, 3];
  expect_slice(stable.as_slice(), stable_sorted.as_slice());

  var compact = std::vec::new<i64>(ref mut zone, 8);
  compact.push(1);
  compact.push(1);
  compact.push(2);
  compact.push(2);
  compact.push(2);
  compact.push(3);
  compact.push(1);
  compact.push(1);
  let compact_len = compact.dedup();
  var compact_expected = [1, 2, 3, 1];
  assert_eq_i64(compact_len, 4);
  assert_eq_i64(compact.len(), 4);
  assert_eq_i64(compact.capacity(), 8);
  expect_slice(compact.as_slice(), compact_expected.as_slice());

  var filled = std::vec::new<i64>(ref mut zone, 3);
  filled.push(1);
  filled.push(2);
  filled.push(3);
  filled.fill(9);
  var filled_expected = [9, 9, 9];
  expect_slice(filled.as_slice(), filled_expected.as_slice());

  var copy_target = std::vec::new<i64>(ref mut zone, 4);
  copy_target.push(0);
  copy_target.push(0);
  copy_target.push(0);
  copy_target.push(0);
  var copy_source = [8, 7, 6];
  let copied = copy_target.copy_from(copy_source.as_slice());
  var copy_expected = [8, 7, 6, 0];
  assert_eq_i64(copied, 3);
  expect_slice(copy_target.as_slice(), copy_expected.as_slice());

  var parted = std::vec::new<i64>(ref mut zone, 6);
  parted.push(1);
  parted.push(2);
  parted.push(3);
  parted.push(4);
  parted.push(5);
  parted.push(6);
  let parted_split = parted.partition(even);
  assert_eq_i64(parted_split, 3);
  assert(partition_ok(parted.as_slice(), parted_split));

  zone::destroy(zone);
  return 0;
}
