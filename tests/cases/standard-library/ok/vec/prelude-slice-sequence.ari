// Covers borrowed Slice[T] sequence helpers: range views, split views,
// subsequence search, lexicographic comparison, and lazy chunk/window iterators.
// Both compare() and ordering() are covered so the compatibility integer API
// and the preferred cmp::Ordering API stay in sync.

fn expect_slice(values: Slice[i64], expected: Slice[i64]) -> void {
  assert(values.equals(expected));
}

fn even(value: ref i64) -> bool {
  let raw = (ref value) as ptr i64;
  return (*raw % 2) == 0;
}

fn less_than_four(value: ref i64) -> bool {
  let raw = (ref value) as ptr i64;
  return (*raw) < 4;
}

fn partition_ok(values: Slice[i64], split: i64) -> bool {
  var index = 0;
  while index < split {
    if (values[index] % 2) != 0 {
      return false;
    }
    index = index + 1;
  }
  while index < values.len {
    if (values[index] % 2) == 0 {
      return false;
    }
    index = index + 1;
  }
  return true;
}

fn main() -> i64 {
  var values = [1, 2, 3, 2, 4, 2];
  var expected_middle = [2, 3, 2];
  var expected_left = [1, 2, 3];
  var expected_right = [2, 4, 2];
  var needle = [3, 2];
  var missing = [4, 4];
  var empty = values.as_slice()[0..0];

  let view = values.as_slice();
  expect_slice(view.slice(1, 4), expected_middle.as_slice());

  let halves = view.split_at(3);
  expect_slice(halves.left(), expected_left.as_slice());
  expect_slice(halves.right(), expected_right.as_slice());

  assert_eq_i64(view.find(needle.as_slice()), 2);
  assert_eq_i64(view.find(empty), 0);
  assert_eq_i64(view.find(missing.as_slice()), -1);
  assert(view.contains_slice(needle.as_slice()));
  assert(!view.contains_slice(missing.as_slice()));

  var same = [1, 2, 3, 2, 4, 2];
  var shorter = [1, 2, 3, 2, 4];
  var larger_at_index = [1, 2, 9];
  assert_eq_i64(view.compare(same.as_slice()), 0);
  assert_eq_i64(view.compare(shorter.as_slice()), 1);
  assert_eq_i64(view.compare(larger_at_index.as_slice()), -1);
  assert(view.ordering(same.as_slice()).is_equal());
  assert(view.ordering(shorter.as_slice()).is_greater());
  assert(view.ordering(larger_at_index.as_slice()).is_less());

  var chunks = view.chunks(2);
  var chunk_score = 0;
  for chunk in ref mut chunks {
    chunk_score = chunk_score + chunk.len + chunk[0];
  }
  assert_eq_i64(chunk_score, 14);

  var windows = view.windows(3);
  var window_score = 0;
  for window in ref mut windows {
    window_score = window_score + window[0] + window[2];
  }
  assert_eq_i64(window_score, 19);

  var split = view.split(2);
  expect_slice(split.next().unwrap(), values.as_slice()[0..1]);
  expect_slice(split.next().unwrap(), values.as_slice()[2..3]);
  expect_slice(split.next().unwrap(), values.as_slice()[4..5]);
  assert_eq_i64(split.next().unwrap().len, 0);
  let no_more = split.next();
  assert(no_more.is_none());

  var order = [5, 1, 4, 3, 2];
  let order_view = order.as_slice();
  assert(!order_view.is_sorted());
  order_view.sort();
  assert(order_view.is_sorted());
  assert_eq_i64(order_view.binary_search(4).unwrap_or(-1), 3);
  assert(order_view.binary_search(9).is_none());
  assert_eq_i64(order_view.lower_bound(3), 2);
  assert_eq_i64(order_view.upper_bound(3), 3);
  assert_eq_i64(order_view.lower_bound(6), 5);
  let range = order_view.equal_range(3);
  assert_eq_i64(range.0, 2);
  assert_eq_i64(range.1, 3);
  assert_eq_i64(order_view.partition_point(less_than_four), 3);
  assert_eq_i64(order_view.min().unwrap_or(0), 1);
  assert_eq_i64(order_view.max().unwrap_or(0), 5);

  var stable = [3, 1, 2, 1];
  let stable_view = stable.as_slice();
  stable_view.stable_sort();
  var stable_expected = [1, 1, 2, 3];
  expect_slice(stable_view, stable_expected.as_slice());

  order_view.reverse();
  order_view.rotate_left(2);
  order_view.rotate_right(1);
  var rotated = [4, 3, 2, 1, 5];
  expect_slice(order_view, rotated.as_slice());

  var target = [0, 0, 0, 0];
  var source = [8, 7, 6];
  let copied = target.as_slice().copy_from(source.as_slice());
  let target_tail = target.as_slice().slice(3, 4);
  target_tail.fill(5);
  var copied_expected = [8, 7, 6, 5];
  assert_eq_i64(copied, 3);
  expect_slice(target.as_slice(), copied_expected.as_slice());

  var compact = [1, 1, 2, 2, 2, 3, 1, 1];
  let unique_len = compact.as_slice().dedup();
  var compact_expected = [1, 2, 3, 1];
  assert_eq_i64(unique_len, 4);
  expect_slice(compact.as_slice().slice(0, unique_len), compact_expected.as_slice());

  var parted = [1, 2, 3, 4, 5, 6];
  let parted_view = parted.as_slice();
  let parted_split = parted_view.partition(even);
  assert_eq_i64(parted_split, 3);
  assert(partition_ok(parted_view, parted_split));

  return 0;
}
