fn main() -> i64 {
  var values = [3, 5, 8, 13];
  var same_values = [3, 5, 8, 13];
  var wrong_values = [5, 8];
  var too_long_values = [3, 5, 8, 13, 21];

  let view = values.as_slice();
  let same = same_values.as_slice();
  let prefix = view[0..2];
  let suffix = view[2..4];
  let wrong = wrong_values.as_slice();
  let too_long = too_long_values.as_slice();
  let empty = view[0..0];

  let a = if view.first() == 3 { 1 } else { 0 };
  let b = if view.last() == 13 { 2 } else { 0 };
  let c = if view.get(2) == 8 { 3 } else { 0 };
  let d = if view.contains(8) { 4 } else { 0 };
  let e = if view.index_of(8) == 2 { 5 } else { 0 };
  let f = if view.count(5) == 1 { 6 } else { 0 };
  let g = if view.equals(same) { 7 } else { 0 };
  let h = if view.starts_with(prefix) { 8 } else { 0 };
  let i = if view.ends_with(suffix) { 9 } else { 0 };
  let j = if view.equals(prefix) { 0 } else { 10 };
  let k = if view.starts_with(wrong) { 0 } else { 11 };
  let l = if view.ends_with(too_long) { 0 } else { 12 };
  let m = if view.starts_with(empty) { 13 } else { 0 };
  let n = if view.ends_with(empty) { 14 } else { 0 };

  return a + b + c + d + e + f + g + h + i + j + k + l + m + n;
}
