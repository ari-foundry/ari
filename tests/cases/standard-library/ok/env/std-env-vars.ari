// Covers std::env environment variable helpers. The variable is process-local
// to this test executable, so later tests do not inherit the mutation.
fn main() -> i64 {
  var zone = zone::create(256);
  var name = std::string::from_string(ref mut zone, "ARI_STD_ENV_TEST_VALUE");
  var first = std::string::from_string(ref mut zone, "first");
  var second_text = std::string::from_string(ref mut zone, "second");
  var third = std::string::from_string(ref mut zone, "third");
  var score = 0;

  env::remove_unchecked(ref name);
  if !env::has(ref name) {
    score = score + 3;
  }

  let missing = env::try_get(ref mut zone, ref name);
  if missing.is_none() {
    score = score + 5;
  }
  assert(env::var(ref mut zone, ref name).is_none());
  assert(env::var_os(ref name).is_none());
  match env::get(ref mut zone, ref name) {
    Ok(_) => {
      panic();
    }
    Err(reason) => {
      assert(reason.is_not_found());
    }
  }

  assert(env::set_var(ref name, ref first).is_ok());
  assert(env::set(ref name, ref first).is_ok());
  if env::set_unchecked(ref name, ref first) {
    score = score + 7;
  }
  if env::has(ref name) {
    score = score + 11;
  }
  assert(env::var(ref mut zone, ref name).is_some());
  assert(env::var_optional(ref mut zone, ref name).is_some());
  assert(env::var_os(ref name).is_some());
  assert(env::var_os_optional(ref name).is_some());

  match env::var(ref mut zone, ref name) {
    std::Some(var_value) => {
      assert(var_value.equals_text("first"));
    }
    std::None => {
      panic();
    }
  }

  match env::try_get(ref mut zone, ref name) {
    std::Some(value) => {
      var expected = std::string::from_string(ref mut zone, "first");
      if value.equals(expected.as_slice()) {
        score = score + 13;
      }
    }
    std::None => {}
  }

  if env::set_unchecked(ref name, ref second_text) {
    score = score + 17;
  }
  match env::get(ref mut zone, ref name) {
    Ok(result_value) => {
      var expected_result = std::string::from_string(ref mut zone, "second");
      assert(result_value.equals(expected_result.as_slice()));
    }
    Err(_) => {
      panic();
    }
  }
  match env::get_os(ref name) {
    Ok(raw_value) => {
      assert(raw_value.len() == 6);
    }
    Err(_) => {
      panic();
    }
  }

  var updated = env::get_or_default(ref mut zone, ref name);
  var second = std::string::from_string(ref mut zone, "second");
  if updated.equals(second.as_slice()) {
    score = score + 19;
  }
  var var_default = env::var_or_default(ref mut zone, ref name);
  assert(var_default.equals(second.as_slice()));
  assert(env::var_os_or_default(ref name).len() == 6);

  if env::remove(ref name).is_ok() {
    score = score + 23;
  }
  assert(env::set_var(ref name, ref third).is_ok());
  assert(env::remove_var(ref name).is_ok());
  if !env::has(ref name) {
    score = score + 29;
  }

  let removed = env::try_get(ref mut zone, ref name);
  if removed.is_none() {
    score = score + 31;
  }

  zone::destroy(zone);
  return score;
}
