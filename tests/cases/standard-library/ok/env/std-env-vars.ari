// Covers std::env environment variable helpers. The variable is process-local
// to this test executable, so later tests do not inherit the mutation.
fn main() -> i64 {
  let name = "ARI_STD_ENV_TEST_VALUE";
  var zone = zone::create(256);
  var score = 0;

  env::remove_unchecked(name);
  if !env::has(name) {
    score = score + 3;
  }

  let missing = env::try_get(name);
  if missing.is_none() {
    score = score + 5;
  }
  match env::get(name) {
    Ok(_) => {
      panic();
    }
    Err(reason) => {
      assert(reason.is_not_found());
    }
  }
  match env::var(name) {
    Ok(_) => {
      panic();
    }
    Err(var_reason) => {
      assert(var_reason.is_not_found());
    }
  }

  assert(env::set_var(name, "first").is_ok());
  assert(env::set(name, "first").is_ok());
  if env::set_unchecked(name, "first") {
    score = score + 7;
  }
  if env::has(name) {
    score = score + 11;
  }
  assert(env::var(name).is_ok());
  assert(env::var_optional(name).is_some());
  assert(env::var_os(name).is_ok());
  assert(env::var_os_optional(name).is_some());

  match env::try_get(name) {
    std::Some(value) => {
      var text = std::string::from_string(ref mut zone, value);
      var expected = std::string::from_string(ref mut zone, "first");
      if text.equals(expected.as_slice()) {
        score = score + 13;
      }
    }
    std::None => {}
  }

  if env::set_unchecked(name, "second") {
    score = score + 17;
  }
  match env::get(name) {
    Ok(result_value) => {
      var text_result = std::string::from_string(ref mut zone, result_value);
      var expected_result = std::string::from_string(ref mut zone, "second");
      assert(text_result.equals(expected_result.as_slice()));
    }
    Err(_) => {
      panic();
    }
  }
  match env::get_os(name) {
    Ok(raw_value) => {
      assert(raw_value.len() == 6);
    }
    Err(_) => {
      panic();
    }
  }

  var updated = std::string::from_string(ref mut zone, env::get_or_default(name));
  var second = std::string::from_string(ref mut zone, "second");
  if updated.equals(second.as_slice()) {
    score = score + 19;
  }
  var var_default = std::string::from_string(ref mut zone, env::var_or_default(name));
  assert(var_default.equals(second.as_slice()));
  assert(env::var_os_or_default(name).len() == 6);

  if env::remove(name).is_ok() {
    score = score + 23;
  }
  assert(env::set_var(name, "third").is_ok());
  assert(env::remove_var(name).is_ok());
  if !env::has(name) {
    score = score + 29;
  }

  let removed = env::try_get(name);
  if removed.is_none() {
    score = score + 31;
  }

  zone::destroy(zone);
  return score;
}
