// Covers source std::env argument helpers built on the runtime context hooks.
fn consume_arg(value: string) -> i64 {
  return 19;
}

fn main() -> i64 {
  var zone = zone::create(1024);
  let count = env::arg_count();
  var score = 0;

  if count == context::argc() {
    score = score + 3;
  }
  if env::has_arg(0) {
    score = score + 5;
  }
  if !env::has_arg(-1) {
    score = score + 7;
  }
  if !env::has_arg(count) {
    score = score + 11;
  }

  let first = env::try_arg(ref mut zone, 0);
  if first.is_some() {
    score = score + 13;
  }
  assert(env::arg_optional(ref mut zone, 0).is_some());
  match env::arg(ref mut zone, 0) {
    Ok(_) => {}
    Err(_) => {
      panic();
    }
  }
  assert(env::arg(ref mut zone, 0).is_ok());
  match env::arg_os(0) {
    Ok(raw_arg) => {
      assert(raw_arg.len() > 0);
    }
    Err(_) => {
      panic();
    }
  }
  assert(env::arg_os(0).is_ok());

  let missing = env::try_arg(ref mut zone, count);
  if missing.is_none() {
    score = score + 17;
  }
  assert(env::arg_optional(ref mut zone, count).is_none());
  assert(env::arg_os_optional(count).is_none());
  match env::arg(ref mut zone, count) {
    Ok(_) => {
      panic();
    }
    Err(reason) => {
      assert(reason.is_not_found());
    }
  }

  if env::has_arg(0) {
    score = score + consume_arg(env::arg_unchecked(0));
  }

  let collected = env::args(ref mut zone);
  assert(collected.len() == count);
  if count > 0 {
    assert(!collected.get(0).is_empty());
  }
  let collected_os = env::args_os(ref mut zone);
  assert(collected_os.len() == count);
  if count > 0 {
    assert(!collected_os.get(0).is_empty());
  }
  let program = env::program_name(ref mut zone);
  if program.is_ok() {
    score = score + 23;
  }
  assert(env::program_name_optional(ref mut zone).is_some());
  assert(env::program_name(ref mut zone).is_ok());
  assert(env::program_name_os().is_ok());
  assert(env::program_name_os_optional().is_some());
  assert(env::program_name_os().is_ok());

  zone::destroy(zone);
  return score;
}
