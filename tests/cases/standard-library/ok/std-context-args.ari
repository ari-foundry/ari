fn main() -> i64 {
  let count = context::argc();
  var score = 0;

  if context::has_arg(0) {
    score = score + 5;
  }
  if context::has_arg(count - 1) {
    score = score + 7;
  }
  if !context::has_arg(count) {
    score = score + 11;
  }
  if !context::has_arg(-1) {
    score = score + 13;
  }
  if has_arg(0) {
    score = score + 17;
  }
  if std::has_arg(0) {
    score = score + 19;
  }
  if arg_count() == count {
    score = score + 23;
  }
  if context::has_args() {
    score = score + 2;
  }
  if context::user_arg_count() == count - 1 {
    score = score + 3;
  }
  if !context::has_user_args() {
    score = score + 5;
  }
  if context::thread_id() == 0 {
    score = score + 7;
  }
  if context::is_main_thread() {
    score = score + 11;
  }

  return score;
}
