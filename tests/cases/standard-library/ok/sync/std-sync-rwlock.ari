// Covers the first source RwLock primitive: explicit read/write lock states.
fn main() -> i64 {
  var lock = RwLock::new();
  if lock.is_locked() {
    return 1;
  }
  if lock.reader_count() != 0 {
    return 2;
  }

  var read_guard = lock.read();
  if !lock.is_read_locked() {
    return 21;
  }
  if lock.try_write().is_some() {
    return 22;
  }
  var maybe_second = lock.try_read();
  if maybe_second.is_none() {
    return 23;
  }
  if lock.reader_count() != 2 {
    return 24;
  }
  var second = maybe_second.unwrap();
  if !second.is_active() {
    return 25;
  }
  second.unlock();
  if second.is_active() {
    return 26;
  }
  if lock.reader_count() != 1 {
    return 27;
  }
  drop read_guard;
  if lock.is_locked() {
    return 28;
  }

  var write_guard = lock.write();
  if !lock.is_write_locked() {
    return 29;
  }
  if lock.try_read().is_some() {
    return 30;
  }
  if lock.try_write().is_some() {
    return 31;
  }
  write_guard.unlock();
  if write_guard.is_active() {
    return 32;
  }
  if lock.is_locked() {
    return 33;
  }

  var drop_write_guard = lock.write();
  if !drop_write_guard.is_active() {
    return 34;
  }
  drop drop_write_guard;
  if lock.is_locked() {
    return 35;
  }

  if !lock.try_read_lock() {
    return 3;
  }
  if !lock.is_read_locked() {
    return 4;
  }
  if lock.is_write_locked() {
    return 5;
  }
  if lock.reader_count() != 1 {
    return 6;
  }

  if !lock.try_read_lock() {
    return 7;
  }
  if lock.reader_count() != 2 {
    return 8;
  }
  if lock.try_write_lock() {
    return 9;
  }

  lock.read_unlock();
  if lock.reader_count() != 1 {
    return 10;
  }
  sync::read_unlock(ref mut lock);
  if lock.is_locked() {
    return 11;
  }

  if !lock.try_write_lock() {
    return 12;
  }
  if !lock.is_write_locked() {
    return 13;
  }
  if lock.is_read_locked() {
    return 14;
  }
  if lock.try_read_lock() {
    return 15;
  }
  if sync::try_write_lock(ref mut lock) {
    return 16;
  }
  lock.write_unlock();
  if lock.is_locked() {
    return 17;
  }

  sync::read_lock(ref mut lock);
  if !sync::is_read_locked(ref lock) {
    return 18;
  }
  sync::read_unlock(ref mut lock);

  sync::write_lock(ref mut lock);
  if !sync::is_write_locked(ref lock) {
    return 19;
  }
  sync::write_unlock(ref mut lock);

  var qualified = std::sync::RwLock::new();
  if !std::sync::try_read_lock(ref mut qualified) {
    return 20;
  }
  std::sync::read_unlock(ref mut qualified);

  return 43;
}
