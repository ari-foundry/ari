// Covers the first source-only std::math slice: signed i64 helper functions.
fn main() -> i64 {
  let absolute = std::math::abs(-9) + math::abs(0) + math::abs(8);
  let sign_score = math::sign(-10) + math::sign(0) + math::sign(10);

  var parity = 0;
  if math::is_even(8) {
    parity = parity + 5;
  }
  if !math::is_even(9) {
    parity = parity + 5;
  }
  if math::is_odd(9) {
    parity = parity + 5;
  }
  if !math::is_odd(8) {
    parity = parity + 5;
  }

  let powers = math::pow(3, 4) + math::pow(5, 0);
  let gcds = math::gcd(48, 18) + math::gcd(-24, 18) + math::gcd(0, 9);

  return absolute + sign_score + parity + powers + gcds;
}
