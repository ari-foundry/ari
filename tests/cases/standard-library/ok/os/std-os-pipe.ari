// Covers OS pipe ownership. pipe() returns a pair of owned descriptor ends;
// callers can inspect borrowed views, take the ends apart, and close them
// independently.
fn main() -> i64 {
  let maybe_pipe = std::os::pipe_optional();
  var score = 0;
  if maybe_pipe.is_some() {
    score = score + 1;
  }
  match std::os::pipe() {
    Ok(result_pipe) => {
      var closable = result_pipe;
      assert(closable.close().is_ok());
    }
    Err(_) => {
      panic();
    }
  }

  var pipe = maybe_pipe.unwrap();
  if pipe.read_end().is_valid() {
    score = score + 2;
  }
  if pipe.write_end().is_valid() {
    score = score + 4;
  }
  if !pipe.read_end().equals(pipe.write_end()) {
    score = score + 8;
  }

  var reader = pipe.take_read_end();
  var writer = pipe.take_write_end();
  if pipe.read_end().is_invalid() && pipe.write_end().is_invalid() {
    score = score + 16;
  }
  if reader.set_nonblocking_bool(true) {
    score = score + 32;
  }
  assert(reader.set_nonblocking(true).is_ok());
  assert(reader.is_nonblocking().unwrap_or(false));
  if writer.set_close_on_exec_bool(true) {
    score = score + 64;
  }
  assert(writer.set_close_on_exec(true).is_ok());
  assert(writer.close_on_exec().unwrap_or(false));
  if reader.close_bool() && writer.close_bool() {
    score = score + 128;
  }
  assert(pipe.close().is_ok());

  return score;
}
