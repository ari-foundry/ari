// Covers thread runtime convenience helpers: available parallelism and sleep.
fn helper_value() -> i64 {
  thread::sleep(time::nanoseconds(0));
  thread::yield_now();
  if thread::available_parallelism().unwrap_or(0u64) < 1u64 {
    return 80;
  }
  if thread::id().as_i64() <= 0 {
    return 81;
  }
  return 11;
}

fn main() -> i64 {
  if thread::available_parallelism().unwrap_or(0u64) < 1u64 {
    return 1;
  }
  if thread::available_parallelism_or(1u64) < 1u64 {
    return 3;
  }
  if thread::available_parallelism_raw() < 1 {
    return 4;
  }

  thread::sleep(time::Duration::zero());

  var helper = thread::spawn(helper_value).unwrap_or(JoinHandle::invalid());
  if !helper.is_valid() {
    return 2;
  }

  let result = helper.join().unwrap_or(-1);
  if result != 11 {
    return result;
  }

  return 24;
}
