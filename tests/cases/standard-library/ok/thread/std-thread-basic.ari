// Covers the first std::thread slice: main-thread identity, function-pointer
// spawn, child runtime thread id, join result propagation, invalid sentinels,
// and cooperative yield.
fn child_value() -> i64 {
  if thread::is_main() {
    return 90;
  }
  let child_id = thread::id().as_i64();
  if child_id <= 0 {
    return 91;
  }
  thread::yield_now();
  return 37;
}

fn child_id_value() -> i64 {
  return thread::id().as_i64();
}

fn main() -> i64 {
  if !thread::is_main() {
    return 1;
  }
  if thread::id().as_i64() != 0 {
    return 2;
  }
  if !thread::id().is_main() {
    return 12;
  }
  let current = thread::current();
  if !current.is_valid() || !current.id().is_main() {
    return 13;
  }

  let invalid = Thread::invalid();
  if invalid.is_valid() {
    return 3;
  }
  if !thread::is_join_error(invalid.join_unchecked()) {
    return 4;
  }
  match invalid.join() {
    Ok(_) => {
      return 5;
    }
    Err(invalid_reason) => {
      match invalid_reason {
        thread::InvalidHandle => {}
        _ => {
          return 6;
        }
      }
    }
  }

  var invalid_join = JoinHandle::invalid();
  match invalid_join.join() {
    Ok(_) => {
      return 14;
    }
    Err(invalid_join_reason) => {
      match invalid_join_reason {
        thread::InvalidHandle => {}
        _ => {
          return 15;
        }
      }
    }
  }
  match invalid_join.detach() {
    Ok(_) => {
      return 16;
    }
    Err(invalid_detach_reason) => {
      match invalid_detach_reason {
        thread::InvalidHandle => {}
        _ => {
          return 17;
        }
      }
    }
  }

  match thread::join_compat(invalid) {
    Ok(_) => {
      return 18;
    }
    Err(compat_reason) => {
      if !compat_reason.is_kind(error::InvalidInput) {
        return 6;
      }
    }
  }

  var first = thread::spawn(child_value).unwrap_or(JoinHandle::invalid());
  if !first.is_valid() {
    return 7;
  }
  if first.thread_id().as_i64() <= 0 {
    return 8;
  }
  let first_result = first.join().unwrap_or(-1);
  if thread::is_join_error(first_result) {
    return 9;
  }
  if first_result != 37 {
    return first_result;
  }
  match first.join() {
    Ok(_) => {
      return 19;
    }
    Err(already_joined_reason) => {
      match already_joined_reason {
        thread::AlreadyJoined => {}
        _ => {
          return 20;
        }
      }
    }
  }

  var second = Thread::spawn(child_id_value).unwrap_or(JoinHandle::invalid());
  if !second.is_valid() {
    return 10;
  }
  let second_id = second.id().as_i64();
  let second_result = thread::join(ref mut second).unwrap_or(-1);
  if second_result != second_id {
    return 11;
  }

  var third = thread::spawn(child_value).unwrap_or(JoinHandle::invalid());
  match third.join_result() {
    Ok(third_result) => {
      if !third_result.equals(37) || third_result.value() != 37 || third_result.as_i64() != 37 || !third_result.is_failure() {
        return 21;
      }
    }
    Err(_) => {
      return 22;
    }
  }

  var fourth = thread::spawn(child_value).unwrap_or(JoinHandle::invalid());
  match thread::join_result(ref mut fourth) {
    Ok(fourth_result) => {
      if fourth_result.is_success() || !fourth_result.equals(37) {
        return 23;
      }
    }
    Err(_) => {
      return 24;
    }
  }

  var fifth_raw = thread::spawn_unchecked(child_value);
  match thread::join_thread_result(fifth_raw) {
    Ok(fifth_result) => {
      if !fifth_result.equals(37) {
        return 25;
      }
    }
    Err(_) => {
      return 26;
    }
  }

  if !ThreadResult::from_i64(0).is_success() {
    return 27;
  }

  thread::yield_now();
  return 42;
}
