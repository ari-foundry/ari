// Covers the first std::thread slice: main-thread identity, function-pointer
// spawn, child runtime thread id, join result propagation, invalid sentinels,
// and cooperative yield.
fn child_value() -> i64 {
  if thread::is_main() {
    return 90;
  }
  let child_id = thread::id();
  if child_id <= 0 {
    return 91;
  }
  thread::yield_now();
  return 37;
}

fn child_id_value() -> i64 {
  return thread::id();
}

fn main() -> i64 {
  if !thread::is_main() {
    return 1;
  }
  if thread::id() != 0 {
    return 2;
  }

  let invalid = Thread::invalid();
  if invalid.is_valid() {
    return 3;
  }
  if !thread::is_join_error(invalid.join_unchecked()) {
    return 4;
  }
  match invalid.join() {
    Ok(_) => {
      return 5;
    }
    Err(reason) => {
      if !reason.is_kind(error::InvalidInput) {
        return 6;
      }
    }
  }

  let first = thread::spawn(child_value).unwrap_or(Thread::invalid());
  if !first.is_valid() {
    return 7;
  }
  if first.id() <= 0 {
    return 8;
  }
  let first_result = first.join().unwrap_or(-1);
  if thread::is_join_error(first_result) {
    return 9;
  }
  if first_result != 37 {
    return first_result;
  }

  let second = Thread::spawn(child_id_value).unwrap_or(Thread::invalid());
  if !second.is_valid() {
    return 10;
  }
  let second_id = second.id();
  let second_result = thread::join(second).unwrap_or(-1);
  if second_result != second_id {
    return 11;
  }

  thread::yield_now();
  return 42;
}
