// Covers Thread builder runtime options and the advisory completion predicate.
fn worker() -> i64 {
  thread::yield_now();
  return 23;
}

fn main() -> i64 {
  let builder = thread::builder().name("ari-worker").stack_size(1048576);
  if !std::string::bytes(builder.configured_name()).equals("ari-worker") {
    return 1;
  }
  if builder.configured_stack_size() != 1048576 {
    return 2;
  }

  var invalid = Thread::invalid();
  if !invalid.is_finished() {
    return 3;
  }

  let spawned = builder.spawn(worker).unwrap_or(Thread::invalid());
  if !spawned.is_valid() {
    return 4;
  }
  let result = spawned.join().unwrap_or(-1);
  if result != 23 {
    return 6;
  }

  let second = builder.spawn_unchecked(worker);
  if !second.is_valid() {
    return 7;
  }
  if second.join_unchecked() != 23 {
    return 8;
  }

  return 42;
}
