// Covers the first Thread builder shape and advisory completion predicate.
fn worker() -> i64 {
  thread::yield_now();
  return 23;
}

fn main() -> i64 {
  let builder = thread::builder().name("ari-worker").stack_size(0);
  if !std::string::bytes(builder.configured_name()).equals("ari-worker") {
    return 1;
  }
  if builder.configured_stack_size() != 0 {
    return 2;
  }

  var invalid = Thread::invalid();
  if !invalid.is_finished() {
    return 3;
  }

  let spawned = builder.spawn(worker);
  if !spawned.is_valid() {
    return 4;
  }
  let result = spawned.join();
  if result != 23 {
    return 6;
  }

  return 42;
}
