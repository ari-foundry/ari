// Covers allocation-free lexical path predicate helpers:
// - has_file_name, has_extension, and has_stem mirror borrowed view helpers.
// - root and hidden files keep the same edge-case policy as file_name/extension/stem.
// - PathBytes exposes the same predicates as receiver methods.
fn main() -> i64 {
  var source = [115u8, 114u8, 99u8, 47u8, 109u8, 97u8, 105u8, 110u8, 46u8, 97u8, 114u8, 105u8];
  var main_name = [109u8, 97u8, 105u8, 110u8, 46u8, 97u8, 114u8, 105u8];
  var main_stem = [109u8, 97u8, 105u8, 110u8];
  var ari = [97u8, 114u8, 105u8];
  var txt = [116u8, 120u8, 116u8];
  var src = [115u8, 114u8, 99u8];
  var hidden = [46u8, 101u8, 110u8, 118u8];
  var root = [47u8];

  var score = 0;
  if path::has_file_name(source.as_slice(), main_name.as_slice()) {
    score = score + 1;
  }
  if !path::has_file_name(source.as_slice(), src.as_slice()) {
    score = score + 2;
  }
  if path::has_extension(source.as_slice(), ari.as_slice()) {
    score = score + 4;
  }
  if !path::has_extension(source.as_slice(), txt.as_slice()) {
    score = score + 8;
  }
  if path::has_stem(source.as_slice(), main_stem.as_slice()) {
    score = score + 16;
  }
  if path::has_file_stem(source.as_slice(), main_stem.as_slice()) {
    score = score + 2048;
  }
  if path::has_stem(hidden.as_slice(), hidden.as_slice()) {
    score = score + 32;
  }
  if path::has_file_stem(hidden.as_slice(), hidden.as_slice()) {
    score = score + 4096;
  }
  if !path::has_extension(hidden.as_slice(), ari.as_slice()) {
    score = score + 64;
  }
  if !path::has_file_name(root.as_slice(), main_name.as_slice()) {
    score = score + 128;
  }

  let typed = path::bytes(source.as_slice());
  if typed.has_file_name(main_name.as_slice()) {
    score = score + 256;
  }
  if typed.has_extension(ari.as_slice()) {
    score = score + 512;
  }
  if typed.has_stem(main_stem.as_slice()) {
    score = score + 1024;
  }
  if typed.has_file_stem(main_stem.as_slice()) {
    score = score + 8192;
  }

  assert_eq_i64(score, 16383);
  return score % 256;
}
