// Covers owned path buffers and ergonomic wrappers over borrowed PathBytes.
fn expect_slice(value: Slice[u8], expected: Slice[u8]) -> void {
  assert(value.equals(expected));
}

fn expect_buf(value: ref std::path::PathBuf, expected: Slice[u8]) -> void {
  expect_slice(value.as_bytes(), expected);
}

fn main() -> i64 {
  var zone = zone::create(512);
  var region = region::create(512);

  let view: std::path::Path = "src/main.ari";
  assert(!std::path::is_empty(view.as_slice()));
  assert(!std::path::contains_nul(view.as_slice()));
  expect_slice(std::path::as_bytes(view), "src/main.ari");

  let copied = std::path::to_string(ref mut zone, view);
  assert(copied.equals_text("src/main.ari"));

  let source_text = std::string::from(ref mut zone, "src/main.ari");
  let from_text = std::path::from_string(ref mut zone, ref source_text);
  expect_buf(ref from_text, "src/main.ari");
  assert(from_text.len() == 12);
  assert(!from_text.is_empty());
  assert(from_text.as_string().equals_text("src/main.ari"));
  assert(from_text.as_path().has_extension(std::string::bytes("ari")));
  assert(from_text.file_stem().unwrap().equals(std::string::bytes("main")));

  var raw_with_nul = [97u8, 0u8, 98u8];
  assert(std::path::contains_nul(raw_with_nul.as_slice()));
  let with_nul = std::path::from_bytes(ref mut zone, raw_with_nul.as_slice());
  assert(with_nul.contains_nul());

  let joined = std::path::join(ref mut zone, "src", "main.ari");
  expect_buf(ref joined, "src/main.ari");
  let joined_method = joined.join(ref mut zone, "cache");
  expect_buf(ref joined_method, "src/main.ari/cache");

  let normalized = std::path::bytes(std::string::bytes("/tmp/./ari//")).normalize(ref mut zone);
  expect_buf(ref normalized, "/tmp/ari");

  let renamed = joined.with_file_name(ref mut zone, std::string::bytes("lib.ari"));
  expect_buf(ref renamed, "src/lib.ari");
  let object = renamed.with_extension(ref mut zone, std::string::bytes("o"));
  expect_buf(ref object, "src/lib.o");

  var parts: [std::path::PathBytes, 3] = [
    std::path::bytes(std::string::bytes("build")),
    std::path::bytes(std::string::bytes("ari")),
    std::path::bytes(std::string::bytes("cache"))
  ];
  let many = std::path::join_many(ref mut zone, parts.as_slice());
  expect_buf(ref many, "build/ari/cache");

  match std::path::current_dir_join(ref mut zone, "Ari.toml") {
    std::Ok(path) => {
      assert(path.is_absolute());
      assert(path.as_path().ends_with("Ari.toml"));
    }
    std::Err(_) => {
      std::panic();
    }
  }

  let copied_back = object.to_string(ref mut zone);
  assert(copied_back.equals_text("src/lib.o"));

  let region_owned = std::path::from_with_region(ref mut region, "region/main.ari");
  expect_buf(ref region_owned, "region/main.ari");

  let region_from_bytes = std::path::from_bytes_with_region(ref mut region, "region/lib.ari");
  expect_buf(ref region_from_bytes, "region/lib.ari");

  let region_from_string = std::path::from_string_with_region(ref mut region, ref source_text);
  expect_buf(ref region_from_string, "src/main.ari");

  let region_text = std::path::to_string_with_region(ref mut region, region_owned.as_path());
  assert(region_text.equals_text("region/main.ari"));

  let region_joined = std::path::join_with_region(ref mut region, "region", "cache");
  expect_buf(ref region_joined, "region/cache");

  var region_parts: [std::path::PathBytes, 3] = [
    "region",
    "build",
    "out"
  ];
  let region_many = std::path::join_many_with_region(ref mut region, region_parts.as_slice());
  expect_buf(ref region_many, "region/build/out");

  match std::path::current_dir_join_with_region(ref mut region, "Ari.toml") {
    std::Ok(region_cwd_path) => {
      assert(region_cwd_path.is_absolute());
      assert(region_cwd_path.as_path().ends_with("Ari.toml"));
    }
    std::Err(_) => {
      std::panic();
    }
  }

  let region_normalized = std::path::normalize_with_region(ref mut region, "/tmp/./ari//");
  expect_buf(ref region_normalized, "/tmp/ari");

  let region_renamed = region_owned.with_file_name_with_region(ref mut region, "lib.ari");
  expect_buf(ref region_renamed, "region/lib.ari");

  let region_object = region_renamed.with_extension_with_region(ref mut region, "o");
  expect_buf(ref region_object, "region/lib.o");

  let view_joined = view.join_with_region(ref mut region, "cache");
  expect_buf(ref view_joined, "src/main.ari/cache");

  let view_normalized = std::path::bytes("/tmp/./zone//").normalize_with_region(ref mut region);
  expect_buf(ref view_normalized, "/tmp/zone");

  let view_text = view.to_string_with_region(ref mut region);
  assert(view_text.equals_text("src/main.ari"));

  let view_renamed = view.with_file_name_with_region(ref mut region, "lib.ari");
  expect_buf(ref view_renamed, "src/lib.ari");

  let view_object = view.with_extension_with_region(ref mut region, "o");
  expect_buf(ref view_object, "src/main.o");

  let region_method_owned = region.path("logs/app.log");
  expect_buf(ref region_method_owned, "logs/app.log");

  let region_method_from_string = region.path_from_string(ref source_text);
  expect_buf(ref region_method_from_string, "src/main.ari");

  let region_method_joined = region.path_join("logs", "today");
  expect_buf(ref region_method_joined, "logs/today");

  let region_method_many = region.path_join_many(region_parts.as_slice());
  expect_buf(ref region_method_many, "region/build/out");

  let region_method_normalized = region.path_normalize("logs/./today//");
  expect_buf(ref region_method_normalized, "logs/today");

  match region.current_dir_join("Ari.toml") {
    std::Ok(region_method_cwd_path) => {
      assert(region_method_cwd_path.is_absolute());
      assert(region_method_cwd_path.as_path().ends_with("Ari.toml"));
    }
    std::Err(_) => {
      std::panic();
    }
  }

  let region_copy_back = region_object.to_string_with_region(ref mut region);
  assert(region_copy_back.equals_text("region/lib.o"));

  region::destroy(region);
  zone::destroy(zone);
  return 0;
}
