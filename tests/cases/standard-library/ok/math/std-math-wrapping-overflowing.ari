// Covers the wrapping and overflowing add/sub/mul policy slice in std::math.
fn main() -> i64 {
  let min = math::min_value();
  let max = math::max_value();

  var score = 0;
  if math::wrapping_add(40, 2) == 42 {
    score = score + 1;
  }
  if math::wrapping_add(max, 1) == min {
    score = score + 1;
  }
  if math::wrapping_add(min, -1) == max {
    score = score + 1;
  }
  if math::wrapping_sub(40, -2) == 42 {
    score = score + 1;
  }
  if math::wrapping_sub(min, 1) == max {
    score = score + 1;
  }
  if math::wrapping_sub(max, -1) == min {
    score = score + 1;
  }
  if math::wrapping_sub(0, min) == min {
    score = score + 1;
  }
  if math::wrapping_mul(6, 7) == 42 {
    score = score + 1;
  }
  if math::wrapping_mul(max, 2) == -2 {
    score = score + 1;
  }
  if math::wrapping_mul(min, 2) == 0 {
    score = score + 1;
  }
  if math::wrapping_mul(min, -1) == min {
    score = score + 1;
  }
  if math::wrapping_mul(-3, 14) == -42 {
    score = score + 1;
  }

  let normal = math::overflowing_add(20, 22);
  if normal.0 == 42 && !normal.1 {
    score = score + 1;
  }

  let positive = math::overflowing_add(max, 1);
  if positive.0 == min && positive.1 {
    score = score + 1;
  }

  let (negative_value, negative_overflowed) = math::overflowing_add(min, -1);
  if negative_value == max && negative_overflowed {
    score = score + 1;
  }

  let normal_sub = math::overflowing_sub(20, -22);
  if normal_sub.0 == 42 && !normal_sub.1 {
    score = score + 1;
  }

  let negative_sub = math::overflowing_sub(min, 1);
  if negative_sub.0 == max && negative_sub.1 {
    score = score + 1;
  }

  let (positive_sub_value, positive_sub_overflowed) = math::overflowing_sub(max, -1);
  if positive_sub_value == min && positive_sub_overflowed {
    score = score + 1;
  }

  let min_sub = math::overflowing_sub(0, min);
  if min_sub.0 == min && min_sub.1 {
    score = score + 1;
  }

  let normal_mul = math::overflowing_mul(6, 7);
  if normal_mul.0 == 42 && !normal_mul.1 {
    score = score + 1;
  }

  let positive_mul = math::overflowing_mul(max, 2);
  if positive_mul.0 == -2 && positive_mul.1 {
    score = score + 1;
  }

  let negative_mul = math::overflowing_mul(min, 2);
  if negative_mul.0 == 0 && negative_mul.1 {
    score = score + 1;
  }

  let min_neg_mul = math::overflowing_mul(min, -1);
  if min_neg_mul.0 == min && min_neg_mul.1 {
    score = score + 1;
  }

  let (small_mul_value, small_mul_overflowed) = math::overflowing_mul(-3, 14);
  if small_mul_value == -42 && !small_mul_overflowed {
    score = score + 1;
  }

  assert_eq_i64(score, 24);
  return score;
}
