// Covers the wrapping and overflowing add policy slice in std::math.
fn main() -> i64 {
  let min = -9223372036854775807 - 1;
  let max = 9223372036854775807;

  var score = 0;
  if math::wrapping_add(40, 2) == 42 {
    score = score + 1;
  }
  if math::wrapping_add(max, 1) == min {
    score = score + 1;
  }
  if math::wrapping_add(min, -1) == max {
    score = score + 1;
  }

  let normal = math::overflowing_add(20, 22);
  if normal.value() == 42 && !normal.overflowed() {
    score = score + 1;
  }

  let positive = math::overflowing_add(max, 1);
  if positive.value() == min && positive.overflowed() {
    score = score + 1;
  }

  let negative = math::overflowing_add(min, -1);
  if negative.value() == max && negative.overflowed() {
    score = score + 1;
  }

  assert_eq_i64(score, 6);
  return score;
}
