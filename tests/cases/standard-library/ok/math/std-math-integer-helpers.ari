// Covers the first source-only std::math slice: signed i64 helper functions.
fn main() -> i64 {
  var bounds = 0;
  if math::min_value() == (-9223372036854775807 - 1) {
    bounds = bounds + 31;
  }
  if math::max_value() == 9223372036854775807 {
    bounds = bounds + 37;
  }

  let absolute = std::math::abs(-9) + math::abs(0) + math::abs(8);
  let sign_score = math::sign(-10) + math::sign(0) + math::sign(10);

  var sign_predicates = 0;
  if math::is_positive(9) {
    sign_predicates = sign_predicates + 3;
  }
  if !math::is_positive(0) {
    sign_predicates = sign_predicates + 5;
  }
  if !math::is_positive(-9) {
    sign_predicates = sign_predicates + 7;
  }
  if math::is_negative(-9) {
    sign_predicates = sign_predicates + 11;
  }
  if !math::is_negative(0) {
    sign_predicates = sign_predicates + 13;
  }
  if !math::is_negative(9) {
    sign_predicates = sign_predicates + 17;
  }
  if std::math::is_zero(0) {
    sign_predicates = sign_predicates + 19;
  }
  if !std::math::is_zero(4) {
    sign_predicates = sign_predicates + 23;
  }
  if !std::math::is_zero(-4) {
    sign_predicates = sign_predicates + 29;
  }

  var parity = 0;
  if math::is_even(8) {
    parity = parity + 5;
  }
  if !math::is_even(9) {
    parity = parity + 5;
  }
  if math::is_odd(9) {
    parity = parity + 5;
  }
  if !math::is_odd(8) {
    parity = parity + 5;
  }

  let powers = math::pow(3, 4) + math::pow(5, 0);
  let gcds = math::gcd(48, 18) + math::gcd(-24, 18) + math::gcd(0, 9);
  let lcms = math::lcm(12, 18) + math::lcm(-6, 8) + math::lcm(0, 10);

  let total =
    bounds + absolute + sign_score + sign_predicates + parity + powers + gcds + lcms;
  assert_eq_i64(total, 395);
  return total % 256;
}
