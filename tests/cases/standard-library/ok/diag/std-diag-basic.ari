// Covers std::diag severity, lightweight diagnostics, notes, and methods.
fn main() -> i64 {
  let diagnostic = diag::error("E0001", "bad token");
  var score = 0;

  if diag::severity_rank(diag::Error) == 3 {
    score = score + 1;
  }
  if diag::is_error(diagnostic.severity()) {
    score = score + 2;
  }
  if diag::is_warning(diag::Warning) {
    score = score + 3;
  }

  let warning_name = diag::severity_name(diag::Warning) as ptr u8;
  if ptr_load(warning_name) == 'w' {
    score = score + 4;
  }

  if diagnostic.code().len() == 5 && diagnostic.message().get(0) == 'b' {
    score = score + 5;
  }
  if !diagnostic.has_note() {
    score = score + 6;
  }

  let noted = diagnostic.with_note("try another token");
  if noted.has_note() {
    score = score + 7;
  }
  if noted.note_message().len() == 17 {
    score = score + 8;
  }

  let warning = diag::warning("W0001", "be careful");
  if warning.severity() == diag::Warning && warning.message().len() == 10 {
    score = score + 9;
  }

  let note = diag::note("N0001", "plain note");
  if note.severity() == diag::Note && !note.has_note() {
    score = score + 10;
  }

  let help = diag::help("H0001", "plain help");
  if help.severity() == diag::Help && help.code().get(0) == 'H' {
    score = score + 11;
  }

  let generic = diag::new(diag::Error, "E0002", "generic error");
  if generic.severity() == diag::Error && generic.message().len() == 13 {
    score = score + 12;
  }

  return score;
}
