// Covers extended std::ascii byte classification helpers.
fn main() -> i64 {
  var score = 0;

  if std::ascii::is_control('\x00') {
    score = score + 1;
  }
  if ascii::is_control('\x1f') {
    score = score + 2;
  }
  if ascii::is_control('\x7f') {
    score = score + 3;
  }
  if !ascii::is_control(' ') {
    score = score + 4;
  }

  if ascii::is_printable(' ') {
    score = score + 5;
  }
  if ascii::is_printable('~') {
    score = score + 6;
  }
  if !ascii::is_printable('\x7f') {
    score = score + 7;
  }
  if !ascii::is_printable('\n') {
    score = score + 8;
  }

  if ascii::is_graphic('!') {
    score = score + 9;
  }
  if ascii::is_graphic('~') {
    score = score + 10;
  }
  if !ascii::is_graphic(' ') {
    score = score + 11;
  }

  if ascii::is_punctuation('!') {
    score = score + 12;
  }
  if ascii::is_punctuation('@') {
    score = score + 13;
  }
  if !ascii::is_punctuation('A') {
    score = score + 14;
  }
  if !ascii::is_punctuation('0') {
    score = score + 15;
  }

  if ascii::is_blank(' ') {
    score = score + 16;
  }
  if ascii::is_blank('\t') {
    score = score + 17;
  }
  if !ascii::is_blank('\n') {
    score = score + 18;
  }

  assert_eq_i64(score, 171);
  return score;
}
