// Covers std::ascii helpers that operate on borrowed Slice[u8] views.
fn main() -> i64 {
  var spaced: Vec[u8] = [32u8, 9u8, 49u8, 50u8, 51u8, 32u8];
  var blank: Vec[u8] = [32u8, 10u8];
  var empty: Vec[u8] = [];
  var hex_values: Vec[u8] = [49u8, 65u8, 102u8];
  var invalid_hex: Vec[u8] = [71u8];

  let all = spaced.as_slice();
  let trimmed_start = ascii::trim_start(all);
  let trimmed_end = ascii::trim_end(all);
  let trimmed = ascii::trim(all);
  let blank_trimmed = ascii::trim(blank.as_slice());

  let skip = std::ascii::skip_whitespace(all);
  let parsed_trimmed = ascii::parse_decimal(trimmed).unwrap_or(0);
  let invalid_decimal = ascii::parse_decimal(all).unwrap_or(77);
  let empty_decimal = ascii::parse_decimal(empty.as_slice()).unwrap_or(9);
  let parsed_hex = ascii::parse_hex(hex_values.as_slice()).unwrap_or(0);
  let invalid_hex_value = ascii::parse_hex(invalid_hex.as_slice()).unwrap_or(33);

  assert_eq_i64(skip, 2);
  assert_eq_i64(trimmed_start.len(), 4);
  assert_eq_i64(trimmed_start[0] as i64, 49);
  assert_eq_i64(trimmed_end.len(), 5);
  assert_eq_i64(trimmed.len(), 3);
  assert_eq_i64(trimmed[2] as i64, 51);
  assert_eq_i64(blank_trimmed.len(), 0);
  assert_eq_i64(parsed_trimmed, 123);
  assert_eq_i64(invalid_decimal, 77);
  assert_eq_i64(empty_decimal, 9);
  assert_eq_i64(parsed_hex, 431);
  assert_eq_i64(invalid_hex_value, 33);

  let total =
    skip +
    trimmed_start.len() +
    (trimmed_start[0] as i64) +
    trimmed_end.len() +
    trimmed.len() +
    (trimmed[2] as i64) +
    blank_trimmed.len() +
    parsed_trimmed +
    invalid_decimal +
    empty_decimal +
    parsed_hex +
    invalid_hex_value;

  assert_eq_i64(total, 787);
  return total % 256;
}
