fn main() -> i64 {
  var zone = zone::create(1024);
  let count = context::argc();
  var score = 0;

  if context::has_arg(0) {
    score = score + 5;
  }
  if context::has_arg(count - 1) {
    score = score + 7;
  }
  if !context::has_arg(count) {
    score = score + 11;
  }
  if !context::has_arg(-1) {
    score = score + 13;
  }
  if has_arg(0) {
    score = score + 17;
  }
  if std::has_arg(0) {
    score = score + 19;
  }
  if arg_count() == count {
    score = score + 23;
  }
  if context::has_args() {
    score = score + 2;
  }
  if context::user_arg_count() == count - 1 {
    score = score + 3;
  }
  if !context::has_user_args() {
    score = score + 5;
  }
  if context::thread_id() == 0 {
    score = score + 7;
  }
  if context::is_main_thread() {
    score = score + 11;
  }

  let startup_cwd = context::cwd(ref mut zone);
  let maybe_cwd = context::try_cwd(ref mut zone);
  let maybe_cwd_os = context::try_cwd_os();
  let cwd_os = context::cwd_os();
  let cwd_path = context::cwd_path();
  assert(context::has_cwd());
  assert(maybe_cwd.is_some());
  assert(maybe_cwd_os.is_some());
  assert(!cwd_os.is_empty());
  assert(cwd_path.is_absolute());
  match env::current_dir(ref mut zone) {
    Ok(current) => {
      assert(startup_cwd.equals(current.as_slice()));
    }
    Err(_) => {
      panic();
    }
  }

  let startup_exe = context::executable_path(ref mut zone);
  let maybe_exe = context::try_executable_path(ref mut zone);
  let maybe_exe_os = context::try_executable_path_os();
  let exe_os = context::executable_path_os();
  assert(context::has_executable_path());
  assert(maybe_exe.is_some());
  assert(maybe_exe_os.is_some());
  assert(!exe_os.is_empty());
  match env::executable_path(ref mut zone) {
    Ok(current_exe) => {
      assert(startup_exe.equals(current_exe.as_slice()));
    }
    Err(_) => {
      panic();
    }
  }

  zone::destroy(zone);
  return score;
}
