// Covers std::parse whole-value parsers over borrowed byte slices.
fn main() -> i64 {
  let min = -9223372036854775807 - 1;
  let max = 9223372036854775807;
  var signed = [32u8, 45u8, 49u8, 50u8, 51u8, 32u8];
  var plus = [43u8, 52u8, 50u8];
  var invalid_integer = [49u8, 50u8, 120u8];
  assert(parse::integer(signed.as_slice()).unwrap_or(0) == -123);
  assert(parse::integer(plus.as_slice()).unwrap_or(0) == 42);
  assert(parse::is_integer(" 77 "));
  assert(!parse::is_integer("12x"));
  assert(parse::integer_or("88", 0) == 88);
  assert(parse::integer_or("nope", 5) == 5);
  assert(parse::integer("9223372036854775807").unwrap_or(0) == max);
  assert(parse::integer("-9223372036854775808").unwrap_or(0) == min);
  assert(parse::integer("9223372036854775808").is_err());
  assert(parse::integer("-9223372036854775809").is_err());
  assert(parse::integer_optional("-9223372036854775809").is_none());
  assert(parse::unsigned("18446744073709551615").unwrap_or(0u64) == 18446744073709551615u64);
  assert(parse::unsigned("+42").unwrap_or(0u64) == 42u64);
  assert(parse::unsigned("18446744073709551616").is_err());
  assert(parse::unsigned("-1").is_err());
  assert(parse::unsigned_optional("-1").is_none());
  assert(parse::unsigned_radix("ff", 16).unwrap_or(0u64) == 255u64);
  assert(parse::unsigned_radix_optional("ff", 16).unwrap_or(0u64) == 255u64);
  assert(parse::unsigned_radix_or("zz", 36, 0u64) == 1295u64);
  assert(parse::unsigned_radix_or("bad", 10, 6u64) == 6u64);
  assert(parse::is_unsigned_radix("10", 2));
  assert(!parse::is_unsigned_radix("2", 2));
  assert(parse::integer_radix("7f", 16).unwrap_or(0) == 127);
  assert(parse::integer_radix("-101", 2).unwrap_or(0) == -5);
  assert(parse::integer_radix("z", 36).unwrap_or(0) == 35);
  assert(parse::integer_radix_or("zz", 36, 0) == 1295);
  assert(parse::integer_radix_or("bad", 10, 6) == 6);
  assert(parse::integer_radix("10", 1).is_err());
  assert(parse::integer_radix("2", 2).is_err());
  assert(parse::integer_radix_optional("10", 1).is_none());
  assert(parse::integer("1_000").is_err());
  assert(parse::integer_with_underscores("1_000").unwrap_or(0) == 1000);
  assert(parse::integer_with_underscores_optional("-9_223").unwrap_or(0) == -9223);
  assert(parse::integer_with_underscores_or("bad_value", 11) == 11);
  assert(parse::is_integer_with_underscores("+1_2_3"));
  assert(!parse::is_integer_with_underscores("_123"));
  assert(!parse::is_integer_with_underscores("123_"));
  assert(!parse::is_integer_with_underscores("12__3"));
  assert(parse::integer_radix_with_underscores("7f_ff", 16).unwrap_or(0) == 32767);
  assert(parse::integer_radix_with_underscores_optional("-10_10", 2).unwrap_or(0) == -10);
  assert(parse::integer_radix_with_underscores_or("bad_value", 16, 33) == 33);
  assert(parse::is_integer_radix_with_underscores("z_z", 36));
  assert(!parse::is_integer_radix_with_underscores("1_", 10));
  assert(parse::unsigned_with_underscores("18_446_744_073_709_551_615").unwrap_or(0u64) == 18446744073709551615u64);
  assert(parse::unsigned_with_underscores_optional("+1_024").unwrap_or(0u64) == 1024u64);
  assert(parse::unsigned_with_underscores_or("bad_value", 55u64) == 55u64);
  assert(parse::unsigned_with_underscores("18_446_744_073_709_551_616").is_err());
  assert(parse::is_unsigned_with_underscores("1_2_3"));
  assert(!parse::is_unsigned_with_underscores("12__3"));
  assert(parse::unsigned_radix_with_underscores("ff_ff", 16).unwrap_or(0u64) == 65535u64);
  assert(parse::unsigned_radix_with_underscores_optional("10_10", 2).unwrap_or(0u64) == 10u64);
  assert(parse::unsigned_radix_with_underscores_or("bad_value", 16, 77u64) == 77u64);
  assert(parse::is_unsigned_radix_with_underscores("7_7", 8));
  assert(!parse::is_unsigned_radix_with_underscores("_77", 8));
  assert(parse::integer("123").unwrap_or(0) == 123);
  match parse::integer("12x") {
    Ok(_) => { panic(); }
    Err(integer_reason) => {
      assert(integer_reason.is_kind(error::InvalidData));
    }
  }
  match parse::integer_error("12x") {
    std::Some(integer_detail) => {
      assert(integer_detail.offset() == 2);
      assert(integer_detail.is_invalid_digit());
      assert(std::string::bytes(integer_detail.name_text()).equals("invalid digit"));
      assert(std::string::bytes(integer_detail.message_text()).equals("input contains a byte that is not valid here"));
      match integer_detail.kind() {
        parse::InvalidDigit => {}
        _ => { panic(); }
      }
    }
    std::None => { panic(); }
  }
  match parse::integer_error("   ") {
    std::Some(empty_detail) => {
      assert(empty_detail.offset() == 0);
      assert(empty_detail.is_empty_input());
      assert(std::string::bytes(empty_detail.name_text()).equals("empty input"));
    }
    std::None => { panic(); }
  }
  match parse::integer_radix("10", 1) {
    Ok(_) => { panic(); }
    Err(radix_reason) => {
      assert(radix_reason.is_kind(error::InvalidInput));
    }
  }
  match parse::integer_radix_error("10", 1) {
    std::Some(radix_detail) => {
      assert(radix_detail.offset() == 0);
      assert(radix_detail.is_invalid_radix());
      assert(std::string::bytes(radix_detail.name_text()).equals("invalid radix"));
      match radix_detail.kind() {
        parse::InvalidRadix => {}
        _ => { panic(); }
      }
    }
    std::None => { panic(); }
  }
  assert(parse::unsigned("+42").unwrap_or(0u64) == 42u64);
  match parse::unsigned_radix("2", 2) {
    Ok(_) => { panic(); }
    Err(unsigned_reason) => {
      assert(unsigned_reason.is_kind(error::InvalidData));
    }
  }
  match parse::unsigned_error("-1") {
    std::Some(sign_detail) => {
      assert(sign_detail.offset() == 0);
      assert(sign_detail.is_invalid_sign());
      assert(std::string::bytes(sign_detail.name_text()).equals("invalid sign"));
      match sign_detail.kind() {
        parse::InvalidSign => {}
        _ => { panic(); }
      }
    }
    std::None => { panic(); }
  }
  match parse::integer_error("9223372036854775808") {
    std::Some(overflow_detail) => {
      assert(overflow_detail.offset() == 18);
      assert(overflow_detail.is_overflow());
      assert(std::string::bytes(overflow_detail.name_text()).equals("overflow"));
      assert(std::string::bytes(overflow_detail.message_text()).equals("parsed value is above the accepted range"));
      match overflow_detail.kind() {
        parse::Overflow => {}
        _ => { panic(); }
      }
    }
    std::None => { panic(); }
  }
  match parse::integer_with_underscores_error("12__3") {
    std::Some(separator_detail) => {
      assert(separator_detail.offset() == 2);
      assert(separator_detail.is_invalid_separator());
      assert(std::string::bytes(separator_detail.name_text()).equals("invalid separator"));
      match separator_detail.kind() {
        parse::InvalidSeparator => {}
        _ => { panic(); }
      }
    }
    std::None => { panic(); }
  }
  match parse::unsigned_with_underscores_error("+1_024") {
    std::Some(_) => { panic(); }
    std::None => {}
  }
  assert(parse::hex_integer("ff").unwrap_or(0) == 255);
  assert(parse::hex_integer("-F").unwrap_or(0) == -15);
  assert(parse::hex_integer_or("gg", 7) == 7);
  assert(parse::hex_integer_optional("ff").unwrap_or(0) == 255);
  assert(parse::is_hex_integer("Ab"));
  assert(parse::hex_integer("7fffffffffffffff").unwrap_or(0) == max);
  assert(parse::hex_integer("-8000000000000000").unwrap_or(0) == min);
  assert(parse::hex_integer("8000000000000000").is_err());
  assert(parse::hex_integer_optional("8000000000000000").is_none());
  assert(parse::hex_integer_with_underscores("7fff_ffff_ffff_ffff").unwrap_or(0) == max);
  assert(parse::hex_integer_with_underscores_optional("-8_0000").unwrap_or(0) == -524288);
  assert(parse::hex_integer_with_underscores_or("bad_value", 9) == 9);
  assert(parse::is_hex_integer_with_underscores("ab_cd"));
  assert(parse::binary_integer("1010").unwrap_or(0) == 10);
  assert(parse::binary_integer_or("102", 4) == 4);
  assert(parse::binary_integer_optional("1010").unwrap_or(0) == 10);
  assert(!parse::is_binary_integer("102"));
  assert(parse::binary_integer_with_underscores("1010_0101").unwrap_or(0) == 165);
  assert(parse::binary_integer_with_underscores_optional("-101_0").unwrap_or(0) == -10);
  assert(parse::binary_integer_with_underscores_or("10_2", 8) == 8);
  assert(parse::is_binary_integer_with_underscores("1_0_1"));
  assert(parse::octal_integer("755").unwrap_or(0) == 493);
  assert(parse::octal_integer("-10").unwrap_or(0) == -8);
  assert(parse::octal_integer_or("778", 12) == 12);
  assert(parse::octal_integer_optional("755").unwrap_or(0) == 493);
  assert(parse::is_octal_integer("17"));
  assert(!parse::is_octal_integer("18"));
  assert(parse::octal_integer_with_underscores("7_55").unwrap_or(0) == 493);
  assert(parse::octal_integer_with_underscores_optional("-1_0").unwrap_or(0) == -8);
  assert(parse::octal_integer_with_underscores_or("7_8", 12) == 12);
  assert(parse::is_octal_integer_with_underscores("1_7"));
  match parse::integer(invalid_integer.as_slice()) {
    Ok(_) => { panic(); }
    Err(reason) => { assert(reason.is_kind(error::InvalidData)); }
  }

  var true_text = [116u8, 114u8, 117u8, 101u8];
  var false_text = [32u8, 102u8, 97u8, 108u8, 115u8, 101u8, 32u8];
  var invalid_bool = [84u8, 114u8, 117u8, 101u8];
  assert(parse::boolean(true_text.as_slice()).unwrap_or(false));
  assert(!parse::boolean(false_text.as_slice()).unwrap_or(true));
  assert(parse::is_boolean("true"));
  assert(!parse::is_boolean("True"));
  assert(parse::boolean_or("false", true) == false);
  assert(parse::boolean_or("missing", true));
  assert(parse::boolean("true").unwrap_or(false));
  match parse::boolean("True") {
    Ok(_) => { panic(); }
    Err(boolean_reason) => {
      assert(boolean_reason.is_kind(error::InvalidData));
    }
  }
  match parse::boolean_optional(invalid_bool.as_slice()) {
    std::Some(_) => { panic(); }
    std::None => {}
  }

  var float_text = [32u8, 45u8, 49u8, 50u8, 46u8, 53u8, 101u8, 50u8, 32u8];
  var invalid_float = [49u8, 46u8, 50u8, 120u8];
  assert(parse::is_float(float_text.as_slice()));
  assert((parse::float(float_text.as_slice()).unwrap_or(0.0f64) as i64) == -1250);
  assert((parse::float_optional(float_text.as_slice()).unwrap_or(0.0f64) as i64) == -1250);
  assert((parse::float_unchecked(float_text.as_slice()) as i64) == -1250);
  match parse::float_error(float_text.as_slice()) {
    std::Some(_) => { panic(); }
    std::None => {}
  }
  assert(!parse::is_float(invalid_float.as_slice()));
  assert(!parse::is_float("1_000.0"));
  assert(parse::is_float_with_underscores("1_000.5_0e1_2"));
  assert(!parse::is_float_with_underscores("1_.0"));
  assert(!parse::is_float_with_underscores("1._0"));
  assert(!parse::is_float_with_underscores("1e_2"));
  assert((parse::float_with_underscores("1_000.5_0e1").unwrap_or(0.0f64) as i64) == 10005);
  assert(((parse::float_with_underscores_optional(".2_5").unwrap_or(0.0f64) * 100.0f64) as i64) == 25);
  assert((parse::float_with_underscores_or("1__0", 4.0f64) as i64) == 4);
  match parse::float_with_underscores_error("1_000.5_0e1_2") {
    std::Some(_) => { panic(); }
    std::None => {}
  }
  match parse::float_error(invalid_float.as_slice()) {
    std::Some(float_detail) => {
      assert(float_detail.offset() == 3);
      assert(float_detail.is_invalid_digit());
      assert(std::string::bytes(float_detail.name_text()).equals("invalid digit"));
      match float_detail.kind() {
        parse::InvalidDigit => {}
        _ => { panic(); }
      }
    }
    std::None => { panic(); }
  }
  match parse::float_error(".") {
    std::Some(dot_detail) => {
      assert(dot_detail.offset() == 1);
      assert(dot_detail.is_expected_digit());
      assert(std::string::bytes(dot_detail.name_text()).equals("expected digit"));
      match dot_detail.kind() {
        parse::ExpectedDigit => {}
        _ => { panic(); }
      }
    }
    std::None => { panic(); }
  }
  match parse::float_error("1_000.0") {
    std::Some(strict_separator_detail) => {
      assert(strict_separator_detail.offset() == 1);
      assert(strict_separator_detail.is_invalid_separator());
      match strict_separator_detail.kind() {
        parse::InvalidSeparator => {}
        _ => { panic(); }
      }
    }
    std::None => { panic(); }
  }
  match parse::float_with_underscores_error("1e_2") {
    std::Some(exponent_separator_detail) => {
      assert(exponent_separator_detail.offset() == 2);
      match exponent_separator_detail.kind() {
        parse::InvalidSeparator => {}
        _ => { panic(); }
      }
    }
    std::None => { panic(); }
  }
  match parse::float_error("1e+") {
    std::Some(exponent_digit_detail) => {
      assert(exponent_digit_detail.offset() == 3);
      match exponent_digit_detail.kind() {
        parse::ExpectedDigit => {}
        _ => { panic(); }
      }
    }
    std::None => { panic(); }
  }
  if parse::is_float("1e309") {
    return 31;
  }
  if !parse::is_float("1.7976931348623157e308") {
    return 47;
  }
  if parse::is_float("1.7976931348623158e308") {
    return 48;
  }
  match parse::float_error("1.7976931348623158e308") {
    std::Some(max_boundary_detail) => {
      if max_boundary_detail.offset() != 17 {
        return 49;
      }
      match max_boundary_detail.kind() {
        parse::Overflow => {}
        _ => { return 50; }
      }
    }
    std::None => { return 51; }
  }
  if parse::is_float("2e308") {
    return 52;
  }
  match parse::float_error("2e308") {
    std::Some(max_digit_detail) => {
      if max_digit_detail.offset() != 0 {
        return 53;
      }
      match max_digit_detail.kind() {
        parse::Overflow => {}
        _ => { return 54; }
      }
    }
    std::None => { return 55; }
  }
  match parse::float_error("1e309") {
    std::Some(float_overflow_detail) => {
      if float_overflow_detail.offset() != 4 {
        return 32;
      }
      if !float_overflow_detail.is_overflow() {
        return 33;
      }
      if !std::string::bytes(float_overflow_detail.name_text()).equals("overflow") {
        return 33;
      }
      match float_overflow_detail.kind() {
        parse::Overflow => {}
        _ => { return 33; }
      }
    }
    std::None => { return 34; }
  }
  match parse::float("1e309") {
    Ok(_) => { return 35; }
    Err(float_overflow_reason) => {
      if !float_overflow_reason.is_kind(error::InvalidData) {
        return 36;
      }
    }
  }
  if !parse::float_optional("1e309").is_none() {
    return 37;
  }
  if (parse::float_or("1e309", 7.0f64) as i64) != 7 {
    return 38;
  }
  if parse::is_float("1e-325") {
    return 39;
  }
  if !parse::is_float("5e-324") {
    return 56;
  }
  if parse::is_float("4e-324") {
    return 57;
  }
  match parse::float_error("4e-324") {
    std::Some(min_boundary_detail) => {
      if min_boundary_detail.offset() != 0 {
        return 58;
      }
      match min_boundary_detail.kind() {
        parse::Underflow => {}
        _ => { return 59; }
      }
    }
    std::None => { return 60; }
  }
  match parse::float_error("1e-325") {
    std::Some(float_underflow_detail) => {
      if float_underflow_detail.offset() != 5 {
        return 40;
      }
      if !float_underflow_detail.is_underflow() {
        return 41;
      }
      if !std::string::bytes(float_underflow_detail.name_text()).equals("underflow") {
        return 41;
      }
      match float_underflow_detail.kind() {
        parse::Underflow => {}
        _ => { return 41; }
      }
    }
    std::None => { return 42; }
  }
  if parse::is_float_with_underscores("1e3_0_9") {
    return 43;
  }
  match parse::float_with_underscores_error("1e3_0_9") {
    std::Some(float_separator_overflow_detail) => {
      if float_separator_overflow_detail.offset() != 6 {
        return 44;
      }
      match float_separator_overflow_detail.kind() {
        parse::Overflow => {}
        _ => { return 45; }
      }
    }
    std::None => { return 46; }
  }
  match parse::float(invalid_float.as_slice()) {
    Ok(_) => { panic(); }
    Err(float_reason) => {
      assert(float_reason.is_kind(error::InvalidData));
    }
  }
  assert(parse::float_optional(invalid_float.as_slice()).is_none());
  assert((parse::float_or(invalid_float.as_slice(), 7.0f64) as i64) == 7);
  assert(parse::parse[i64](" -44 ") == -44);
  assert(parse::parse[u64]("44") == 44u64);
  assert(parse::parse[bool]("true"));
  assert((parse::parse[f64]("1.5e1") as i64) == 15);
  assert(parse::parse_or[i64]("bad", 9) == 9);
  assert(parse::parse_or[u64]("bad", 9u64) == 9u64);
  assert(parse::parse_or[bool]("bad", true));
  assert((parse::parse_or[f64]("bad", 9.0f64) as i64) == 9);
  assert(parse::is_parse[i64]("12"));
  assert(!parse::is_parse[i64]("12x"));
  assert(parse::is_parse[u64]("+12"));
  assert(!parse::is_parse[u64]("-12"));
  assert(parse::is_parse[bool]("false"));
  assert(parse::is_parse[f64](".25"));

  return 9;
}
