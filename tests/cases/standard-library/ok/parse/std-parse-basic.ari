// Covers std::parse whole-value parsers over borrowed byte slices.
fn main() -> i64 {
  var signed = [32u8, 45u8, 49u8, 50u8, 51u8, 32u8];
  var plus = [43u8, 52u8, 50u8];
  var invalid_integer = [49u8, 50u8, 120u8];
  assert(parse::integer(signed.as_slice()).unwrap_or(0) == -123);
  assert(parse::integer(plus.as_slice()).unwrap_or(0) == 42);
  match parse::integer(invalid_integer.as_slice()) {
    std::Some(_) => { panic(); }
    std::None => {}
  }

  var true_text = [116u8, 114u8, 117u8, 101u8];
  var false_text = [32u8, 102u8, 97u8, 108u8, 115u8, 101u8, 32u8];
  var invalid_bool = [84u8, 114u8, 117u8, 101u8];
  assert(parse::boolean(true_text.as_slice()).unwrap_or(false));
  assert(!parse::boolean(false_text.as_slice()).unwrap_or(true));
  match parse::boolean(invalid_bool.as_slice()) {
    std::Some(_) => { panic(); }
    std::None => {}
  }

  var float_text = [32u8, 45u8, 49u8, 50u8, 46u8, 53u8, 101u8, 50u8, 32u8];
  var invalid_float = [49u8, 46u8, 50u8, 120u8];
  assert(parse::is_float(float_text.as_slice()));
  assert((parse::float(float_text.as_slice()) as i64) == -1250);
  assert(!parse::is_float(invalid_float.as_slice()));
  assert((parse::float_or(invalid_float.as_slice(), 7.0f64) as i64) == 7);

  return 9;
}
