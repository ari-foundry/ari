// Covers natural map lookup aliases. The legacy contains method remains valid,
// while contains_key and get_or read better at map call sites.
fn constant_hash(value: i64) -> u64 {
  return 3;
}

fn main() -> i64 {
  var zone = zone::create(4096);
  var hash = HashMap::with_hash<i64, i64>(ref mut zone, 1, constant_hash);
  var tree = TreeMap::with_less<i64, i64>(ref mut zone, 1, collections::less_i64);
  var default_hash = HashMap::with_capacity<i64, i64>(ref mut zone, 1);
  var default_set = HashSet::with_capacity<i64>(ref mut zone, 1);
  var default_tree = TreeMap::with_capacity<i64, i64>(ref mut zone, 1);
  var default_tree_set = TreeSet::with_capacity<i64>(ref mut zone, 1);
  var natural_hash = HashMap::new<i64, i64>(ref mut zone);
  var natural_set = HashSet::new<i64>(ref mut zone);
  var natural_tree = TreeMap::new<i64, i64>(ref mut zone);
  var natural_tree_set = TreeSet::new<i64>(ref mut zone);
  var score = 0;

  assert(natural_hash.is_empty());
  natural_hash.insert(ref mut zone, 12, 120);
  assert(natural_hash.get_or(12, 0) == 120);

  assert(natural_set.is_empty());
  assert(natural_set.insert(ref mut zone, 12));
  assert(natural_set.contains(12));

  assert(natural_tree.is_empty());
  natural_tree.insert(ref mut zone, 12, 120);
  assert(natural_tree.get_or(12, 0) == 120);

  assert(natural_tree_set.is_empty());
  assert(natural_tree_set.insert(ref mut zone, 12));
  assert(natural_tree_set.contains(12));

  default_hash.insert(ref mut zone, 4, 40);
  default_hash.insert(ref mut zone, 4, 41);
  assert(default_hash.len() == 1);
  assert(default_hash.get_or(4, 0) == 41);
  assert(default_hash.get_or(8, 88) == 88);

  assert(default_set.insert(ref mut zone, 7));
  assert(!default_set.insert(ref mut zone, 7));
  assert(default_set.contains(7));

  default_tree.insert(ref mut zone, 3, 30);
  default_tree.insert(ref mut zone, 1, 10);
  assert(default_tree.first_entry().key() == 1);
  assert(default_tree.last_entry().value() == 30);

  assert(default_tree_set.insert(ref mut zone, 9));
  assert(default_tree_set.insert(ref mut zone, 2));
  assert(default_tree_set.first() == 2);
  assert(default_tree_set.last() == 9);

  hash.insert(ref mut zone, 1, 10);
  hash.insert(ref mut zone, 9, 90);
  if hash.contains_key(9) {
    score = score + 7;
  }
  if !hash.contains_key(2) {
    score = score + 11;
  }
  hash.remove(1);
  if !hash.contains_key(1) {
    score = score + 13;
  }
  if hash.contains(9) {
    score = score + 17;
  }
  if hash.get_or(9, 0) == 90 {
    score = score + 3;
  }
  if hash.get_or(2, 31) == 31 {
    score = score + 5;
  }

  tree.insert(ref mut zone, 4, 40);
  tree.insert(ref mut zone, 2, 20);
  tree.insert(ref mut zone, 8, 80);
  if tree.contains_key(2) {
    score = score + 19;
  }
  if !tree.contains_key(7) {
    score = score + 23;
  }
  if tree.contains(8) {
    score = score + 29;
  }
  if tree.get_or(2, 0) == 20 {
    score = score + 7;
  }
  if tree.get_or(7, 11) == 11 {
    score = score + 11;
  }

  zone::destroy(zone);
  return score;
}
