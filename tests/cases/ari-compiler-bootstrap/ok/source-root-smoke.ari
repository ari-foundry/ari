fn lexer_text_cursor_score() -> i64 {
  let text: Slice[u8] = "alpha9+";
  let first = lexer::cursor_from_text(text, 0);
  if !lexer::cursor_is_identifier(first) {
    return 1;
  }
  if lexer::cursor_token_start(first) != 0 {
    return 2;
  }
  if lexer::cursor_token_end(first) != 6 {
    return 3;
  }
  if lexer::cursor_token_score(first) != 7 {
    return 4;
  }
  let second = lexer::cursor_advance_in_text(first, text);
  if !lexer::cursor_is_operator(second) {
    return 5;
  }
  if lexer::cursor_token_start(second) != 6 {
    return 6;
  }
  if lexer::cursor_token_end(second) != 7 {
    return 7;
  }
  if lexer::cursor_token_score(second) != 13 {
    return 8;
  }
  let eof = lexer::cursor_advance_in_text(second, text);
  if !lexer::cursor_is_eof(eof) {
    return 9;
  }
  if lexer::cursor_token_start(eof) != 7 {
    return 10;
  }
  return 0;
}

fn lexer_keyword_case_score(
  text: Slice[u8],
  keyword_width: i64,
  expected_keyword_score: i64,
  longer: Slice[u8],
  longer_width: i64,
  expected_longer_score: i64,
  keyword_text: Slice[u8],
  single: char
) -> i64 {
  let keyword = lexer::cursor_from_text(text, 0);
  if !lexer::cursor_is_keyword(keyword) {
    return 1;
  }
  if lexer::cursor_is_identifier(keyword) {
    return 2;
  }
  if lexer::cursor_is_unknown(keyword) {
    return 3;
  }
  if lexer::cursor_token_start(keyword) != 0 {
    return 4;
  }
  if lexer::cursor_token_end(keyword) != keyword_width {
    return 5;
  }
  if lexer::cursor_token_score(keyword) != expected_keyword_score {
    return 6;
  }
  let after_keyword = lexer::cursor_advance_in_text(keyword, text);
  if !lexer::cursor_is_whitespace(after_keyword) {
    return 7;
  }
  let name = lexer::cursor_advance_significant_in_text(keyword, text);
  if !lexer::cursor_is_identifier(name) {
    return 8;
  }
  if lexer::cursor_token_start(name) != keyword_width + 1 {
    return 9;
  }
  if lexer::cursor_token_end(name) != keyword_width + 5 {
    return 10;
  }

  let identifier = lexer::cursor_from_text(longer, 0);
  if !lexer::cursor_is_identifier(identifier) {
    return 11;
  }
  if lexer::cursor_is_keyword(identifier) {
    return 12;
  }
  if lexer::cursor_token_end(identifier) != longer_width {
    return 13;
  }
  if lexer::cursor_token_score(identifier) != expected_longer_score {
    return 14;
  }

  let handoff = lexer::handoff_from_text(keyword_text);
  if !lexer::handoff_starts_with_keyword(handoff) {
    return 15;
  }
  if parser::parse_text_kind_score(keyword_text) != 45 {
    return 16;
  }
  if parser::parse_failure_code(parser::parse_text(keyword_text)) != 2006 {
    return 17;
  }
  let single_cursor = lexer::cursor_from_one(single, 0);
  if !lexer::cursor_is_identifier(single_cursor) {
    return 18;
  }
  if lexer::cursor_is_keyword(single_cursor) {
    return 19;
  }
  return 0;
}

fn lexer_keyword_case_with_base_score(
  base: i64,
  text: Slice[u8],
  keyword_width: i64,
  expected_keyword_score: i64,
  longer: Slice[u8],
  longer_width: i64,
  expected_longer_score: i64,
  keyword_text: Slice[u8],
  single: char
) -> i64 {
  let score = lexer_keyword_case_score(
    text,
    keyword_width,
    expected_keyword_score,
    longer,
    longer_width,
    expected_longer_score,
    keyword_text,
    single
  );
  if score != 0 {
    return base + score;
  }
  return 0;
}

