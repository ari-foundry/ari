fn parse_leading_comment_case_score(
  text: Slice[u8],
  expected_statement_start: i64,
  expected_statement_end: i64
) -> i64 {
  let parsed = parser::parse_text(text);
  if !parser::parse_is_success(parsed) {
    return 1;
  }
  if parser::parse_statement_start_offset(parsed) != expected_statement_start {
    return 2;
  }
  if parser::parse_statement_end_offset(parsed) != expected_statement_end {
    return 3;
  }
  if parser::parse_statement_span_len(parsed) != expected_statement_end - expected_statement_start {
    return 4;
  }
  zone(65536) {
    let keyword_parsed = parser::parse_text_with_keywords(text);
    if !parser::parse_is_success(keyword_parsed) {
      return 5;
    }
    if parser::parse_statement_start_offset(keyword_parsed) != expected_statement_start {
      return 6;
    }
    if parser::parse_statement_end_offset(keyword_parsed) != expected_statement_end {
      return 7;
    }
  }
  return 0;
}

fn parse_leading_comment_line_block_score(
  line_text: Slice[u8],
  line_expected_start: i64,
  line_expected_end: i64,
  block_text: Slice[u8],
  block_expected_start: i64,
  block_expected_end: i64
) -> i64 {
  var score = parse_leading_comment_case_score(
    line_text,
    line_expected_start,
    line_expected_end
  );
  if score != 0 {
    return score;
  }
  score = parse_leading_comment_case_score(
    block_text,
    block_expected_start,
    block_expected_end
  );
  if score != 0 {
    return 10 + score;
  }
  return 0;
}

