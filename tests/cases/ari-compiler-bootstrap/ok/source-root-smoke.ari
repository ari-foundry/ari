mod source;
mod diagnostic;
mod lexer;
mod ast;
mod parser;
mod driver;

fn file_driver_score() -> i64 {
  zone(16384) {
    return driver::exit_code(driver::run_file("tests/cases/ari-compiler-bootstrap/ok/source-root-smoke.ari"));
  }
}

fn file_driver_result_score() -> i64 {
  zone(16384) {
    return driver::result_code(driver::run_file(
      "tests/cases/ari-compiler-bootstrap/ok/source-root-smoke.ari"
    ));
  }
}

fn missing_file_driver_score() -> i64 {
  zone(16384) {
    return driver::result_code(driver::run_file(
      "tests/cases/ari-compiler-bootstrap/missing-input.ari"
    ));
  }
}

fn empty_source_text_driver_score() -> i64 {
  zone(16384) {
    return driver::result_code(driver::run_source_text(std::string::empty()));
  }
}

fn source_text_driver_score() -> i64 {
  zone(16384) {
    return driver::result_code(driver::run_source_text(std::string::from("p")));
  }
}

fn default_driver_result_score() -> i64 {
  return driver::result_code(driver::run());
}

fn loaded_source_score() -> i64 {
  let loaded = source::loaded_source_summary(7, 5, 'm', 0);
  if !source::loaded_source_has_first(loaded) {
    return 1;
  }
  return source::loaded_source_score(source::loaded_source_summary(7, 5, 'm', 0));
}

fn loaded_driver_score() -> i64 {
  return driver::exit_code(driver::run_loaded_source_summary(1, 16, 'p', 2));
}

fn loaded_driver_result_score() -> i64 {
  return driver::result_code(driver::run_loaded_source_summary(1, 16, 'p', 2));
}

fn invalid_loaded_driver_score() -> i64 {
  return driver::result_code(driver::run_loaded_source_summary(1, 3, 'p', 3));
}

fn parse_success_score() -> i64 {
  if !parser::parse_is_success(parser::parse_one('q', 1)) {
    return 1;
  }
  if !parser::parse_is_success(parser::parse_one('9', 2)) {
    return 3;
  }
  if parser::parse_is_success(parser::parse_one(' ', 4)) {
    return 2;
  }
  return 0;
}

fn parse_statement_node_score() -> i64 {
  if !parser::parse_is_statement_node(parser::parse_one('q', 1)) {
    return 1;
  }
  if parser::parse_is_statement_node(parser::parse_one(' ', 4)) {
    return 2;
  }
  return 0;
}

fn parse_statement_span_score() -> i64 {
  if parser::parse_statement_span_len(parser::parse_one('q', 1)) != 1 {
    return 1;
  }
  if parser::parse_statement_span_len(parser::parse_one(' ', 4)) != -1 {
    return 2;
  }
  return 0;
}

fn parse_statement_value_score() -> i64 {
  if parser::parse_statement_value(parser::parse_one('q', 1)) != 2 {
    return 1;
  }
  if parser::parse_statement_value(parser::parse_one(' ', 4)) != -1 {
    return 2;
  }
  return 0;
}

fn parse_statement_start_score() -> i64 {
  if parser::parse_statement_start_offset(parser::parse_one('q', 1)) != 1 {
    return 1;
  }
  if parser::parse_statement_start_offset(parser::parse_one(' ', 4)) != -1 {
    return 2;
  }
  return 0;
}

fn parse_statement_end_score() -> i64 {
  if parser::parse_statement_end_offset(parser::parse_one('q', 1)) != 2 {
    return 1;
  }
  if parser::parse_statement_end_offset(parser::parse_one(' ', 4)) != -1 {
    return 2;
  }
  return 0;
}

fn parse_statement_source_score() -> i64 {
  if parser::parse_statement_source_id(parser::parse_one('q', 1)) != 0 {
    return 1;
  }
  if parser::parse_statement_source_id(parser::parse_one(' ', 4)) != -1 {
    return 2;
  }
  return 0;
}

fn failed_parse_driver_score() -> i64 {
  return driver::result_code(driver::run_loaded_source_summary(1, 3, ' ', 0));
}

fn failed_unknown_driver_score() -> i64 {
  return driver::result_code(driver::run_loaded_source_summary(1, 3, '!', 0));
}

fn input_success_score() -> i64 {
  return driver::result_code(driver::run_input(driver::driver_input(
    1,
    16,
    'p',
    2
  )));
}

fn input_start_bound_score() -> i64 {
  return driver::result_code(driver::run_input(driver::driver_input(
    1,
    3,
    'p',
    -1
  )));
}

fn input_end_bound_score() -> i64 {
  return driver::result_code(driver::run_input(driver::driver_input(
    1,
    3,
    'p',
    3
  )));
}

fn diagnostic_code_score() -> i64 {
  return diagnostic::diagnostic_code(diagnostic::error(77, 1, 2));
}

fn parse_failure_code_score() -> i64 {
  if parser::parse_failure_code(parser::parse_one('q', 1)) != 0 {
    return 1;
  }
  return parser::parse_failure_code(parser::parse_one(' ', 4));
}

fn parse_empty_failure_code_score() -> i64 {
  return parser::parse_failure_code(parser::parse_empty());
}

fn parse_eof_cursor_failure_code_score() -> i64 {
  return parser::parse_failure_code(parser::parse_one_eof('p', 2));
}

fn parse_unknown_failure_code_score() -> i64 {
  return parser::parse_failure_code(parser::parse_one('!', 5));
}

fn parse_missing_eof_failure_code_score() -> i64 {
  return parser::parse_failure_code(parser::parse_one_without_eof('p', 2));
}

fn main() -> i64 {
  let file = source::source_file(3, 12);
  let span = source::span(3, 2, 5);

  if !source::contains(file, span.end) {
    return 1;
  }

  return source::span_len(span) +
    lexer::scan_result_score(lexer::scan_one_result('!', 4)) +
    lexer::handoff_score(lexer::handoff_from_one('x', 6)) -
    16 +
    ast::node_score(ast::token_node(3, 2, 5, 8)) -
    12 +
    parser::parse_score(parser::parse_one('q', 1)) +
    parser::parse_score(parser::parse_one(' ', 4)) +
    parser::parse_score(parser::parse_one('!', 5)) -
    4017 +
    parser::parse_one_kind_score('9', 2) -
    42 +
    driver::exit_code(driver::run()) +
    default_driver_result_score() +
    loaded_source_score() -
    121 +
    loaded_driver_score() +
    loaded_driver_result_score() +
    invalid_loaded_driver_score() -
    1103 +
    parse_success_score() +
    parse_statement_node_score() +
    parse_statement_span_score() +
    parse_statement_value_score() +
    parse_statement_start_score() +
    parse_statement_end_score() +
    parse_statement_source_score() +
    failed_parse_driver_score() -
    2004 +
    failed_unknown_driver_score() -
    2005 +
    input_success_score() +
    input_start_bound_score() -
    1001 +
    input_end_bound_score() -
    1002 +
    diagnostic_code_score() -
    77 +
    parse_failure_code_score() -
    2004 +
    parse_empty_failure_code_score() -
    2002 +
    parse_eof_cursor_failure_code_score() -
    2001 +
    parse_unknown_failure_code_score() -
    2005 +
    parse_missing_eof_failure_code_score() -
    2003 +
    file_driver_score() +
    file_driver_result_score() +
    missing_file_driver_score() -
    1102 +
    empty_source_text_driver_score() -
    1101 +
    source_text_driver_score() +
    parser::parse_score(parser::parse_empty()) -
    3018;
}
