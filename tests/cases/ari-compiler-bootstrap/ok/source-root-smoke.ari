  }
  if lexer::cursor_is_operator(path) {
    return 2;
  }
  if lexer::cursor_token_start(path) != 65 {
    return 3;
  }
  if lexer::cursor_token_end(path) != 67 {
    return 4;
  }
  if lexer::cursor_token_ranked_width(path) != 47 {
    return 5;
  }
  let fallback = lexer::cursor_from_two(':', 68, '+');
  if lexer::cursor_token_end(fallback) != 69 {
    return 6;
  }
  if lexer::cursor_token_ranked_width(fallback) != 10 {
    return 7;
  }
  return 0;
}

