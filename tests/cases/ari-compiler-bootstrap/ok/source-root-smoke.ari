  let invalid_unicode_escape_text: Slice[u8] = "\"\\u12\"";
  failure_score = lexer_failure_case_score(invalid_unicode_escape_text, 1006, 2, 5);
  if failure_score != 0 {
    return 53 + failure_score;
  }

  let invalid_wide_unicode_escape_text: Slice[u8] = "\"\\U1234\"";
  failure_score = lexer_failure_case_score(
    invalid_wide_unicode_escape_text,
    1006,
    2,
    7
  );
  if failure_score != 0 {
    return 60 + failure_score;
  }

  let invalid_braced_unicode_digit_text: Slice[u8] = "\"\\u{Q}\"";
  failure_score = lexer_failure_case_score(
    invalid_braced_unicode_digit_text,
    1006,
    4,
    5
  );
  if failure_score != 0 {
