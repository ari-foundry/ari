fn file_driver_score() -> i64 {
  zone(65536) {
    return driver::exit_code(driver::run_file("tests/cases/ari-compiler-bootstrap/input/one-token.ari"));
  }
}

fn file_driver_result_score() -> i64 {
  zone(65536) {
    return driver::result_code(driver::run_file(
      "tests/cases/ari-compiler-bootstrap/input/one-token.ari"
    ));
  }
}

fn missing_file_driver_score() -> i64 {
  zone(65536) {
    return driver::result_code(driver::run_file(
      "tests/cases/ari-compiler-bootstrap/missing-input.ari"
    ));
  }
}

fn empty_source_text_driver_score() -> i64 {
  zone(65536) {
    return driver::result_code(driver::run_source_text(std::string::empty()));
  }
}

fn source_text_driver_score() -> i64 {
  zone(65536) {
    return driver::result_code(driver::run_source_text(std::string::from("p")));
  }
}

fn source_text_extra_token_driver_score() -> i64 {
  zone(65536) {
    return driver::result_code(driver::run_source_text(std::string::from("p+")));
  }
}

fn default_driver_result_score() -> i64 {
  return driver::result_code(driver::run());
}

fn loaded_source_score() -> i64 {
  let loaded = source::loaded_source_summary(7, 5, 'm', 0);
  if !source::loaded_source_has_first(loaded) {
    return 1;
  }
  return source::loaded_source_score(source::loaded_source_summary(7, 5, 'm', 0));
}

fn loaded_driver_score() -> i64 {
  return driver::exit_code(driver::run_loaded_source_summary(1, 16, 'p', 2));
}

fn loaded_driver_result_score() -> i64 {
  return driver::result_code(driver::run_loaded_source_summary(1, 16, 'p', 2));
}

fn invalid_loaded_driver_score() -> i64 {
  return driver::result_code(driver::run_loaded_source_summary(1, 3, 'p', 3));
}

fn lexer_stream_score() -> i64 {
  let stream = lexer::stream_from_two('a', 7, '9');
  if lexer::stream_len(stream) != 2 {
    return 1;
  }
  if !lexer::cursor_is_identifier(lexer::stream_first(stream)) {
    return 2;
  }
  if !lexer::stream_has_two_tokens(stream) {
    return 3;
  }
  if !lexer::cursor_is_number(lexer::stream_second(stream)) {
    return 4;
  }
  if lexer::cursor_token_start(lexer::stream_second(stream)) != 8 {
    return 5;
  }
  if lexer::cursor_token_end(lexer::stream_second(stream)) != 9 {
    return 6;
  }
  if !lexer::stream_has_eof(stream) {
    return 7;
  }
  if lexer::cursor_token_start(lexer::stream_eof(stream)) != 9 {
    return 8;
  }
  return 0;
}

fn lexer_punctuation_score() -> i64 {
  if !lexer::cursor_is_punctuation(lexer::cursor_from_one('(', 10)) {
    return 1;
  }
  if lexer::cursor_is_unknown(lexer::cursor_from_one('(', 10)) {
    return 2;
  }
  if lexer::scan_result_score(lexer::scan_one_result('(', 10)) != 5 {
    return 3;
  }
  if lexer::scan_score(')') != 6 {
    return 4;
  }
  if lexer::scan_score('{') != 7 {
    return 5;
  }
  if lexer::scan_score('}') != 8 {
    return 6;
  }
  if lexer::scan_score(',') != 9 {
    return 7;
  }
  if lexer::scan_score(':') != 10 {
    return 8;
  }
  if lexer::scan_score(';') != 11 {
    return 9;
  }
  if !lexer::handoff_starts_with_punctuation(lexer::handoff_from_one(';', 3)) {
    return 10;
  }
  return 0;
}

fn lexer_operator_score() -> i64 {
  if !lexer::cursor_is_operator(lexer::cursor_from_one('=', 12)) {
    return 1;
  }
  if lexer::cursor_is_unknown(lexer::cursor_from_one('=', 12)) {
    return 2;
  }
  if lexer::scan_result_score(lexer::scan_one_result('=', 12)) != 12 {
    return 3;
  }
  if lexer::scan_score('+') != 13 {
    return 4;
  }
  if lexer::scan_score('-') != 14 {
    return 5;
  }
  if lexer::scan_score('*') != 15 {
    return 6;
  }
  if lexer::scan_score('/') != 16 {
    return 7;
  }
  if lexer::scan_score('%') != 17 {
    return 8;
  }
  if !lexer::handoff_starts_with_operator(lexer::handoff_from_one('+', 3)) {
    return 9;
  }
  if lexer::scan_score('!') != 22 {
    return 10;
  }
  if lexer::scan_score('<') != 23 {
    return 11;
  }
  if lexer::scan_score('>') != 24 {
    return 12;
  }
  if !lexer::cursor_is_operator(lexer::cursor_from_one('!', 18)) {
    return 13;
  }
  if !lexer::handoff_starts_with_operator(lexer::handoff_from_one('<', 19)) {
    return 14;
  }
  if lexer::scan_score('&') != 31 {
    return 15;
  }
  if lexer::scan_score('|') != 32 {
    return 16;
  }
  if lexer::scan_score('^') != 33 {
    return 17;
  }
  if !lexer::cursor_is_operator(lexer::cursor_from_one('&', 20)) {
    return 18;
  }
  if !lexer::handoff_starts_with_operator(lexer::handoff_from_one('|', 21)) {
    return 19;
  }
  return 0;
}

fn lexer_identifier_span_score() -> i64 {
  let text: Slice[u8] = "alpha9+";
  let cursor = lexer::cursor_from_text(text, 0);
  if !lexer::cursor_is_identifier(cursor) {
    return 1;
  }
  if lexer::cursor_token_start(cursor) != 0 {
    return 2;
  }
  if lexer::cursor_token_end(cursor) != 6 {
    return 3;
  }
  if lexer::cursor_token_score(cursor) != 7 {
    return 4;
  }
  let after_identifier = lexer::cursor_advance_in_text(cursor, text);
  if !lexer::cursor_is_operator(after_identifier) {
    return 5;
  }
  if lexer::cursor_token_start(after_identifier) != 6 {
    return 6;
  }
  return 0;
}

