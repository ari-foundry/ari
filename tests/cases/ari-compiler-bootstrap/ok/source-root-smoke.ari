mod source;
mod diagnostic;
mod lexer;
mod ast;
mod parser;
mod driver;

// Test-only score helpers feed this fixture's process exit code. They return
// stable expected values or small failure codes because this smoke has no
// assertion framework yet; do not copy these helpers into compiler modules.

fn file_driver_score() -> i64 {
  zone(65536) {
    return driver::exit_code(driver::run_file("tests/cases/ari-compiler-bootstrap/input/one-token.ari"));
  }
}

fn file_driver_result_score() -> i64 {
  zone(65536) {
    return driver::result_code(driver::run_file(
      "tests/cases/ari-compiler-bootstrap/input/one-token.ari"
    ));
  }
}

fn missing_file_driver_score() -> i64 {
  zone(65536) {
    return driver::result_code(driver::run_file(
      "tests/cases/ari-compiler-bootstrap/missing-input.ari"
    ));
  }
}

fn empty_source_text_driver_score() -> i64 {
  zone(65536) {
    return driver::result_code(driver::run_source_text(std::string::empty()));
  }
}

fn source_text_driver_result(text: Slice[u8]) -> i64 {
  zone(65536) {
    return driver::result_code(driver::run_source_text(std::string::from(text)));
  }
}

fn source_text_line_block_driver_score(
  line_text: Slice[u8],
  block_text: Slice[u8],
  expected_code: i64
) -> i64 {
  let line_code = source_text_driver_result(line_text);
  if line_code != expected_code {
    return 1;
  }
  let block_code = source_text_driver_result(block_text);
  if block_code != expected_code {
    return 2;
  }
  return 0;
}

fn source_text_driver_score() -> i64 {
  zone(65536) {
    return driver::result_code(driver::run_source_text(std::string::from("p")));
  }
}

fn source_text_extra_token_driver_score() -> i64 {
  zone(65536) {
