  let parsed = parser::parse_text(text);
  if !parser::parse_is_success(parsed) {
    return 1;
  }
  if parser::parse_statement_start_offset(parsed) != 0 {
    return 2;
  }
  if parser::parse_statement_end_offset(parsed) != expected_statement_end {
    return 3;
  }
  if parser::parse_statement_span_len(parsed) != expected_statement_end {
    return 4;
  }
  zone(65536) {
    let keyword_parsed = parser::parse_text_with_keywords(text);
    if !parser::parse_is_success(keyword_parsed) {
      return 5;
    }
    if parser::parse_statement_end_offset(keyword_parsed) != expected_statement_end {
      return 6;
    }
  }
  return 0;
}

