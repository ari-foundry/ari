  if score != 0 {
    return 6 + score;
  }
  score = lexer_number_case_score("0xffu8 ", 6, 8);
  if score != 0 {
    return 12 + score;
  }
  score = lexer_number_case_score("0b1010i16;", 9, 11);
  if score != 0 {
    return 18 + score;
  }
  score = lexer_number_case_score("0o755u64 ", 8, 10);
  if score != 0 {
    return 24 + score;
  }
  score = lexer_number_case_score("42f32 ", 5, 7);
  if score != 0 {
    return 30 + score;
