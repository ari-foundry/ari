  let after_literal = lexer::cursor_advance_in_text(literal, text);
  if !lexer::cursor_is_whitespace(after_literal) {
    return 6;
  }
  if lexer::cursor_token_start(after_literal) != 5 {
    return 7;
  }
  if lexer::cursor_token_end(after_literal) != 6 {
