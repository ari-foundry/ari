  let invalid_hex_value_escape_text: Slice[u8] = "\"\\x100\"";
  failure_score = lexer_failure_case_score(invalid_hex_value_escape_text, 1007, 2, 6);
  if failure_score != 0 {
    return 82 + failure_score;
  }

  let invalid_octal_value_escape_text: Slice[u8] = "\"\\777\"";
  failure_score = lexer_failure_case_score(invalid_octal_value_escape_text, 1007, 2, 5);
  if failure_score != 0 {
