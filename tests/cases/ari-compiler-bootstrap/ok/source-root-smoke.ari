    1007,
    2,
    11
  );
  if failure_score != 0 {
    return 110 + failure_score;
  }

  let digit_escape_text: Slice[u8] = "\"\\x21\\u0041\\U00000042\\u{1F600}\\0123\" tail";
  let digit_escape = lexer::cursor_from_text(digit_escape_text, 0);
  if !lexer::cursor_is_string_literal(digit_escape) {
    return 118;
  }
  if lexer::cursor_token_end(digit_escape) != 36 {
    return 119;
  }
  if lexer::cursor_token_ranked_width(digit_escape) != 87 {
    return 120;
  }
  let after_digit_escape = lexer::cursor_advance_in_text(digit_escape, digit_escape_text);
  if !lexer::cursor_is_whitespace(after_digit_escape) {
    return 121;
  }
  return 0;
}

fn lexer_line_comment_span_score(text: Slice[u8], expected_comment_end: i64) -> i64 {
  let line = lexer::cursor_from_text(text, 0);
  if !lexer::cursor_is_whitespace(line) {
    return 1;
  }
  if lexer::cursor_token_start(line) != 0 {
    return 2;
  }
  if lexer::cursor_token_end(line) != expected_comment_end {
    return 3;
  }
  if lexer::cursor_token_ranked_width(line) != expected_comment_end + 3 {
    return 4;
  }
  return 0;
}

fn lexer_line_comment_named_case_score(
  text: Slice[u8],
  expected_comment_end: i64,
  expected_name_start: i64,
  expected_name_end: i64
) -> i64 {
  let span_score = lexer_line_comment_span_score(text, expected_comment_end);
  if span_score != 0 {
    return span_score;
  }
  let line = lexer::cursor_from_text(text, 0);
  let line_newline = lexer::cursor_advance_in_text(line, text);
  if !lexer::cursor_is_whitespace(line_newline) {
    return 5;
  }
  if lexer::cursor_token_start(line_newline) != expected_comment_end {
    return 6;
  }
  let line_name = lexer::cursor_advance_significant_in_text(line, text);
  if !lexer::cursor_is_identifier(line_name) {
    return 7;
  }
  if lexer::cursor_token_start(line_name) != expected_name_start {
    return 8;
  }
  if lexer::cursor_token_end(line_name) != expected_name_end {
    return 9;
  }
  if !parser::parse_is_success(parser::parse_text(text)) {
    return 10;
  }
  return 0;
}

fn lexer_line_comment_eof_case_score(text: Slice[u8], expected_comment_end: i64) -> i64 {
  let span_score = lexer_line_comment_span_score(text, expected_comment_end);
  if span_score != 0 {
    return span_score;
  }
  let line = lexer::cursor_from_text(text, 0);
  let line_eof = lexer::cursor_advance_in_text(line, text);
  if !lexer::cursor_is_eof(line_eof) {
    return 5;
  }
  if lexer::cursor_token_start(line_eof) != expected_comment_end {
    return 6;
  }
  if lexer::cursor_token_end(line_eof) != expected_comment_end {
    return 7;
  }
  let significant_eof = lexer::cursor_advance_significant_in_text(line, text);
  if !lexer::cursor_is_eof(significant_eof) {
    return 8;
  }
  if lexer::cursor_token_start(significant_eof) != expected_comment_end {
    return 9;
  }
  return 0;
}

fn lexer_comment_span_score() -> i64 {
  let line_text: Slice[u8] = "// skip\nname";
  var line_score = lexer_line_comment_named_case_score(line_text, 7, 8, 12);
  if line_score != 0 {
    return line_score;
  }
  let crlf_line_text: Slice[u8] = "// skip\r\nname";
  line_score = lexer_line_comment_named_case_score(crlf_line_text, 8, 9, 13);
  if line_score != 0 {
    return 10 + line_score;
  }
  let eof_line_text: Slice[u8] = "// skip";
  line_score = lexer_line_comment_eof_case_score(eof_line_text, 7);
  if line_score != 0 {
    return 20 + line_score;
  }

  let block_text: Slice[u8] = "/* outer /* inner */ still */name";
  let block = lexer::cursor_from_text(block_text, 0);
  if !lexer::cursor_is_whitespace(block) {
    return 31;
  }
  if lexer::cursor_token_start(block) != 0 {
    return 32;
  }
  if lexer::cursor_token_end(block) != 29 {
    return 33;
  }
  if lexer::cursor_token_ranked_width(block) != 32 {
    return 34;
  }
  let block_name = lexer::cursor_advance_significant_in_text(block, block_text);
  if !lexer::cursor_is_identifier(block_name) {
    return 35;
  }
  if lexer::cursor_token_start(block_name) != 29 {
    return 36;
  }
  if lexer::cursor_token_end(block_name) != 33 {
    return 37;
  }
  if !parser::parse_is_success(parser::parse_text(block_text)) {
    return 38;
  }

  let unterminated_block_text: Slice[u8] = "/* open";
  let failure_score = lexer_failure_case_score(unterminated_block_text, 1008, 0, 7);
  if failure_score != 0 {
    return 39 + failure_score;
  }
  return 0;
}

