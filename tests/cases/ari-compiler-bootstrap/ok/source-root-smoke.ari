  }
}

fn source_text_comment_only_driver_score() -> i64 {
  return source_text_line_block_driver_score("// skip", "/* skip */", 2001);
}

fn source_text_eof_line_comment_driver_score() -> i64 {
  let code = source_text_driver_result("// eof");
  if code != 2001 {
    return 1;
  }
  return 0;
}

fn source_text_leading_comment_driver_score() -> i64 {
  return source_text_line_block_driver_score("// skip\np", "/* skip */p", 0);
}

fn source_text_crlf_line_comment_driver_score() -> i64 {
  let code = source_text_driver_result("// skip\r\np");
  if code != 0 {
    return 1;
  }
  return 0;
}

