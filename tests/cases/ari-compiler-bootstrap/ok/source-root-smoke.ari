  if lexer::scan_score('*') != 15 {
    return 6;
  }
  if lexer::scan_score('/') != 16 {
    return 7;
  }
  if lexer::scan_score('%') != 17 {
    return 8;
  }
  if !lexer::handoff_starts_with_operator(lexer::handoff_from_one('+', 3)) {
    return 9;
  }
  if lexer::scan_score('!') != 22 {
    return 10;
  }
  if lexer::scan_score('<') != 23 {
    return 11;
  }
  if lexer::scan_score('>') != 24 {
    return 12;
  }
  if !lexer::cursor_is_operator(lexer::cursor_from_one('!', 18)) {
    return 13;
  }
  if !lexer::handoff_starts_with_operator(lexer::handoff_from_one('<', 19)) {
    return 14;
  }
  if lexer::scan_score('&') != 31 {
    return 15;
  }
  if lexer::scan_score('|') != 32 {
    return 16;
  }
  if lexer::scan_score('^') != 33 {
    return 17;
  }
  if !lexer::cursor_is_operator(lexer::cursor_from_one('&', 20)) {
    return 18;
  }
  if !lexer::handoff_starts_with_operator(lexer::handoff_from_one('|', 21)) {
    return 19;
  }
  return 0;
}

fn lexer_identifier_span_score() -> i64 {
  let text: Slice[u8] = "alpha9+";
  let cursor = lexer::cursor_from_text(text, 0);
  if !lexer::cursor_is_identifier(cursor) {
    return 1;
  }
  if lexer::cursor_token_start(cursor) != 0 {
    return 2;
  }
  if lexer::cursor_token_end(cursor) != 6 {
    return 3;
  }
  if lexer::cursor_token_score(cursor) != 7 {
    return 4;
  }
  let after_identifier = lexer::cursor_advance_in_text(cursor, text);
  if !lexer::cursor_is_operator(after_identifier) {
    return 5;
  }
  if lexer::cursor_token_start(after_identifier) != 6 {
    return 6;
  }
  return 0;
}

