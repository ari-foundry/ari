fn lexer_text_cursor_score() -> i64 {
  let text: Slice[u8] = "alpha9+";
  let first = lexer::cursor_from_text(text, 0);
  if !lexer::cursor_is_identifier(first) {
    return 1;
  }
  if lexer::cursor_token_start(first) != 0 {
    return 2;
  }
  if lexer::cursor_token_end(first) != 6 {
    return 3;
  }
  if lexer::cursor_token_score(first) != 7 {
    return 4;
  }
  let second = lexer::cursor_advance_in_text(first, text);
  if !lexer::cursor_is_operator(second) {
    return 5;
  }
  if lexer::cursor_token_start(second) != 6 {
    return 6;
  }
  if lexer::cursor_token_end(second) != 7 {
    return 7;
  }
  if lexer::cursor_token_score(second) != 13 {
    return 8;
  }
  let eof = lexer::cursor_advance_in_text(second, text);
  if !lexer::cursor_is_eof(eof) {
    return 9;
  }
  if lexer::cursor_token_start(eof) != 7 {
    return 10;
  }
  return 0;
}

fn parse_text_score() -> i64 {
  if !parser::parse_is_success(parser::parse_text("name9")) {
    return 1;
  }
  if parser::parse_statement_span_len(parser::parse_text("name9")) != 5 {
    return 2;
  }
  if !parser::parse_is_success(parser::parse_text("  name9 \n")) {
    return 3;
  }
  if parser::parse_statement_start_offset(parser::parse_text("  name9 \n")) != 2 {
    return 4;
  }
  if parser::parse_failure_code(parser::parse_text("p+")) != 2003 {
    return 5;
  }
  if !parser::parse_is_success(parser::parse_text("12345")) {
    return 6;
  }
  if parser::parse_statement_span_len(parser::parse_text("12345")) != 5 {
    return 7;
  }
  return 0;
}

