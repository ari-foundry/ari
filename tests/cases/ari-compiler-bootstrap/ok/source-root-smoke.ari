fn source_text_leading_comment_byte_char_numeric_escape_driver_score() -> i64 {
  let hex_score = source_text_line_block_driver_score("// skip\n'\\x41'", "/* skip */'\\x41'", 0);
  if hex_score != 0 {
    return hex_score;
  }
  let octal_score = source_text_line_block_driver_score("// skip\n'\\101'", "/* skip */'\\101'", 0);
  if octal_score != 0 {
    return 10 + octal_score;
  }
  return 0;
}

fn source_text_leading_comment_byte_char_fixed_unicode_escape_driver_score() -> i64 {
  let u_score = source_text_line_block_driver_score("// skip\n'\\u0041'", "/* skip */'\\u0041'", 0);
  if u_score != 0 {
    return u_score;
  }
  let big_u_score = source_text_line_block_driver_score(
    "// skip\n'\\U00000041'",
    "/* skip */'\\U00000041'",
    0
  );
  if big_u_score != 0 {
    return 10 + big_u_score;
  }
  return 0;
}

fn source_text_leading_comment_byte_char_braced_unicode_escape_driver_score() -> i64 {
  return source_text_line_block_driver_score("// skip\n'\\u{41}'", "/* skip */'\\u{41}'", 0);
}

