  if !lexer::cursor_is_string_literal(empty) {
    return 9;
  }
  if lexer::cursor_token_end(empty) != 2 {
    return 10;
  }
  if lexer::cursor_token_ranked_width(empty) != 53 {
    return 11;
  }
  let after_empty = lexer::cursor_advance_in_text(empty, empty_text);
  if !lexer::cursor_is_operator(after_empty) {
    return 12;
  }
  if lexer::cursor_token_start(after_empty) != 2 {
    return 13;
  }

  let escaped_quote_text: Slice[u8] = "\"a\\\"b\" tail";
  let escaped_quote = lexer::cursor_from_text(escaped_quote_text, 0);
  if !lexer::cursor_is_string_literal(escaped_quote) {
    return 14;
  }
  if lexer::cursor_token_end(escaped_quote) != 6 {
    return 15;
  }
  if lexer::cursor_token_ranked_width(escaped_quote) != 57 {
    return 16;
  }
  let after_escaped_quote = lexer::cursor_advance_in_text(
    escaped_quote,
    escaped_quote_text
  );
  if !lexer::cursor_is_whitespace(after_escaped_quote) {
    return 17;
  }
  if lexer::cursor_token_start(after_escaped_quote) != 6 {
    return 18;
