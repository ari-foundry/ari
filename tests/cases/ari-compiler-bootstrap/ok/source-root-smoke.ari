fn lexer_failure_case_score(
  text: Slice[u8],
  expected_code: i64,
  expected_start: i64,
  expected_end: i64
) -> i64 {
  let scanned = lexer::scan_text_result(text, 0);
  if !lexer::scan_result_is_failure(scanned) {
    return 1;
  }
  if lexer::scan_result_failure_code(scanned) != expected_code {
    return 2;
  }
  if lexer::scan_result_failure_start_offset(scanned) != expected_start {
    return 3;
  }
  if lexer::scan_result_failure_end_offset(scanned) != expected_end {
    return 4;
  }
  let parsed = parser::parse_text(text);
  if parser::parse_failure_code(parsed) != expected_code {
    return 5;
  }
  if parser::parse_failure_start_offset(parsed) != expected_start {
    return 6;
  }
  if parser::parse_failure_end_offset(parsed) != expected_end {
    return 7;
  }
  return 0;
}

fn lexer_handoff_failure_case_score(
  text: Slice[u8],
  expected_code: i64,
  expected_start: i64,
  expected_end: i64
) -> i64 {
  match lexer::handoff_from_text_result(text) {
    std::Ok(_) => {
      return 1;
    }
    std::Err(failure) => {
      if lexer::lex_failure_code(failure) != expected_code {
        return 2;
      }
      if lexer::lex_failure_start_offset(failure) != expected_start {
        return 3;
      }
      if lexer::lex_failure_end_offset(failure) != expected_end {
        return 4;
      }
      return 0;
    }
  }
}

fn lexer_string_literal_span_score() -> i64 {
  let text: Slice[u8] = "\"ari\" name";
  let literal = lexer::cursor_from_text(text, 0);
  if !lexer::cursor_is_string_literal(literal) {
    return 1;
  }
  if lexer::cursor_is_punctuation(literal) {
    return 2;
  }
  if lexer::cursor_token_start(literal) != 0 {
    return 3;
  }
  if lexer::cursor_token_end(literal) != 5 {
