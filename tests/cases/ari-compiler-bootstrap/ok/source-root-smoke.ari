fn loaded_source_score() -> i64 {
  let loaded = source::loaded_source_summary(7, 5, 'm', 0);
  if !source::loaded_source_has_first(loaded) {
    return 1;
  }
  return source::loaded_source_score(source::loaded_source_summary(7, 5, 'm', 0));
}

fn loaded_driver_score() -> i64 {
  return driver::exit_code(driver::run_loaded_source_summary(1, 16, 'p', 2));
}

fn loaded_driver_result_score() -> i64 {
  return driver::result_code(driver::run_loaded_source_summary(1, 16, 'p', 2));
}

fn invalid_loaded_driver_score() -> i64 {
  return driver::result_code(driver::run_loaded_source_summary(1, 3, 'p', 3));
}

fn lexer_stream_score() -> i64 {
  let stream = lexer::stream_from_two('a', 7, '9');
  if lexer::stream_len(stream) != 2 {
    return 1;
  }
  if !lexer::cursor_is_identifier(lexer::stream_first(stream)) {
    return 2;
  }
  if !lexer::stream_has_two_tokens(stream) {
    return 3;
  }
  if !lexer::cursor_is_number(lexer::stream_second(stream)) {
    return 4;
  }
  if lexer::cursor_token_start(lexer::stream_second(stream)) != 8 {
    return 5;
  }
  if lexer::cursor_token_end(lexer::stream_second(stream)) != 9 {
    return 6;
  }
  if !lexer::stream_has_eof(stream) {
    return 7;
  }
  if lexer::cursor_token_start(lexer::stream_eof(stream)) != 9 {
    return 8;
  }
  return 0;
}

fn lexer_punctuation_score() -> i64 {
  if !lexer::cursor_is_punctuation(lexer::cursor_from_one('(', 10)) {
    return 1;
  }
  if lexer::cursor_is_unknown(lexer::cursor_from_one('(', 10)) {
    return 2;
  }
  if lexer::scan_result_score(lexer::scan_one_result('(', 10)) != 5 {
    return 3;
  }
  if lexer::scan_score(')') != 6 {
    return 4;
  }
  if lexer::scan_score('{') != 7 {
    return 5;
  }
  if lexer::scan_score('}') != 8 {
    return 6;
  }
  if lexer::scan_score(',') != 9 {
    return 7;
  }
  if lexer::scan_score(':') != 10 {
    return 8;
  }
  if lexer::scan_score(';') != 11 {
    return 9;
  }
  if !lexer::handoff_starts_with_punctuation(lexer::handoff_from_one(';', 3)) {
    return 10;
  }
  return 0;
}

