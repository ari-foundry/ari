fn ast_node_test_value(node: ast::Node) -> i64 {
  return ast::node_kind_rank(node) +
    ast::node_span_len(node) +
    ast::node_value(node);
}

fn loaded_source_score() -> i64 {
  let loaded = source::loaded_source_summary(7, 5, 'm', 0);
  if !source::loaded_source_has_first(loaded) {
    return 1;
  }
  let loaded_span = source::loaded_source_span(loaded, 2, 5);
  if source::span_source(loaded_span) != 7 {
    return 2;
  }
  if source::span_start(loaded_span) != 2 {
    return 3;
  }
  if source::span_end(loaded_span) != 5 {
    return 4;
  }
  if !source::loaded_source_byte_len_valid(loaded) {
    return 5;
  }
  let bad_loaded = source::loaded_source_summary(7, -1, 'm', 0);
  if source::loaded_source_byte_len_valid(bad_loaded) {
    return 6;
  }
  if source::loaded_source_has_first(bad_loaded) {
    return 7;
  }
  if !source::loaded_source_contains(loaded, 0) {
    return 8;
  }
  if !source::loaded_source_contains(loaded, 5) {
    return 9;
  }
  if source::loaded_source_contains(loaded, 6) {
    return 10;
  }
  if source::loaded_source_contains(bad_loaded, 0) {
    return 11;
  }
  if !source::loaded_source_first_offset_valid(loaded) {
    return 12;
  }
  let eof_first_loaded = source::loaded_source_summary(7, 5, 'm', 5);
  if source::loaded_source_first_offset_valid(eof_first_loaded) {
    return 13;
  }
  if source::loaded_source_has_first(eof_first_loaded) {
    return 14;
  }
  let negative_first_loaded = source::loaded_source_summary(7, 5, 'm', -1);
  if source::loaded_source_first_offset_valid(negative_first_loaded) {
    return 15;
  }
  let first_span = source::loaded_source_first_span(loaded);
  if source::span_source(first_span) != 7 {
    return 16;
  }
  if source::span_start(first_span) != 0 {
    return 17;
  }
  if source::span_end(first_span) != 1 {
    return 18;
  }
  if !source::loaded_source_valid_span(loaded, first_span) {
    return 19;
  }
  let eof_first_span = source::loaded_source_first_span(eof_first_loaded);
  if source::loaded_source_valid_span(eof_first_loaded, eof_first_span) {
    return 20;
  }
  let negative_first_span = source::loaded_source_first_span(negative_first_loaded);
  if source::loaded_source_valid_span(negative_first_loaded, negative_first_span) {
    return 21;
  }
  let bad_first_span = source::loaded_source_first_span(bad_loaded);
  if source::loaded_source_valid_span(bad_loaded, bad_first_span) {
    return 22;
  }
  return source::loaded_source_id(loaded) +
    source::loaded_source_byte_len(loaded) +
    source::loaded_source_first_offset(loaded) +
    source::loaded_source_first(loaded) as i64;
}

fn source_table_entry_score() -> i64 {
  let entry = source::source_table_entry(9, 21, 4);
  if source::source_table_entry_id(entry) != 9 {
    return 1;
  }
  if source::source_table_entry_byte_len(entry) != 21 {
    return 2;
  }
  if source::source_table_entry_path_id(entry) != 4 {
    return 3;
  }
  if !source::source_table_entry_contains(entry, 21) {
    return 4;
  }
  if source::source_table_entry_contains(entry, 22) {
    return 5;
  }
  let file = source::source_table_entry_file(entry);
  if !source::contains(file, 0) {
    return 6;
  }
  if !source::source_table_entry_valid_span(entry, source::span(9, 2, 21)) {
    return 7;
  }
  if source::source_table_entry_valid_span(entry, source::span(10, 2, 21)) {
    return 8;
  }
  if source::source_table_entry_valid_span(entry, source::span(9, 9, 2)) {
    return 9;
  }
  if source::source_table_entry_valid_span(entry, source::span(9, 2, 22)) {
    return 10;
  }
  let entry_span = source::source_table_entry_span(entry, 4, 9);
  if source::span_source(entry_span) != 9 {
    return 11;
  }
  if source::span_start(entry_span) != 4 {
    return 12;
  }
  if source::span_end(entry_span) != 9 {
    return 13;
  }
  if !source::source_table_entry_valid_span(entry, entry_span) {
    return 14;
  }
  if !source::source_table_entry_byte_len_valid(entry) {
    return 15;
  }
  let bad_entry = source::source_table_entry(9, -1, 4);
  if source::source_table_entry_byte_len_valid(bad_entry) {
    return 16;
  }
  if source::source_table_entry_contains(bad_entry, 0) {
    return 17;
  }
  return source::source_table_entry_id(entry) +
    source::source_table_entry_byte_len(entry) +
    source::source_table_entry_path_id(entry);
}

fn source_line_starts_score() -> i64 {
  let file = source::source_file(3, 12);
  let lines = source::source_line_starts(0, 8, 2);
  if source::source_line_starts_first(lines) != 0 {
    return 1;
  }
  if source::source_line_starts_second(lines) != 8 {
    return 2;
  }
  if source::source_line_starts_count(lines) != 2 {
    return 3;
  }
  if !source::source_line_starts_has_second(lines) {
    return 4;
  }
  if !source::source_line_starts_valid(lines, file) {
    return 5;
  }
  let bad_first = source::source_line_starts(1, 8, 2);
  if source::source_line_starts_valid(bad_first, file) {
    return 6;
  }
  let bad_second_bounds = source::source_line_starts(0, 13, 2);
  if source::source_line_starts_valid(bad_second_bounds, file) {
    return 7;
  }
  let bad_second_order = source::source_line_starts(0, 0, 2);
  if source::source_line_starts_valid(bad_second_order, file) {
    return 8;
  }
  let bad_count = source::source_line_starts(0, 8, 0);
  if source::source_line_starts_valid(bad_count, file) {
    return 9;
  }
  let bad_file = source::source_file(3, -1);
  if source::source_line_starts_valid(lines, bad_file) {
    return 10;
  }
  let bad_count_too_many = source::source_line_starts(0, 8, 3);
  if source::source_line_starts_valid(bad_count_too_many, file) {
    return 11;
  }
  if source::source_line_starts_line_number(lines, file, 0) != 1 {
    return 12;
  }
  if source::source_line_starts_line_number(lines, file, 7) != 1 {
    return 13;
  }
  if source::source_line_starts_line_number(lines, file, 8) != 2 {
    return 14;
  }
  if source::source_line_starts_line_number(lines, file, 12) != 2 {
    return 15;
  }
  if source::source_line_starts_line_number(lines, file, 99) != 2 {
    return 16;
  }
  if source::source_line_starts_line_number(lines, file, -1) != 0 {
    return 17;
  }
  if source::source_line_starts_line_number(bad_count_too_many, file, 8) != 0 {
    return 18;
  }
  let one_line = source::source_line_starts(0, 0, 1);
  if source::source_line_starts_line_number(one_line, file, 12) != 1 {
    return 19;
  }
  if source::source_line_starts_line_number(one_line, file, 99) != 1 {
    return 20;
  }
  let bad_single_line_second = source::source_line_starts(0, 8, 1);
  if source::source_line_starts_valid(bad_single_line_second, file) {
    return 21;
  }
  if source::source_line_starts_line_number(bad_single_line_second, file, 0) != 0 {
    return 22;
  }
  if source::source_line_starts_byte_column(lines, file, 0) != 1 {
    return 23;
  }
  if source::source_line_starts_byte_column(lines, file, 7) != 8 {
    return 24;
  }
  if source::source_line_starts_byte_column(lines, file, 8) != 1 {
    return 25;
  }
  if source::source_line_starts_byte_column(lines, file, 12) != 5 {
    return 26;
  }
  if source::source_line_starts_byte_column(lines, file, 99) != 5 {
    return 27;
  }
  if source::source_line_starts_byte_column(lines, file, -1) != 0 {
    return 28;
  }
  if source::source_line_starts_byte_column(bad_count_too_many, file, 8) != 0 {
    return 29;
  }
  if source::source_line_starts_byte_column(one_line, file, 12) != 13 {
    return 30;
  }
  if source::source_line_starts_byte_column(one_line, file, 99) != 13 {
    return 31;
  }
  if !source::source_file_byte_len_valid(file) {
    return 32;
  }
  if source::source_file_byte_len_valid(bad_file) {
    return 33;
  }
  if source::contains(bad_file, 0) {
    return 34;
  }
  return source::source_line_starts_first(lines) +
    source::source_line_starts_second(lines) +
    source::source_line_starts_count(lines);
}

fn source_location_summary_score() -> i64 {
  let file = source::source_file(3, 12);
  let lines = source::source_line_starts(0, 8, 2);
  let location = source::source_location_summary(file, lines, 9);
  if source::source_location_summary_source(location) != 3 {
    return 1;
  }
  if source::source_location_summary_byte_offset(location) != 9 {
    return 2;
  }
  if source::source_location_summary_line(location) != 2 {
    return 3;
  }
  if source::source_location_summary_column(location) != 2 {
    return 4;
  }
  if !source::source_location_summary_valid(location) {
    return 5;
  }
  let eof_location = source::source_location_summary(file, lines, 99);
  if source::source_location_summary_byte_offset(eof_location) != 12 {
    return 6;
  }
  if source::source_location_summary_line(eof_location) != 2 {
