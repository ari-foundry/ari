// Test-only exit-code arithmetic for parser result smoke coverage.
fn parse_result_test_score(result: parser::ParseResult) -> i64 {
  if parser::parse_is_success(result) {
    return 2 +
      parser::parse_statement_span_len(result) +
      parser::parse_statement_value(result);
  }
  return parser::parse_failure_code(result) +
    parser::parse_failure_end_offset(result) -
    parser::parse_failure_start_offset(result) +
    parser::parse_failure_severity_rank(result);
}

fn parse_text_score() -> i64 {
  if !parser::parse_is_success(parser::parse_text("name9")) {
    return 1;
  }
  if parser::parse_statement_span_len(parser::parse_text("name9")) != 5 {
    return 2;
  }
  if !parser::parse_is_success(parser::parse_text("  name9 \n")) {
    return 3;
  }
  if parser::parse_statement_start_offset(parser::parse_text("  name9 \n")) != 2 {
    return 4;
  }
  if parser::parse_failure_code(parser::parse_text("p+")) != 2003 {
    return 5;
  }
  if !parser::parse_is_success(parser::parse_text("12345")) {
    return 6;
  }
  if parser::parse_statement_span_len(parser::parse_text("12345")) != 5 {
    return 7;
  }
  let keyword_score = parser_keyword_failure_keywords_score();
  if keyword_score != 0 {
    return 8 + keyword_score;
  }
  return 0;
}

