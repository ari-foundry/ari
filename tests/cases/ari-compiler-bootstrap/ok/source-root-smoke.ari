fn lexer_keyword_table_case_score(
  table: ref lexer::KeywordTable,
  base: i64,
  keyword_text: Slice[u8],
  expected_keyword_score: i64,
  keyword_width: i64,
  longer_text: Slice[u8],
  longer_width: i64
) -> i64 {
  let keyword = lexer::cursor_from_text_with_keywords(table, keyword_text, 0);
  if !lexer::cursor_is_keyword(keyword) {
    return base + 1;
  }
  if lexer::cursor_token_ranked_width(keyword) != expected_keyword_score {
    return base + 2;
  }
  if lexer::cursor_token_end(keyword) != keyword_width {
    return base + 3;
  }

  let longer = lexer::cursor_from_text_with_keywords(table, longer_text, 0);
  if !lexer::cursor_is_identifier(longer) {
    return base + 4;
  }
  if lexer::cursor_is_keyword(longer) {
    return base + 5;
  }
  if lexer::cursor_token_end(longer) != longer_width {
    return base + 6;
  }
  return 0;
}

fn lexer_keyword_table_flow_score(table: ref lexer::KeywordTable) -> i64 {
  let text = "meta name";
  let keyword = lexer::cursor_from_text_with_keywords(table, text, 0);
  if !lexer::cursor_is_keyword(keyword) {
    return 1;
  }
  if lexer::cursor_token_ranked_width(keyword) != 106 {
    return 2;
  }

  let name = lexer::cursor_advance_significant_in_text_with_keywords(table, keyword, text);
  if !lexer::cursor_is_identifier(name) {
    return 3;
  }
  if lexer::cursor_token_start(name) != 5 {
    return 4;
  }

  let longer = lexer::cursor_from_text_with_keywords(table, "metadata", 0);
  if !lexer::cursor_is_identifier(longer) {
    return 5;
  }
  if lexer::cursor_is_keyword(longer) {
    return 6;
  }

  let handoff = lexer::handoff_from_text_with_keywords(table, "as");
  if !lexer::handoff_starts_with_keyword(handoff) {
    return 7;
  }
  if !lexer::handoff_has_eof(handoff) {
    return 8;
  }
  return 0;
}

fn lexer_keyword_table_keywords_score(table: ref lexer::KeywordTable) -> i64 {
  return
    lexer_keyword_table_case_score(table, 60, "fn", 82, 2, "fn1", 3) +
    lexer_keyword_table_case_score(table, 70, "const", 105, 5, "constant", 8) +
    lexer_keyword_table_case_score(table, 80, "as", 103, 2, "ask", 3) +
    lexer_keyword_table_case_score(table, 90, "meta", 106, 4, "metadata", 8) +
    lexer_keyword_table_case_score(table, 100, "struct", 109, 6, "structure", 9) +
    lexer_keyword_table_case_score(table, 110, "extern", 110, 6, "external", 8) +
    lexer_keyword_table_case_score(table, 120, "enum", 109, 4, "enumerate", 9) +
    lexer_keyword_table_case_score(table, 130, "trait", 111, 5, "traitor", 7) +
    lexer_keyword_table_case_score(table, 140, "dyn", 110, 3, "dynamic", 7) +
    lexer_keyword_table_case_score(table, 150, "match", 113, 5, "matches", 7) +
    lexer_keyword_table_case_score(table, 160, "mod", 112, 3, "module", 6) +
    lexer_keyword_table_case_score(table, 170, "pub", 113, 3, "public", 6) +
    lexer_keyword_table_case_score(table, 180, "use", 114, 3, "user", 4) +
    lexer_keyword_table_case_score(table, 190, "impl", 116, 4, "implicit", 8) +
    lexer_keyword_table_case_score(table, 200, "for", 116, 3, "forest", 6) +
    lexer_keyword_table_case_score(table, 210, "in", 116, 2, "inside", 6) +
    lexer_keyword_table_case_score(table, 220, "let", 84, 3, "letter", 6) +
    lexer_keyword_table_case_score(table, 230, "var", 85, 3, "variant", 7) +
    lexer_keyword_table_case_score(table, 240, "own", 86, 3, "owner", 5) +
    lexer_keyword_table_case_score(table, 250, "ref", 87, 3, "reference", 9) +
    lexer_keyword_table_case_score(table, 260, "mut", 88, 3, "mutable", 7) +
    lexer_keyword_table_case_score(table, 270, "ptr", 89, 3, "ptrace", 6) +
    lexer_keyword_table_case_score(table, 280, "return", 93, 6, "returning", 9) +
    lexer_keyword_table_case_score(table, 290, "if", 90, 2, "iffy", 4) +
    lexer_keyword_table_case_score(table, 300, "else", 93, 4, "elsewhere", 9) +
    lexer_keyword_table_case_score(table, 310, "while", 95, 5, "while1", 6) +
    lexer_keyword_table_case_score(table, 320, "init", 95, 4, "initial", 7) +
    lexer_keyword_table_case_score(table, 330, "next", 96, 4, "next1", 5) +
    lexer_keyword_table_case_score(table, 340, "continue", 101, 8, "continue1", 9) +
    lexer_keyword_table_case_score(table, 350, "break", 99, 5, "break1", 6) +
    lexer_keyword_table_case_score(table, 360, "drop", 99, 4, "drop1", 5) +
    lexer_keyword_table_case_score(table, 370, "forget", 102, 6, "forget1", 7) +
    lexer_keyword_table_case_score(table, 380, "null", 101, 4, "null1", 5) +
    lexer_keyword_table_case_score(table, 390, "true", 102, 4, "true1", 5) +
    lexer_keyword_table_case_score(table, 400, "false", 104, 5, "false1", 6);
}

fn lexer_keyword_table_score() -> i64 {
  zone(65536) {
    var table = lexer::keyword_table();
    let flow_score = lexer_keyword_table_flow_score(ref table);
    if flow_score != 0 {
      return flow_score;
    }
    return lexer_keyword_table_keywords_score(ref table);
  }
}

fn lexer_leading_comment_keyword_handoff_case_score(
  table: ref lexer::KeywordTable,
  text: Slice[u8],
  expected_start: i64,
  expected_end: i64
) -> i64 {
  let handoff = lexer::handoff_from_text_with_keywords(table, text);
  if !lexer::handoff_starts_with_keyword(handoff) {
    return 1;
  }
  let first = lexer::handoff_first(handoff);
  if lexer::cursor_token_start(first) != expected_start {
    return 2;
  }
  if lexer::cursor_token_end(first) != expected_end {
    return 3;
  }
  if lexer::cursor_token_ranked_width(first) != 104 {
    return 4;
  }
  if !lexer::handoff_has_eof(handoff) {
    return 5;
  }
  return 0;
}

fn lexer_leading_comment_keyword_handoff_score() -> i64 {
  zone(65536) {
    var table = lexer::keyword_table();
    var score = lexer_leading_comment_keyword_handoff_case_score(ref table, "// skip\nfalse", 8, 13);
    if score != 0 {
      return score;
    }
    score = lexer_leading_comment_keyword_handoff_case_score(ref table, "/* skip */false", 10, 15);
    if score != 0 {
      return 10 + score;
    }
  }
  return 0;
}

fn lexer_leading_comment_unknown_handoff_case_score(
  text: Slice[u8],
  expected_start: i64,
  expected_end: i64
) -> i64 {
  let handoff = lexer::handoff_from_text(text);
  if !lexer::handoff_starts_with_unknown(handoff) {
    return 1;
  }
  let span_score = lexer_leading_comment_handoff_span_score(handoff, expected_start, expected_end);
  if span_score != 0 {
    return 1 + span_score;
  }
  return 0;
}

fn lexer_leading_comment_handoff_span_score(
  handoff: lexer::TokenHandoff,
  expected_start: i64,
  expected_end: i64
) -> i64 {
  let first = lexer::handoff_first(handoff);
  if lexer::cursor_token_start(first) != expected_start {
    return 1;
  }
  if lexer::cursor_token_end(first) != expected_end {
    return 2;
  }
  if !lexer::handoff_has_eof(handoff) {
    return 3;
  }
  let eof = lexer::handoff_eof(handoff);
  if lexer::cursor_token_start(eof) != expected_end {
    return 4;
  }
  if lexer::cursor_token_end(eof) != expected_end {
    return 5;
  }
  return 0;
}

fn lexer_leading_comment_unknown_handoff_score() -> i64 {
  var score = lexer_leading_comment_unknown_handoff_case_score("// skip\n$", 8, 9);
  if score != 0 {
    return score;
  }
  score = lexer_leading_comment_unknown_handoff_case_score("/* skip */$", 10, 11);
  if score != 0 {
    return 10 + score;
  }
  return 0;
}

fn lexer_leading_comment_unsupported_handoff_case_score(
  text: Slice[u8],
  expected_start: i64,
  expected_end: i64,
  expected_operator: bool
) -> i64 {
  let handoff = lexer::handoff_from_text(text);
  if expected_operator {
    if !lexer::handoff_starts_with_operator(handoff) {
      return 1;
    }
  } else {
    if !lexer::handoff_starts_with_punctuation(handoff) {
      return 1;
    }
  }
  let span_score = lexer_leading_comment_handoff_span_score(handoff, expected_start, expected_end);
  if span_score != 0 {
    return 1 + span_score;
  }
  return 0;
}

