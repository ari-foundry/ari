  if lexer::cursor_token_start(after_braced_unicode_escape_byte_char) != 8 {
    return 64;
  }
  if !parser::parse_is_success(parser::parse_text("'a'")) {
    return 12;
  }
  if !parser::parse_is_success(parser::parse_text("'\\n'")) {
    return 26;
  }
  if !parser::parse_is_success(parser::parse_text("'\\x41'")) {
    return 40;
  }
  if !parser::parse_is_success(parser::parse_text("'\\101'")) {
