  let unclosed_newline_text: Slice[u8] = "\"open\nname";
  failure_score = lexer_failure_case_score(unclosed_newline_text, 1004, 0, 6);
  if failure_score != 0 {
    return 25 + failure_score;
  }

  let unsupported_escape_text: Slice[u8] = "\"\\q\"";
  failure_score = lexer_failure_case_score(unsupported_escape_text, 1005, 2, 3);
  if failure_score != 0 {
    return 32 + failure_score;
  }

  let invalid_hex_escape_text: Slice[u8] = "\"\\x\"";
  failure_score = lexer_failure_case_score(invalid_hex_escape_text, 1006, 2, 3);
  if failure_score != 0 {
    return 39 + failure_score;
  }

  let invalid_hex_digit_escape_text: Slice[u8] = "\"\\xG\"";
  failure_score = lexer_failure_case_score(invalid_hex_digit_escape_text, 1006, 2, 3);
  if failure_score != 0 {
    return 46 + failure_score;
