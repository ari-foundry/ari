fn main() -> i64 {
  let file = source::source_file(3, 12);
  let span = source::span(3, 2, 5);

  if !source::contains(file, span.end) {
    return 1;
  }

  return source::span_len(span) +
    lexer::scan_result_score(lexer::scan_one_result('$', 4)) +
    lexer::handoff_score(lexer::handoff_from_one('x', 6)) -
    16 +
    lexer_stream_score() +
    lexer_punctuation_score() +
    lexer_operator_score() +
    lexer_identifier_span_score() +
    lexer_number_span_score() +
    lexer_whitespace_span_score() +
    lexer_path_separator_span_score() +
    lexer_dot_punctuation_score() +
