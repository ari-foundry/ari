fn parse_lexer_failure_code_case_score(
  text: Slice[u8],
  expected_code: i64,
  expected_start: i64,
  expected_end: i64
) -> i64 {
  let parsed = parser::parse_text(text);
  if parser::parse_failure_code(parsed) != expected_code {
    return 1;
  }
  if parser::parse_failure_start_offset(parsed) != expected_start {
    return 2;
  }
  if parser::parse_failure_end_offset(parsed) != expected_end {
    return 3;
  }
  let keyword_score = parser_keyword_failure_case_score(text, expected_code, expected_start, expected_end);
  if keyword_score != 0 {
    return 3 + keyword_score;
  }
  return 0;
}

fn parse_lexer_failure_case_score(
  text: Slice[u8],
  expected_start: i64,
  expected_end: i64
) -> i64 {
  return parse_lexer_failure_code_case_score(text, 1004, expected_start, expected_end);
}

