fn lexer_at_punctuation_score() -> i64 {
  let at = lexer::cursor_from_one('@', 73);
  if !lexer::cursor_is_punctuation(at) {
    return 1;
  }
  if lexer::cursor_is_operator(at) {
    return 2;
  }
  if lexer::cursor_is_unknown(at) {
    return 3;
  }
  if lexer::cursor_token_start(at) != 73 {
    return 4;
  }
  if lexer::cursor_token_end(at) != 74 {
    return 5;
  }
  if lexer::cursor_token_ranked_width(at) != 35 {
    return 6;
  }
  if lexer::scan_ranked_width('@') != 35 {
    return 7;
  }

  let text: Slice[u8] = "@test";
  let text_cursor = lexer::cursor_from_text(text, 0);
  if !lexer::cursor_is_punctuation(text_cursor) {
    return 8;
  }
  if lexer::cursor_token_end(text_cursor) != 1 {
    return 9;
  }
  let after_text = lexer::cursor_advance_in_text(text_cursor, text);
  if !lexer::cursor_is_identifier(after_text) {
    return 10;
  }
  if lexer::cursor_token_start(after_text) != 1 {
    return 11;
  }
  if lexer::cursor_token_end(after_text) != 5 {
    return 12;
  }
  return 0;
}

fn lexer_question_operator_score() -> i64 {
  let question = lexer::cursor_from_one('?', 74);
  if !lexer::cursor_is_operator(question) {
    return 1;
  }
  if lexer::cursor_is_punctuation(question) {
    return 2;
  }
  if lexer::cursor_is_unknown(question) {
    return 3;
  }
  if lexer::cursor_token_start(question) != 74 {
    return 4;
  }
  if lexer::cursor_token_end(question) != 75 {
    return 5;
  }
  if lexer::cursor_token_ranked_width(question) != 34 {
    return 6;
  }

  let coalescing = lexer::cursor_from_two('?', 76, '?');
  if !lexer::cursor_is_operator(coalescing) {
    return 7;
  }
  if lexer::cursor_token_end(coalescing) != 78 {
    return 8;
  }
  if lexer::cursor_token_ranked_width(coalescing) != 49 {
    return 9;
  }

  let fallback = lexer::cursor_from_two('?', 80, '+');
  if lexer::cursor_token_end(fallback) != 81 {
    return 10;
  }
  if lexer::cursor_token_ranked_width(fallback) != 34 {
    return 11;
  }

  let text: Slice[u8] = "??name";
  let text_cursor = lexer::cursor_from_text(text, 0);
  if !lexer::cursor_is_operator(text_cursor) {
    return 12;
  }
  if lexer::cursor_token_start(text_cursor) != 0 {
    return 13;
  }
  if lexer::cursor_token_end(text_cursor) != 2 {
    return 14;
  }
  if lexer::cursor_token_ranked_width(text_cursor) != 49 {
    return 15;
  }

  let after_text = lexer::cursor_advance_in_text(text_cursor, text);
  if !lexer::cursor_is_identifier(after_text) {
    return 16;
  }
  if lexer::cursor_token_start(after_text) != 2 {
    return 17;
  }
  return 0;
}

