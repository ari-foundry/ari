fn source_text_post_comment_lexer_failure_driver_score() -> i64 {
  let score = source_text_line_block_driver_score(
    "p// skip\n\"open",
    "p/* skip */\"open",
    1004
  );
  if score != 0 {
    return score;
  }
  let crlf_code = source_text_driver_result("p// skip\r\n\"open");
  if crlf_code != 1004 {
    return 10;
  }
  return 0;
}

