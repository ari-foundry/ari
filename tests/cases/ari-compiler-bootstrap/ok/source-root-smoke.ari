}

fn source_text_trailing_unterminated_block_driver_score() -> i64 {
  let direct_code = source_text_driver_result("p/* open");
  if direct_code != 1008 {
    return 1;
  }
  let spaced_code = source_text_driver_result("p /* open");
  if spaced_code != 1008 {
    return 2;
  }
  return 0;
}

