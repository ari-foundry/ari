mod source;
mod lexer;
mod ast;
mod parser;
mod driver;

fn file_driver_score() -> i64 {
  zone {
    return driver::exit_code(driver::run_file("tests/cases/ari-compiler-bootstrap/ok/source-root-smoke.ari"));
  }
}

fn main() -> i64 {
  let file = source::source_file(3, 12);
  let span = source::span(3, 2, 5);

  if !source::contains(file, span.end) {
    return 1;
  }

  return source::span_len(span) +
    lexer::scan_result_score(lexer::scan_one_result('!', 4)) +
    lexer::handoff_score(lexer::handoff_from_one('x', 6)) -
    16 +
    ast::node_score(ast::token_node(3, 2, 5, 8)) -
    12 +
    parser::parse_score(parser::parse_one('q', 1)) +
    parser::parse_one_kind_score('9', 2) -
    42 +
    driver::exit_code(driver::run()) +
    file_driver_score() +
    parser::parse_score(parser::parse_empty()) -
    3018;
}
