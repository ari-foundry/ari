  expected_end: i64
) -> i64 {
  return lexer_leading_comment_unsupported_handoff_case_score(
    text,
    expected_start,
    expected_end,
    false
  );
}

fn lexer_leading_comment_operator_handoff_case_score(
  text: Slice[u8],
