meta fn suffix_expr(input: token_stream) -> token_stream {
  return if tokens_ends_with(input, "+", "fast") {
    tokens!(30)
  } else {
    tokens!(input)
  };
}

meta fn suffix_item(input: token_stream) -> token_stream {
  return if input.ends_with("}") {
    tokens!(input)
  } else {
    tokens!(fn generated_suffix() -> i64 {
      return 6;
    })
  };
}

meta fn suffix_pattern(input: token_stream) -> token_stream {
  return if input.ends_with(")") {
    tokens!(input)
  } else {
    tokens!(None)
  };
}

suffix_item!(fn kept_suffix() -> i64 {
  return 7;
});

suffix_item!();

enum MaybeI64 {
  None,
  Some(i64),
}

fn score(value: MaybeI64) -> i64 {
  return match value {
    suffix_pattern!(Some(inner)) => {
      inner
    }
    suffix_pattern!(_) => {
      9
    }
  };
}

fn main() -> i64 {
  return suffix_expr!(1 + fast) + suffix_expr!(4) + kept_suffix() + generated_suffix() + score(Some(5)) + score(None());
}
