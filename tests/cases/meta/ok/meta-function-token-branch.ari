meta fn default_expr(input: token_stream) -> token_stream {
  return if tokens_empty(input) {
    tokens!(9)
  } else {
    tokens!((input) + 1)
  };
}

meta fn default_item(input: token_stream) -> token_stream {
  return if input.is_empty() {
    tokens!(fn generated() -> i64 {
      return 5;
    })
  } else {
    tokens!(input)
  };
}

meta fn maybe_payload(input: token_stream) -> token_stream {
  return if tokens_empty(input) {
    tokens!(None)
  } else {
    tokens!(Some(input))
  };
}

default_item!();

default_item!(fn kept() -> i64 {
  return 7;
});

enum MaybeI64 {
  None,
  Some(i64),
}

fn score(value: MaybeI64) -> i64 {
  return match value {
    maybe_payload!() => {
      11
    }
    maybe_payload!(inner) => {
      inner
    }
  };
}

fn main() -> i64 {
  return default_expr!() + default_expr!(4) + generated() + kept() + score(None()) + score(Some(6));
}
