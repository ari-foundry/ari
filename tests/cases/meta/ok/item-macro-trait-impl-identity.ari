meta fn make_item(input: token_stream) -> token_stream {
}

make_item!(trait Score {
  fn score(self) -> i64
});

make_item!(impl Score for i64 {
  fn score(self) -> i64 {
    return self + 37;
  }
});

fn choose[T: Score](value: T) -> i64 {
  return value.score();
}

fn main() -> i64 {
  return choose<i64>(5);
}
