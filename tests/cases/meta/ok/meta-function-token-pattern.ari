meta fn pattern_expr(input: token_stream) -> token_stream {
  return if tokens_match(input, "fast", "_", "end") {
    tokens!(41)
  } else {
    input
  };
}

meta fn pattern_item(input: token_stream) -> token_stream {
  return if input.matches("fn", "_", "(", ")", "->", "i64", "{", "return", "_", ";", "}") {
    input
  } else {
    tokens!(fn generated_fallback() -> i64 {
      return 2;
    })
  };
}

meta fn pattern_case(input: token_stream) -> token_stream {
  return if input.matches("Some", "(", "_", ")") {
    input
  } else {
    tokens!(_)
  };
}

pattern_item!(fn generated_pattern() -> i64 {
  return 6;
});

pattern_item!(const ignored: i64 = 0);

enum MaybeI64 {
  None,
  Some(i64),
}

fn score(value: MaybeI64) -> i64 {
  return match value {
    pattern_case!(Some(inner)) => {
      inner
    }
    pattern_case!(None()) => {
      3
    }
  };
}

fn main() -> i64 {
  return pattern_expr!(fast + end) + pattern_expr!(5) + generated_pattern() + generated_fallback() + score(Some(4)) + score(None());
}
