meta fn wrapped_expr(input: token_stream) -> token_stream {
  return if tokens_wrapped_by(input, "(", ")") {
    tokens!(40)
  } else {
    tokens!(input)
  };
}

meta fn wrapped_edges(input: token_stream) -> token_stream {
  return if input.wrapped_by("(", ")") {
    tokens!(1)
  } else {
    tokens!(2)
  };
}

meta fn wrapped_item(input: token_stream) -> token_stream {
  return if input.wrapped_by("{", "}") {
    tokens!(fn generated_wrapped() -> i64 {
      return 6;
    })
  } else {
    tokens!(fn generated_plain() -> i64 {
      return 3;
    })
  };
}

meta fn wrapped_pattern(input: token_stream) -> token_stream {
  return if input.wrapped_by("(", ")") {
    tokens!(input)
  } else {
    tokens!(None)
  };
}

wrapped_item!({ marker });

wrapped_item!(marker);

enum MaybeI64 {
  None,
  Some(i64),
}

fn score(value: MaybeI64) -> i64 {
  return match value {
    wrapped_pattern!((Some(inner))) => {
      inner
    }
    wrapped_pattern!(_) => {
      9
    }
  };
}

fn main() -> i64 {
  return wrapped_expr!((1 + fast)) + wrapped_expr!(4) + wrapped_edges!((1) + (2)) + generated_wrapped() + generated_plain() + score(Some(5)) + score(None());
}
