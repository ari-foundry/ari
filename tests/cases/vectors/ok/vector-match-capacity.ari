enum MaybeI64 {
  None,
  Some(i64),
}

fn choose(flag: bool) -> MaybeI64 {
  if flag {
    return Some(1);
  }
  return None();
}

fn main() -> i64 {
  let from_match: Vec[i64] = match 1 {
    0 => [1, 2, 3],
    _ => {
      [4, 5, 6]
    },
  };
  let match_len = from_match.len();

  let from_iflet: Vec[i64] = if let Some(value) = choose(true) {
    [value, value + 1, value + 2]
  } else {
    [7, 8, 9]
  };
  let iflet_len = from_iflet.len();

  return from_match.capacity() + match_len + from_match[2] +
         from_iflet.capacity() + iflet_len + from_iflet[2];
}
