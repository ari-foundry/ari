fn add(left: i64, right: i64) -> i64 {
  return left + right;
}

fn combine(first: i64, second: i64, third: i64) -> i64 {
  return first * second + third;
}

fn fact(value: i64) -> i64 {
  if value <= 1 {
    return 1;
  }
  return value * fact(value - 1);
}

fn nested_branch_return(value: i64) -> i64 {
  if value > 0 {
    {
      if value == 7 {
        return 11;
      }
    }
  }
  return 3;
}

fn locals_and_assignment() -> i64 {
  let immutable = 4;
  var total = immutable;
  total = total + 3;
  let inferred_bool = total == 7;
  if inferred_bool {
    return total;
  }
  return 0;
}

fn arithmetic() -> i64 {
  let value = ((10 + 5) * 2 - 6) / 3 + (17 % 5);
  return value;
}

fn comparisons_and_boolean() -> i64 {
  let ordered = 4 < 5;
  let at_least = 10 >= 10;
  let different = 3 != 4;
  let same = 6 == 6;
  if ordered && at_least && different && same && !(false || false) {
    return 9;
  }
  return 0;
}

fn bitwise() -> i64 {
  let mixed = ((12 & 10) | 1) ^ 3;
  let shifted = (mixed << 1) >> 2;
  return shifted;
}

fn unary_and_casts() -> i64 {
  let negated = -5;
  let byte: u8 = 12u8;
  return (byte as i64) + negated;
}

fn blocks_and_nested_if() -> i64 {
  let value = {
    let seed = 2;
    var total = seed + 3;
    total = total * 2;
    total
  };
  let branch = if value == 10 {
    let inner = 4;
    inner
  } else {
    1
  };
  let nested = if false {
    1
  } else if branch == 4 {
    6
  } else {
    2
  };
  return nested;
}

fn while_loop() -> i64 {
  var index = 0;
  var total = 0;
  while index < 6 {
    index = index + 1;
    if index == 2 {
      continue;
    }
    if index == 5 {
      break;
    }
    total = total + index;
  }
  return total;
}

fn for_range_loop() -> i64 {
  var total = 0;
  for value in 0..6 {
    if value == 1 {
      continue;
    }
    if value == 5 {
      break;
    }
    total = total + value;
  }
  return total;
}

fn main() -> i64 {
  return add(2, 3) +
         combine(3, 4, 2) +
         fact(4) +
         nested_branch_return(7) +
         locals_and_assignment() +
         arithmetic() +
         comparisons_and_boolean() +
         bitwise() +
         unary_and_casts() +
         blocks_and_nested_if() +
         while_loop() +
         for_range_loop();
}
