struct Point {
  x: i64,
  mut y: i64,
}

struct Holder {
  point: Point,
  values: [i64, 3],
}

fn main() -> i64 {
  var point = Point { x: 3, y: 4 };
  point.y = point.x + 2;

  let pair = (point.y, 8);
  let values: [i64, 3] = [1, 2, 3];
  let index = 1;
  let holder = Holder { point: point, values: values };

  return holder.point.y + pair.0 + values[index];
}
