struct Pair {
  left: i64,
  right: i64,
}

fn add(left: i64, right: i64) -> i64 {
  return left + right;
}

fn main() -> i64 {
  let tuple = (add(1, 2), 4);
  let values = [5, 6, 7];
  let pair = Pair { right: values[1], left: tuple.0 };
  return pair.left + pair.right + values[2] + tuple.1 + add(10, 12);
}
