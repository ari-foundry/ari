struct Pair {
  left: i64,
  right: i64,
}

fn inc(value: i64) -> i64 {
  return value + 1;
}

fn main() -> i64 {
  let pair = Pair { left: inc(4), right: 7 };
  let tuple = (pair.left, pair.right);

  var total = 0;
  for value in [5, 6, 7] {
    total = total + value;
  }

  return tuple.0 + tuple.1 + total + inc(11);
}
