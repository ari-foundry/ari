struct Pair(i64, i64)

struct Wrap {
  pair: Pair,
  total: i64,
}

fn pick(flag: bool) -> Pair {
  if flag {
    Pair(4, 5)
  } else {
    Pair(6, 7)
  }
}

fn main() -> i64 {
  let tuple = (1, 2);
  let pair = Pair(tuple.0, tuple.1 + 3);
  let wrap = Wrap { total: pair.0 + pair.1, pair: pick(true) };

  var sum = 0;
  for value in range(0, 3) {
    sum = sum + value;
  }

  return wrap.total + wrap.pair.0 + wrap.pair.1 + sum;
}
