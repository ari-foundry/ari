fn main() -> i64 {
  var score: i64 = 0;
  let wide: f64 = 1.5f32 as f64;
  let narrow: f32 = 2.25f64 as f32;
  let same32: f32 = narrow as f32;
  let same64: f64 = wide as f64;
  if wide == 1.5f64 {
    score = score + 1;
  }
  if narrow == 2.25f32 {
    score = score + 2;
  }
  if same32 == narrow {
    score = score + 4;
  }
  if same64 == wide {
    score = score + 8;
  }
  return score;
}
