fn make_owned(value: i64) -> own i64 {
  return value;
}

fn main() -> i64 {
  let literal_token: own i64 = make_owned(1);
  for value in [10, 11] {
    let seen = value;
    drop literal_token;
    break;
  }

  let values: Vec[i64] = [20, 21];
  let stored_token: own i64 = make_owned(2);
  for item in values {
    let stored_seen = item;
    drop stored_token;
    break;
  }

  return 0;
}
