fn main() -> i64 {
  var values: Vec[i64] = [3, 4, 5];
  values.truncate(1);

  var total = 0;
  for value in values {
    total = total + value;
  }

  values.clear();
  for _ in values {
    total = total + 100;
  }

  var left: Vec[i64] = [7, 8, 9];
  left.truncate(1);

  var right: Vec[i64] = [11, 12, 13];
  right.truncate(1);

  for selected in if true {
    left
  } else {
    right
  } {
    total = total + selected;
  }

  return total;
}
