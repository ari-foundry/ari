fn main() -> i64 {
  var total = 0;

  outer: while total < 20 {
    total = total + 1;
    block: {
      total = total + 2;
      break block;
      total = 99;
    }

    for value in 0..5 {
      if value == 2 {
        break outer;
      }
      total += value;
    }
  }

  scan: for item in 0..5 {
    if item == 3 {
      break scan;
    }
    total += item;
  }

  return total;
}
